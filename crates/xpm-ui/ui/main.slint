    property <string> icon-globe: "M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20zM2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z";
    property <string> icon-file: "M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7z";
    property <string> icon-graduation: "M22 10v6M2 10l10-5 10 5-10 5z M6 12v5c3 3 9 3 12 0v-5";
    property <string> icon-flask: "M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.13A1 1 0 0 0 5.596 22h12.808a1 1 0 0 0 .876-1.87l-5.07-9.707A2 2 0 0 1 14 9.527V2M8.5 2h7";
    property <string> icon-cpu: "M4 4h16v16H4zM9 9h6v6H9zM9 1v3M15 1v3M9 20v3M15 20v3M20 9h3M20 14h3M1 9h3M1 14h3";
    property <string> icon-lock: "M19 11H5a2 2 0 00-2 2v7a2 2 0 002 2h14a2 2 0 002-2v-7a2 2 0 00-2-2zM7 11V7a5 5 0 0110 0v4";
    property <string> icon-wrench: "M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94z";
    property <string> icon-refresh: "M1 4v6h6M23 20v-6h-6M20.49 9A9 9 0 0 0 5.64 5.64L1 10M23 14l-4.64 4.36A9 9 0 0 1 3.51 15";

    property <string> icon-flatpak: "M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5";
    property <string> icon-rss: "M4 11a9 9 0 0 1 9 9M4 4a16 16 0 0 1 16 16M5 19h.01";

    // Drives the indeterminate shimmer on the loading chip (sweeps -40% → 105%)
    property <float> _load-shimmer: -0.4;
    Timer {
        interval: 40ms;
        running: loading || (busy && progress == 0);
        triggered => {
            _load-shimmer = _load-shimmer >= 1.05 ? -0.4 : _load-shimmer + 0.038;
        }
    }

    // Forces ScrollView viewport-y bindings to re-evaluate while output is live.
    // Without this, Slint may not re-evaluate the binding when text grows.
    property <int> _scroll-tick: 0;
    Timer {
        interval: 80ms;
        running: show-terminal || show-progress-popup;
        triggered => { _scroll-tick = _scroll-tick + 1; }
    }

    function get-list() -> [PackageData] {
        if view == 0 { return installed-packages; }
        if view == 1 { return update-packages; }
        if view == 10 { return remote-apps; }
        if view == 8 { return repo-packages; }
        return [];
    }

    Rectangle {
        x: 0;
        y: 0;
        width: 200px;
        height: parent.height;
        background: Cat.mantle;

        VerticalLayout {
            padding: 12px;
            spacing: 2px;

            VerticalLayout {
                alignment: center;
                spacing: 6px;
                padding-bottom: 4px;

                HorizontalLayout {
                    alignment: center;
                    Image {
                        source: @image-url("xerolinux.png");
                        width: 100px;
                        height: 100px;
                        image-fit: contain;
                    }
                }

                Text {
                    text: "XeroLinux Package Manager GUI";
                    font-size: 13px;
                    font-weight: 600;
                    color: Cat.overlay1;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }
            }

            Rectangle { height: 8px; }
            SectionLabel { section-title: "LIBRARY"; }
            Rectangle { height: 4px; }

            NavButton {
                icon-path: icon-home;
                label: "Home";
                active: view == 9;
                clicked => { view = 9; }
            }

            NavButton {
                icon-path: icon-rss;
                label: "Arch News";
                active: view == 13;
                clicked => {
                    view = 13;
                    if arch-news-items.length == 0 { root.refresh-arch-news(); }
                }
            }

            if setting-flatpak-enabled: NavButton {
                icon-path: icon-flatpak;
                label: "Flatpaks";
                active: view == 10;
                clicked => {
                    view = 10; selected-index = -1; show-flatpak-detail = false;
                    if flatpak-remotes.length == 0 { root.browse-remote(""); }
                }
            }

            NavButton {
                icon-path: icon-folder;
                label: "Browse Repos";
                active: view == 7 || view == 8;
                clicked => {
                    view = 7; repos-view = 0; selected-index = -1;
                    if pacman-repos.length == 0 { root.load-pacman-repos(); }
                    if repo-packages.length == 0 && !repo-loading { root.browse-repo(""); }
                }
            }

            Rectangle { height: 6px; }
            Rectangle { height: 1px; background: Cat.surface0; }
            Rectangle { height: 6px; }

            NavButton {
                icon-path: icon-wrench;
                label: "Troubleshooting";
                active: view == 11;
                clicked => { view = 11; root.read-ignorepkg(); }
            }

            NavButton {
                icon-path: icon-gear;
                label: "App Settings";
                active: view == 5;
                clicked => { view = 5; }
            }

            Rectangle { vertical-stretch: 1; }

            if stats.update-count > 0: NavButton {
                icon-path: icon-arrow-up;
                label: "Updates";
                badge: stats.update-count;
                active: view == 1;
                clicked => { view = 1; selected-index = -1; }
            }

            Rectangle {
                height: 31px;
                border-radius: 8px;
                background: sync-touch.has-hover ? Cat.mauve : Cat.mauve.with-alpha(0.85);
                opacity: busy ? 0.5 : 1.0;
                animate background { duration: 100ms; }

                Text {
                    text: "Check for Updates";
                    font-size: 13px;
                    font-weight: 600;
                    color: Cat.crust;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                sync-touch := TouchArea {
                    mouse-cursor: busy ? default : pointer;
                    clicked => { if !busy { root.sync-databases(); } }
                }
            }

            Rectangle { height: 8px; }

            HorizontalLayout {
                padding-left: 4px;
                spacing: 4px;

                Text {
                    text: stats.pacman-count + " pacman";
                    font-size: 14px;
                    color: Cat.overlay0;
                }
                Text {
                    text: "/";
                    font-size: 14px;
                    color: Cat.surface2;
                }
                Text {
                    text: stats.flatpak-count + " flatpak";
                    font-size: 14px;
                    color: Cat.overlay0;
                }
            }
        }
    }

    Rectangle {
        x: 200px;
        y: 0;
        width: 1px;
        height: parent.height;
        background: Cat.surface0;
    }

    Rectangle {
        x: 201px;
        y: 0;
        width: parent.width - 201px;
        height: parent.height;
        clip: true;

        VerticalLayout {
            padding: (view == 11 || view == 12) ? 0px : 24px;
            padding-top: (view == 11 || view == 12) ? 0px : 20px;
            spacing: 12px;

            if view != 11 && view != 12: HorizontalLayout {
                spacing: 12px;

                Text {
                    text: view == 9 ? "Home" :
                          view == 0 ? "Installed" :
                          view == 1 ? "Updates" :
                          view == 2 ? "Search Results" :
                          view == 5 ? "Settings" :
                          view == 7 ? "Browse Repos" :
                          view == 8 ? selected-repo :
                          view == 10 ? (show-flatpak-detail ? flatpak-detail-name : "Flatpaks") :
                          view == 13 ? "Arch News" : "";
                    font-size: 22px;
                    font-weight: 700;
                    color: Cat.text;
                }

                Rectangle { horizontal-stretch: 1; }

                if (view == 0 || view == 1 || view == 8) || (view == 10 && !show-flatpak-detail): Text {
                    text: get-list().length + " packages";
                    font-size: 13px;
                    color: Cat.overlay0;
                    vertical-alignment: center;
                }

                if view == 1 && (update-packages.length > 0 || flatpak-update-packages.length > 0): Btn {
                    label: "Update All";
                    primary: true;
                    enabled: !busy;
                    clicked => { root.update-all(); }
                }

                // Flatpaks view — update flatpaks button
                if view == 10 && flatpak-update-count > 0: Btn {
                    label: "Update Flatpaks (" + flatpak-update-count + ")";
                    primary: true;
                    enabled: !busy;
                    clicked => { root.update-all-flatpaks(); }
                }

                // Browse Repos view — update native packages button
                if (view == 7 || view == 8) && native-update-count > 0: Btn {
                    label: "Update All (" + native-update-count + ")";
                    primary: true;
                    enabled: !busy;
                    clicked => { root.update-all(); }
                }

                if view == 0: Btn {
                    label: "Refresh";
                    clicked => { root.refresh(); }
                }

                if view == 13: Btn {
                    label: arch-news-loading ? "Loading..." : "Refresh";
                    enabled: !arch-news-loading;
                    clicked => { root.refresh-arch-news(); }
                }
            }

            if view != 11 && view != 12: Rectangle { height: 1px; background: Cat.surface0; opacity: 0.6; }

            // ── Pinned search bars for Native Packages (view 0) ─────────────
            if view == 0: VerticalLayout {
                spacing: 4px;
                padding-bottom: 4px;

                // Bar 1: Filter installed (instant client-side)
                Rectangle {
                    height: 29px;

                    TouchArea { clicked => { inst-ti.focus(); } }

                    Rectangle {
                        y: 0;
                        width: parent.width;
                        height: 29px;
                        border-radius: 16px;
                        background: Cat.surface0;
                        border-width: inst-ti.has-focus ? 1px : 0px;
                        border-color: Cat.blue.with-alpha(0.4);
                        clip: true;
                        animate border-width { duration: 80ms; }

                        HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 12px;
                            spacing: 8px;

                            VerticalLayout {
                                alignment: center;
                                NavIcon {
                                    d: "M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0";
                                    icon-color: inst-ti.has-focus ? Cat.blue.with-alpha(0.9) : Cat.overlay1;
                                    width: 13px;
                                    height: 13px;
                                }
                            }

                            VerticalLayout {
                                alignment: center;
                                horizontal-stretch: 1;

                                if installed-filter-text == "" && !inst-ti.has-focus: Text {
                                    height: 29px;
                                    text: "Filter installed...";
                                    font-size: 12px;
                                    color: Cat.overlay0;
                                    vertical-alignment: center;
                                }

                                inst-ti := TextInput {
                                    height: 29px;
                                    text <=> installed-filter-text;
                                    font-size: 12px;
                                    color: Cat.text;
                                    single-line: true;
                                    vertical-alignment: center;
                                    selection-background-color: Cat.blue.with-alpha(0.3);
                                    selection-foreground-color: Cat.text;
                                    edited => { root.filter-installed(self.text); }
                                    accepted => { root.filter-installed(self.text); }
                                }
                            }

                            if installed-filter-text != "": VerticalLayout {
                                alignment: center;
                                Rectangle {
                                    width: 18px; height: 18px; border-radius: 9px;
                                    background: clr-touch.has-hover ? Cat.surface1 : transparent;
                                    NavIcon { d: "M18 6L6 18M6 6l12 12"; icon-color: Cat.overlay1; width: 10px; height: 10px; x: 4px; y: 4px; }
                                    clr-touch := TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => { installed-filter-text = ""; root.filter-installed(""); }
                                    }
                                }
                            }
                        }
                    }
                }

                // Bar 2: Search all packages in repos
                Rectangle {
                    height: 29px;

                    TouchArea { clicked => { all-pkg-ti.focus(); } }

                    Rectangle {
                        y: 0;
                        width: parent.width;
                        height: 29px;
                        border-radius: 16px;
                        background: Cat.surface0;
                        border-width: all-pkg-ti.has-focus ? 1px : 0px;
                        border-color: Cat.mauve.with-alpha(0.4);
                        clip: true;
                        animate border-width { duration: 80ms; }

                        HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 12px;
                            spacing: 8px;

                            VerticalLayout {
                                alignment: center;
                                NavIcon {
                                    d: "M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0";
                                    icon-color: all-pkg-ti.has-focus ? Cat.mauve.with-alpha(0.9) : Cat.overlay1;
                                    width: 13px;
                                    height: 13px;
                                }
                            }

                            VerticalLayout {
                                alignment: center;
                                horizontal-stretch: 1;

                                if search-text == "" && !all-pkg-ti.has-focus: Text {
                                    height: 29px;
                                    text: "Search all packages...";
                                    font-size: 12px;
                                    color: Cat.overlay0;
                                    vertical-alignment: center;
                                }

                                all-pkg-ti := TextInput {
                                    height: 29px;
                                    text <=> search-text;
                                    font-size: 12px;
                                    color: Cat.text;
                                    single-line: true;
                                    vertical-alignment: center;
                                    selection-background-color: Cat.mauve.with-alpha(0.3);
                                    selection-foreground-color: Cat.text;
                                    accepted => {
                                        if search-text != "" {
                                            view = 2;
                                            root.search(search-text);
                                        }
                                    }
                                }
                            }

                            if search-text != "": VerticalLayout {
                                alignment: center;
                                Rectangle {
                                    width: 18px; height: 18px; border-radius: 9px;
                                    background: all-clr.has-hover ? Cat.surface1 : transparent;
                                    NavIcon { d: "M18 6L6 18M6 6l12 12"; icon-color: Cat.overlay1; width: 10px; height: 10px; x: 4px; y: 4px; }
                                    all-clr := TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => { search-text = ""; }
                                    }
                                }
                            }
                        }
                    }
                }
            }

            // Search results empty state (view 2)
            if !loading && view == 2 && search-installed.length == 0 && search-available.length == 0: VerticalLayout {
                vertical-stretch: 1;
                alignment: center;
                spacing: 8px;

                NavIcon {
                    d: icon-search;
                    icon-color: Cat.surface2;
                    width: 32px;
                    height: 29px;
                    x: (parent.width - 32px) / 2;
                }

                Text {
                    text: "Search for packages";
                    font-size: 15px;
                    color: Cat.overlay0;
                    horizontal-alignment: center;
                }
            }

            // Loading skeleton for view 0 / 1
            if loading && (view == 0 || view == 1): VerticalLayout {
                vertical-stretch: 1;
                spacing: 1px;
                for i in [0, 1, 2, 3, 4, 5, 6, 7]: Rectangle {
                    height: 47px;
                    background: Math.mod(i, 2) == 0 ? Cat.surface0.with-alpha(0.15) : transparent;
                    HorizontalLayout {
                        padding-left: 16px;
                        padding-right: 16px;
                        spacing: 12px;
                        VerticalLayout {
                            alignment: center;
                            Rectangle { width: 120px; height: 12px; border-radius: 4px; background: Cat.surface0.with-alpha(0.5); }
                        }
                        Rectangle { horizontal-stretch: 1; }
                        VerticalLayout {
                            alignment: center;
                            Rectangle { width: 60px; height: 10px; border-radius: 4px; background: Cat.surface0.with-alpha(0.35); }
                        }
                    }
                }
            }

            // Empty state for view 0/1 (not loading, no results)
            if !loading && (view == 0 || view == 1) && get-list().length == 0: VerticalLayout {
                vertical-stretch: 1;
                alignment: center;
                spacing: 8px;

                NavIcon {
                    d: icon-package;
                    icon-color: Cat.surface2;
                    width: 32px;
                    height: 29px;
                    x: (parent.width - 32px) / 2;
                }

                Text {
                    text: "No packages found";
                    font-size: 15px;
                    color: Cat.overlay0;
                    horizontal-alignment: center;
                }
            }

            // Installed packages (view 0) — paginated
            if !loading && view == 0 && installed-packages.length > 0: VerticalLayout {
                vertical-stretch: 1;

                ListView {
                    vertical-stretch: 1;
                    for p[i] in installed-packages: PackageRow {
                        pkg: p;
                        show-separator: i < installed-packages.length - 1;
                        show-checkbox: multi-select-mode;
                        install => { root.request-install(p.name, p.backend); }
                        remove => { root.request-remove(p.name, p.backend); }
                        toggle-selected(val) => { root.toggle-package-selected(p.name, p.backend, val); }
                    }
                }

                if total-pages > 1: Paginator {
                    current-page: root.current-page;
                    total-pages: root.total-pages;
                    go-to-page(p) => { root.current-page = p; root.load-page(p); }
                }
            }

            // Updates (view 1) — two sections: Native + Flatpaks
            if !loading && view == 1 && (update-packages.length > 0 || flatpak-update-packages.length > 0): ScrollView {
                vertical-stretch: 1;
                VerticalLayout {
                    alignment: start;
                    spacing: 0px;

                    // ── Native section ─────────────────────────────────────────
                    if update-packages.length > 0: Rectangle {
                        height: 29px;
                        background: Cat.surface0.with-alpha(0.4);
                        HorizontalLayout {
                            padding-left: 16px; padding-right: 16px;
                            spacing: 8px;
                            VerticalLayout { alignment: center;
                                Text { text: "NATIVE PACKAGES"; font-size: 10px; font-weight: 700; color: Cat.mauve; letter-spacing: 0.8px; }
                            }
                            Rectangle { horizontal-stretch: 1; }
                            VerticalLayout { alignment: center;
                                Text { text: update-packages.length + " updates"; font-size: 12px; color: Cat.overlay1; }
                            }
                        }
                    }
                    if update-packages.length > 0: VerticalLayout {
                        spacing: 0px;
                        for p[i] in update-packages: PackageRow {
                            pkg: p;
                            show-separator: i < update-packages.length - 1;
                            show-checkbox: false;
                            show-action-button: false;
                            install => { }
                            remove => { }
                        }
                    }

                    // ── Flatpak section ────────────────────────────────────────
                    if flatpak-update-packages.length > 0: Rectangle {
                        height: 29px;
                        background: Cat.surface0.with-alpha(0.4);
                        HorizontalLayout {
                            padding-left: 16px; padding-right: 16px;
                            spacing: 8px;
                            VerticalLayout { alignment: center;
                                Text { text: "FLATPAKS"; font-size: 10px; font-weight: 700; color: Cat.blue; letter-spacing: 0.8px; }
                            }
                            Rectangle { horizontal-stretch: 1; }
                            VerticalLayout { alignment: center;
                                Text { text: flatpak-update-packages.length + " updates"; font-size: 12px; color: Cat.overlay1; }
                            }
                        }
                    }
                    if flatpak-update-packages.length > 0: VerticalLayout {
                        spacing: 0px;
                        for p[i] in flatpak-update-packages: PackageRow {
                            pkg: p;
                            show-separator: i < flatpak-update-packages.length - 1;
                            show-checkbox: false;
                            show-action-button: true;
                            install => { root.request-update(p.name, p.backend); }
                            remove => { }
                        }
                    }
                }
            }

            if !loading && view == 1 && update-packages.length == 0 && flatpak-update-packages.length == 0: VerticalLayout {
                vertical-stretch: 1; alignment: center;
                Text { text: "System is up to date"; font-size: 15px; color: Cat.overlay0; horizontal-alignment: center; }
            }

            // Flatpaks (view 10) — flat list with pill search + multi-select + detail
            if view == 10: VerticalLayout {
                vertical-stretch: 1;
                spacing: 0;

                // ── Tab strip: Browse | Installed ─────────────────────────────
                Rectangle {
                    height: 40px;
                    background: transparent;

                    HorizontalLayout {
                        padding-left: 16px;
                        spacing: 0;

                        Rectangle {
                            width: 90px;
                            height: parent.height;
                            Text {
                                text: "Browse";
                                font-size: 14px;
                                font-weight: flatpak-tab == 0 ? 700 : 500;
                                color: flatpak-tab == 0 ? Cat.mauve : Cat.overlay1;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            Rectangle {
                                y: parent.height - 2px;
                                height: 2px;
                                width: parent.width;
                                background: flatpak-tab == 0 ? Cat.mauve : transparent;
                                animate background { duration: 120ms; }
                            }
                            TouchArea {
                                mouse-cursor: pointer;
                                clicked => { flatpak-tab = 0; show-flatpak-detail = false; }
                            }
                        }

                        Rectangle {
                            width: 100px;
                            height: parent.height;
                            Text {
                                text: "Installed";
                                font-size: 14px;
                                font-weight: flatpak-tab == 1 ? 700 : 500;
                                color: flatpak-tab == 1 ? Cat.green : Cat.overlay1;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            Rectangle {
                                y: parent.height - 2px;
                                height: 2px;
                                width: parent.width;
                                background: flatpak-tab == 1 ? Cat.green : transparent;
                                animate background { duration: 120ms; }
                            }
                            TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    flatpak-tab = 1;
                                    show-flatpak-detail = false;
                                    if installed-flatpaks.length == 0 { root.load-installed-flatpaks(); }
                                }
                            }
                        }

                        Rectangle { horizontal-stretch: 1; }
                    }

                    Rectangle {
                        y: parent.height - 1px;
                        height: 1px;
                        width: parent.width;
                        background: Cat.surface0;
                    }
                }

                // ── Browse tab ────────────────────────────────────────────────
                if flatpak-tab == 0: VerticalLayout {
                    vertical-stretch: 1;
                    spacing: 0;

                // ── Pill search bar (same style as Repos) ──────────────────────────
                Rectangle {
                    height: 52px;
                    background: transparent;

                    TouchArea { clicked => { fk-ti.focus(); } }

                    Rectangle {
                        x: 14px;
                        y: 11px;
                        width: parent.width - 28px;
                        height: 32px;
                        border-radius: 18px;
                        background: Cat.surface0;
                        border-width: fk-ti.has-focus ? 1px : 0px;
                        border-color: Cat.mauve.with-alpha(0.4);
                        clip: true;
                        animate border-width { duration: 80ms; }

                        HorizontalLayout {
                            padding-left: 14px;
                            padding-right: 14px;
                            spacing: 10px;

                            VerticalLayout {
                                alignment: center;
                                NavIcon {
                                    d: "M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0";
                                    icon-color: fk-ti.has-focus ? Cat.mauve.with-alpha(0.9) : Cat.overlay1;
                                    width: 14px;
                                    height: 14px;
                                }
                            }

                            VerticalLayout {
                                alignment: center;
                                horizontal-stretch: 1;

                                if flatpak-search == "" && !fk-ti.has-focus: Text {
                                    height: 32px;
                                    text: "Search Flathub apps...";
                                    font-size: 14px;
                                    color: Cat.overlay0;
                                    vertical-alignment: center;
                                }

                                fk-ti := TextInput {
                                    height: 32px;
                                    text <=> flatpak-search;
                                    font-size: 14px;
                                    color: Cat.text;
                                    single-line: true;
                                    vertical-alignment: center;
                                    selection-background-color: Cat.mauve.with-alpha(0.3);
                                    selection-foreground-color: Cat.text;
                                    accepted => {
                                        show-flatpak-detail = false;
                                        root.filter-flatpak(selected-flatpak-category, self.text);
                                    }
                                    edited => {
                                        show-flatpak-detail = false;
                                        root.filter-flatpak(selected-flatpak-category, self.text);
                                    }
                                }
                            }
                        }
                    }
                }

                // ── Category pills — centered ───────────────────────────────────────
                Rectangle {
                    height: 40px;

                    HorizontalLayout {
                        alignment: center;
                        padding-left: 14px;
                        padding-right: 14px;
                        spacing: 6px;

                        for cat[ci] in flatpak-categories: CategoryPill {
                            label: cat;
                            active: selected-flatpak-category == cat;
                            clicked => {
                                selected-flatpak-category = cat;
                                show-flatpak-detail = false;
                                root.filter-flatpak(cat, flatpak-search);
                            }
                        }
                    }
                }

                // ── Add-ons info banner ──────────────────────────────────────────────
                if !show-flatpak-detail: Rectangle {
                    height: 25px;
                    background: Cat.mauve.with-alpha(0.06);
                    border-width: 0px;

                    HorizontalLayout {
                        padding-left: 14px; padding-right: 14px; spacing: 6px; alignment: center;
                        VerticalLayout { alignment: center;
                            NavIcon {
                                d: "M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5";
                                icon-color: Cat.mauve.with-alpha(0.6);
                                width: 12px; height: 12px;
                            }
                        }
                        Text {
                            text: "Apps with add-ons are marked  + Add-ons. Install add-ons via the app's info page.";
                            font-size: 10px;
                            color: Cat.mauve.with-alpha(0.75);
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }
                    }

                    Rectangle { y: parent.height - 1px; height: 1px; width: 100%; background: Cat.surface0.with-alpha(0.5); }
                }

                // ── Loading — geeky terminal card ───────────────────────────────────
                if remote-apps-loading || !flatpak-store-ready: VerticalLayout {
                    vertical-stretch: 1;
                    alignment: center;
                    spacing: 0;

                    // Centre the card
                    HorizontalLayout {
                        alignment: center;

                        Rectangle {
                            width: 320px;
                            border-radius: 10px;
                            background: Cat.crust.with-alpha(0.7);
                            border-width: 1px;
                            border-color: Cat.mauve.with-alpha(0.18);
                            clip: true;

                            VerticalLayout {
                                padding: 20px;
                                spacing: 14px;

                                // Title bar dots
                                HorizontalLayout {
                                    spacing: 6px;
                                    Rectangle { width: 8px; height: 8px; border-radius: 4px; background: Cat.red.with-alpha(0.7); }
                                    Rectangle { width: 8px; height: 8px; border-radius: 4px; background: Cat.yellow.with-alpha(0.7); }
                                    Rectangle { width: 8px; height: 8px; border-radius: 4px; background: Cat.green.with-alpha(0.7); }
                                    Rectangle { horizontal-stretch: 1; }
                                    Text { text: "appstream.xml"; font-size: 13px; color: Cat.overlay0; vertical-alignment: center; }
                                }

                                // Fake terminal lines
                                VerticalLayout {
                                    spacing: 5px;

                                    HorizontalLayout {
                                        spacing: 6px;
                                        Text { text: "$"; font-size: 14px; color: Cat.mauve; vertical-alignment: center; }
                                        Text { text: "flatpak remote-info flathub"; font-size: 14px; color: Cat.text; vertical-alignment: center; }
                                    }
                                    HorizontalLayout {
                                        spacing: 6px;
                                        Text { text: "›"; font-size: 14px; color: Cat.overlay0; vertical-alignment: center; }
                                        Text { text: "Parsing appstream metadata..."; font-size: 14px; color: Cat.subtext0; vertical-alignment: center; }
                                    }
                                    HorizontalLayout {
                                        spacing: 6px;
                                        Text { text: "›"; font-size: 14px; color: Cat.overlay0; vertical-alignment: center; }
                                        Text { text: "Indexing application catalogue"; font-size: 14px; color: Cat.subtext0; vertical-alignment: center; }
                                    }
                                }

                                // Progress bar + spinner row
                                HorizontalLayout {
                                    spacing: 10px;

                                    Rectangle {
                                        horizontal-stretch: 1;
                                        height: 3px;
                                        border-radius: 2px;
                                        background: Cat.surface1;
                                        y: 8px;

                                        Rectangle {
                                            height: 3px;
                                            border-radius: 2px;
                                            background: @linear-gradient(90deg, Cat.mauve 0%, Cat.blue 100%);
                                            width: 60px;
                                            animate width { duration: 900ms; easing: ease-in-out; }
                                        }
                                    }

                                    Spinner { indeterminate: true; width: 14px; height: 14px; }
                                }

                                // Status line
                                Text {
                                    text: remote-apps-loading ? "Fetching from remote..." : "Building index...";
                                    font-size: 10px;
                                    color: Cat.overlay0;
                                    horizontal-alignment: center;
                                }
                            }
                        }
                    }
                }

                // ── Detail view ──────────────────────────────────────────────────────
                if !remote-apps-loading && show-flatpak-detail: ScrollView {
                    vertical-stretch: 1;

                    VerticalLayout {
                        padding: 0;
                        spacing: 0;

                        // Screenshot banner
                        if flatpak-screenshot.width > 0: Rectangle {
                            height: 300px;
                            clip: true;
                            background: Cat.surface0.with-alpha(0.3);

                            Image {
                                source: flatpak-screenshot;
                                width: parent.width;
                                height: parent.height;
                                image-fit: cover;
                            }

                            Rectangle {
                                y: parent.height - 100px;
                                height: 100px;
                                width: parent.width;
                                background: @linear-gradient(180deg, transparent 0%, Cat.base 100%);
                            }
                        }

                        VerticalLayout {
                            padding: 24px;
                            spacing: 22px;

                            // Back row
                            HorizontalLayout {
                                spacing: 8px;
                                Rectangle {
                                    width: bk-lbl.preferred-width + 28px;
                                    height: 31px;
                                    border-radius: 8px;
                                    background: bk-touch.has-hover ? Cat.surface1 : Cat.surface0.with-alpha(0.7);
                                    border-width: 1px;
                                    border-color: Cat.surface0;
                                    animate background { duration: 80ms; }
                                    VerticalLayout {
                                        alignment: center;
                                        HorizontalLayout {
                                            alignment: center; spacing: 6px;
                                            NavIcon { d: "M19 12H5M12 19l-7-7 7-7"; icon-color: Cat.subtext0; width: 13px; height: 13px; }
                                            bk-lbl := Text { text: "All Apps"; font-size: 13px; color: Cat.subtext0; }
                                        }
                                    }
                                    bk-touch := TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => {
                                            show-flatpak-detail = false;
                                            flatpak-screenshot = @image-url("");
                                            flatpak-detail-icon = @image-url("");
                                        }
                                    }
                                }
                                Rectangle { horizontal-stretch: 1; }
                                Rectangle {
                                    width: rem-d-lbl.preferred-width + 14px;
                                    height: 31px;
                                    border-radius: 8px;
                                    background: Cat.surface0.with-alpha(0.5);
                                    rem-d-lbl := Text {
                                        text: selected-remote;
                                        font-size: 15px;
                                        color: Cat.overlay1;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }

                            // App header: icon + name + buttons
                            HorizontalLayout {
                                spacing: 18px;

                                // Icon
                                VerticalLayout {
                                    alignment: center;
                                    Rectangle {
                                        width: 80px;
                                        height: 80px;
                                        border-radius: 20px;
                                        clip: true;
                                        background: Cat.surface0;

                                        if flatpak-detail-icon.width > 0: Image {
                                            source: flatpak-detail-icon;
                                            width: parent.width;
                                            height: parent.height;
                                            image-fit: contain;
                                        }
                                        if flatpak-detail-icon.width == 0: NavIcon {
                                            d: "M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4";
                                            icon-color: Cat.mauve.with-alpha(0.6);
                                            width: 38px;
                                            height: 38px;
                                            x: 21px;
                                            y: 21px;
                                        }
                                    }
                                }

                                // Name + app_id + developer
                                VerticalLayout {
                                    horizontal-stretch: 1;
                                    spacing: 6px;
                                    alignment: center;

                                    Text {
                                        text: flatpak-detail-name;
                                        font-size: 25px;
                                        font-weight: 800;
                                        color: Cat.text;
                                        wrap: word-wrap;
                                    }

                                    HorizontalLayout {
                                        spacing: 8px;
                                        alignment: start;
                                        Text {
                                            text: current-flatpak-id;
                                            font-size: 15px;
                                            color: Cat.overlay0;
                                            vertical-alignment: center;
                                        }
                                        if flatpak-detail-developer != "": Text {
                                            text: "·  " + flatpak-detail-developer;
                                            font-size: 15px;
                                            color: Cat.subtext0;
                                            vertical-alignment: center;
                                        }
                                    }
                                }

                                // Install/Remove + Add-Ons buttons
                                VerticalLayout {
                                    alignment: center;
                                    spacing: 8px;

                                    // Install / Remove button
                                    if !flatpak-detail-installed: Rectangle {
                                        width: 120px;
                                        height: 38px;
                                        border-radius: 10px;
                                        background: inst-touch.has-hover ? Cat.mauve : Cat.mauve.with-alpha(0.88);
                                        animate background { duration: 80ms; }
                                        Text { text: "Install"; font-size: 15px; font-weight: 700; color: #ffffff; horizontal-alignment: center; vertical-alignment: center; }
                                        inst-touch := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => {
                                                flatpak-detail-installed = true;
                                                root.request-install(current-flatpak-id, 1);
                                            }
                                        }
                                    }
                                    if flatpak-detail-installed: Rectangle {
                                        width: 120px;
                                        height: 38px;
                                        border-radius: 10px;
                                        background: rm-touch.has-hover ? Cat.red : Cat.red.with-alpha(0.85);
                                        animate background { duration: 80ms; }
                                        Text { text: "Remove"; font-size: 15px; font-weight: 700; color: #ffffff; horizontal-alignment: center; vertical-alignment: center; }
                                        rm-touch := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => {
                                                root.fp-confirm-id = current-flatpak-id;
                                                root.fp-confirm-name = flatpak-detail-name;
                                                root.fp-confirm-open = true;
                                            }
                                        }
                                    }

                                    // Add-Ons button — shown if any addons exist (installed or not)
                                    if flatpak-addons.length > 0 || flatpak-addons-installed.length > 0: Rectangle {
                                        width: 120px;
                                        height: 31px;
                                        border-radius: 10px;
                                        // all-installed = nothing left to install
                                        property <bool> all-installed: flatpak-addons.length == 0;
                                        property <bool> some-installed: flatpak-addons-installed.length > 0 && flatpak-addons.length > 0;
                                        background: all-installed
                                            ? Cat.green.with-alpha(0.15)
                                            : some-installed
                                                ? Cat.peach.with-alpha(0.15)
                                                : Cat.surface0.with-alpha(0.6);
                                        border-width: 1px;
                                        border-color: all-installed
                                            ? Cat.green.with-alpha(0.3)
                                            : some-installed
                                                ? Cat.peach.with-alpha(0.3)
                                                : Cat.surface1;
                                        animate background { duration: 80ms; }

                                        HorizontalLayout {
                                            alignment: center;
                                            spacing: 6px;

                                            VerticalLayout {
                                                alignment: center;
                                                Rectangle {
                                                    width: 7px; height: 7px; border-radius: 3.5px;
                                                    background: all-installed ? Cat.green
                                                        : some-installed ? Cat.peach : Cat.overlay0;
                                                }
                                            }

                                            Text {
                                                text: "Add-Ons";
                                                font-size: 13px; font-weight: 600;
                                                color: all-installed ? Cat.green
                                                    : some-installed ? Cat.peach : Cat.subtext0;
                                                vertical-alignment: center;
                                            }
                                        }

                                        addon-btn-touch := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => { root.show-addons-modal = true; }
                                        }
                                    }
                                }
                            }

                            // Summary tagline
                            if flatpak-detail-summary != "": Text {
                                text: flatpak-detail-summary;
                                font-size: 16px;
                                color: Cat.subtext0;
                                wrap: word-wrap;
                            }

                            Rectangle { height: 1px; background: Cat.surface0; opacity: 0.6; }

                            // Description
                            Text {
                                text: flatpak-detail-description != "" ? flatpak-detail-description : "No description available.";
                                font-size: 14px;
                                color: flatpak-detail-description != "" ? Cat.text : Cat.overlay0;
                                wrap: word-wrap;
                                opacity: 0.9;
                            }

                            // ── Changelog card ───────────────────────────────────────
                            if flatpak-detail-version != "" && flatpak-detail-changelog != "": Rectangle {
                                border-radius: 10px;
                                background: Cat.surface0.with-alpha(0.5);
                                border-width: 1px;
                                border-color: Cat.surface1;
                                VerticalLayout {
                                    padding: 16px;
                                    spacing: 10px;
                                    HorizontalLayout {
                                        spacing: 8px;
                                        alignment: start;
                                        Text {
                                            text: "Changes in version " + flatpak-detail-version;
                                            font-size: 14px;
                                            font-weight: 700;
                                            color: Cat.text;
                                            vertical-alignment: center;
                                        }
                                        if flatpak-detail-version-date != "": Text {
                                            text: "·  " + flatpak-detail-version-date;
                                            font-size: 15px;
                                            color: Cat.overlay1;
                                            vertical-alignment: center;
                                        }
                                    }
                                    Text {
                                        text: flatpak-detail-changelog;
                                        font-size: 13px;
                                        color: Cat.subtext0;
                                        wrap: word-wrap;
                                    }
                                }
                            }

                            // ── Links section ────────────────────────────────────────
                            if flatpak-detail-url-homepage != "" || flatpak-detail-url-bug != "" || flatpak-detail-url-translate != "" || flatpak-detail-url-vcs != "": Rectangle {
                                border-radius: 10px;
                                background: Cat.surface0.with-alpha(0.5);
                                border-width: 1px;
                                border-color: Cat.surface1;
                                VerticalLayout {
                                    padding: 16px;
                                    spacing: 10px;
                                    Text {
                                        text: "Links";
                                        font-size: 14px;
                                        font-weight: 700;
                                        color: Cat.text;
                                    }
                                    if flatpak-detail-url-homepage != "": Rectangle {
                                        height: 26px;
                                        link-home-ta := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => { root.open-url(flatpak-detail-url-homepage); }
                                        }
                                        HorizontalLayout {
                                            spacing: 8px; alignment: start;
                                            VerticalLayout { alignment: center; NavIcon { d: "M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"; icon-color: Cat.blue; width: 14px; height: 14px; } }
                                            Text { text: "Project Website"; font-size: 14px; color: link-home-ta.has-hover ? Cat.lavender : Cat.blue; vertical-alignment: center; animate color { duration: 80ms; } }
                                        }
                                    }
                                    if flatpak-detail-url-bug != "": Rectangle {
                                        height: 26px;
                                        link-bug-ta := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => { root.open-url(flatpak-detail-url-bug); }
                                        }
                                        HorizontalLayout {
                                            spacing: 8px; alignment: start;
                                            VerticalLayout { alignment: center; NavIcon { d: "M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"; icon-color: Cat.peach; width: 14px; height: 14px; } }
                                            Text { text: "Report an Issue"; font-size: 14px; color: link-bug-ta.has-hover ? Cat.yellow : Cat.peach; vertical-alignment: center; animate color { duration: 80ms; } }
                                        }
                                    }
                                    if flatpak-detail-url-translate != "": Rectangle {
                                        height: 26px;
                                        link-tr-ta := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => { root.open-url(flatpak-detail-url-translate); }
                                        }
                                        HorizontalLayout {
                                            spacing: 8px; alignment: start;
                                            VerticalLayout { alignment: center; NavIcon { d: "M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"; icon-color: Cat.teal; width: 14px; height: 14px; } }
                                            Text { text: "Contribute Translations"; font-size: 14px; color: link-tr-ta.has-hover ? Cat.sky : Cat.teal; vertical-alignment: center; animate color { duration: 80ms; } }
                                        }
                                    }
                                    if flatpak-detail-url-vcs != "": Rectangle {
                                        height: 26px;
                                        link-vcs-ta := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => { root.open-url(flatpak-detail-url-vcs); }
                                        }
                                        HorizontalLayout {
                                            spacing: 8px; alignment: start;
                                            VerticalLayout { alignment: center; NavIcon { d: "M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"; icon-color: Cat.mauve; width: 14px; height: 14px; } }
                                            Text { text: "Browse Source Code"; font-size: 14px; color: link-vcs-ta.has-hover ? Cat.lavender : Cat.mauve; vertical-alignment: center; animate color { duration: 80ms; } }
                                        }
                                    }
                                }
                            }

                            // ── Tags row ─────────────────────────────────────────────
                            if flatpak-detail-tags.length > 0: HorizontalLayout {
                                spacing: 6px;
                                alignment: start;
                                for tag in flatpak-detail-tags: Rectangle {
                                    width: tag-lbl.preferred-width + 16px;
                                    height: 24px;
                                    border-radius: 12px;
                                    background: Cat.mauve.with-alpha(0.1);
                                    border-width: 1px;
                                    border-color: Cat.mauve.with-alpha(0.25);
                                    tag-lbl := Text {
                                        text: tag;
                                        font-size: 15px;
                                        color: Cat.mauve;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }

                            // Bottom padding
                            Rectangle { height: 12px; }
                        }
                    }
                }

                // ── Flat app list (replaces AppTile grid) ────────────────────────────
                if !remote-apps-loading && flatpak-store-ready && !show-flatpak-detail: VerticalLayout {
                    vertical-stretch: 1;
                    spacing: 0;

                    // Hero watermark area
                    Rectangle {
                        height: 65px;
                        clip: true;

                        // Package glyph
                        NavIcon {
                            d: "M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5";
                            icon-color: Cat.mauve.with-alpha(0.07);
                            width: 44px;
                            height: 40px;
                            x: parent.width - 54px;
                            y: (parent.height - 44px) / 2;
                        }

                        // Column headers
                        HorizontalLayout {
                            padding-left: 16px;
                            padding-right: 14px;
                            spacing: 10px;

                            VerticalLayout {
                                alignment: center;
                                width: 44px; // avatar placeholder
                            }

                            Text {
                                horizontal-stretch: 1;
                                text: "APPLICATION";
                                font-size: 10px;
                                font-weight: 700;
                                color: Cat.overlay0;
                                letter-spacing: 0.8px;
                                vertical-alignment: center;
                            }

                            if flatpak-total-matches > 0 && flatpak-total-matches > remote-apps.length: Text {
                                text: remote-apps.length + " / " + flatpak-total-matches;
                                font-size: 13px;
                                color: Cat.overlay0;
                                vertical-alignment: center;
                                horizontal-alignment: center;
                            }

                            Text {
                                text: "STATUS";
                                font-size: 10px;
                                font-weight: 700;
                                color: Cat.overlay0;
                                letter-spacing: 0.8px;
                                vertical-alignment: center;
                                width: 70px;
                                horizontal-alignment: center;
                            }
                        }

                        // Bottom separator
                        Rectangle {
                            y: parent.height - 1px;
                            height: 1px;
                            width: parent.width;
                            background: Cat.surface0;
                            opacity: 0.6;
                        }
                    }

                    if remote-apps.length == 0: VerticalLayout {
                        vertical-stretch: 1;
                        alignment: center;
                        Text { text: "No apps found."; font-size: 14px; color: Cat.overlay0; horizontal-alignment: center; }
                    }

                    ScrollView {
                        vertical-stretch: 1;

                        VerticalLayout {
                            spacing: 0;

                            for pkg[i] in remote-apps: Rectangle {
                                height: 56px;
                                background: fk-row-touch.has-hover ? Cat.surface0.with-alpha(0.4) : transparent;
                                animate background { duration: 60ms; }

                                // Row tap → open detail (defined first so it's behind the checkbox)
                                fk-row-touch := TouchArea {
                                    clicked => {
                                        current-flatpak-id = pkg.name;
                                        flatpak-detail-installed = pkg.installed;
                                        flatpak-detail-name = pkg.display-name;
                                        flatpak-detail-summary = pkg.description;
                                        flatpak-detail-description = "";
                                        flatpak-detail-developer = "";
                                        flatpak-detail-version = "";
                                        flatpak-detail-version-date = "";
                                        flatpak-detail-changelog = "";
                                        flatpak-detail-url-homepage = "";
                                        flatpak-detail-url-bug = "";
                                        flatpak-detail-url-translate = "";
                                        flatpak-detail-url-vcs = "";
                                        flatpak-detail-tags = [];
                                        flatpak-screenshot = @image-url("");
                                        flatpak-detail-icon = @image-url("");
                                        flatpak-addons = [];
                                        flatpak-addons-installed = [];
                                        root.load-flatpak-detail(pkg.name);
                                        root.load-flatpak-icon(pkg.name);
                                        show-flatpak-detail = true;
                                    }
                                }

                                HorizontalLayout {
                                    padding-left: 16px;
                                    padding-right: 14px;
                                    spacing: 10px;

                                    // Checkbox
                                    VerticalLayout {
                                        alignment: center;
                                        CheckBox {
                                            checked: pkg.selected;
                                            toggled(val) => {
                                                root.toggle-flatpak-selected(pkg.name, val);
                                            }
                                        }
                                    }

                                    // Avatar (letter + category color)
                                    VerticalLayout {
                                        alignment: center;
                                        AppAvatar {
                                            initial: pkg.required-by;
                                            category: pkg.installed-size;
                                            width: 40px;
                                            height: 40px;
                                            border-radius: 10px;
                                        }
                                    }

                                    // Name + app id + description + add-ons tag
                                    VerticalLayout {
                                        horizontal-stretch: 1;
                                        alignment: center;
                                        spacing: 2px;

                                        Text {
                                            text: pkg.display-name;
                                            font-size: 14px;
                                            font-weight: 600;
                                            color: Cat.text;
                                            overflow: elide;
                                        }
                                        HorizontalLayout {
                                            spacing: 6px;
                                            Text {
                                                text: pkg.name;
                                                font-size: 14px;
                                                color: Cat.overlay0;
                                                overflow: elide;
                                            }
                                            if pkg.description != "": Text {
                                                text: "·";
                                                font-size: 14px;
                                                color: Cat.overlay0;
                                            }
                                            if pkg.description != "": Text {
                                                text: pkg.description;
                                                font-size: 14px;
                                                color: Cat.subtext0;
                                                opacity: 0.75;
                                                overflow: elide;
                                                horizontal-stretch: 1;
                                            }
                                            // Add-ons indicator tag
                                            if pkg.explicit: Rectangle {
                                                width: addon-tag-lbl.preferred-width + 12px;
                                                height: 14px;
                                                border-radius: 4px;
                                                background: Cat.mauve.with-alpha(0.12);
                                                border-width: 1px;
                                                border-color: Cat.mauve.with-alpha(0.3);
                                                addon-tag-lbl := Text {
                                                    text: "+ Add-ons";
                                                    font-size: 9px;
                                                    font-weight: 700;
                                                    color: Cat.mauve.with-alpha(0.85);
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }
                                            }
                                        }
                                    }

                                    // Install / Remove button
                                    VerticalLayout {
                                        alignment: center;
                                        Rectangle {
                                            width: pkg.installed ? 72px : 86px;
                                            height: 25px;
                                            border-radius: 6px;
                                            background: pkg.installed
                                                ? Cat.red.with-alpha(0.15)
                                                : Cat.mauve.with-alpha(0.15);

                                            Text {
                                                text: pkg.installed ? "Remove" : "Info / Install";
                                                font-size: pkg.installed ? 11px : 10px;
                                                font-weight: 600;
                                                color: pkg.installed ? Cat.red : Cat.mauve;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }

                                            TouchArea {
                                                mouse-cursor: pointer;
                                                clicked => {
                                                    if pkg.installed {
                                                        root.fp-confirm-id = pkg.name;
                                                        root.fp-confirm-name = pkg.display-name;
                                                        root.fp-confirm-open = true;
                                                    } else {
                                                        // Open detail view — install button is there
                                                        current-flatpak-id = pkg.name;
                                                        flatpak-detail-installed = pkg.installed;
                                                        flatpak-detail-name = pkg.display-name;
                                                        flatpak-detail-summary = pkg.description;
                                                        flatpak-detail-description = "";
                                                        flatpak-detail-developer = "";
                                                        flatpak-detail-version = "";
                                                        flatpak-detail-version-date = "";
                                                        flatpak-detail-changelog = "";
                                                        flatpak-detail-url-homepage = "";
                                                        flatpak-detail-url-bug = "";
                                                        flatpak-detail-url-translate = "";
                                                        flatpak-detail-url-vcs = "";
                                                        flatpak-detail-tags = [];
                                                        flatpak-screenshot = @image-url("");
                                                        flatpak-detail-icon = @image-url("");
                                                        flatpak-addons = [];
                                                        flatpak-addons-installed = [];
                                                        root.load-flatpak-detail(pkg.name);
                                                        root.load-flatpak-icon(pkg.name);
                                                        show-flatpak-detail = true;
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }

                                // Row separator
                                Rectangle {
                                    x: 16px;
                                    y: parent.height - 1px;
                                    width: parent.width - 32px;
                                    height: 1px;
                                    background: Cat.surface0;
                                    opacity: 0.5;
                                }
                            }

                            // Load More button — shown when there are more results beyond the current page
                            if flatpak-total-matches > remote-apps.length: Rectangle {
                                height: 56px;
                                background: transparent;

                                HorizontalLayout {
                                    alignment: center;
                                    padding: 10px;

                                    Rectangle {
                                        width: fk-lm-lbl.preferred-width + (flatpak-loading-more ? 52px : 36px);
                                        height: 32px;
                                        border-radius: 8px;
                                        background: load-more-touch.has-hover && !flatpak-loading-more
                                            ? Cat.mauve.with-alpha(0.18)
                                            : Cat.surface0.with-alpha(0.5);
                                        border-width: 1px;
                                        border-color: Cat.mauve.with-alpha(0.2);
                                        animate background { duration: 100ms; }

                                        HorizontalLayout {
                                            alignment: center;
                                            spacing: 6px;

                                            if flatpak-loading-more: Spinner {
                                                indeterminate: true;
                                                width: 14px;
                                                height: 14px;
                                            }

                                            fk-lm-lbl := Text {
                                                text: flatpak-loading-more
                                                    ? "Loading..."
                                                    : "Load More  (" + (flatpak-total-matches - remote-apps.length) + " remaining)";
                                                font-size: 13px;
                                                font-weight: 600;
                                                color: flatpak-loading-more ? Cat.overlay0 : Cat.mauve;
                                                vertical-alignment: center;
                                            }
                                        }

                                        load-more-touch := TouchArea {
                                            mouse-cursor: flatpak-loading-more ? default : pointer;
                                            clicked => {
                                                if !flatpak-loading-more {
                                                    flatpak-loading-more = true;
                                                    root.load-more-flatpaks();
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
                } // end browse tab VerticalLayout (if flatpak-tab == 0)

                // ── Installed Flatpaks tab ────────────────────────────────────
                if flatpak-tab == 1: VerticalLayout {
                    vertical-stretch: 1;
                    spacing: 0;

                    // Search bar for installed flatpaks
                    Rectangle {
                        height: 54px;
                        background: transparent;

                        TouchArea { clicked => { ifk-search-ti.focus(); } }

                        Rectangle {
                            x: 14px;
                            y: 9px;
                            width: parent.width - 28px;
                            height: 32px;
                            border-radius: 18px;
                            background: Cat.surface0;
                            border-width: ifk-search-ti.has-focus ? 1px : 0px;
                            border-color: Cat.green.with-alpha(0.4);
                            clip: true;
                            animate border-width { duration: 80ms; }

                            HorizontalLayout {
                                padding-left: 14px;
                                padding-right: 14px;
                                spacing: 10px;

                                VerticalLayout {
                                    alignment: center;
                                    NavIcon {
                                        d: "M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0";
                                        icon-color: ifk-search-ti.has-focus ? Cat.green.with-alpha(0.9) : Cat.overlay1;
                                        width: 13px;
                                        height: 13px;
                                    }
                                }

                                VerticalLayout {
                                    alignment: center;
                                    horizontal-stretch: 1;

                                    if installed-flatpak-filter == "" && !ifk-search-ti.has-focus: Text {
                                        height: 32px;
                                        text: "Filter installed Flatpaks...";
                                        font-size: 13px;
                                        color: Cat.overlay0;
                                        vertical-alignment: center;
                                    }

                                    ifk-search-ti := TextInput {
                                        height: 32px;
                                        text <=> installed-flatpak-filter;
                                        font-size: 13px;
                                        color: Cat.text;
                                        single-line: true;
                                        vertical-alignment: center;
                                        selection-background-color: Cat.green.with-alpha(0.3);
                                        selection-foreground-color: Cat.text;
                                        edited => { root.filter-installed-flatpaks(self.text); }
                                    }
                                }

                                if installed-flatpak-filter != "": VerticalLayout {
                                    alignment: center;
                                    Rectangle {
                                        width: 18px; height: 18px; border-radius: 9px;
                                        background: ifk-clr.has-hover ? Cat.surface1 : transparent;
                                        NavIcon { d: "M18 6L6 18M6 6l12 12"; icon-color: Cat.overlay1; width: 10px; height: 10px; x: 4px; y: 4px; }
                                        ifk-clr := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => { installed-flatpak-filter = ""; root.filter-installed-flatpaks(""); }
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // Column header
                    Rectangle {
                        height: 38px;

                        HorizontalLayout {
                            padding-left: 16px;
                            padding-right: 16px;
                            spacing: 10px;

                            Text {
                                horizontal-stretch: 1;
                                text: "INSTALLED FLATPAKS";
                                font-size: 10px;
                                font-weight: 700;
                                color: Cat.overlay0;
                                letter-spacing: 0.8px;
                                vertical-alignment: center;
                            }

                            Text {
                                text: installed-flatpaks.length + " apps";
                                font-size: 14px;
                                color: Cat.overlay0;
                                vertical-alignment: center;
                            }
                        }

                        Rectangle {
                            y: parent.height - 1px;
                            height: 1px;
                            width: parent.width;
                            background: Cat.surface0;
                            opacity: 0.6;
                        }
                    }

                    // Empty state
                    if installed-flatpaks.length == 0: VerticalLayout {
                        vertical-stretch: 1;
                        alignment: center;
                        spacing: 8px;

                        NavIcon {
                            d: "M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4";
                            icon-color: Cat.surface2;
                            width: 32px;
                            height: 29px;
                            x: (parent.width - 32px) / 2;
                        }

                        Text {
                            text: "No installed flatpaks";
                            font-size: 15px;
                            color: Cat.overlay0;
                            horizontal-alignment: center;
                        }
                    }

                    // Installed list
                    if installed-flatpaks.length > 0: ScrollView {
                        vertical-stretch: 1;

                        VerticalLayout {
                            spacing: 0;

                            for pkg[i] in installed-flatpaks: Rectangle {
                                height: 56px;
                                background: ifk-touch.has-hover ? Cat.surface0.with-alpha(0.4) : transparent;
                                animate background { duration: 60ms; }

                                // TouchArea FIRST so Remove button's TouchArea sits on top of it
                                ifk-touch := TouchArea {}

                                HorizontalLayout {
                                    padding-left: 16px;
                                    padding-right: 14px;
                                    spacing: 10px;

                                    // Avatar (letter initial)
                                    VerticalLayout {
                                        alignment: center;
                                        AppAvatar {
                                            initial: pkg.required-by;
                                            category: "System";
                                            width: 36px;
                                            height: 32px;
                                            border-radius: 9px;
                                        }
                                    }

                                    // Name + app_id
                                    VerticalLayout {
                                        horizontal-stretch: 1;
                                        alignment: center;
                                        spacing: 2px;

                                        Text {
                                            text: pkg.display-name;
                                            font-size: 14px;
                                            font-weight: 600;
                                            color: Cat.text;
                                            overflow: elide;
                                        }

                                        Text {
                                            text: pkg.name;
                                            font-size: 14px;
                                            color: Cat.overlay0;
                                            overflow: elide;
                                        }
                                    }

                                    // Version pill
                                    VerticalLayout {
                                        alignment: center;
                                        Rectangle {
                                            width: ifk-ver.preferred-width + 16px;
                                            height: 22px;
                                            border-radius: 5px;
                                            background: Cat.surface0.with-alpha(0.7);
                                            ifk-ver := Text {
                                                text: pkg.version;
                                                font-size: 14px;
                                                color: Cat.subtext0;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }

                                    // Remove button
                                    VerticalLayout {
                                        alignment: center;
                                        Rectangle {
                                            width: 72px;
                                            height: 32px;
                                            border-radius: 6px;
                                            background: ifk-rm-touch.has-hover
                                                ? Cat.red.with-alpha(0.28)
                                                : Cat.red.with-alpha(0.15);
                                            animate background { duration: 60ms; }

                                            Text {
                                                text: "Remove";
                                                font-size: 15px;
                                                font-weight: 600;
                                                color: Cat.red;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }

                                            ifk-rm-touch := TouchArea {
                                                mouse-cursor: pointer;
                                                clicked => {
                                                    root.fp-confirm-id = pkg.name;
                                                    root.fp-confirm-name = pkg.display-name;
                                                    root.fp-confirm-open = true;
                                                }
                                            }
                                        }
                                    }
                                }

                                Rectangle {
                                    x: 16px;
                                    y: parent.height - 1px;
                                    width: parent.width - 32px;
                                    height: 1px;
                                    background: Cat.surface0;
                                    opacity: 0.5;
                                }
                            }
                        }
                    }
                } // end installed tab VerticalLayout (if flatpak-tab == 1)

            } // end view 10 VerticalLayout

            // Repos browser — Flatpak-style layout with search + repo tabs + hero
            if view == 7 || view == 8: VerticalLayout {
                vertical-stretch: 1;
                spacing: 0;

                // ── Tab strip: Browse | Installed ─────────────────────────
                Rectangle {
                    height: 40px;
                    background: transparent;

                    HorizontalLayout {
                        padding-left: 16px;
                        spacing: 0;

                        Rectangle {
                            width: 90px;
                            height: parent.height;
                            Text {
                                text: "Browse";
                                font-size: 14px;
                                font-weight: repos-view == 0 ? 700 : 500;
                                color: repos-view == 0 ? Cat.blue : Cat.overlay1;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            Rectangle {
                                y: parent.height - 2px;
                                height: 2px;
                                width: parent.width;
                                background: repos-view == 0 ? Cat.blue : transparent;
                                animate background { duration: 120ms; }
                            }
                            TouchArea {
                                mouse-cursor: pointer;
                                clicked => { repos-view = 0; }
                            }
                        }

                        Rectangle {
                            width: 100px;
                            height: parent.height;
                            Text {
                                text: "Installed";
                                font-size: 14px;
                                font-weight: repos-view == 1 ? 700 : 500;
                                color: repos-view == 1 ? Cat.mauve : Cat.overlay1;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            Rectangle {
                                y: parent.height - 2px;
                                height: 2px;
                                width: parent.width;
                                background: repos-view == 1 ? Cat.mauve : transparent;
                                animate background { duration: 120ms; }
                            }
                            TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    repos-view = 1;
                                    if installed-grouped.length == 0 { root.load-installed-grouped(); }
                                }
                            }
                        }

                        Rectangle { horizontal-stretch: 1; }
                    }

                    Rectangle {
                        y: parent.height - 1px;
                        height: 1px;
                        width: parent.width;
                        background: Cat.surface0;
                    }
                }

                // ── Browse tab ─────────────────────────────────────────────
                if repos-view == 0: VerticalLayout {
                    vertical-stretch: 1;
                    spacing: 0;

                // ── Pill-shaped search bar ─────────────────────────────────
                Rectangle {
                    height: 52px;
                    background: transparent;

                    TouchArea { clicked => { rs-ti.focus(); } }

                    Rectangle {
                        x: 14px;
                        y: 11px;
                        width: parent.width - 28px;
                        height: 32px;
                        border-radius: 18px;
                        background: Cat.surface0;
                        border-width: rs-ti.has-focus ? 1px : 0px;
                        border-color: Cat.blue.with-alpha(0.4);
                        clip: true;
                        animate border-width { duration: 80ms; }

                        HorizontalLayout {
                            padding-left: 14px;
                            padding-right: 14px;
                            spacing: 10px;

                            VerticalLayout {
                                alignment: center;
                                NavIcon {
                                    d: "M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0";
                                    icon-color: rs-ti.has-focus ? Cat.blue.with-alpha(0.9) : Cat.overlay1;
                                    width: 14px;
                                    height: 14px;
                                }
                            }

                            VerticalLayout {
                                alignment: center;
                                horizontal-stretch: 1;

                                if repo-search == "" && !rs-ti.has-focus: Text {
                                    height: 32px;
                                    text: selected-repo != "" ? "Search in " + selected-repo + "..." : "Search all packages...";
                                    font-size: 14px;
                                    color: Cat.overlay0;
                                    vertical-alignment: center;
                                }

                                rs-ti := TextInput {
                                    height: 32px;
                                    text <=> repo-search;
                                    font-size: 14px;
                                    color: Cat.text;
                                    single-line: true;
                                    vertical-alignment: center;
                                    selection-background-color: Cat.blue.with-alpha(0.3);
                                    selection-foreground-color: Cat.text;
                                    accepted => { root.filter-repo(self.text); }
                                    edited => { root.filter-repo(self.text); }
                                }
                            }
                        }
                    }
                }

                // ── Repo tabs as centered pills ─────────────────────────────
                Rectangle {
                    height: 50px;

                    if pacman-repos.length == 0: HorizontalLayout {
                        padding-left: 14px;
                        spacing: 8px;
                        alignment: center;
                        NavIcon {
                            d: "M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15";
                            icon-color: Cat.overlay0;
                            width: 14px;
                            height: 14px;
                        }
                        Text { text: "Loading repositories..."; font-size: 13px; color: Cat.overlay0; vertical-alignment: center; }
                    }

                    if pacman-repos.length > 0: HorizontalLayout {
                        alignment: center;
                        spacing: 8px;
                        padding: 10px;

                        // "All" pill — shows combined packages from all repos
                        Rectangle {
                            width: all-pill-lbl.preferred-width + 28px;
                            height: 30px;
                            border-radius: 15px;
                            border-width: 1px;
                            border-color: selected-repo == "" ? Cat.blue.with-alpha(0.5) : Cat.surface1;
                            background: selected-repo == "" ? Cat.blue.with-alpha(0.12) :
                                        (all-pill-ta.has-hover ? Cat.surface1 : Cat.surface0.with-alpha(0.5));
                            animate background { duration: 70ms; }
                            all-pill-lbl := Text {
                                text: "All";
                                font-size: 13px;
                                font-weight: selected-repo == "" ? 700 : 400;
                                color: selected-repo == "" ? Cat.blue : Cat.subtext0;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            all-pill-ta := TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    selected-repo = "";
                                    view = 8;
                                    repo-search = "";
                                    root.browse-repo("");
                                }
                            }
                        }

                        for repo[i] in pacman-repos: Rectangle {
                            width: rp-lbl.preferred-width + 28px;
                            height: 30px;
                            border-radius: 15px;
                            border-width: 1px;
                            border-color: selected-repo == repo ? Cat.blue.with-alpha(0.5) : Cat.surface1;
                            background: selected-repo == repo ? Cat.blue.with-alpha(0.12) :
                                        (rp-t.has-hover ? Cat.surface1 : Cat.surface0.with-alpha(0.5));
                            animate background { duration: 70ms; }

                            rp-lbl := Text {
                                text: repo;
                                font-size: 13px;
                                font-weight: selected-repo == repo ? 700 : 400;
                                color: selected-repo == repo ? Cat.blue : Cat.subtext0;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            rp-t := TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    selected-repo = repo;
                                    view = 8;
                                    show-repo-detail = false;
                                    repo-search = "";
                                    root.browse-repo(repo);
                                }
                            }
                        }
                    }
                }

                // ── Package list ─────────────────────────────────────────────
                VerticalLayout {
                    vertical-stretch: 1;

                    // Loading state
                    if repo-loading: VerticalLayout {
                        vertical-stretch: 1; alignment: center; spacing: 8px;
                        Spinner { width: 24px; height: 24px; indeterminate: true; x: (parent.width - 24px) / 2; }
                        Text { text: selected-repo != "" ? "Loading " + selected-repo + "..." : "Loading packages..."; font-size: 13px; color: Cat.overlay0; horizontal-alignment: center; }
                    }

                    // Column header
                    if !repo-loading: Rectangle {
                        height: 30px;
                        background: Cat.surface0.with-alpha(0.5);
                        HorizontalLayout {
                            padding-left: 14px; padding-right: 12px;
                            Text { text: "Name"; font-size: 14px; font-weight: 700; color: Cat.overlay0; letter-spacing: 0.5px; vertical-alignment: center; horizontal-stretch: 1; }
                            Rectangle { width: 120px; Text { text: "Version"; font-size: 14px; font-weight: 700; color: Cat.overlay0; letter-spacing: 0.5px; vertical-alignment: center; horizontal-alignment: right; } }
                            Rectangle { width: 80px; Text { text: "Repo"; font-size: 14px; font-weight: 700; color: Cat.overlay0; letter-spacing: 0.5px; vertical-alignment: center; horizontal-alignment: right; } }
                            Rectangle { width: 90px; Text { text: "Action"; font-size: 14px; font-weight: 700; color: Cat.overlay0; letter-spacing: 0.5px; vertical-alignment: center; horizontal-alignment: center; } }
                        }
                    }

                    if !repo-loading && repo-packages.length == 0: VerticalLayout {
                        vertical-stretch: 1; alignment: center;
                        Text { text: "No packages found"; font-size: 14px; color: Cat.overlay0; horizontal-alignment: center; }
                    }

                    if !repo-loading && repo-packages.length > 0: ListView {
                        vertical-stretch: 1;
                        for p[i] in repo-packages: RepoRow {
                            pkg: p;
                            show-checkbox: multi-select-mode;
                            toggle-selected(val) => { root.toggle-package-selected(p.name, p.backend, val); }
                            install => { root.request-install(p.name, p.backend); }
                            remove => { root.request-remove(p.name, p.backend); }
                            show-tree => {
                                dep-tree-pkg = p.name;
                                dep-tree-tab = 0;
                                dep-tree-nodes = [];
                                dep-reqby-nodes = [];
                                dep-tree-loading = true;
                                view = 12;
                                root.load-dep-tree(p.name);
                            }
                        }
                    }

                    // Load More button
                    if !repo-loading && repo-has-more: Rectangle {
                        height: 40px;
                        background: Cat.surface0.with-alpha(0.3);
                        Rectangle {
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            width: lm-lbl.preferred-width + 36px; height: 32px; border-radius: 8px;
                            background: lm-ta.has-hover ? Cat.blue.with-alpha(0.2) : Cat.blue.with-alpha(0.1);
                            border-width: 1px; border-color: Cat.blue.with-alpha(0.3);
                            animate background { duration: 60ms; }
                            lm-lbl := Text { text: "Load " + repo-extra-count + " more packages"; font-size: 15px; font-weight: 600; color: Cat.blue; horizontal-alignment: center; vertical-alignment: center; }
                            lm-ta := TouchArea { mouse-cursor: pointer; clicked => { root.load-more-repo-pkgs(); } }
                        }
                    }
                }
            }

            if !loading && view == 2 && (search-installed.length > 0 || search-available.length > 0): ScrollView {
                vertical-stretch: 1;

                VerticalLayout {
                    spacing: 0px;

                    if search-installed.length > 0: VerticalLayout {
                        spacing: 0px;

                        Rectangle {
                            height: 29px;
                            background: Cat.green.with-alpha(0.06);
                            border-radius: 6px;

                            HorizontalLayout {
                                padding-left: 12px;
                                spacing: 6px;
                                alignment: center;

                                VerticalLayout { alignment: center;
                                    NavIcon {
                                        d: "M20 6L9 17l-5-5";
                                        icon-color: Cat.green;
                                        width: 14px;
                                        height: 14px;
                                    }
                                }

                                Text {
                                    text: "Installed (" + search-installed.length + ")";
                                    font-size: 15px;
                                    font-weight: 700;
                                    color: Cat.green;
                                    vertical-alignment: center;
                                }
                            }
                        }

                        for p[i] in search-installed: PackageRow {
                            pkg: p;
                            show-separator: i < search-installed.length - 1;
                            show-checkbox: multi-select-mode;
                            install => { root.request-install(p.name, p.backend); }
                            remove => { root.request-remove(p.name, p.backend); }
                            toggle-selected(val) => { root.toggle-package-selected(p.name, p.backend, val); }
                        }
                    }

                    if search-available.length > 0: VerticalLayout {
                        spacing: 0px;

                        Rectangle {
                            height: 29px;
                            background: Cat.blue.with-alpha(0.06);
                            border-radius: 6px;

                            HorizontalLayout {
                                padding-left: 12px;
                                spacing: 6px;
                                alignment: center;

                                VerticalLayout { alignment: center;
                                    NavIcon {
                                        d: icon-package;
                                        icon-color: Cat.blue;
                                        width: 14px;
                                        height: 14px;
                                    }
                                }

                                Text {
                                    text: "Available (" + search-available.length + ")";
                                    font-size: 15px;
                                    font-weight: 700;
                                    color: Cat.blue;
                                    vertical-alignment: center;
                                }
                            }
                        }

                        for p[i] in search-available: PackageRow {
                            pkg: p;
                            show-separator: i < search-available.length - 1;
                            show-checkbox: multi-select-mode;
                            install => { root.request-install(p.name, p.backend); }
                            remove => { root.request-remove(p.name, p.backend); }
                            toggle-selected(val) => { root.toggle-package-selected(p.name, p.backend, val); }
                        }
                    }
                }
                } // end browse tab (repos-view == 0)

                // ── Installed tab — packages grouped by repo ───────────────
                if repos-view == 1: VerticalLayout {
                    vertical-stretch: 1;
                    spacing: 0;

                    // Search bar for installed native packages
                    Rectangle {
                        height: 54px;
                        background: transparent;

                        TouchArea { clicked => { ni-search-ti.focus(); } }

                        Rectangle {
                            x: 14px;
                            y: 9px;
                            width: parent.width - 28px;
                            height: 32px;
                            border-radius: 18px;
                            background: Cat.surface0;
                            border-width: ni-search-ti.has-focus ? 1px : 0px;
                            border-color: Cat.mauve.with-alpha(0.4);
                            clip: true;
                            animate border-width { duration: 80ms; }

                            HorizontalLayout {
                                padding-left: 14px;
                                padding-right: 14px;
                                spacing: 10px;

                                VerticalLayout {
                                    alignment: center;
                                    NavIcon {
                                        d: "M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0";
                                        icon-color: ni-search-ti.has-focus ? Cat.mauve.with-alpha(0.9) : Cat.overlay1;
                                        width: 13px;
                                        height: 13px;
                                    }
                                }

                                VerticalLayout {
                                    alignment: center;
                                    horizontal-stretch: 1;

                                    if installed-grouped-filter == "" && !ni-search-ti.has-focus: Text {
                                        height: 32px;
                                        text: "Filter installed packages...";
                                        font-size: 13px;
                                        color: Cat.overlay0;
                                        vertical-alignment: center;
                                    }

                                    ni-search-ti := TextInput {
                                        height: 32px;
                                        text <=> installed-grouped-filter;
                                        font-size: 13px;
                                        color: Cat.text;
                                        single-line: true;
                                        vertical-alignment: center;
                                        selection-background-color: Cat.mauve.with-alpha(0.3);
                                        selection-foreground-color: Cat.text;
                                        edited => { root.filter-installed-grouped(self.text); }
                                        accepted => { root.filter-installed-grouped(self.text); }
                                    }
                                }

                                if installed-grouped-filter != "": VerticalLayout {
                                    alignment: center;
                                    Rectangle {
                                        width: 18px; height: 18px; border-radius: 9px;
                                        background: ni-clr.has-hover ? Cat.surface1 : transparent;
                                        NavIcon { d: "M18 6L6 18M6 6l12 12"; icon-color: Cat.overlay1; width: 10px; height: 10px; x: 4px; y: 4px; }
                                        ni-clr := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => { installed-grouped-filter = ""; root.filter-installed-grouped(""); }
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // Column header — filter pills only, centered
                    Rectangle {
                        height: 46px;

                        HorizontalLayout {
                            padding-left: 16px;
                            padding-right: 16px;
                            spacing: 8px;
                            alignment: center;

                            // Filter pills: All / Explicit / Deps
                            for opt[idx] in ["All", "Explicit", "Deps"]: Rectangle {
                                property <bool> active: installed-explicit-filter == idx;
                                width: pill-lbl.preferred-width + 16px;
                                height: 22px;
                                border-radius: 6px;
                                background: active
                                    ? (idx == 1 ? Cat.mauve : idx == 2 ? Cat.sapphire : Cat.surface1)
                                    : (pill-ta.has-hover ? Cat.surface1.with-alpha(0.6) : Cat.surface0.with-alpha(0.5));
                                animate background { duration: 80ms; }
                                pill-lbl := Text {
                                    text: opt;
                                    font-size: 14px;
                                    font-weight: active ? 700 : 400;
                                    color: active ? Cat.crust : Cat.subtext0;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                                pill-ta := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => {
                                        installed-explicit-filter = idx;
                                        root.apply-explicit-filter(idx);
                                    }
                                }
                            }
                        }

                        Rectangle {
                            y: parent.height - 1px;
                            height: 1px;
                            width: parent.width;
                            background: Cat.surface0;
                            opacity: 0.6;
                        }
                    }

                    if installed-grouped.length == 0: VerticalLayout {
                        vertical-stretch: 1;
                        alignment: center;
                        spacing: 6px;
                        Spinner { indeterminate: true; width: 20px; height: 20px; x: (parent.width - 20px) / 2; }
                        Text { text: "Loading..."; font-size: 13px; color: Cat.overlay0; horizontal-alignment: center; }
                    }

                    if installed-grouped.length > 0: ListView {
                        vertical-stretch: 1;

                            for pkg[i] in installed-grouped: Rectangle {
                                height: pkg.backend == -1 ? 30px : 54px;
                                background: pkg.backend != -1 && ri-touch.has-hover
                                    ? Cat.surface0.with-alpha(0.35) : transparent;
                                animate background { duration: 60ms; }

                                // hover area BEHIND content so buttons get clicks
                                ri-touch := TouchArea {}

                                // ── Repo header ─────────────────────────────
                                if pkg.backend == -1: HorizontalLayout {
                                    padding-left: 16px;
                                    padding-right: 16px;
                                    spacing: 8px;
                                    VerticalLayout {
                                        alignment: center;
                                        Rectangle {
                                            width: ri-repo-lbl.preferred-width + 14px;
                                            height: 18px;
                                            border-radius: 5px;
                                            background: Cat.surface1.with-alpha(0.7);
                                            ri-repo-lbl := Text {
                                                text: pkg.name;
                                                font-size: 10px;
                                                font-weight: 700;
                                                color: pkg.repository == "core" ? Cat.blue :
                                                       pkg.repository == "extra" ? Cat.mauve :
                                                       pkg.repository == "multilib" ? Cat.teal :
                                                       pkg.repository == "aur" ? Cat.peach :
                                                       Cat.overlay1;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                                letter-spacing: 0.5px;
                                            }
                                        }
                                    }
                                    Rectangle {
                                        horizontal-stretch: 1;
                                        height: 1px;
                                        y: parent.height / 2;
                                        background: Cat.surface1.with-alpha(0.4);
                                    }
                                }

                                // ── Package row ──────────────────────────────
                                if pkg.backend != -1: HorizontalLayout {
                                    padding-left: 16px;
                                    padding-right: 14px;
                                    spacing: 10px;

                                    // Avatar
                                    VerticalLayout {
                                        alignment: center;
                                        AppAvatar {
                                            initial: pkg.required-by;
                                            category: pkg.installed-size;
                                            width: 36px;
                                            height: 32px;
                                            border-radius: 9px;
                                        }
                                    }

                                    // Name + description
                                    VerticalLayout {
                                        horizontal-stretch: 1;
                                        alignment: center;
                                        spacing: 2px;
                                        Text {
                                            text: pkg.display-name;
                                            font-size: 14px;
                                            font-weight: 600;
                                            color: Cat.text;
                                            overflow: elide;
                                        }
                                        Text {
                                            text: pkg.description;
                                            font-size: 14px;
                                            color: Cat.subtext0;
                                            opacity: 0.75;
                                            overflow: elide;
                                        }
                                    }

                                    // Version pill
                                    VerticalLayout {
                                        alignment: center;
                                        Rectangle {
                                            width: ri-ver.preferred-width + 14px;
                                            height: 20px;
                                            border-radius: 5px;
                                            background: Cat.surface0.with-alpha(0.7);
                                            ri-ver := Text {
                                                text: pkg.version;
                                                font-size: 14px;
                                                color: Cat.subtext0;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }

                                    // Explicit badge
                                    VerticalLayout {
                                        alignment: center;
                                        visible: pkg.explicit;
                                        width: pkg.explicit ? 54px : 0px;
                                        Rectangle {
                                            width: 54px;
                                            height: 20px;
                                            border-radius: 5px;
                                            background: Cat.mauve.with-alpha(0.18);
                                            border-width: 1px;
                                            border-color: Cat.mauve.with-alpha(0.4);
                                            Text {
                                                text: "Explicit";
                                                font-size: 13px;
                                                font-weight: 600;
                                                color: Cat.mauve;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }

                                    // Tree button
                                    VerticalLayout {
                                        alignment: center;
                                        Rectangle {
                                            width: 66px;
                                            height: 32px;
                                            border-radius: 6px;
                                            background: ri-tr-touch.has-hover
                                                ? Cat.sapphire.with-alpha(0.28)
                                                : Cat.sapphire.with-alpha(0.15);
                                            animate background { duration: 60ms; }
                                            Text {
                                                text: "Tree";
                                                font-size: 15px;
                                                font-weight: 600;
                                                color: Cat.sapphire;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                            ri-tr-touch := TouchArea {
                                                mouse-cursor: pointer;
                                                clicked => {
                                                    dep-tree-pkg = pkg.name;
                                                    dep-tree-tab = 0;
                                                    dep-tree-nodes = [];
                                                    dep-reqby-nodes = [];
                                                    dep-tree-loading = true;
                                                    view = 12;
                                                    root.load-dep-tree(pkg.name);
                                                }
                                            }
                                        }
                                    }

                                    // Downgrade button
                                    VerticalLayout {
                                        alignment: center;
                                        Rectangle {
                                            width: 82px;
                                            height: 31px;
                                            border-radius: 6px;
                                            background: ri-dg-touch.has-hover
                                                ? Cat.yellow.with-alpha(0.28)
                                                : Cat.yellow.with-alpha(0.15);
                                            animate background { duration: 60ms; }
                                            Text {
                                                text: "Downgrade";
                                                font-size: 14px;
                                                font-weight: 600;
                                                color: Cat.yellow;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                            ri-dg-touch := TouchArea {
                                                mouse-cursor: pointer;
                                                clicked => { root.downgrade-package(pkg.name); }
                                            }
                                        }
                                    }

                                    // Remove button
                                    VerticalLayout {
                                        alignment: center;
                                        Rectangle {
                                            width: 82px;
                                            height: 32px;
                                            border-radius: 6px;
                                            background: ri-rm-touch.has-hover
                                                ? Cat.red.with-alpha(0.28)
                                                : Cat.red.with-alpha(0.15);
                                            animate background { duration: 60ms; }
                                            Text {
                                                text: "Remove";
                                                font-size: 15px;
                                                font-weight: 600;
                                                color: Cat.red;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                            ri-rm-touch := TouchArea {
                                                mouse-cursor: pointer;
                                                clicked => { root.request-remove(pkg.name, pkg.backend); }
                                            }
                                        }
                                    }
                                }

                                if pkg.backend != -1: Rectangle {
                                    x: 16px;
                                    y: parent.height - 1px;
                                    width: parent.width - 32px;
                                    height: 1px;
                                    background: Cat.surface0;
                                    opacity: 0.4;
                                }
                            }
                    }

                    // Load All button
                    if !installed-grouped-all-loaded: Rectangle {
                        height: 40px;
                        background: Cat.surface0.with-alpha(0.3);
                        border-width: 1px;
                        border-color: Cat.surface1;

                        HorizontalLayout {
                            alignment: center;
                            spacing: 8px;

                            VerticalLayout {
                                alignment: center;
                                NavIcon {
                                    d: "M19 9l-7 7-7-7";
                                    icon-color: load-all-ta.has-hover ? Cat.blue : Cat.overlay1;
                                    width: 14px;
                                    height: 14px;
                                }
                            }

                            Text {
                                text: "Load All Installed Packages";
                                font-size: 13px;
                                font-weight: 500;
                                color: load-all-ta.has-hover ? Cat.blue : Cat.subtext0;
                                vertical-alignment: center;
                                animate color { duration: 80ms; }
                            }
                        }

                        load-all-ta := TouchArea {
                            mouse-cursor: pointer;
                            clicked => {
                                installed-grouped-all-loaded = true;
                                root.load-all-installed-grouped();
                            }
                        }
                    }
                } // end installed tab (repos-view == 1)

            } // end view 7/8 VerticalLayout

            if view == 5: ScrollView {
                vertical-stretch: 1;

                VerticalLayout {
                    padding: 4px;
                    spacing: 28px;
                    alignment: start;


                    VerticalLayout {
                        spacing: 8px;
                        SectionLabel { section-title: "GENERAL"; }

                        SettingsRow {
                            label: "Flatpak Support";
                            subtitle: "Enable Flatpak package management";
                            checked: setting-flatpak-enabled;
                            toggled(val) => {
                                setting-flatpak-enabled = val;
                                if !val && view == 10 { view = 9; }
                                root.save-settings();
                            }
                        }

                        SettingsRow {
                            label: "Check Updates on Startup";
                            subtitle: "Automatically sync databases on launch";
                            checked: setting-check-updates-on-start;
                            toggled(val) => { setting-check-updates-on-start = val; root.save-settings(); }
                        }

                        // Parallel downloads picker
                        Rectangle {
                            border-radius: 8px;
                            background: Cat.surface0.with-alpha(0.4);

                            // Compute whether the current value is a preset or custom
                            property <bool> is-preset: setting-parallel-downloads == 5
                                || setting-parallel-downloads == 10
                                || setting-parallel-downloads == 15
                                || setting-parallel-downloads == 20
                                || setting-parallel-downloads == 25;

                            VerticalLayout {
                                padding-left: 16px;
                                padding-right: 16px;
                                padding-top: 12px;
                                padding-bottom: 12px;
                                spacing: 10px;

                                // Row 1: label + pills
                                HorizontalLayout {
                                    spacing: 0px;

                                    VerticalLayout {
                                        alignment: center;
                                        horizontal-stretch: 1;
                                        spacing: 2px;

                                        Text {
                                            text: "Parallel Downloads";
                                            font-size: 14px;
                                            color: Cat.text;
                                        }
                                        Text {
                                            text: "Current: " + setting-parallel-downloads
                                                + (is-preset ? "" : "  (Custom)");
                                            font-size: 15px;
                                            color: is-preset ? Cat.overlay0 : Cat.peach;
                                        }
                                    }

                                    HorizontalLayout {
                                        alignment: center;
                                        spacing: 4px;

                                        // Preset pills
                                        for opt[i] in [5, 10, 15, 20, 25]: Rectangle {
                                            width: 36px;
                                            height: 31px;
                                            border-radius: 6px;
                                            background: (setting-parallel-downloads == opt && is-preset) ?
                                                Cat.mauve : (pd-touch.has-hover ? Cat.surface1 : Cat.surface0);
                                            animate background { duration: 80ms; }

                                            Text {
                                                text: opt;
                                                font-size: 15px;
                                                font-weight: (setting-parallel-downloads == opt && is-preset) ? 700 : 400;
                                                color: (setting-parallel-downloads == opt && is-preset) ? Cat.crust : Cat.subtext0;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }

                                            pd-touch := TouchArea {
                                                mouse-cursor: pointer;
                                                clicked => {
                                                    setting-parallel-downloads = opt;
                                                    setting-pd-custom-mode = false;
                                                    setting-pd-custom-text = "";
                                                    root.save-settings();
                                                    root.set-parallel-downloads(opt);
                                                }
                                            }
                                        }

                                        // Custom pill
                                        Rectangle {
                                            width: 52px;
                                            height: 29px;
                                            border-radius: 6px;
                                            background: setting-pd-custom-mode ?
                                                Cat.peach : (custom-pill-ta.has-hover ? Cat.surface1 : Cat.surface0);
                                            animate background { duration: 80ms; }

                                            Text {
                                                text: "Custom";
                                                font-size: 14px;
                                                font-weight: setting-pd-custom-mode ? 700 : 400;
                                                color: setting-pd-custom-mode ? Cat.crust : Cat.subtext0;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }

                                            custom-pill-ta := TouchArea {
                                                mouse-cursor: pointer;
                                                clicked => {
                                                    setting-pd-custom-mode = !setting-pd-custom-mode;
                                                }
                                            }
                                        }
                                    }
                                }

                                // Row 2: custom input (visible only when custom mode)
                                if setting-pd-custom-mode: HorizontalLayout {
                                    spacing: 8px;

                                    Rectangle {
                                        horizontal-stretch: 1;
                                        height: 30px;
                                        border-radius: 6px;
                                        background: Cat.surface1;
                                        border-width: custom-input.has-focus ? 1px : 0px;
                                        border-color: Cat.peach.with-alpha(0.5);
                                        clip: true;

                                        HorizontalLayout {
                                            padding-left: 10px;
                                            padding-right: 10px;

                                            if setting-pd-custom-text == "" && !custom-input.has-focus: Text {
                                                height: 30px;
                                                text: "Enter number (e.g. 8)";
                                                font-size: 13px;
                                                color: Cat.overlay0;
                                                vertical-alignment: center;
                                            }

                                            custom-input := TextInput {
                                                height: 30px;
                                                text <=> setting-pd-custom-text;
                                                font-size: 13px;
                                                color: Cat.text;
                                                single-line: true;
                                                vertical-alignment: center;
                                                accepted => {
                                                    if setting-pd-custom-text != "" {
                                                        setting-parallel-downloads = setting-pd-custom-text.to-float();
                                                        root.save-settings();
                                                        root.set-parallel-downloads(setting-parallel-downloads);
                                                    }
                                                }
                                            }
                                        }
                                    }

                                    Rectangle {
                                        width: 60px;
                                        height: 32px;
                                        border-radius: 6px;
                                        background: apply-ta.has-hover ? Cat.peach.with-alpha(0.85) : Cat.peach;
                                        animate background { duration: 80ms; }

                                        Text {
                                            text: "Apply";
                                            font-size: 15px;
                                            font-weight: 700;
                                            color: Cat.crust;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }

                                        apply-ta := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => {
                                                if setting-pd-custom-text != "" {
                                                    setting-parallel-downloads = setting-pd-custom-text.to-float();
                                                    root.save-settings();
                                                    root.set-parallel-downloads(setting-parallel-downloads);
                                                }
                                            }
                                        }
                                    }
                                }

                                // Row 3: caution — always show when custom mode active
                                if setting-pd-custom-mode: Rectangle {
                                    height: 38px;
                                    border-radius: 5px;
                                    background: Cat.peach.with-alpha(0.08);
                                    border-width: 1px;
                                    border-color: Cat.peach.with-alpha(0.3);

                                    HorizontalLayout {
                                        padding-left: 10px;
                                        padding-right: 10px;
                                        padding-top: 6px;
                                        padding-bottom: 6px;
                                        spacing: 8px;

                                        VerticalLayout {
                                            alignment: center;
                                            NavIcon {
                                                d: "M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z";
                                                icon-color: Cat.peach;
                                                width: 14px;
                                                height: 14px;
                                            }
                                        }

                                        Text {
                                            text: "Values above 25 may overwhelm mirrors and cause slower or failed downloads. Use at your own risk.";
                                            font-size: 11px;
                                            color: Cat.peach;
                                            vertical-alignment: center;
                                            wrap: word-wrap;
                                        }
                                    }
                                }
                            }
                        }
                    }

                    VerticalLayout {
                        spacing: 8px;
                        SectionLabel { section-title: "SYSTEM TRAY"; }

                        SettingsRow {
                            label: "Enable System Tray Icon";
                            subtitle: "Show xPM in the system tray — also enables autostart on login";
                            checked: setting-tray-enabled;
                            toggled(val) => {
                                setting-tray-enabled = val;
                                root.toggle-tray-enabled(val);
                                root.save-settings();
                            }
                        }

                        // Update check frequency — only shown when tray is enabled
                        if setting-tray-enabled: Rectangle {
                            border-radius: 8px;
                            background: Cat.surface0.with-alpha(0.4);

                            VerticalLayout {
                                padding-left: 16px; padding-right: 16px;
                                padding-top: 12px; padding-bottom: 12px;
                                spacing: 10px;

                                HorizontalLayout {
                                    spacing: 0px;

                                    VerticalLayout {
                                        alignment: center;
                                        horizontal-stretch: 1;
                                        spacing: 2px;
                                        Text { text: "Update Check Frequency"; font-size: 14px; color: Cat.text; }
                                        Text {
                                            text: "Check for updates every "
                                                + (setting-tray-check-interval == 15 ? "15 minutes" :
                                                   setting-tray-check-interval == 30 ? "30 minutes" :
                                                   setting-tray-check-interval == 60 ? "1 hour" :
                                                   setting-tray-check-interval == 120 ? "2 hours" : "6 hours");
                                            font-size: 15px; color: Cat.overlay0;
                                        }
                                    }

                                    HorizontalLayout {
                                        alignment: center;
                                        spacing: 4px;

                                        for opt in [15, 30, 60, 120, 360]: Rectangle {
                                            width: 44px; height: 31px; border-radius: 6px;
                                            background: setting-tray-check-interval == opt
                                                ? Cat.mauve : (tray-freq-ta.has-hover ? Cat.surface1 : Cat.surface0);
                                            animate background { duration: 80ms; }
                                            Text {
                                                text: opt == 15 ? "15m" :
                                                      opt == 30 ? "30m" :
                                                      opt == 60 ? "1h"  :
                                                      opt == 120 ? "2h" : "6h";
                                                font-size: 15px;
                                                font-weight: setting-tray-check-interval == opt ? 700 : 400;
                                                color: setting-tray-check-interval == opt ? Cat.crust : Cat.subtext0;
                                                horizontal-alignment: center; vertical-alignment: center;
                                            }
                                            tray-freq-ta := TouchArea {
                                                mouse-cursor: pointer;
                                                clicked => {
                                                    setting-tray-check-interval = opt;
                                                    root.save-settings();
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        // Info box
                        Rectangle {
                            border-radius: 8px;
                            background: Cat.blue.with-alpha(0.06);
                            border-width: 1px;
                            border-color: Cat.blue.with-alpha(0.2);

                            HorizontalLayout {
                                padding-left: 14px; padding-right: 14px;
                                padding-top: 10px; padding-bottom: 10px;
                                spacing: 12px;

                                VerticalLayout {
                                    alignment: start;
                                    padding-top: 1px;
                                    NavIcon {
                                        d: "M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z";
                                        icon-color: Cat.blue;
                                        width: 15px; height: 15px;
                                    }
                                }

                                Text {
                                    text: "Not required on XeroLinux. The Apdatifier plasmoid already handles that stuff and more. Only enable if needed (Other Distros).";
                                    font-size: 11px;
                                    color: Cat.blue.with-alpha(0.85);
                                    vertical-alignment: center;
                                    wrap: word-wrap;
                                    horizontal-stretch: 1;
                                }
                            }
                        }
                    }

                    VerticalLayout {
                        spacing: 8px;
                        SectionLabel { section-title: "ABOUT"; }

                        // ── Geeky about card ──────────────────────────────────
                        Rectangle {
                            height: 180px;
                            border-radius: 12px;
                            background: Cat.crust;
                            border-width: 1px;
                            border-color: Cat.surface0;
                            clip: true;

                            VerticalLayout {
                                // Terminal title bar with traffic-light dots
                                Rectangle {
                                    height: 31px;
                                    background: Cat.mantle;

                                    HorizontalLayout {
                                        padding-left: 12px; padding-right: 12px;

                                        VerticalLayout { alignment: center;
                                            HorizontalLayout { spacing: 6px;
                                                Rectangle { width: 10px; height: 10px; border-radius: 5px; background: #ed6a5e; }
                                                Rectangle { width: 10px; height: 10px; border-radius: 5px; background: #f4bf4f; }
                                                Rectangle { width: 10px; height: 10px; border-radius: 5px; background: #61c554; }
                                            }
                                        }

                                        Text {
                                            text: "xpm  —  about";
                                            font-size: 15px; font-family: "monospace";
                                            color: Cat.overlay0;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                            horizontal-stretch: 1;
                                        }

                                        Rectangle { width: 34px; }
                                    }
                                }

                                Rectangle { height: 1px; background: Cat.surface0; }

                                // Centered content body
                                VerticalLayout {
                                    alignment: center;
                                    padding-left: 20px; padding-right: 20px;
                                    padding-top: 12px; padding-bottom: 12px;
                                    spacing: 10px;

                                    // App info — centered
                                    VerticalLayout {
                                        spacing: 4px;
                                        Text {
                                            text: "XeroLinux Package Manager";
                                            font-size: 14px; font-family: "monospace"; font-weight: 700;
                                            color: Cat.text; horizontal-alignment: center;
                                        }
                                        Text {
                                            text: "Built with Rust + Slint  /  pacman + flatpak backends";
                                            font-size: 11px; font-family: "monospace";
                                            color: Cat.overlay1; horizontal-alignment: center;
                                        }
                                        Text {
                                            text: "\u{25A0} " + stats.pacman-count + " pacman   \u{25A0} " + stats.flatpak-count + " flatpak   \u{25A0} " + stats.orphan-count + " orphans";
                                            font-size: 14px; font-family: "monospace";
                                            color: Cat.mauve.with-alpha(0.65); horizontal-alignment: center;
                                        }
                                    }

                                    Rectangle { height: 1px; background: Cat.surface0; }

                                    // Social links row
                                    HorizontalLayout {
                                        spacing: 8px;

                                        // GitHub
                                        Rectangle {
                                            horizontal-stretch: 1; height: 31px; border-radius: 8px;
                                            background: gh-ta.has-hover ? Cat.surface1 : Cat.surface0;
                                            border-width: 1px; border-color: Cat.surface1;
                                            animate background { duration: 80ms; }
                                            HorizontalLayout {
                                                alignment: center; spacing: 7px;
                                                VerticalLayout { alignment: center;
                                                    NavIcon {
                                                        d: "M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z";
                                                        icon-color: Cat.text; width: 13px; height: 13px;
                                                    }
                                                }
                                                Text { text: "GitHub"; font-size: 12px; font-weight: 600; color: Cat.text; vertical-alignment: center; }
                                            }
                                            gh-ta := TouchArea { mouse-cursor: pointer; clicked => { root.open-url("https://github.com/xerolinux"); } }
                                        }

                                        // Ko-Fi
                                        Rectangle {
                                            horizontal-stretch: 1; height: 31px; border-radius: 8px;
                                            background: kofi-ta2.has-hover ? #ff5e5b.with-alpha(0.28) : #ff5e5b.with-alpha(0.12);
                                            border-width: 1px; border-color: #ff5e5b.with-alpha(0.35);
                                            animate background { duration: 80ms; }
                                            HorizontalLayout {
                                                alignment: center; spacing: 6px;
                                                Text { text: "☕"; font-size: 14px; vertical-alignment: center; }
                                                Text { text: "Ko-Fi"; font-size: 12px; font-weight: 700; color: #ff5e5b; vertical-alignment: center; }
                                            }
                                            kofi-ta2 := TouchArea { mouse-cursor: pointer; clicked => { root.open-url("https://ko-fi.com/xerolinux"); } }
                                        }

                                        // Discord
                                        Rectangle {
                                            horizontal-stretch: 1; height: 31px; border-radius: 8px;
                                            background: disc-ta.has-hover ? #5865f2.with-alpha(0.28) : #5865f2.with-alpha(0.12);
                                            border-width: 1px; border-color: #5865f2.with-alpha(0.35);
                                            animate background { duration: 80ms; }
                                            HorizontalLayout {
                                                alignment: center; spacing: 6px;
                                                VerticalLayout { alignment: center;
                                                    NavIcon {
                                                        d: "M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z";
                                                        icon-color: #5865f2; width: 13px; height: 13px;
                                                    }
                                                }
                                                Text { text: "Discord"; font-size: 12px; font-weight: 700; color: #5865f2; vertical-alignment: center; }
                                            }
                                            disc-ta := TouchArea { mouse-cursor: pointer; clicked => { root.open-url("https://discord.gg/5sqxTSuKZu"); } }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }

            // ─── View 12: Dependency Tree ─────────────────────────────────────
            if view == 12: Rectangle {
                vertical-stretch: 1;
                border-radius: 14px;
                background: Cat.base.with-alpha(0.82);
                border-width: 1px;
                border-color: Cat.surface0.with-alpha(0.5);
                clip: true;

              VerticalLayout {

                // ── Header — pill card + back button ─────────────────────────
                Rectangle {
                    height: 88px;
                    background: Cat.crust;

                    HorizontalLayout {
                        padding-left: 14px; padding-right: 14px;
                        padding-top: 12px; padding-bottom: 12px;
                        spacing: 12px;

                        // Back button — VerticalLayout centers the 30px button in the 64px height
                        VerticalLayout {
                            alignment: center;
                            Rectangle {
                                width: 76px; height: 30px; border-radius: 8px;
                                background: dt-back-ta.has-hover ? Cat.surface1 : Cat.surface0;
                                animate background { duration: 80ms; }
                                VerticalLayout {
                                    alignment: center;
                                    HorizontalLayout {
                                        alignment: center; spacing: 6px;
                                        NavIcon { d: "M19 12H5M12 19l-7-7 7-7"; icon-color: Cat.subtext0; width: 14px; height: 14px; }
                                        Text { text: "Back"; font-size: 13px; font-weight: 600; color: Cat.subtext0; }
                                    }
                                }
                                dt-back-ta := TouchArea { mouse-cursor: pointer; clicked => { view = 7; repos-view = 1; } }
                            }
                        }

                        // Pill card — horizontal-stretch:1 now works (no alignment: center on parent)
                        Rectangle {
                            horizontal-stretch: 1;
                            border-radius: 14px;
                            background: Cat.mauve.with-alpha(0.1);
                            border-width: 1px; border-color: Cat.mauve.with-alpha(0.28);

                            HorizontalLayout {
                                padding-left: 16px; padding-right: 16px; spacing: 12px;

                                // Icon badge
                                VerticalLayout {
                                    alignment: center;
                                    Rectangle {
                                        width: 38px; height: 38px; border-radius: 10px;
                                        background: Cat.mauve.with-alpha(0.16);
                                        NavIcon { d: icon-package; icon-color: Cat.mauve; width: 20px; height: 20px; x: 9px; y: 9px; }
                                    }
                                }

                                // Package name + version/status
                                VerticalLayout {
                                    alignment: center; horizontal-stretch: 1; spacing: 3px;
                                    Text { text: dep-tree-pkg; font-size: 16px; font-weight: 700; color: Cat.mauve; overflow: elide; }
                                    Text {
                                        text: dep-tree-loading ? "Resolving dependency tree…"
                                            : (dep-tree-root-version == "" ? "version unknown" : dep-tree-root-version);
                                        font-size: 15px; color: Cat.overlay1;
                                    }
                                }

                                // Stat badges (hidden while loading)
                                if !dep-tree-loading: VerticalLayout {
                                    alignment: center; spacing: 5px;
                                    Rectangle {
                                        height: 20px; width: 82px; border-radius: 5px;
                                        background: Cat.blue.with-alpha(0.14);
                                        border-width: 1px; border-color: Cat.blue.with-alpha(0.22);
                                        Text { text: dep-tree-nodes.length + " deps"; font-size: 14px; font-weight: 600; color: Cat.blue; horizontal-alignment: center; vertical-alignment: center; }
                                    }
                                    Rectangle {
                                        height: 20px; width: 82px; border-radius: 5px;
                                        background: Cat.green.with-alpha(0.12);
                                        border-width: 1px; border-color: Cat.green.with-alpha(0.2);
                                        Text { text: dep-reqby-nodes.length + " req by"; font-size: 14px; font-weight: 600; color: Cat.green; horizontal-alignment: center; vertical-alignment: center; }
                                    }
                                }

                                // Loading spinner
                                if dep-tree-loading: VerticalLayout {
                                    alignment: center;
                                    Spinner { width: 22px; height: 22px; indeterminate: true; }
                                }
                            }
                        }
                    }
                }

                // ── Tab strip ────────────────────────────────────────────────
                Rectangle {
                    height: 40px;
                    background: Cat.mantle;

                    HorizontalLayout {
                        padding-left: 14px; spacing: 0px;

                        Rectangle {
                            width: 130px; height: 40px;
                            background: transparent;
                            VerticalLayout {
                                alignment: center;
                                Text { text: "Depends On"; font-size: 13px; font-weight: dep-tree-tab == 0 ? 700 : 400; color: dep-tree-tab == 0 ? Cat.blue : Cat.overlay1; horizontal-alignment: center; }
                            }
                            if dep-tree-tab == 0: Rectangle { y: parent.height - 2px; height: 2px; background: Cat.blue; }
                            dt-tab0 := TouchArea { clicked => { dep-tree-tab = 0; } }
                        }

                        Rectangle {
                            width: 130px; height: 40px;
                            background: transparent;
                            VerticalLayout {
                                alignment: center;
                                Text { text: "Required By"; font-size: 13px; font-weight: dep-tree-tab == 1 ? 700 : 400; color: dep-tree-tab == 1 ? Cat.green : Cat.overlay1; horizontal-alignment: center; }
                            }
                            if dep-tree-tab == 1: Rectangle { y: parent.height - 2px; height: 2px; background: Cat.green; }
                            dt-tab1 := TouchArea { clicked => { dep-tree-tab = 1; } }
                        }

                        Rectangle { horizontal-stretch: 1; }
                    }
                }

                // ── Legend row (clearly separated from tabs) ──────────────────
                Rectangle {
                    height: 25px;
                    background: Cat.crust;

                    HorizontalLayout {
                        padding-left: 16px; padding-right: 16px; spacing: 0px;
                        Rectangle { horizontal-stretch: 1; }
                        VerticalLayout {
                            alignment: center;
                            HorizontalLayout {
                                spacing: 16px;
                                HorizontalLayout { spacing: 5px; VerticalLayout { alignment: center; Rectangle { width: 7px; height: 7px; border-radius: 3px; background: Cat.green; } } Text { text: "installed"; font-size: 14px; color: Cat.overlay0; vertical-alignment: center; } }
                                HorizontalLayout { spacing: 5px; VerticalLayout { alignment: center; Rectangle { width: 7px; height: 7px; border-radius: 3px; background: Cat.red; } } Text { text: "missing"; font-size: 14px; color: Cat.overlay0; vertical-alignment: center; } }
                                HorizontalLayout { spacing: 5px; VerticalLayout { alignment: center; Rectangle { width: 7px; height: 7px; border-radius: 3px; background: Cat.peach; } } Text { text: "optional"; font-size: 14px; color: Cat.overlay0; vertical-alignment: center; } }
                            }
                        }
                    }
                }

                Rectangle { height: 1px; background: Cat.surface0; }

                // ── Loading ──────────────────────────────────────────────────
                if dep-tree-loading: Rectangle {
                    vertical-stretch: 1;
                    Text { text: "Resolving…"; horizontal-alignment: center; vertical-alignment: center; color: Cat.overlay0; font-size: 13px; }
                }

                // ── Depends On tab ───────────────────────────────────────────
                if !dep-tree-loading && dep-tree-tab == 0: VerticalLayout {
                    vertical-stretch: 1;

                    // ── Dependency tree list ──────────────────────────────────
                    if dep-tree-nodes.length == 0: Rectangle {
                        vertical-stretch: 1;
                        Text { text: "No dependencies found."; horizontal-alignment: center; vertical-alignment: center; color: Cat.overlay0; font-size: 14px; }
                    }

                    if dep-tree-nodes.length > 0: ListView {
                        vertical-stretch: 1;

                        for node[i] in dep-tree-nodes: Rectangle {
                            // depth -1 = section separator; depth 1 = direct dep; depth 2 = transitive
                            height: node.depth == -1 ? 32px : 42px;
                            background: node.depth != -1 && dt-node-ta.has-hover
                                ? Cat.surface0.with-alpha(0.25) : transparent;
                            animate background { duration: 60ms; }

                            dt-node-ta := TouchArea {}

                            // Section separator row (optional deps divider)
                            if node.depth == -1: HorizontalLayout {
                                padding-left: 16px; padding-right: 16px; spacing: 10px;
                                VerticalLayout {
                                    alignment: center;
                                    Rectangle { height: 1px; horizontal-stretch: 1; background: Cat.peach.with-alpha(0.3); }
                                }
                                VerticalLayout {
                                    alignment: center;
                                    Text { text: "Optional Dependencies"; font-size: 14px; font-weight: 700; color: Cat.peach.with-alpha(0.7); }
                                }
                                VerticalLayout {
                                    alignment: center;
                                    Rectangle { height: 1px; horizontal-stretch: 1; background: Cat.peach.with-alpha(0.3); }
                                }
                            }

                            // Normal dep row
                            if node.depth != -1: HorizontalLayout {
                                padding-left: 16px; padding-right: 16px; spacing: 0px;

                                // Tree prefix — fixed width prevents squeezing the name
                                VerticalLayout {
                                    alignment: center;
                                    Text {
                                        text: node.prefix;
                                        font-size: 14px;
                                        color: node.is-optional ? Cat.peach.with-alpha(0.5) : Cat.overlay0;
                                        vertical-alignment: center;
                                        width: node.depth == 1 ? 28px : 52px;
                                    }
                                }

                                // Status dot
                                VerticalLayout {
                                    alignment: center; width: 18px;
                                    Rectangle {
                                        width: 8px; height: 8px; border-radius: 4px;
                                        background: node.is-optional ? Cat.peach
                                            : (node.installed ? Cat.green : Cat.red);
                                    }
                                }

                                // Name + hard badge
                                // Rectangle propagates width correctly; no alignment on inner HLayout
                                Rectangle {
                                    horizontal-stretch: 1;
                                    HorizontalLayout {
                                        spacing: 8px;
                                        Text {
                                            preferred-width: 0px;
                                            horizontal-stretch: 1;
                                            text: node.name;
                                            font-size: node.depth == 1 ? 13px : 12px;
                                            font-weight: node.depth == 1 ? 500 : 400;
                                            font-italic: node.is-optional;
                                            color: node.is-optional ? Cat.peach.with-alpha(0.85)
                                                : (node.installed
                                                    ? (node.depth == 1 ? Cat.text : Cat.subtext0)
                                                    : Cat.red);
                                            vertical-alignment: center;
                                            overflow: elide;
                                        }
                                        if !node.is-optional && node.depth == 1: VerticalLayout {
                                            alignment: center;
                                            Rectangle {
                                                width: 34px; height: 16px; border-radius: 4px;
                                                background: Cat.blue.with-alpha(0.12);
                                                Text { text: "hard"; font-size: 13px; font-weight: 700; color: Cat.blue.with-alpha(0.8); horizontal-alignment: center; vertical-alignment: center; }
                                            }
                                        }
                                    }
                                }

                                // Version pill / install button
                                VerticalLayout {
                                    alignment: center; width: 80px;
                                    
                                    if node.installable && !node.installed: dt-install-btn := Rectangle {
                                        width: 76px; height: 24px;
                                        border-radius: 6px;
                                        background: dt-install-ta.has-hover ? Cat.green.with-alpha(0.25) : Cat.green.with-alpha(0.12);
                                        border-width: 1px;
                                        border-color: dt-install-ta.has-hover ? Cat.green.with-alpha(0.6) : Cat.green.with-alpha(0.3);
                                        animate background, border-color { duration: 80ms; }
                                        Text {
                                            text: "Install";
                                            font-size: 12px; font-weight: 700;
                                            color: Cat.green;
                                            horizontal-alignment: center; vertical-alignment: center;
                                        }
                                        dt-install-ta := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => { root.install-dep-package(node.name); }
                                        }
                                    }
                                }
                                
                                if !(node.installable && !node.installed): VerticalLayout {
                                    alignment: center; width: 80px;
                                    Rectangle {
                                        height: 20px; border-radius: 5px;
                                        background: Cat.surface0.with-alpha(0.5);
                                        Text {
                                            text: node.version == "" ? "not installed" : node.version;
                                            font-size: 14px;
                                            color: node.version == "" ? Cat.red.with-alpha(0.7) : Cat.overlay1;
                                            horizontal-alignment: center; vertical-alignment: center;
                                            overflow: elide;
                                        }
                                    }
                                }
                            }

                            if node.depth != -1: Rectangle {
                                x: 16px; y: parent.height - 1px;
                                width: parent.width - 32px; height: 1px;
                                background: Cat.surface0.with-alpha(0.35);
                            }
                        }
                    }
                }

                // ── Required By tab ──────────────────────────────────────────
                if !dep-tree-loading && dep-tree-tab == 1: VerticalLayout {
                    vertical-stretch: 1;

                    if dep-reqby-nodes.length == 0: Rectangle {
                        vertical-stretch: 1;
                        VerticalLayout {
                            alignment: center; spacing: 10px;
                            NavIcon { d: icon-package; icon-color: Cat.green; width: 32px; height: 29px; }
                            Text { text: "Nothing depends on " + dep-tree-pkg; font-size: 15px; font-weight: 600; color: Cat.text; horizontal-alignment: center; }
                            Text { text: "This package can be safely removed without breaking other packages."; font-size: 13px; color: Cat.overlay1; horizontal-alignment: center; }
                        }
                    }

                    if dep-reqby-nodes.length > 0: VerticalLayout {
                        vertical-stretch: 1;

                        // Required-by pill header
                        Rectangle { height: 20px; background: transparent; }
                        HorizontalLayout {
                            padding-left: 20px; padding-right: 20px;
                            Rectangle {
                                horizontal-stretch: 1; height: 60px;
                                border-radius: 14px;
                                background: Cat.green.with-alpha(0.08);
                                border-width: 1px; border-color: Cat.green.with-alpha(0.2);
                                HorizontalLayout {
                                    padding-left: 18px; padding-right: 18px; spacing: 12px;
                                    VerticalLayout { alignment: center; NavIcon { d: icon-package; icon-color: Cat.green; width: 20px; height: 20px; } }
                                    VerticalLayout {
                                        alignment: center; horizontal-stretch: 1;
                                        Text { text: dep-tree-pkg + " is required by " + dep-reqby-nodes.length + " installed packages"; font-size: 13px; font-weight: 600; color: Cat.text; }
                                        Text { text: "Removing it may break these packages"; font-size: 14px; color: Cat.overlay1; }
                                    }
                                }
                            }
                        }
                        Rectangle { height: 14px; background: transparent; }
                        Rectangle { x: 20px; height: 1px; width: parent.width - 40px; background: Cat.surface0.with-alpha(0.6); }
                        Rectangle { height: 4px; background: transparent; }

                        ListView {
                            vertical-stretch: 1;
                            for node[i] in dep-reqby-nodes: Rectangle {
                                height: 46px;
                                background: rb-node-ta.has-hover ? Cat.surface0.with-alpha(0.25) : transparent;
                                animate background { duration: 60ms; }

                                rb-node-ta := TouchArea {}

                                HorizontalLayout {
                                    padding-left: 24px; padding-right: 20px; spacing: 12px;
                                    VerticalLayout {
                                        alignment: center;
                                        Rectangle { width: 8px; height: 8px; border-radius: 4px; background: Cat.green; }
                                    }
                                    Text {
                                        preferred-width: 0px; horizontal-stretch: 1;
                                        text: node.name; font-size: 14px; font-weight: 500; color: Cat.text; overflow: elide; vertical-alignment: center;
                                    }
                                    VerticalLayout {
                                        alignment: center;
                                        Rectangle {
                                            height: 20px; width: 80px; border-radius: 5px;
                                            background: Cat.surface0.with-alpha(0.5);
                                            Text { text: node.version == "" ? "—" : node.version; font-size: 14px; color: Cat.overlay1; horizontal-alignment: center; vertical-alignment: center; overflow: elide; }
                                        }
                                    }
                                }

                                Rectangle { x: 16px; y: parent.height - 1px; width: parent.width - 32px; height: 1px; background: Cat.surface0.with-alpha(0.35); }
                            }
                        }
                    }
                }
              } // end inner VerticalLayout
            } // end view 12 Rectangle

            // ─── View 13: Arch News RSS ───────────────────────────────────────
            if view == 13: VerticalLayout {
                vertical-stretch: 1;
                spacing: 0px;

                if arch-news-loading && arch-news-items.length == 0: VerticalLayout {
                    vertical-stretch: 1;
                    alignment: center;
                    spacing: 14px;
                    Spinner { indeterminate: true; width: 28px; height: 28px; }
                    Text { text: "Fetching Arch news..."; font-size: 14px; color: Cat.overlay0; horizontal-alignment: center; }
                }

                if !arch-news-loading && arch-news-items.length == 0: VerticalLayout {
                    vertical-stretch: 1;
                    alignment: center;
                    Text { text: "No news loaded. Press Refresh."; font-size: 14px; color: Cat.overlay0; horizontal-alignment: center; }
                }

                if arch-news-items.length > 0: ScrollView {
                    vertical-stretch: 1;

                    VerticalLayout {
                        padding: 4px;
                        spacing: 12px;
                        alignment: start;

                        for item[i] in arch-news-items: Rectangle {
                            border-radius: 10px;
                            background: Cat.surface0.with-alpha(0.45);
                            border-width: 1px;
                            border-color: Cat.surface1.with-alpha(0.6);

                            VerticalLayout {
                                padding-left: 18px; padding-right: 18px;
                                padding-top: 14px; padding-bottom: 14px;
                                spacing: 6px;

                                HorizontalLayout {
                                    spacing: 8px;
                                    Text {
                                        text: item.title;
                                        font-size: 15px; font-weight: 700;
                                        color: Cat.text;
                                        wrap: word-wrap;
                                        horizontal-stretch: 1;
                                    }
                                }

                                Text {
                                    text: item.date;
                                    font-size: 12px;
                                    color: Cat.overlay0;
                                }

                                if item.summary != "": Rectangle {
                                    height: 1px;
                                    background: Cat.surface1.with-alpha(0.5);
                                }

                                if item.summary != "": Text {
                                    text: item.summary;
                                    font-size: 13px;
                                    color: Cat.subtext0;
                                    wrap: word-wrap;
                                }

                                if item.link != "": HorizontalLayout {
                                    alignment: end;
                                    Rectangle {
                                        width: news-link-lbl.preferred-width + 20px;
                                        height: 26px;
                                        border-radius: 6px;
                                        background: news-link-ta.has-hover ? Cat.blue.with-alpha(0.18) : Cat.blue.with-alpha(0.08);
                                        border-width: 1px;
                                        border-color: Cat.blue.with-alpha(0.3);
                                        animate background { duration: 60ms; }
                                        news-link-lbl := Text {
                                            text: "Read more";
                                            font-size: 12px; font-weight: 600;
                                            color: Cat.blue;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                        news-link-ta := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => { root.open-url(item.link); }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }

            // ─── View 11: Troubleshooting ─────────────────────────────────────
            if view == 11: VerticalLayout {
                vertical-stretch: 1;

                // Header
                Rectangle {
                    height: 70px;
                    background: Cat.crust;

                    Rectangle { y: parent.height - 1px; width: 100%; height: 1px; background: Cat.green.with-alpha(0.15); }

                    HorizontalLayout {
                        padding-left: 20px; padding-right: 20px; spacing: 12px;

                        VerticalLayout {
                            alignment: center;
                            Rectangle {
                                width: 34px; height: 31px; border-radius: 8px;
                                background: Cat.green.with-alpha(0.12);
                                border-width: 1px; border-color: Cat.green.with-alpha(0.25);
                                NavIcon { d: icon-wrench; icon-color: Cat.green; width: 18px; height: 18px; x: 8px; y: 8px; }
                            }
                        }

                        VerticalLayout {
                            horizontal-stretch: 1; alignment: center; spacing: 2px;
                            Text { text: "Troubleshooting"; font-size: 16px; font-weight: 800; color: Cat.green; }
                            Text { text: "System & Pacman diagnostics — repair tools for common issues"; font-size: 14px; color: Cat.overlay1; }
                        }

                        VerticalLayout {
                            alignment: center; spacing: 3px;
                            Rectangle { width: 7px; height: 7px; border-radius: 4px; background: Cat.green; }
                            Text { text: "READY"; font-size: 9px; font-weight: 700; color: Cat.green.with-alpha(0.6); horizontal-alignment: center; }
                        }
                    }
                }

                // Use at own risk warning strip
                Rectangle {
                    height: 32px;
                    background: Cat.peach.with-alpha(0.08);
                    border-width: 1px; border-color: Cat.peach.with-alpha(0.2);
                    HorizontalLayout {
                        padding-left: 16px; padding-right: 16px; spacing: 6px; alignment: center;
                        Text { text: "⚠"; font-size: 15px; color: Cat.peach; vertical-alignment: center; }
                        Text { text: "Use at your own risk — these operations modify system files and may require a reboot."; font-size: 10px; color: Cat.peach.with-alpha(0.85); vertical-alignment: center; horizontal-stretch: 1; }
                    }
                }

                // Content - scrollable, no stretch
                ScrollView {
                VerticalLayout {
                    alignment: window-width > 1200 ? center : start;
                    padding-left: 28px; padding-right: 28px;
                    padding-top: 16px; padding-bottom: 16px;
                    spacing: 14px;

                    // ── SYSTEM label ─────────────────────────────────────────
                    HorizontalLayout {
                        spacing: 8px;
                        Rectangle { width: 3px; border-radius: 2px; background: Cat.green; }
                        Text { text: "SYSTEM"; font-size: 10px; font-weight: 800; color: Cat.green; letter-spacing: 1.2px; vertical-alignment: center; }
                        Rectangle { height: 1px; horizontal-stretch: 1; background: Cat.green.with-alpha(0.2); y: parent.height / 2; }
                    }

                    // ── SYSTEM 2×2 grid ───────────────────────────────────────
                    GridLayout {
                        spacing: 10px;

                        // Update Mirrorlists
                        Rectangle {
                            row: 0; col: 0; height: 125px; border-radius: 12px;
                            background: mir-ta.has-hover ? Cat.surface0.with-alpha(0.7) : Cat.surface0.with-alpha(0.45);
                            animate background { duration: 80ms; }
                            mir-ta := TouchArea {}
                            HorizontalLayout {
                                Rectangle { width: 3px; background: Cat.teal; }
                                HorizontalLayout { padding-left: 14px; padding-right: 14px; padding-top: 10px; padding-bottom: 10px; spacing: 12px;
                                    VerticalLayout { alignment: center;
                                        Rectangle { width: 38px; height: 38px; border-radius: 19px; background: Cat.teal.with-alpha(0.12); border-width: 1px; border-color: Cat.teal.with-alpha(0.25);
                                            NavIcon { d: icon-globe; icon-color: Cat.teal; width: 18px; height: 18px; x: 10px; y: 10px; } } }
                                    VerticalLayout { horizontal-stretch: 1; alignment: center; spacing: 2px;
                                        Text { text: "Update Mirrorlists"; font-size: 15px; font-weight: 700; color: Cat.text; }
                                        Text { text: "Re-rank fastest mirrors via rate-mirrors"; font-size: 13px; color: Cat.overlay1; }
                                        Text { text: "$ rate-mirrors arch | tee /etc/pacman.d/mirrorlist"; font-size: 14px; color: Cat.teal.with-alpha(0.7); overflow: elide; } }
                                    VerticalLayout { alignment: center;
                                        Rectangle { width: 58px; height: 26px; border-radius: 6px; background: mir-btn.has-hover ? Cat.teal.with-alpha(0.25) : Cat.teal.with-alpha(0.1); border-width: 1px; border-color: Cat.teal.with-alpha(0.35); animate background { duration: 70ms; }
                                            Text { text: "▶  RUN"; font-size: 10px; font-weight: 700; color: Cat.teal; horizontal-alignment: center; vertical-alignment: center; }
                                            mir-btn := TouchArea { mouse-cursor: pointer; clicked => { root.update-mirrorlists(); } } } }
                                }
                            }
                        }

                        // Rebuild InitRamFS
                        Rectangle {
                            row: 0; col: 1; height: 125px; border-radius: 12px;
                            background: ini-ta.has-hover ? Cat.surface0.with-alpha(0.7) : Cat.surface0.with-alpha(0.45);
                            animate background { duration: 80ms; }
                            ini-ta := TouchArea {}
                            HorizontalLayout {
                                Rectangle { width: 3px; background: Cat.mauve; }
                                HorizontalLayout { padding-left: 14px; padding-right: 14px; padding-top: 10px; padding-bottom: 10px; spacing: 12px;
                                    VerticalLayout { alignment: center;
                                        Rectangle { width: 38px; height: 38px; border-radius: 19px; background: Cat.mauve.with-alpha(0.12); border-width: 1px; border-color: Cat.mauve.with-alpha(0.25);
                                            NavIcon { d: icon-cpu; icon-color: Cat.mauve; width: 18px; height: 18px; x: 10px; y: 10px; } } }
                                    VerticalLayout { horizontal-stretch: 1; alignment: center; spacing: 2px;
                                        Text { text: "Rebuild InitRamFS"; font-size: 13px; font-weight: 700; color: Cat.text; }
                                        Text { text: "Regenerate initramfs images via mkinitcpio"; font-size: 14px; color: Cat.overlay1; }
                                        Text { text: "$ mkinitcpio -P"; font-size: 13px; color: Cat.mauve.with-alpha(0.7); } }
                                    VerticalLayout { alignment: center;
                                        Rectangle { width: 58px; height: 26px; border-radius: 6px; background: ini-btn.has-hover ? Cat.mauve.with-alpha(0.25) : Cat.mauve.with-alpha(0.1); border-width: 1px; border-color: Cat.mauve.with-alpha(0.35); animate background { duration: 70ms; }
                                            Text { text: "▶  RUN"; font-size: 10px; font-weight: 700; color: Cat.mauve; horizontal-alignment: center; vertical-alignment: center; }
                                            ini-btn := TouchArea { mouse-cursor: pointer; clicked => { root.rebuild-initramfs(); } } } }
                                }
                            }
                        }

                        // Fix GnuPG Keyring
                        Rectangle {
                            row: 1; col: 0; height: 125px; border-radius: 12px;
                            background: key-ta.has-hover ? Cat.surface0.with-alpha(0.7) : Cat.surface0.with-alpha(0.45);
                            animate background { duration: 80ms; }
                            key-ta := TouchArea {}
                            HorizontalLayout {
                                Rectangle { width: 3px; background: Cat.yellow; }
                                HorizontalLayout { padding-left: 14px; padding-right: 14px; padding-top: 10px; padding-bottom: 10px; spacing: 12px;
                                    VerticalLayout { alignment: center;
                                        Rectangle { width: 38px; height: 38px; border-radius: 19px; background: Cat.yellow.with-alpha(0.12); border-width: 1px; border-color: Cat.yellow.with-alpha(0.25);
                                            NavIcon { d: icon-refresh; icon-color: Cat.yellow; width: 18px; height: 18px; x: 10px; y: 10px; } } }
                                    VerticalLayout { horizontal-stretch: 1; alignment: center; spacing: 2px;
                                        Text { text: "Fix GnuPG Keyring"; font-size: 13px; font-weight: 700; color: Cat.text; }
                                        Text { text: "Reset and repopulate pacman keys"; font-size: 14px; color: Cat.overlay1; }
                                        Text { text: "$ pacman-key --init && pacman-key --populate"; font-size: 13px; color: Cat.yellow.with-alpha(0.7); overflow: elide; } }
                                    VerticalLayout { alignment: center;
                                        Rectangle { width: 58px; height: 26px; border-radius: 6px; background: key-btn.has-hover ? Cat.yellow.with-alpha(0.25) : Cat.yellow.with-alpha(0.1); border-width: 1px; border-color: Cat.yellow.with-alpha(0.35); animate background { duration: 70ms; }
                                            Text { text: "▶  RUN"; font-size: 10px; font-weight: 700; color: Cat.yellow; horizontal-alignment: center; vertical-alignment: center; }
                                            key-btn := TouchArea { mouse-cursor: pointer; clicked => { root.fix-keyring(); } } } }
                                }
                            }
                        }

                        // Rebuild Grub
                        Rectangle {
                            row: 1; col: 1; height: 125px; border-radius: 12px;
                            background: grb-ta.has-hover ? Cat.surface0.with-alpha(0.7) : Cat.surface0.with-alpha(0.45);
                            animate background { duration: 80ms; }
                            grb-ta := TouchArea {}
                            HorizontalLayout {
                                Rectangle { width: 3px; background: Cat.peach; }
                                HorizontalLayout { padding-left: 14px; padding-right: 14px; padding-top: 10px; padding-bottom: 10px; spacing: 12px;
                                    VerticalLayout { alignment: center;
                                        Rectangle { width: 38px; height: 38px; border-radius: 19px; background: Cat.peach.with-alpha(0.12); border-width: 1px; border-color: Cat.peach.with-alpha(0.25);
                                            NavIcon { d: icon-chip; icon-color: Cat.peach; width: 18px; height: 18px; x: 10px; y: 10px; } } }
                                    VerticalLayout { horizontal-stretch: 1; alignment: center; spacing: 2px;
                                        Text { text: "Rebuild Grub"; font-size: 13px; font-weight: 700; color: Cat.text; }
                                        Text { text: "Regenerate GRUB bootloader config"; font-size: 14px; color: Cat.overlay1; }
                                        Text { text: "$ update-grub"; font-size: 13px; color: Cat.peach.with-alpha(0.7); } }
                                    VerticalLayout { alignment: center;
                                        Rectangle { width: 58px; height: 26px; border-radius: 6px; background: grb-btn.has-hover ? Cat.peach.with-alpha(0.25) : Cat.peach.with-alpha(0.1); border-width: 1px; border-color: Cat.peach.with-alpha(0.35); animate background { duration: 70ms; }
                                            Text { text: "▶  RUN"; font-size: 10px; font-weight: 700; color: Cat.peach; horizontal-alignment: center; vertical-alignment: center; }
                                            grb-btn := TouchArea { mouse-cursor: pointer; clicked => { root.rebuild-grub(); } } } }
                                }
                            }
                        }
                    }

                    // ── PACMAN label ──────────────────────────────────────────
                    HorizontalLayout {
                        spacing: 8px;
                        Rectangle { width: 3px; border-radius: 2px; background: Cat.blue; }
                        Text { text: "PACMAN"; font-size: 10px; font-weight: 800; color: Cat.blue; letter-spacing: 1.2px; vertical-alignment: center; }
                        Rectangle { height: 1px; horizontal-stretch: 1; background: Cat.blue.with-alpha(0.2); y: parent.height / 2; }
                    }

                    // ── PACMAN 2×2 grid ───────────────────────────────────────
                    GridLayout {
                        spacing: 10px;

                        // Export Package List
                        Rectangle {
                            row: 0; col: 0; height: 125px; border-radius: 12px;
                            background: exp-ta.has-hover ? Cat.surface0.with-alpha(0.7) : Cat.surface0.with-alpha(0.45);
                            animate background { duration: 80ms; }
                            exp-ta := TouchArea {}
                            HorizontalLayout {
                                Rectangle { width: 3px; background: Cat.sapphire; }
                                HorizontalLayout { padding-left: 14px; padding-right: 14px; padding-top: 10px; padding-bottom: 10px; spacing: 12px;
                                    VerticalLayout { alignment: center;
                                        Rectangle { width: 38px; height: 38px; border-radius: 19px; background: Cat.sapphire.with-alpha(0.12); border-width: 1px; border-color: Cat.sapphire.with-alpha(0.25);
                                            NavIcon { d: icon-file; icon-color: Cat.sapphire; width: 18px; height: 18px; x: 10px; y: 10px; } } }
                                    VerticalLayout { horizontal-stretch: 1; alignment: center; spacing: 2px;
                                        Text { text: "Export Package List"; font-size: 13px; font-weight: 700; color: Cat.text; }
                                        Text { text: "Save explicitly installed packages to a file"; font-size: 14px; color: Cat.overlay1; }
                                        Text { text: "$ pacman -Qqe > packages.txt"; font-size: 13px; color: Cat.sapphire.with-alpha(0.7); } }
                                    VerticalLayout { alignment: center;
                                        Rectangle { width: 58px; height: 26px; border-radius: 6px; background: exp-btn.has-hover ? Cat.sapphire.with-alpha(0.25) : Cat.sapphire.with-alpha(0.1); border-width: 1px; border-color: Cat.sapphire.with-alpha(0.35); animate background { duration: 70ms; }
                                            Text { text: "▶  RUN"; font-size: 10px; font-weight: 700; color: Cat.sapphire; horizontal-alignment: center; vertical-alignment: center; }
                                            exp-btn := TouchArea { mouse-cursor: pointer; clicked => { root.export-package-list(); } } } }
                                }
                            }
                        }

                        // Import Package List
                        Rectangle {
                            row: 0; col: 1; height: 125px; border-radius: 12px;
                            background: imp-ta.has-hover ? Cat.surface0.with-alpha(0.7) : Cat.surface0.with-alpha(0.45);
                            animate background { duration: 80ms; }
                            imp-ta := TouchArea {}
                            HorizontalLayout {
                                Rectangle { width: 3px; background: Cat.green; }
                                HorizontalLayout { padding-left: 14px; padding-right: 14px; padding-top: 10px; padding-bottom: 10px; spacing: 12px;
                                    VerticalLayout { alignment: center;
                                        Rectangle { width: 38px; height: 38px; border-radius: 19px; background: Cat.green.with-alpha(0.12); border-width: 1px; border-color: Cat.green.with-alpha(0.25);
                                            NavIcon { d: icon-folder; icon-color: Cat.green; width: 18px; height: 18px; x: 10px; y: 10px; } } }
                                    VerticalLayout { horizontal-stretch: 1; alignment: center; spacing: 2px;
                                        Text { text: "Import Package List"; font-size: 13px; font-weight: 700; color: Cat.text; }
                                        Text { text: "Install packages from an exported list file"; font-size: 14px; color: Cat.overlay1; }
                                        Text { text: "$ pacman -S --needed $(cat packages.txt)"; font-size: 13px; color: Cat.green.with-alpha(0.7); overflow: elide; } }
                                    VerticalLayout { alignment: center;
                                        Rectangle { width: 58px; height: 26px; border-radius: 6px; background: imp-btn.has-hover ? Cat.green.with-alpha(0.25) : Cat.green.with-alpha(0.1); border-width: 1px; border-color: Cat.green.with-alpha(0.35); animate background { duration: 70ms; }
                                            Text { text: "▶  RUN"; font-size: 10px; font-weight: 700; color: Cat.green; horizontal-alignment: center; vertical-alignment: center; }
                                            imp-btn := TouchArea { mouse-cursor: pointer; clicked => { root.import-package-list(); } } } }
                                }
                            }
                        }

                        // Unlock Database
                        Rectangle {
                            row: 1; col: 0; height: 125px; border-radius: 12px;
                            background: ulk-ta.has-hover ? Cat.surface0.with-alpha(0.7) : Cat.surface0.with-alpha(0.45);
                            animate background { duration: 80ms; }
                            ulk-ta := TouchArea {}
                            HorizontalLayout {
                                Rectangle { width: 3px; background: Cat.red; }
                                HorizontalLayout { padding-left: 14px; padding-right: 14px; padding-top: 10px; padding-bottom: 10px; spacing: 12px;
                                    VerticalLayout { alignment: center;
                                        Rectangle { width: 38px; height: 38px; border-radius: 19px; background: Cat.red.with-alpha(0.12); border-width: 1px; border-color: Cat.red.with-alpha(0.25);
                                            NavIcon { d: icon-lock; icon-color: Cat.red; width: 18px; height: 18px; x: 10px; y: 10px; } } }
                                    VerticalLayout { horizontal-stretch: 1; alignment: center; spacing: 2px;
                                        Text { text: "Unlock Database"; font-size: 13px; font-weight: 700; color: Cat.text; }
                                        Text { text: "Remove stale pacman DB lock file"; font-size: 14px; color: Cat.overlay1; }
                                        Text { text: "$ rm /var/lib/pacman/db.lck"; font-size: 13px; color: Cat.red.with-alpha(0.7); } }
                                    VerticalLayout { alignment: center;
                                        Rectangle { width: 58px; height: 26px; border-radius: 6px; background: ulk-btn.has-hover ? Cat.red.with-alpha(0.3) : Cat.red.with-alpha(0.12); border-width: 1px; border-color: Cat.red.with-alpha(0.4); animate background { duration: 70ms; }
                                            Text { text: "▶  RUN"; font-size: 10px; font-weight: 700; color: Cat.red; horizontal-alignment: center; vertical-alignment: center; }
                                            ulk-btn := TouchArea { mouse-cursor: pointer; clicked => { root.show-unlock-db-confirm = true; } } } }
                                }
                            }
                        }

                        // IgnorePkg
                        Rectangle {
                            row: 1; col: 1;
                            height: 125px;
                            border-radius: 12px;
                            background: Cat.surface0.with-alpha(0.45);
                            border-width: 1px;
                            border-color: ignorepkg-active ? Cat.peach.with-alpha(0.3) : Cat.surface0.with-alpha(0.0);
                            animate height { duration: 120ms; }
                            animate border-color { duration: 120ms; }
                            HorizontalLayout {
                                Rectangle { width: 3px; background: Cat.peach; }
                                VerticalLayout {
                                    padding-left: 14px; padding-right: 14px;
                                    padding-top: 10px; padding-bottom: 10px;
                                    spacing: 8px;

                                    // Top row
                                    HorizontalLayout {
                                        spacing: 12px;
                                        VerticalLayout { alignment: center;
                                            Rectangle { width: 38px; height: 38px; border-radius: 19px; background: Cat.peach.with-alpha(0.12); border-width: 1px; border-color: Cat.peach.with-alpha(0.25);
                                                NavIcon { d: icon-chip; icon-color: Cat.peach; width: 18px; height: 18px; x: 10px; y: 10px; } } }
                                        VerticalLayout { horizontal-stretch: 1; alignment: center; spacing: 2px;
                                            Text { text: "IgnorePkg"; font-size: 13px; font-weight: 700; color: Cat.text; }
                                            Text {
                                                text: ignorepkg-active
                                                    ? (ignorepkg-value == "" ? "Active — no packages set" : "Active: " + ignorepkg-value)
                                                    : (ignorepkg-value == "" ? "Inactive — none configured" : "Inactive: " + ignorepkg-value);
                                                font-size: 14px;
                                                color: ignorepkg-active ? Cat.peach : Cat.overlay1;
                                                overflow: elide;
                                            }
                                            Text { text: "# /etc/pacman.conf IgnorePkg"; font-size: 13px; color: Cat.peach.with-alpha(0.6); }
                                        }
                                        VerticalLayout { alignment: center;
                                            Rectangle {
                                                width: 70px; height: 26px; border-radius: 6px;
                                                background: ignorepkg-active
                                                    ? (ig-tog.has-hover ? Cat.peach.with-alpha(0.3) : Cat.peach.with-alpha(0.18))
                                                    : (ig-tog.has-hover ? Cat.surface1 : Cat.surface0);
                                                border-width: 1px;
                                                border-color: ignorepkg-active ? Cat.peach.with-alpha(0.5) : Cat.surface1;
                                                animate background { duration: 80ms; }
                                                Text { text: ignorepkg-active ? "Active" : "Inactive"; font-size: 10px; font-weight: 700; color: ignorepkg-active ? Cat.peach : Cat.overlay1; horizontal-alignment: center; vertical-alignment: center; }
                                                ig-tog := TouchArea {
                                                    mouse-cursor: pointer;
                                                    clicked => {
                                                        ignorepkg-active = !ignorepkg-active;
                                                        root.save-ignorepkg(ignorepkg-active, ignorepkg-value);
                                                    }
                                                }
                                            }
                                        }
                                    }

                                    // Editor row (only when active)
                                    if ignorepkg-active: HorizontalLayout {
                                        spacing: 6px;
                                        Rectangle {
                                            horizontal-stretch: 1; height: 25px; border-radius: 6px;
                                            background: Cat.surface1;
                                            border-width: ig-ti.has-focus ? 1px : 0px;
                                            border-color: Cat.peach.with-alpha(0.5);
                                            clip: true; animate border-width { duration: 80ms; }
                                            HorizontalLayout {
                                                padding-left: 8px; padding-right: 8px;
                                                if ignorepkg-edit-text == "" && !ig-ti.has-focus: Text { height: 25px; text: "Packages (space-separated)"; font-size: 14px; color: Cat.overlay0; vertical-alignment: center; }
                                                ig-ti := TextInput {
                                                    height: 25px; text <=> ignorepkg-edit-text;
                                                    font-size: 14px; color: Cat.text; single-line: true; vertical-alignment: center;
                                                    selection-background-color: Cat.peach.with-alpha(0.3);
                                                    accepted => { ignorepkg-value = ignorepkg-edit-text; root.save-ignorepkg(true, ignorepkg-edit-text); }
                                                }
                                            }
                                        }
                                        Rectangle {
                                            width: 52px; height: 25px; border-radius: 6px;
                                            background: ig-save.has-hover ? Cat.peach.with-alpha(0.85) : Cat.peach;
                                            animate background { duration: 70ms; }
                                            Text { text: "Save"; font-size: 14px; font-weight: 700; color: Cat.crust; horizontal-alignment: center; vertical-alignment: center; }
                                            ig-save := TouchArea {
                                                mouse-cursor: pointer;
                                                clicked => { ignorepkg-value = ignorepkg-edit-text; root.save-ignorepkg(true, ignorepkg-edit-text); }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                } // end content VerticalLayout
                } // end ScrollView
            }

            if view == 9: ScrollView {
                vertical-stretch: 1;

                VerticalLayout {
                    padding: 4px;
                    spacing: 20px;
                    alignment: start;

                    // AUR info pill — centered, width = content
                    HorizontalLayout {
                        alignment: center;
                        Rectangle {
                            width: aur-pill-text.preferred-width + 15px + 8px + 24px;
                            border-radius: 8px;
                            background: Cat.yellow.with-alpha(0.08);
                            border-width: 1px;
                            border-color: Cat.yellow.with-alpha(0.35);

                            HorizontalLayout {
                                padding-left: 12px; padding-right: 12px;
                                padding-top: 9px; padding-bottom: 9px;
                                spacing: 8px;

                                VerticalLayout { alignment: center;
                                    NavIcon {
                                        d: "M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z";
                                        icon-color: Cat.yellow;
                                        width: 15px; height: 15px;
                                    }
                                }

                                aur-pill-text := Text {
                                    text: "A.U.R support disabled for stability purposes. Use the Chaotic-AUR (on XeroLinux) for pre-built packages. Use | paru packagename | in Terminal instead.";
                                    font-size: 13px;
                                    color: Cat.yellow;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }

                    // Stat cards
                    VerticalLayout {
                        spacing: 8px;
                        SectionLabel { section-title: "SYSTEM OVERVIEW"; }

                        HorizontalLayout {
                            spacing: 10px;

                            Rectangle {
                                horizontal-stretch: 1;
                                height: 82px;
                                border-radius: 10px;
                                background: Cat.blue.with-alpha(0.1);
                                border-width: 1px;
                                border-color: Cat.blue.with-alpha(0.25);

                                VerticalLayout {
                                    alignment: center;
                                    spacing: 4px;

                                    if loading: Rectangle { width: 52px; height: 20px; border-radius: 5px; background: Cat.blue.with-alpha(0.18); x: (parent.width - 52px) / 2; }
                                    if !loading: Text {
                                        text: stats.pacman-count;
                                        font-size: 30px;
                                        font-weight: 700;
                                        color: Cat.blue;
                                        horizontal-alignment: center;
                                    }
                                    Text {
                                        text: "Pacman Packages";
                                        font-size: 15px;
                                        color: Cat.overlay1;
                                        horizontal-alignment: center;
                                    }
                                }
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                                height: 82px;
                                border-radius: 10px;
                                background: Cat.teal.with-alpha(0.1);
                                border-width: 1px;
                                border-color: Cat.teal.with-alpha(0.25);

                                VerticalLayout {
                                    alignment: center;
                                    spacing: 4px;

                                    if loading: Rectangle { width: 40px; height: 20px; border-radius: 5px; background: Cat.teal.with-alpha(0.18); x: (parent.width - 40px) / 2; }
                                    if !loading: Text {
                                        text: stats.flatpak-count;
                                        font-size: 30px;
                                        font-weight: 700;
                                        color: Cat.teal;
                                        horizontal-alignment: center;
                                    }
                                    Text {
                                        text: "Flatpak Apps";
                                        font-size: 15px;
                                        color: Cat.overlay1;
                                        horizontal-alignment: center;
                                    }
                                }
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                                height: 82px;
                                border-radius: 10px;
                                background: stats.orphan-count > 0 ? Cat.yellow.with-alpha(0.1) : Cat.surface0.with-alpha(0.35);
                                border-width: 1px;
                                border-color: stats.orphan-count > 0 ? Cat.yellow.with-alpha(0.25) : Cat.surface0.with-alpha(0.2);

                                VerticalLayout {
                                    alignment: center;
                                    spacing: 4px;

                                    if loading: Rectangle { width: 36px; height: 20px; border-radius: 5px; background: Cat.overlay0.with-alpha(0.12); x: (parent.width - 36px) / 2; }
                                    if !loading: Text {
                                        text: stats.orphan-count;
                                        font-size: 30px;
                                        font-weight: 700;
                                        color: stats.orphan-count > 0 ? Cat.yellow : Cat.overlay0;
                                        horizontal-alignment: center;
                                    }
                                    Text {
                                        text: "Orphaned";
                                        font-size: 15px;
                                        color: Cat.overlay1;
                                        horizontal-alignment: center;
                                    }
                                }
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                                height: 82px;
                                border-radius: 10px;
                                background: stats.update-count > 0 ? Cat.peach.with-alpha(0.1) : Cat.surface0.with-alpha(0.35);
                                border-width: 1px;
                                border-color: stats.update-count > 0 ? Cat.peach.with-alpha(0.25) : Cat.surface0.with-alpha(0.2);

                                VerticalLayout {
                                    alignment: center;
                                    spacing: 4px;

                                    if loading: Rectangle { width: 36px; height: 20px; border-radius: 5px; background: Cat.overlay0.with-alpha(0.12); x: (parent.width - 36px) / 2; }
                                    if !loading: Text {
                                        text: stats.update-count;
                                        font-size: 30px;
                                        font-weight: 700;
                                        color: stats.update-count > 0 ? Cat.peach : Cat.overlay0;
                                        horizontal-alignment: center;
                                    }
                                    Text {
                                        text: "Updates";
                                        font-size: 15px;
                                        color: Cat.overlay1;
                                        horizontal-alignment: center;
                                    }
                                }
                            }
                        }
                    }

                    // Quick actions
                    VerticalLayout {
                        spacing: 8px;
                        SectionLabel { section-title: "QUICK ACTIONS"; }

                        HorizontalLayout {
                            spacing: 10px;

                            Rectangle {
                                horizontal-stretch: 1;
                                height: 66px;
                                border-radius: 10px;
                                background: home-sync-touch.has-hover ? Cat.mauve.with-alpha(0.18) : Cat.surface0.with-alpha(0.4);
                                opacity: busy ? 0.5 : 1.0;
                                animate background { duration: 100ms; }

                                home-sync-touch := TouchArea {
                                    mouse-cursor: busy ? default : pointer;
                                    clicked => { if !busy { root.sync-databases(); } }
                                }

                                VerticalLayout {
                                    padding-left: 16px;
                                    padding-right: 16px;
                                    alignment: center;
                                    spacing: 3px;

                                    Text {
                                        text: "Check for Updates";
                                        font-size: 14px;
                                        font-weight: 600;
                                        color: Cat.mauve;
                                    }
                                    if loading: Rectangle { width: 110px; height: 11px; border-radius: 3px; background: Cat.overlay0.with-alpha(0.1); }
                                    if !loading: Text {
                                        text: stats.update-count > 0 ? stats.update-count + " updates pending" : "System is up to date";
                                        font-size: 15px;
                                        color: Cat.overlay0;
                                    }
                                }
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                                height: 66px;
                                border-radius: 10px;
                                background: home-cache-touch.has-hover ? Cat.blue.with-alpha(0.15) : Cat.surface0.with-alpha(0.4);
                                animate background { duration: 100ms; }

                                home-cache-touch := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.clean-package-cache(); }
                                }

                                VerticalLayout {
                                    padding-left: 16px;
                                    padding-right: 16px;
                                    alignment: center;
                                    spacing: 3px;

                                    Text {
                                        text: "Clean Cache";
                                        font-size: 14px;
                                        font-weight: 600;
                                        color: Cat.blue;
                                    }
                                    if loading: Rectangle { width: 70px; height: 11px; border-radius: 3px; background: Cat.overlay0.with-alpha(0.1); }
                                    if !loading: Text {
                                        text: stats.cache-size + " used";
                                        font-size: 15px;
                                        color: Cat.overlay0;
                                    }
                                }
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                                height: 66px;
                                border-radius: 10px;
                                background: home-orphan-touch.has-hover ? (stats.orphan-count > 0 ? Cat.red.with-alpha(0.18) : Cat.surface0.with-alpha(0.5)) : Cat.surface0.with-alpha(0.4);
                                opacity: stats.orphan-count == 0 ? 0.5 : 1.0;
                                animate background { duration: 100ms; }

                                home-orphan-touch := TouchArea {
                                    mouse-cursor: stats.orphan-count > 0 ? pointer : default;
                                    clicked => { if stats.orphan-count > 0 { root.load-orphan-list(); root.show-orphan-dialog = true; } }
                                }

                                VerticalLayout {
                                    padding-left: 16px;
                                    padding-right: 16px;
                                    alignment: center;
                                    spacing: 3px;

                                    Text {
                                        text: "Remove Orphans";
                                        font-size: 14px;
                                        font-weight: 600;
                                        color: stats.orphan-count > 0 ? Cat.red : Cat.overlay0;
                                    }
                                    if loading: Rectangle { width: 130px; height: 11px; border-radius: 3px; background: Cat.overlay0.with-alpha(0.1); }
                                    if !loading: Text {
                                        text: stats.orphan-count + " orphaned packages";
                                        font-size: 15px;
                                        color: Cat.overlay0;
                                    }
                                }
                            }
                        }
                    }

                    // ── SYSTEM ──────────────────────────────────────────────
                    VerticalLayout {
                        spacing: 8px;

                        SectionLabel { section-title: "SYSTEM"; }

                        // System info terminal card
                        Rectangle {
                            border-radius: 12px;
                            background: Cat.crust.with-alpha(0.25);
                            border-width: 1px;
                            border-color: Cat.surface0;
                            clip: true;

                            VerticalLayout {
                                // Terminal title bar
                                Rectangle {
                                    height: 31px;
                                    background: Cat.mantle.with-alpha(0.5);

                                    HorizontalLayout {
                                        padding-left: 12px; padding-right: 12px;

                                        VerticalLayout { alignment: center;
                                            HorizontalLayout { spacing: 6px;
                                                Rectangle { width: 10px; height: 10px; border-radius: 5px; background: #ed6a5e; }
                                                Rectangle { width: 10px; height: 10px; border-radius: 5px; background: #f4bf4f; }
                                                Rectangle { width: 10px; height: 10px; border-radius: 5px; background: #61c554; }
                                            }
                                        }

                                        Text {
                                            text: "System Info";
                                            font-size: 12px; font-family: "monospace";
                                            color: Cat.overlay0;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                            horizontal-stretch: 1;
                                        }

                                        Rectangle { width: 34px; }
                                    }
                                }

                                Rectangle { height: 1px; background: Cat.surface0; }

                                // Specs grid
                                VerticalLayout {
                                    padding: 14px;
                                    spacing: 9px;

                                    // Hostname + distro row
                                    HorizontalLayout {
                                        spacing: 8px;
                                        Text { text: "HOST"; font-size: 9px; font-weight: 700; color: Cat.overlay0; letter-spacing: 0.6px; vertical-alignment: center; width: 44px; }
                                        Text {
                                            text: sys-info.hostname != "" ? sys-info.hostname : "localhost";
                                            font-size: 12px; font-weight: 600; font-family: "monospace";
                                            color: Cat.mauve; vertical-alignment: center; horizontal-stretch: 1; overflow: elide;
                                        }
                                        if sys-info.distro != "": Rectangle {
                                            width: distro-lbl2.preferred-width + 14px;
                                            height: 20px; border-radius: 4px;
                                            background: Cat.mauve.with-alpha(0.1);
                                            border-width: 1px; border-color: Cat.mauve.with-alpha(0.25);
                                            distro-lbl2 := Text {
                                                text: sys-info.distro;
                                                font-size: 9px; font-weight: 600;
                                                color: Cat.mauve;
                                                horizontal-alignment: center; vertical-alignment: center;
                                            }
                                        }
                                    }

                                    Rectangle { height: 1px; background: Cat.surface0.with-alpha(0.6); }

                                    HorizontalLayout {
                                        spacing: 24px;

                                        VerticalLayout {
                                            horizontal-stretch: 1; spacing: 9px;

                                            HorizontalLayout { spacing: 8px;
                                                Text { text: "OS "; font-size: 9px; font-weight: 700; color: Cat.overlay0; letter-spacing: 0.6px; vertical-alignment: center; width: 44px; }
                                                Text { text: sys-info.kernel; font-size: 12px; font-weight: 500; font-family: "monospace"; color: Cat.teal; vertical-alignment: center; horizontal-stretch: 1; overflow: elide; }
                                            }
                                            HorizontalLayout { spacing: 8px;
                                                Text { text: "CPU"; font-size: 9px; font-weight: 700; color: Cat.overlay0; letter-spacing: 0.6px; vertical-alignment: center; width: 44px; }
                                                Text { text: sys-info.cpu; font-size: 12px; font-weight: 500; font-family: "monospace"; color: Cat.text; vertical-alignment: center; horizontal-stretch: 1; overflow: elide; }
                                            }
                                            HorizontalLayout { spacing: 8px;
                                                Text { text: "MEM"; font-size: 9px; font-weight: 700; color: Cat.overlay0; letter-spacing: 0.6px; vertical-alignment: center; width: 44px; }
                                                Text { text: sys-info.ram-used + " / " + sys-info.ram-total; font-size: 12px; font-weight: 500; font-family: "monospace"; color: Cat.green; vertical-alignment: center; horizontal-stretch: 1; }
                                            }
                                        }

                                        VerticalLayout {
                                            horizontal-stretch: 1; spacing: 9px;

                                            HorizontalLayout { spacing: 8px;
                                                Text { text: "UP "; font-size: 9px; font-weight: 700; color: Cat.overlay0; letter-spacing: 0.6px; vertical-alignment: center; width: 44px; }
                                                Text { text: sys-info.uptime; font-size: 12px; font-weight: 500; font-family: "monospace"; color: Cat.yellow; vertical-alignment: center; horizontal-stretch: 1; }
                                            }
                                            if sys-info.gpu != "": HorizontalLayout { spacing: 8px;
                                                Text { text: "GPU"; font-size: 9px; font-weight: 700; color: Cat.overlay0; letter-spacing: 0.6px; vertical-alignment: center; width: 44px; }
                                                Text { text: sys-info.gpu; font-size: 12px; font-weight: 500; font-family: "monospace"; color: Cat.text; vertical-alignment: center; horizontal-stretch: 1; overflow: elide; }
                                            }
                                            if sys-info.disk-total != "": HorizontalLayout { spacing: 8px;
                                                Text { text: "DSK"; font-size: 9px; font-weight: 700; color: Cat.overlay0; letter-spacing: 0.6px; vertical-alignment: center; width: 44px; }
                                                Text { text: sys-info.disk-used + " / " + sys-info.disk-total; font-size: 12px; font-weight: 500; font-family: "monospace"; color: Cat.sapphire; vertical-alignment: center; horizontal-stretch: 1; }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // ── RECENT ACTIVITY ──────────────────────────────────────
                    VerticalLayout {
                        spacing: 8px;

                        SectionLabel { section-title: "RECENT ACTIVITY"; }

                        VerticalLayout {
                            spacing: 0;

                            if activity-items.length == 0: Rectangle {
                                height: 40px;
                                border-radius: 8px;
                                background: Cat.surface0.with-alpha(0.3);
                                Text {
                                    text: "No activity found";
                                    font-size: 15px;
                                    color: Cat.overlay0;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }

                            for item[i] in activity-items: Rectangle {
                                height: 38px;

                                HorizontalLayout {
                                    padding-left: 12px;
                                    padding-right: 12px;
                                    spacing: 10px;

                                    Rectangle {
                                        width: action-lbl.preferred-width + 12px;
                                        height: 18px;
                                        border-radius: 5px;
                                        y: (parent.height - 18px) / 2;
                                        background: item.action == "installed" ? Cat.green.with-alpha(0.18)
                                            : item.action == "removed" ? Cat.red.with-alpha(0.18)
                                            : Cat.peach.with-alpha(0.18);

                                        action-lbl := Text {
                                            text: item.action;
                                            font-size: 10px;
                                            font-weight: 600;
                                            color: item.action == "installed" ? Cat.green
                                                : item.action == "removed" ? Cat.red
                                                : Cat.peach;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }

                                    Text {
                                        text: item.package;
                                        font-size: 13px;
                                        font-weight: 500;
                                        color: Cat.text;
                                        vertical-alignment: center;
                                        horizontal-stretch: 1;
                                        overflow: elide;
                                    }

                                    Text {
                                        text: item.date;
                                        font-size: 14px;
                                        color: Cat.overlay0;
                                        vertical-alignment: center;
                                    }
                                }

                                if i < activity-items.length - 1: Rectangle {
                                    x: 12px;
                                    y: parent.height - 1px;
                                    width: parent.width - 24px;
                                    height: 1px;
                                    background: Cat.surface0;
                                    opacity: 0.5;
                                }
                            }
                        }
                    }
                }

            // Catch-all stretch: keeps all content pinned to top when no view provides a flex child
            if view == 2 || view == 5 || view == 3 || view == 4: Rectangle { vertical-stretch: 1; }
        }
    }

    // ── Top-right loading / progress indicator ──────────────────────────────
    if loading || busy: Rectangle {
        x: parent.width - self.width - 16px;
        y: 12px;
        width: 228px;
        height: 40px;
        border-radius: 8px;
        background: Cat.surface0.with-alpha(0.96);
        border-width: 1px;
        border-color: Cat.mauve.with-alpha(0.3);
        drop-shadow-blur: 14px;
        drop-shadow-color: Cat.crust.with-alpha(0.45);
        drop-shadow-offset-y: 2px;
        clip: true;

        // Left accent stripe
        Rectangle {
            x: 0; y: 0;
            width: 2px; height: parent.height;
            background: Cat.mauve.with-alpha(0.65);
        }

        // ── Text row ─────────────────────────────────────────────────
        HorizontalLayout {
            padding-left: 12px;
            padding-right: 10px;
            padding-top: 7px;
            padding-bottom: 20px;   // leaves 12px for the fill bar below
            spacing: 5px;

            Text {
                text: ">";
                font-size: 14px;
                font-weight: 800;
                color: Cat.mauve;
                vertical-alignment: center;
            }

            Text {
                text: progress-text != "" ? progress-text :
                      busy ? "running operation..." : "resolving packages...";
                font-size: 14px;
                color: Cat.subtext0;
                vertical-alignment: center;
                horizontal-stretch: 1;
                overflow: elide;
            }

            if busy && progress > 0: Text {
                text: progress + "%";
                font-size: 14px;
                font-weight: 700;
                color: Cat.mauve;
                vertical-alignment: center;
            }
        }

        // ── Fill bar — spans full chip width, pinned to bottom ───────
        Rectangle {
            x: 0;
            y: parent.height - 12px;
            width: parent.width;
            height: 12px;
            clip: true;
            background: transparent;

            // Dim background blocks (always visible)
            Text {
                text: "░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░";
                font-size: 9px;
                color: Cat.surface1;
                vertical-alignment: center;
                overflow: clip;
            }

            // Indeterminate shimmer — sweeps left→right on a loop
            if !busy || progress == 0: Rectangle {
                clip: true;
                x: root._load-shimmer * parent.width;
                y: 0;
                height: parent.height;
                width: parent.width * 0.38;

                Text {
                    text: "████████████████████████████████████████████";
                    font-size: 9px;
                    color: Cat.mauve.with-alpha(0.85);
                    vertical-alignment: center;
                    overflow: clip;
                }
            }

            // Determinate fill — grows right as progress increases
            if busy && progress > 0: Rectangle {
                clip: true;
                x: 0; y: 0;
                height: parent.height;
                width: parent.width * progress / 100;
                animate width { duration: 350ms; easing: ease-out; }

                Text {
                    text: "████████████████████████████████████████████";
                    font-size: 9px;
                    color: Cat.mauve;
                    vertical-alignment: center;
                    overflow: clip;
                }
            }
        }
    }

    if selected-count > 0: Rectangle {
        x: (parent.width - 420px) / 2;
        y: parent.height - 72px;
        width: 420px;
        height: 47px;
        border-radius: 24px;
        background: Cat.surface0;
        drop-shadow-blur: 20px;
        drop-shadow-color: Cat.crust.with-alpha(0.5);
        drop-shadow-offset-y: 4px;
        border-width: 1px;
        border-color: Cat.surface1;

        HorizontalLayout {
            padding-left: 16px;
            padding-right: 10px;
            padding-top: 0px;
            padding-bottom: 0px;
            spacing: 8px;
            alignment: center;

            VerticalLayout {
                alignment: center;
                Text {
                    text: selected-count + " selected";
                    font-size: 13px;
                    font-weight: 500;
                    color: Cat.text;
                }
            }

            Rectangle { horizontal-stretch: 1; }

            VerticalLayout {
                alignment: center;
                Rectangle {
                    width: 64px;
                    height: 32px;
                    border-radius: 6px;
                    background: fab-clear-touch.has-hover ? Cat.surface1 : transparent;

                    Text {
                        text: "Clear";
                        font-size: 15px;
                        color: Cat.subtext0;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    fab-clear-touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.clear-selection(); }
                    }
                }
            }

            VerticalLayout {
                alignment: center;
                Btn {
                    label: "Install";
                    primary: selected-uninstalled-count > 0;
                    enabled: selected-uninstalled-count > 0;
                    min-width: 60px;
                    clicked => {
                        if view == 10 { root.batch-flatpak-install(); }
                        else { root.bulk-install(); }
                    }
                }
            }

            VerticalLayout {
                alignment: center;
                Btn {
                    label: "Remove";
                    danger: selected-installed-count > 0;
                    enabled: selected-installed-count > 0;
                    min-width: 64px;
                    clicked => {
                        if view == 10 { root.batch-flatpak-remove(); }
                        else { root.bulk-remove(); }
                    }
                }
            }
        }
    }

    if show-addons-modal: Rectangle {
        width: 100%;
        height: 100%;
        background: Cat.crust.with-alpha(0.65);

        TouchArea { clicked => { root.show-addons-modal = false; root.addon-select-all(false); } }

        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: 500px;
            height: min(560px, parent.height - 60px);
            background: Cat.base;
            border-radius: 14px;
            border-width: 1px;
            border-color: Cat.surface1;
            drop-shadow-blur: 40px;
            drop-shadow-color: Cat.crust.with-alpha(0.7);
            drop-shadow-offset-y: 10px;

            TouchArea {} // intercept backdrop click

            property <bool> all-selected: flatpak-addons.length > 0 && addon-selected-count == flatpak-addons.length;

            VerticalLayout {
                padding: 24px;
                spacing: 0;

                // ── Header ───────────────────────────────────────────────────
                HorizontalLayout {
                    spacing: 10px;

                    NavIcon {
                        d: "M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5";
                        icon-color: Cat.mauve; width: 20px; height: 20px;
                    }
                    Text {
                        text: "Add-Ons & Extensions";
                        font-size: 17px; font-weight: 700; color: Cat.text;
                        vertical-alignment: center; horizontal-stretch: 1;
                    }
                    // Select All button — only when there are uninstalled addons
                    if flatpak-addons.length > 0: Rectangle {
                        width: sel-all-lbl.preferred-width + 24px; height: 32px; border-radius: 6px;
                        background: sel-all-t.has-hover
                            ? (all-selected ? Cat.peach.with-alpha(0.2) : Cat.mauve.with-alpha(0.2))
                            : (all-selected ? Cat.peach.with-alpha(0.1) : Cat.mauve.with-alpha(0.1));
                        border-width: 1px;
                        border-color: all-selected ? Cat.peach.with-alpha(0.4) : Cat.mauve.with-alpha(0.35);
                        animate background { duration: 60ms; }
                        sel-all-lbl := Text {
                            text: all-selected ? "Deselect All" : "Select All";
                            font-size: 15px; font-weight: 600;
                            color: all-selected ? Cat.peach : Cat.mauve;
                            horizontal-alignment: center; vertical-alignment: center;
                        }
                        sel-all-t := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.addon-select-all(!all-selected); }
                        }
                    }
                    Rectangle { width: 6px; }
                    Rectangle {
                        width: 28px; height: 25px; border-radius: 6px;
                        background: close-modal-t.has-hover ? Cat.surface1 : transparent;
                        NavIcon { d: "M18 6L6 18M6 6l12 12"; icon-color: Cat.overlay1; width: 14px; height: 14px; x: 7px; y: 7px; }
                        close-modal-t := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.show-addons-modal = false; root.addon-select-all(false); }
                        }
                    }
                }

                Rectangle { height: 14px; }

                // ── Scrollable list: two sections ────────────────────────────
                ScrollView {
                    vertical-stretch: 1;

                    VerticalLayout {
                        spacing: 0;

                        // ── Section: Available to Install ─────────────────────
                        if flatpak-addons.length > 0: Rectangle {
                            height: 25px;
                            background: Cat.surface0.with-alpha(0.4);
                            border-radius: 6px;
                            HorizontalLayout {
                                padding-left: 10px; padding-right: 10px;
                                Text {
                                    text: "Available to Install";
                                    font-size: 14px; font-weight: 700;
                                    color: Cat.subtext0; vertical-alignment: center;
                                    letter-spacing: 0.5px;
                                }
                            }
                        }

                        for addon[ai] in flatpak-addons: Rectangle {
                            property <bool> is-checked: ai < addon-selected.length && addon-selected[ai];
                            height: 56px;
                            border-radius: 6px;
                            animate background { duration: 60ms; }
                            background: arow-ta.has-hover ? Cat.surface0.with-alpha(0.6) : transparent;

                            arow-ta := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.toggle-addon-selected(ai); }
                            }

                            HorizontalLayout {
                                padding-left: 10px; padding-right: 10px; spacing: 12px;

                                VerticalLayout {
                                    alignment: center;
                                    Rectangle {
                                        width: 18px; height: 18px; border-radius: 5px;
                                        border-width: 1.5px;
                                        border-color: is-checked ? Cat.mauve : Cat.surface2;
                                        background: is-checked ? Cat.mauve : transparent;
                                        animate background { duration: 80ms; }
                                        if is-checked: NavIcon {
                                            d: "M20 6L9 17l-5-5"; icon-color: Cat.crust;
                                            width: 10px; height: 10px; x: 4px; y: 4px;
                                        }
                                    }
                                }

                                VerticalLayout {
                                    horizontal-stretch: 1; spacing: 3px; alignment: center;
                                    Text {
                                        text: addon.display-name;
                                        font-size: 14px; font-weight: 600; color: Cat.text; overflow: elide;
                                    }
                                    Text {
                                        text: addon.description;
                                        font-size: 15px; color: Cat.overlay1; overflow: elide;
                                    }
                                }
                            }

                            if ai < flatpak-addons.length - 1: Rectangle {
                                x: 10px; y: parent.height - 1px;
                                width: parent.width - 20px; height: 1px;
                                background: Cat.surface0; opacity: 0.6;
                            }
                        }

                        // ── Section: Already Installed ────────────────────────
                        if flatpak-addons.length > 0 && flatpak-addons-installed.length > 0: Rectangle {
                            height: 8px; background: transparent;
                        }
                        if flatpak-addons-installed.length > 0: Rectangle {
                            height: 25px;
                            background: Cat.green.with-alpha(0.08);
                            border-radius: 6px;
                            HorizontalLayout {
                                padding-left: 10px; padding-right: 10px;
                                Text {
                                    text: "Already Installed";
                                    font-size: 14px; font-weight: 700;
                                    color: Cat.green; vertical-alignment: center;
                                    letter-spacing: 0.5px;
                                }
                            }
                        }

                        for inst[ii] in flatpak-addons-installed: Rectangle {
                            height: 56px;
                            border-radius: 6px;
                            animate background { duration: 60ms; }
                            background: inst-row-ta.has-hover ? Cat.red.with-alpha(0.06) : transparent;

                            inst-row-ta := TouchArea { mouse-cursor: pointer; }

                            HorizontalLayout {
                                padding-left: 10px; padding-right: 10px; spacing: 12px;

                                // Green installed indicator
                                VerticalLayout {
                                    alignment: center;
                                    Rectangle {
                                        width: 18px; height: 18px; border-radius: 9px;
                                        background: Cat.green.with-alpha(0.15);
                                        NavIcon {
                                            d: "M20 6L9 17l-5-5"; icon-color: Cat.green;
                                            width: 10px; height: 10px; x: 4px; y: 4px;
                                        }
                                    }
                                }

                                VerticalLayout {
                                    horizontal-stretch: 1; spacing: 3px; alignment: center;
                                    Text {
                                        text: inst.display-name;
                                        font-size: 14px; font-weight: 600; color: Cat.subtext1; overflow: elide;
                                    }
                                    Text {
                                        text: inst.description;
                                        font-size: 15px; color: Cat.overlay0; overflow: elide;
                                    }
                                }

                                // Remove button
                                VerticalLayout {
                                    alignment: center;
                                    Rectangle {
                                        width: 64px; height: 26px; border-radius: 6px;
                                        background: rem-ta.has-hover ? Cat.red.with-alpha(0.25) : Cat.red.with-alpha(0.12);
                                        border-width: 1px; border-color: Cat.red.with-alpha(0.3);
                                        animate background { duration: 60ms; }
                                        Text {
                                            text: "Remove";
                                            font-size: 11px; font-weight: 600; color: Cat.red;
                                            horizontal-alignment: center; vertical-alignment: center;
                                        }
                                        rem-ta := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => {
                                                root.remove-addon(inst.name);
                                                root.show-addons-modal = false;
                                            }
                                        }
                                    }
                                }
                            }

                            if ii < flatpak-addons-installed.length - 1: Rectangle {
                                x: 10px; y: parent.height - 1px;
                                width: parent.width - 20px; height: 1px;
                                background: Cat.surface0; opacity: 0.6;
                            }
                        }
                    }
                }

                Rectangle { height: 16px; }

                // ── Footer ───────────────────────────────────────────────────
                HorizontalLayout {
                    alignment: end; spacing: 8px;

                    Rectangle {
                        width: 80px; height: 31px; border-radius: 8px;
                        background: close-btn-t.has-hover ? Cat.surface1 : Cat.surface0.with-alpha(0.6);
                        animate background { duration: 60ms; }
                        Text { text: "Close"; font-size: 13px; font-weight: 500; color: Cat.subtext0; horizontal-alignment: center; vertical-alignment: center; }
                        close-btn-t := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.show-addons-modal = false; root.addon-select-all(false); }
                        }
                    }

                    if addon-selected-count > 0: Rectangle {
                        width: inst-sel-lbl.preferred-width + 28px; height: 31px; border-radius: 8px;
                        background: inst-sel-t.has-hover ? Cat.mauve : Cat.mauve.with-alpha(0.85);
                        animate background { duration: 60ms; }
                        inst-sel-lbl := Text {
                            text: "Install " + addon-selected-count + " Add-On" + (addon-selected-count == 1 ? "" : "s");
                            font-size: 13px; font-weight: 600; color: Cat.crust;
                            horizontal-alignment: center; vertical-alignment: center;
                        }
                        inst-sel-t := TouchArea {
                            mouse-cursor: pointer;
                            clicked => {
                                root.install-selected-addons();
                                root.show-addons-modal = false;
                                root.addon-select-all(false);
                            }
                        }
                    }
                }
            }
        }
    }

    if show-local-install: Rectangle {
        width: 100%;
        height: 100%;
        background: Cat.crust.with-alpha(0.7);

        TouchArea { clicked => { root.cancel-local-install(); } }

        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: 440px;
            height: 300px;
            background: Cat.base;
            border-radius: 12px;
            border-width: 1px;
            border-color: Cat.surface0;
            drop-shadow-blur: 30px;
            drop-shadow-color: Cat.crust.with-alpha(0.6);
            drop-shadow-offset-y: 8px;

            TouchArea {}

            VerticalLayout {
                padding: 24px;
                spacing: 16px;

                HorizontalLayout {
                    spacing: 12px;
                    NavIcon {
                        d: icon-package;
                        icon-color: Cat.mauve;
                        width: 24px;
                        height: 24px;
                    }
                    Text {
                        text: "Install Local Package";
                        font-size: 17px;
                        font-weight: 600;
                        color: Cat.text;
                        vertical-alignment: center;
                    }
                }

                Rectangle { height: 1px; background: Cat.surface0; }

                VerticalLayout {
                    spacing: 8px;
                    DetailProperty { prop-label: "Name"; prop-value: local-package.display-name != "" ? local-package.display-name : "Unknown"; }
                    DetailProperty { prop-label: "Version"; prop-value: local-package.version; }
                    DetailProperty { prop-label: "Size"; prop-value: local-package.installed-size; }
                    DetailProperty { prop-label: "File"; prop-value: local-package-path; }
                }

                Rectangle { vertical-stretch: 1; }

                HorizontalLayout {
                    spacing: 8px;
                    alignment: end;

                    Btn {
                        label: "Cancel";
                        clicked => { root.cancel-local-install(); }
                    }

                    Btn {
                        label: "Install";
                        primary: true;
                        enabled: !busy;
                        clicked => { root.install-local-package(local-package-path); }
                    }
                }
            }
        }
    }

    if show-progress-popup: Rectangle {
        width: 100%;
        height: 100%;
        background: Cat.crust.with-alpha(0.65);

        TouchArea {}

        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: min(620px, parent.width - 40px);
            height: min(500px, parent.height - 40px);
            background: Cat.base;
            border-radius: 12px;
            clip: true;
            border-width: 1px;
            border-color: Cat.surface0;
            drop-shadow-blur: 32px;
            drop-shadow-color: Cat.crust.with-alpha(0.7);
            drop-shadow-offset-y: 10px;

            VerticalLayout {
                spacing: 0;

                // Title bar
                Rectangle {
                    height: 48px;
                    background: Cat.mantle;

                    HorizontalLayout {
                        padding-left: 16px;
                        padding-right: 10px;
                        spacing: 10px;

                        if !progress-popup-done: VerticalLayout {
                            alignment: center;
                            Spinner { indeterminate: true; width: 16px; height: 16px; }
                        }

                        if progress-popup-done: VerticalLayout {
                            alignment: center;
                            NavIcon {
                                d: progress-popup-success ? "M20 6L9 17l-5-5" : icon-close;
                                icon-color: progress-popup-success ? Cat.green : Cat.red;
                                width: 16px;
                                height: 16px;
                            }
                        }

                        Text {
                            text: progress-popup-title;
                            font-size: 15px;
                            font-weight: 600;
                            color: Cat.text;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                            overflow: elide;
                        }

                        if !progress-popup-done: VerticalLayout {
                            alignment: center;
                            Rectangle {
                                width: cancel-label.preferred-width + 20px;
                                height: 32px;
                                border-radius: 6px;
                                background: cancel-touch.has-hover ? Cat.red.with-alpha(0.2) : Cat.surface0;
                                animate background { duration: 80ms; }

                                cancel-label := Text {
                                    text: "Cancel";
                                    font-size: 15px;
                                    font-weight: 600;
                                    color: cancel-touch.has-hover ? Cat.red : Cat.overlay0;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                    animate color { duration: 80ms; }
                                }

                                cancel-touch := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.cancel-operation(); }
                                }
                            }
                        }

                        if progress-popup-done: VerticalLayout {
                            alignment: center;
                            Rectangle {
                                width: 28px;
                                height: 25px;
                                border-radius: 6px;
                                background: prog-close-x.has-hover ? Cat.surface0 : transparent;

                                NavIcon {
                                    d: icon-close;
                                    icon-color: Cat.overlay0;
                                    width: 12px;
                                    height: 12px;
                                    x: 8px;
                                    y: 8px;
                                }

                                prog-close-x := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.close-progress-popup(); }
                                }
                            }
                        }
                    }
                }

                // Progress bar + stage
                Rectangle {
                    height: 50px;
                    background: Cat.mantle;

                    Rectangle {
                        y: 0;
                        width: 100%;
                        height: 1px;
                        background: Cat.surface0;
                        opacity: 0.6;
                    }

                    VerticalLayout {
                        padding-left: 16px;
                        padding-right: 16px;
                        padding-top: 10px;
                        spacing: 6px;

                        Rectangle {
                            height: 5px;
                            border-radius: 3px;
                            background: Cat.surface0;

                            Rectangle {
                                width: progress-popup-done ? parent.width :
                                       (progress-popup-percent > 0 ? parent.width * progress-popup-percent / 100 : 4px);
                                height: 100%;
                                border-radius: 3px;
                                background: progress-popup-done ?
                                            (progress-popup-success ? Cat.green : Cat.red) : Cat.mauve;
                                animate width { duration: 300ms; easing: ease-in-out; }
                            }
                        }

                        HorizontalLayout {
                            Text {
                                text: progress-popup-done ?
                                      (progress-popup-success ? "Completed successfully" : "Operation failed") :
                                      progress-popup-stage;
                                font-size: 15px;
                                color: progress-popup-done ?
                                       (progress-popup-success ? Cat.green : Cat.red) : Cat.overlay0;
                                overflow: elide;
                                horizontal-stretch: 1;
                            }

                            Text {
                                text: progress-popup-done ? "done" : progress-popup-percent + "%";
                                font-size: 15px;
                                font-weight: 600;
                                color: progress-popup-done ?
                                       (progress-popup-success ? Cat.green : Cat.red) : Cat.mauve;
                            }
                        }
                    }
                }

                Rectangle { height: 1px; background: Cat.surface0; opacity: 0.5; }

                // Live log output — always visible
                Rectangle {
                    vertical-stretch: 1;
                    background: Cat.crust;

                    ScrollView {
                        // _scroll-tick dependency forces re-eval every 80ms while live
                        viewport-y: { let _ = root._scroll-tick; min(0px, self.visible-height - self.viewport-height); }

                        VerticalLayout {
                            padding: 12px;

                            Text {
                                text: progress-popup-output;
                                font-size: 12px;
                                font-family: "monospace";
                                color: Cat.text;
                                opacity: 0.85;
                                wrap: word-wrap;
                            }
                        }
                    }
                }

                // User input prompt (conflict resolution / password / questions)
                if progress-popup-show-input: Rectangle {
                    height: 60px;
                    background: Cat.yellow.with-alpha(0.06);

                    Rectangle { y: 0; width: 100%; height: 1px; background: Cat.surface0; opacity: 0.5; }

                    VerticalLayout {
                        padding: 8px;
                        padding-left: 16px;
                        padding-right: 16px;
                        spacing: 3px;

                        Text {
                            text: progress-popup-prompt;
                            font-size: 11px;
                            font-weight: 500;
                            color: Cat.yellow;
                            overflow: elide;
                        }

                        Input {
                            placeholder: "Type response and press Enter...";
                            accepted(text) => {
                                root.progress-popup-send-input(text);
                                self.text = "";
                            }
                        }
                    }
                }

                // Footer when done
                if progress-popup-done: Rectangle {
                    height: 46px;
                    background: progress-popup-success ? Cat.green.with-alpha(0.06) : Cat.red.with-alpha(0.06);

                    Rectangle { y: 0; width: 100%; height: 1px; background: Cat.surface0; opacity: 0.4; }

                    HorizontalLayout {
                        padding-left: 16px;
                        padding-right: 16px;
                        alignment: end;
                        spacing: 10px;

                        // Reboot button - only when terminal-is-upgrade AND success
                        if terminal-is-upgrade && progress-popup-success: VerticalLayout {
                            alignment: center;
                            Rectangle {
                                width: done-reboot-label.preferred-width + 28px;
                                height: 29px;
                                border-radius: 8px;
                                background: done-reboot-touch.has-hover ? Cat.peach.with-alpha(0.28) : Cat.peach.with-alpha(0.14);
                                border-width: 1px; border-color: Cat.peach.with-alpha(0.4);
                                animate background { duration: 80ms; }

                                done-reboot-label := Text {
                                    text: "Reboot System";
                                    font-size: 14px;
                                    font-weight: 600;
                                    color: Cat.peach;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }

                                done-reboot-touch := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.terminal-reboot(); }
                                }
                            }
                        }

                        VerticalLayout {
                            alignment: center;
                            Rectangle {
                                width: done-close-label.preferred-width + 28px;
                                height: 29px;
                                border-radius: 8px;
                                background: done-close-touch.has-hover ? Cat.mauve : Cat.mauve.with-alpha(0.85);
                                animate background { duration: 80ms; }

                                done-close-label := Text {
                                    text: "Close";
                                    font-size: 14px;
                                    font-weight: 600;
                                    color: Cat.crust;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }

                                done-close-touch := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.close-progress-popup(); }
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    // ── Flatpak remove confirmation dialog ────────────────────────────────────
    if fp-confirm-open: Rectangle {
        width: 100%; height: 100%;
        background: Cat.crust.with-alpha(0.70);
        TouchArea {}

        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: 400px; height: 210px;
            background: Cat.base;
            border-radius: 14px;
            border-width: 1px;
            border-color: Cat.red.with-alpha(0.3);
            drop-shadow-blur: 28px;
            drop-shadow-color: Cat.crust.with-alpha(0.6);
            drop-shadow-offset-y: 8px;

            VerticalLayout {
                padding: 24px; spacing: 16px;

                // Header
                HorizontalLayout {
                    spacing: 10px;
                    VerticalLayout {
                        alignment: center;
                        Rectangle {
                            width: 36px; height: 32px; border-radius: 10px;
                            background: Cat.red.with-alpha(0.12);
                            NavIcon { d: "M3 6h18M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6M8 6V4a2 2 0 012-2h4a2 2 0 012 2v2"; icon-color: Cat.red; width: 18px; height: 18px; x: 9px; y: 9px; }
                        }
                    }
                    VerticalLayout {
                        alignment: center; horizontal-stretch: 1; spacing: 3px;
                        Text { text: "Remove " + fp-confirm-name + "?"; font-size: 15px; font-weight: 700; color: Cat.text; overflow: elide; }
                        Text { text: "This will uninstall the application from your system."; font-size: 15px; color: Cat.overlay1; }
                    }
                }

                // Data question
                Rectangle {
                    height: 40px; border-radius: 8px;
                    background: Cat.surface0;
                    HorizontalLayout {
                        padding-left: 14px; padding-right: 14px;
                        VerticalLayout {
                            alignment: center; horizontal-stretch: 1;
                            Text { text: "Also remove leftover user data?"; font-size: 13px; color: Cat.subtext1; }
                            Text { text: "Saved settings, files, and app data will be deleted."; font-size: 14px; color: Cat.overlay0; }
                        }
                    }
                }

                // Buttons
                HorizontalLayout {
                    spacing: 8px;

                    // Cancel
                    Rectangle {
                        horizontal-stretch: 1; height: 29px; border-radius: 7px;
                        background: fp-cancel-ta.has-hover ? Cat.surface1 : Cat.surface0;
                        animate background { duration: 60ms; }
                        VerticalLayout { alignment: center; Text { text: "Cancel"; font-size: 13px; font-weight: 600; color: Cat.subtext0; horizontal-alignment: center; } }
                        fp-cancel-ta := TouchArea { mouse-cursor: pointer; clicked => { root.fp-confirm-open = false; } }
                    }

                    // Remove only
                    Rectangle {
                        horizontal-stretch: 1; height: 29px; border-radius: 7px;
                        background: fp-remonly-ta.has-hover ? Cat.red.with-alpha(0.25) : Cat.red.with-alpha(0.14);
                        animate background { duration: 60ms; }
                        VerticalLayout { alignment: center; Text { text: "Remove Only"; font-size: 13px; font-weight: 600; color: Cat.red; horizontal-alignment: center; } }
                        fp-remonly-ta := TouchArea {
                            mouse-cursor: pointer;
                            clicked => {
                                root.fp-confirm-open = false;
                                root.remove-flatpak(root.fp-confirm-id, false);
                            }
                        }
                    }

                    // Remove + Data
                    Rectangle {
                        horizontal-stretch: 1; height: 29px; border-radius: 7px;
                        background: fp-remdata-ta.has-hover ? Cat.red.with-alpha(0.5) : Cat.red.with-alpha(0.3);
                        animate background { duration: 60ms; }
                        VerticalLayout { alignment: center; Text { text: "Remove + Data"; font-size: 13px; font-weight: 700; color: Cat.red; horizontal-alignment: center; } }
                        fp-remdata-ta := TouchArea {
                            mouse-cursor: pointer;
                            clicked => {
                                root.fp-confirm-open = false;
                                root.remove-flatpak(root.fp-confirm-id, true);
                            }
                        }
                    }
                }
            }
        }
    }

    // ── Orphan Removal Dialog ────────────────────────────────────────────────
    if show-orphan-dialog: Rectangle {
        width: 100%;
        height: 100%;
        background: Cat.crust.with-alpha(0.75);

        TouchArea {}

        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: min(560px, parent.width - 40px);
            height: min(580px, parent.height - 40px);
            background: Cat.base;
            border-radius: 12px;
            clip: true;
            border-width: 1px;
            border-color: Cat.red.with-alpha(0.4);
            drop-shadow-blur: 36px;
            drop-shadow-color: Cat.crust.with-alpha(0.8);
            drop-shadow-offset-y: 12px;

            VerticalLayout {
                spacing: 0;

                // Header
                Rectangle {
                    height: 56px;
                    background: Cat.red.with-alpha(0.1);

                    Rectangle {
                        y: parent.height - 1px;
                        width: 100%;
                        height: 1px;
                        background: Cat.red.with-alpha(0.25);
                    }

                    HorizontalLayout {
                        padding-left: 18px;
                        padding-right: 18px;
                        spacing: 12px;

                        VerticalLayout {
                            alignment: center;
                            NavIcon {
                                d: "M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z";
                                icon-color: Cat.red;
                                width: 20px;
                                height: 20px;
                            }
                        }

                        VerticalLayout {
                            horizontal-stretch: 1;
                            alignment: center;
                            spacing: 2px;
                            Text {
                                text: "Remove Orphaned Packages";
                                font-size: 15px;
                                font-weight: 700;
                                color: Cat.text;
                            }
                            Text {
                                text: orphan-list.length + " packages found";
                                font-size: 11px;
                                color: Cat.subtext0;
                            }
                        }

                        // Close button
                        VerticalLayout {
                            alignment: center;
                            Rectangle {
                                width: 28px; height: 25px; border-radius: 8px;
                                background: oph-close-ta.has-hover ? Cat.surface1 : transparent;
                                NavIcon { d: "M18 6L6 18M6 6l12 12"; icon-color: Cat.overlay1; width: 14px; height: 14px; x: 7px; y: 7px; }
                                oph-close-ta := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.show-orphan-dialog = false; }
                                }
                            }
                        }
                    }
                }

                // ⚠ Scary warning banner — no fixed height, auto-sizes to wrapped text
                Rectangle {
                    background: Cat.red.with-alpha(0.07);
                    border-width: 0;

                    Rectangle {
                        y: parent.height - 1px;
                        width: 100%;
                        height: 1px;
                        background: Cat.red.with-alpha(0.18);
                    }

                    HorizontalLayout {
                        padding-left: 16px;
                        padding-right: 16px;
                        padding-top: 10px;
                        padding-bottom: 10px;
                        spacing: 12px;

                        VerticalLayout {
                            alignment: center;
                            Rectangle {
                                width: 32px; height: 29px; border-radius: 8px;
                                background: Cat.red.with-alpha(0.18);
                                NavIcon {
                                    d: "M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z";
                                    icon-color: Cat.red;
                                    width: 18px; height: 18px; x: 7px; y: 7px;
                                }
                            }
                        }

                        VerticalLayout {
                            horizontal-stretch: 1;
                            alignment: center;
                            spacing: 3px;
                            Text {
                                text: "DANGER — Read before proceeding";
                                font-size: 15px;
                                font-weight: 800;
                                color: Cat.red;
                                letter-spacing: 0.5px;
                            }
                            Text {
                                text: "Orphans are packages no longer required as dependencies. Some may still be needed by manually installed software or config. Removing them can break your system. Review carefully.";
                                font-size: 14px;
                                color: Cat.subtext0;
                                wrap: word-wrap;
                            }
                        }
                    }
                }

                // Select-all row
                Rectangle {
                    height: 32px;
                    background: Cat.surface0.with-alpha(0.3);

                    Rectangle {
                        y: parent.height - 1px;
                        width: 100%;
                        height: 1px;
                        background: Cat.surface1.with-alpha(0.5);
                    }

                    HorizontalLayout {
                        padding-left: 16px;
                        padding-right: 16px;
                        padding-top: 0px;
                        padding-bottom: 0px;
                        spacing: 8px;

                        VerticalLayout {
                            alignment: center;
                            Rectangle {
                                width: 16px; height: 16px; border-radius: 4px;
                                background: all-ta.has-hover ? Cat.surface1 : Cat.surface0;
                                border-width: 1px;
                                border-color: Cat.overlay0;
                                NavIcon {
                                    visible: orphan-selected-count == orphan-list.length && orphan-list.length > 0;
                                    d: "M5 13l4 4L19 7";
                                    icon-color: Cat.red;
                                    width: 10px; height: 10px; x: 3px; y: 3px;
                                }
                                all-ta := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => {
                                        root.orphan-select-all(!(orphan-selected-count == orphan-list.length && orphan-list.length > 0));
                                    }
                                }
                            }
                        }

                        Text {
                            horizontal-stretch: 1;
                            text: "Select / Deselect All";
                            font-size: 15px;
                            color: Cat.subtext0;
                            vertical-alignment: center;
                        }

                        Text {
                            text: orphan-selected-count + " selected";
                            font-size: 11px;
                            color: Cat.overlay1;
                            vertical-alignment: center;
                        }
                    }
                }

                // Package checklist
                ListView {
                    vertical-stretch: 1;

                    for pkg[i] in orphan-list: Rectangle {
                        height: 47px;
                        background: row-ta.has-hover ? Cat.surface0.with-alpha(0.4) : transparent;
                        animate background { duration: 60ms; }

                        row-ta := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.orphan-toggle(i); }
                        }

                        HorizontalLayout {
                            padding-left: 16px;
                            padding-right: 16px;
                            spacing: 10px;

                            // Checkbox
                            VerticalLayout {
                                alignment: center;
                                Rectangle {
                                    width: 16px; height: 16px; border-radius: 4px;
                                    background: orphan-checked[i] ? Cat.red.with-alpha(0.2) : Cat.surface0;
                                    border-width: 1px;
                                    border-color: orphan-checked[i] ? Cat.red : Cat.overlay0;
                                    animate background { duration: 60ms; }
                                    NavIcon {
                                        visible: orphan-checked[i];
                                        d: "M5 13l4 4L19 7";
                                        icon-color: Cat.red;
                                        width: 10px; height: 10px; x: 3px; y: 3px;
                                    }
                                }
                            }

                            // Name + description
                            VerticalLayout {
                                horizontal-stretch: 1;
                                alignment: center;
                                spacing: 2px;
                                Text {
                                    text: pkg.name;
                                    font-size: 13px;
                                    font-weight: 600;
                                    color: Cat.text;
                                    overflow: elide;
                                }
                                Text {
                                    text: pkg.description;
                                    font-size: 14px;
                                    color: Cat.subtext0;
                                    overflow: elide;
                                }
                            }

                            // Version
                            VerticalLayout {
                                alignment: center;
                                Text {
                                    text: pkg.version;
                                    font-size: 10px;
                                    color: Cat.overlay1;
                                    vertical-alignment: center;
                                }
                            }

                            // Tag badge: Explicit / Dep (clickable → shows dep info)
                            VerticalLayout {
                                alignment: center;
                                width: 54px;
                                Rectangle {
                                    width: 54px;
                                    height: 18px;
                                    border-radius: 5px;
                                    background: tag-ta.has-hover
                                        ? (pkg.explicit ? Cat.mauve.with-alpha(0.3) : Cat.sapphire.with-alpha(0.3))
                                        : (pkg.explicit ? Cat.mauve.with-alpha(0.18) : Cat.sapphire.with-alpha(0.18));
                                    border-width: 1px;
                                    border-color: pkg.explicit ? Cat.mauve.with-alpha(0.4) : Cat.sapphire.with-alpha(0.4);
                                    animate background { duration: 60ms; }
                                    Text {
                                        text: pkg.explicit ? "Explicit" : "Dep";
                                        font-size: 9px;
                                        font-weight: 600;
                                        color: pkg.explicit ? Cat.mauve : Cat.sapphire;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                    tag-ta := TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => {
                                            orphan-dep-info-title = pkg.name;
                                            orphan-dep-info-text = "Loading...";
                                            show-orphan-dep-info = true;
                                            root.load-orphan-dep-info(pkg.name);
                                        }
                                    }
                                }
                            }
                        }

                        Rectangle {
                            x: 16px;
                            y: parent.height - 1px;
                            width: parent.width - 32px;
                            height: 1px;
                            background: Cat.surface0;
                            opacity: 0.4;
                        }
                    }
                }

                // Dep-info panel (shown when tag clicked)
                if show-orphan-dep-info: Rectangle {
                    height: 80px;
                    background: Cat.surface0.with-alpha(0.5);
                    border-width: 1px;
                    border-color: Cat.sapphire.with-alpha(0.3);

                    HorizontalLayout {
                        padding-left: 14px;
                        padding-right: 14px;
                        padding-top: 10px;
                        padding-bottom: 10px;
                        spacing: 10px;

                        VerticalLayout {
                            horizontal-stretch: 1;
                            spacing: 4px;
                            Text {
                                text: orphan-dep-info-title + " — required by:";
                                font-size: 11px;
                                font-weight: 700;
                                color: Cat.sapphire;
                            }
                            Text {
                                text: orphan-dep-info-text;
                                font-size: 11px;
                                color: Cat.subtext0;
                                wrap: word-wrap;
                                overflow: elide;
                            }
                        }

                        VerticalLayout {
                            alignment: start;
                            Rectangle {
                                width: 22px; height: 22px; border-radius: 6px;
                                background: di-close.has-hover ? Cat.surface1 : transparent;
                                NavIcon { d: "M18 6L6 18M6 6l12 12"; icon-color: Cat.overlay1; width: 10px; height: 10px; x: 6px; y: 6px; }
                                di-close := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { show-orphan-dep-info = false; }
                                }
                            }
                        }
                    }
                }

                // Footer buttons
                Rectangle {
                    height: 60px;
                    background: Cat.surface0.with-alpha(0.3);

                    Rectangle {
                        y: 0;
                        width: 100%;
                        height: 1px;
                        background: Cat.surface1.with-alpha(0.5);
                    }

                    HorizontalLayout {
                        padding-left: 16px;
                        padding-right: 16px;
                        spacing: 10px;
                        alignment: end;

                        // Cancel
                        Rectangle {
                            width: 88px; height: 32px; border-radius: 8px;
                            background: oph-cancel-ta.has-hover ? Cat.surface1 : Cat.surface0;
                            animate background { duration: 80ms; }
                            Text {
                                text: "Cancel";
                                font-size: 13px;
                                font-weight: 600;
                                color: Cat.subtext0;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            oph-cancel-ta := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.show-orphan-dialog = false; }
                            }
                        }

                        // Remove selected
                        Rectangle {
                            width: 150px; height: 32px; border-radius: 8px;
                            background: orphan-selected-count == 0 ? Cat.red.with-alpha(0.3) :
                                (oph-rm-ta.has-hover ? Cat.red : Cat.red.with-alpha(0.85));
                            animate background { duration: 80ms; }
                            Text {
                                text: "Remove Selected";
                                font-size: 13px;
                                font-weight: 700;
                                color: Cat.crust;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            oph-rm-ta := TouchArea {
                                mouse-cursor: orphan-selected-count > 0 ? pointer : default;
                                clicked => {
                                    if orphan-selected-count > 0 {
                                        root.show-orphan-dialog = false;
                                        root.remove-selected-orphans();
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    // ── Unlock DB confirmation dialog ─────────────────────────────────────────
    if show-unlock-db-confirm: Rectangle {
        width: 100%; height: 100%;
        background: Cat.crust.with-alpha(0.75);
        TouchArea {}
        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: min(440px, parent.width - 40px);
            height: 240px;
            background: Cat.base;
            border-radius: 12px;
            clip: true;
            border-width: 1px;
            border-color: Cat.red.with-alpha(0.4);
            drop-shadow-blur: 32px;
            drop-shadow-color: Cat.crust.with-alpha(0.7);
            drop-shadow-offset-y: 10px;
            VerticalLayout {
                spacing: 0;
                // Header
                Rectangle {
                    height: 47px;
                    background: Cat.red.with-alpha(0.1);
                    Rectangle { y: parent.height - 1px; width: 100%; height: 1px; background: Cat.red.with-alpha(0.25); }
                    HorizontalLayout {
                        padding-left: 18px; padding-right: 18px; spacing: 12px;
                        VerticalLayout {
                            alignment: center;
                            NavIcon { d: icon-lock; icon-color: Cat.red; width: 20px; height: 20px; }
                        }
                        Text {
                            horizontal-stretch: 1;
                            text: "Unlock Pacman Database";
                            font-size: 15px; font-weight: 700; color: Cat.text;
                            vertical-alignment: center;
                        }
                        VerticalLayout {
                            alignment: center;
                            Rectangle {
                                width: 28px; height: 25px; border-radius: 8px;
                                background: ulk-cl.has-hover ? Cat.surface1 : transparent;
                                NavIcon { d: "M18 6L6 18M6 6l12 12"; icon-color: Cat.overlay1; width: 14px; height: 14px; x: 7px; y: 7px; }
                                ulk-cl := TouchArea { mouse-cursor: pointer; clicked => { root.show-unlock-db-confirm = false; } }
                            }
                        }
                    }
                }
                // Body
                VerticalLayout {
                    vertical-stretch: 1;
                    alignment: center;
                    padding-left: 24px; padding-right: 24px;
                    spacing: 10px;
                    Text {
                        text: "Only do this if pacman is NOT running. Removing the lock while pacman is active will corrupt your database.";
                        font-size: 12px; color: Cat.subtext0;
                        wrap: word-wrap; horizontal-alignment: center;
                    }
                    Rectangle {
                        height: 30px; border-radius: 6px;
                        background: Cat.red.with-alpha(0.08);
                        border-width: 1px; border-color: Cat.red.with-alpha(0.25);
                        Text {
                            text: "$ rm /var/lib/pacman/db.lck";
                            font-size: 11px; color: Cat.red.with-alpha(0.8);
                            horizontal-alignment: center; vertical-alignment: center;
                        }
                    }
                }
                // Footer
                Rectangle {
                    height: 56px;
                    background: Cat.surface0.with-alpha(0.3);
                    Rectangle { y: 0; width: 100%; height: 1px; background: Cat.surface1.with-alpha(0.5); }
                    HorizontalLayout {
                        padding-left: 16px; padding-right: 16px; spacing: 10px; alignment: end;
                        Rectangle {
                            width: 88px; height: 32px; border-radius: 8px;
                            background: ulk-cancel.has-hover ? Cat.surface1 : Cat.surface0;
                            animate background { duration: 80ms; }
                            Text { text: "Cancel"; font-size: 13px; font-weight: 600; color: Cat.subtext0; horizontal-alignment: center; vertical-alignment: center; }
                            ulk-cancel := TouchArea { mouse-cursor: pointer; clicked => { root.show-unlock-db-confirm = false; } }
                        }
                        Rectangle {
                            width: 130px; height: 32px; border-radius: 8px;
                            background: ulk-confirm.has-hover ? Cat.red : Cat.red.with-alpha(0.85);
                            animate background { duration: 80ms; }
                            Text { text: "Unlock DB"; font-size: 13px; font-weight: 700; color: Cat.crust; horizontal-alignment: center; vertical-alignment: center; }
                            ulk-confirm := TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    root.show-unlock-db-confirm = false;
                                    root.unlock-db();
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    if show-conflict-dialog: Rectangle {
        width: 100%;
        height: 100%;
        background: Cat.crust.with-alpha(0.72);

        TouchArea {}

        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: min(540px, parent.width - 40px);
            height: min(420px, parent.height - 40px);
            background: Cat.base;
            border-radius: 12px;
            clip: true;
            border-width: 1px;
            border-color: Cat.yellow.with-alpha(0.35);
            drop-shadow-blur: 32px;
            drop-shadow-color: Cat.crust.with-alpha(0.7);
            drop-shadow-offset-y: 10px;

            VerticalLayout {
                spacing: 0;

                // Header
                Rectangle {
                    height: 47px;
                    background: Cat.yellow.with-alpha(0.08);

                    Rectangle {
                        y: parent.height - 1px;
                        width: 100%;
                        height: 1px;
                        background: Cat.yellow.with-alpha(0.25);
                    }

                    HorizontalLayout {
                        padding-left: 18px;
                        padding-right: 18px;
                        spacing: 12px;

                        VerticalLayout {
                            alignment: center;
                            NavIcon {
                                d: "M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z M12 9v4 M12 17h.01";
                                icon-color: Cat.yellow;
                                width: 20px;
                                height: 20px;
                            }
                        }

                        VerticalLayout {
                            alignment: center;
                            horizontal-stretch: 1;
                            spacing: 2px;

                            Text {
                                text: "Conflict Detected";
                                font-size: 16px;
                                font-weight: 700;
                                color: Cat.text;
                            }

                            Text {
                                text: conflict-can-force ? "File already exists in filesystem" : "Package dependency conflict";
                                font-size: 15px;
                                color: Cat.yellow;
                            }
                        }
                    }
                }

                // Conflict details (scrollable)
                Rectangle {
                    vertical-stretch: 1;
                    background: Cat.crust;

                    ScrollView {
                        VerticalLayout {
                            padding: 14px;

                            Text {
                                text: conflict-summary;
                                font-size: 12px;
                                font-family: "monospace";
                                color: Cat.text;
                                opacity: 0.85;
                                wrap: word-wrap;
                            }
                        }
                    }
                }

                // Advice
                Rectangle {
                    height: 32px;
                    background: conflict-can-force ? Cat.yellow.with-alpha(0.06) : Cat.red.with-alpha(0.06);

                    Rectangle { y: 0; width: 100%; height: 1px; background: Cat.surface0; opacity: 0.5; }

                    Text {
                        x: 18px;
                        width: parent.width - 36px;
                        height: parent.height;
                        text: conflict-can-force
                            ? "Force overwrite will replace the conflicting files. Use with caution."
                            : "This conflict requires manual resolution. Remove the conflicting package first.";
                        font-size: 11px;
                        color: conflict-can-force ? Cat.yellow : Cat.red;
                        opacity: 0.8;
                        vertical-alignment: center;
                        wrap: word-wrap;
                        overflow: elide;
                    }
                }

                // Buttons
                Rectangle {
                    height: 47px;
                    background: Cat.mantle;

                    Rectangle { y: 0; width: 100%; height: 1px; background: Cat.surface0; opacity: 0.5; }

                    HorizontalLayout {
                        padding-left: 16px;
                        padding-right: 16px;
                        spacing: 10px;
                        alignment: end;

                        Rectangle {
                            width: cancel-conf-label.preferred-width + 24px;
                            height: 30px;
                            border-radius: 7px;
                            background: cancel-conf-touch.has-hover ? Cat.surface1 : Cat.surface0;
                            animate background { duration: 80ms; }

                            cancel-conf-label := Text {
                                text: "Cancel";
                                font-size: 13px;
                                font-weight: 500;
                                color: Cat.text;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }

                            cancel-conf-touch := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.conflict-cancel(); }
                            }
                        }

                        if conflict-can-force: Rectangle {
                            width: force-label.preferred-width + 24px;
                            height: 30px;
                            border-radius: 7px;
                            background: force-touch.has-hover ? Cat.yellow : Cat.yellow.with-alpha(0.85);
                            animate background { duration: 80ms; }

                            force-label := Text {
                                text: "Force Overwrite";
                                font-size: 13px;
                                font-weight: 700;
                                color: Cat.crust;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }

                            force-touch := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.conflict-force-overwrite(); }
                            }
                        }
                    }
                }
            }
        }
    }

    if show-terminal: Rectangle {
        width: 100%;
        height: 100%;
        background: Cat.crust.with-alpha(0.6);

        // Safe deferred focus — fires from Timer callback (not during property evaluation)
        // so it never triggers Slint's "Recursion detected" panic.
        Timer {
            interval: 8ms;
            running: root.terminal-focus-pending && !root.terminal-done;
            triggered => {
                root.terminal-focus-pending = false;
                term-input.grab-focus();
            }
        }

        TouchArea {}

        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: min(640px, parent.width - 40px);
            height: min(460px, parent.height - 40px);
            border-radius: 12px;
            clip: true;
            background: Cat.base;
            border-width: 1px;
            border-color: Cat.surface0;
            drop-shadow-blur: 30px;
            drop-shadow-color: Cat.crust.with-alpha(0.6);
            drop-shadow-offset-y: 8px;

            VerticalLayout {
                Rectangle {
                    height: 40px;
                    background: Cat.mantle;

                    HorizontalLayout {
                        padding-left: 14px;
                        padding-right: 8px;

                        Text {
                            text: terminal-title;
                            font-size: 14px;
                            font-weight: 500;
                            color: Cat.text;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                            overflow: elide;
                        }

                        VerticalLayout {
                            alignment: center;
                            Rectangle {
                                width: 28px;
                                height: 25px;
                                border-radius: 6px;
                                background: close-touch.has-hover ? Cat.surface0 : transparent;

                                NavIcon {
                                    d: icon-close;
                                    icon-color: Cat.overlay0;
                                    width: 12px;
                                    height: 12px;
                                    x: 8px;
                                    y: 8px;
                                }

                                close-touch := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.terminal-close(); }
                                }
                            }
                        }
                    }
                }

                Rectangle { height: 1px; background: Cat.surface0; }

                Rectangle {
                    vertical-stretch: 1;
                    background: Cat.crust;

                    ScrollView {
                        // _scroll-tick dependency forces re-eval every 80ms while live
                        viewport-y: { let _ = root._scroll-tick; min(0px, self.visible-height - self.viewport-height); }
                        VerticalLayout {
                            padding: 12px;
                            Text {
                                text: terminal-output;
                                font-size: 13px;
                                font-family: "monospace";
                                color: Cat.text;
                                opacity: 0.9;
                                wrap: word-wrap;
                            }
                        }
                    }
                }

                // Input bar — always visible while operation runs, hidden when done.
                // Password mode only when a sudo/auth prompt is detected.
                Rectangle {
                    visible: !terminal-done;
                    height: terminal-done ? 0px : 52px;
                    background: root.terminal-show-password
                        ? Cat.yellow.with-alpha(0.12)
                        : Cat.crust;
                    border-width: 1px;
                    border-color: root.terminal-show-password
                        ? Cat.yellow.with-alpha(0.5)
                        : Cat.surface1;

                    HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 12px;
                        padding-top: 9px;
                        padding-bottom: 9px;
                        spacing: 8px;

                        // Label — lock icon for password, chevron otherwise
                        Text {
                            text: root.terminal-show-password ? "🔒" : "❯";
                            font-size: root.terminal-show-password ? 14px : 13px;
                            color: root.terminal-show-password ? Cat.yellow : Cat.overlay1;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                            width: 18px;
                        }

                        term-input := Input {
                            horizontal-stretch: 1;
                            placeholder: root.terminal-show-password
                                ? "Enter password and press Enter..."
                                : "Type input and press Enter...";
                            is-password: root.terminal-show-password;
                            accepted(text) => {
                                root.terminal-send-input(text);
                                self.text = "";
                                root.terminal-show-password = false;
                            }
                        }
                    }
                }

                // Done bar — shown when operation completes
                Rectangle {
                    visible: terminal-done;
                    height: terminal-done ? 48px : 0px;
                    background: terminal-success ? Cat.green.with-alpha(0.08) : Cat.red.with-alpha(0.08);
                    border-width: 1px;
                    border-color: terminal-success ? Cat.green.with-alpha(0.15) : Cat.red.with-alpha(0.15);

                    HorizontalLayout {
                        padding-left: 14px; padding-right: 14px; spacing: 10px;

                        VerticalLayout { alignment: center;
                            NavIcon {
                                d: terminal-success ? "M20 6L9 17l-5-5" : icon-close;
                                icon-color: terminal-success ? Cat.green : Cat.red;
                                width: 13px; height: 13px;
                            }
                        }

                        Text {
                            text: terminal-success
                                ? (terminal-is-upgrade ? "Update complete  —  a reboot may be needed for kernel/firmware changes." : "Completed successfully")
                                : "Operation failed";
                            font-size: 15px; font-weight: 500;
                            color: terminal-success ? Cat.green : Cat.red;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                            overflow: elide;
                        }

                        // Reboot — only on successful upgrade
                        if terminal-is-upgrade && terminal-success: VerticalLayout {
                            alignment: center;
                            Rectangle {
                                width: 80px; height: 32px; border-radius: 7px;
                                background: reboot-ta.has-hover ? Cat.peach.with-alpha(0.28) : Cat.peach.with-alpha(0.14);
                                border-width: 1px; border-color: Cat.peach.with-alpha(0.4);
                                animate background { duration: 60ms; }
                                VerticalLayout { alignment: center;
                                    Text { text: "Reboot"; font-size: 15px; font-weight: 700; color: Cat.peach; horizontal-alignment: center; }
                                }
                                reboot-ta := TouchArea { mouse-cursor: pointer; clicked => { root.terminal-reboot(); } }
                            }
                        }

                        // OK / Close button
                        VerticalLayout {
                            alignment: center;
                            Rectangle {
                                width: 60px; height: 32px; border-radius: 7px;
                                background: ok-done-ta.has-hover ? Cat.surface1 : Cat.surface0;
                                animate background { duration: 60ms; }
                                VerticalLayout { alignment: center;
                                    Text { text: "OK"; font-size: 15px; font-weight: 700; color: Cat.subtext0; horizontal-alignment: center; }
                                }
                                ok-done-ta := TouchArea { mouse-cursor: pointer; clicked => { root.terminal-close(); } }
                            }
                        }
                    }
                }
            }
        }
    }

    // ── Distro warning dialog ──────────────────────────────────────────────────
    if show-distro-warning: Rectangle {
        width: 100%; height: 100%;
        background: #000000.with-alpha(0.72);
        TouchArea {}

        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: min(500px, parent.width - 48px);
            height: layout.min-height;
            border-radius: 14px;
            background: #1a0a0a;
            border-width: 2px;
            border-color: Cat.red.with-alpha(0.7);
            drop-shadow-blur: 40px;
            drop-shadow-color: Cat.red.with-alpha(0.35);
            drop-shadow-offset-y: 8px;

            layout := VerticalLayout {
                padding: 28px;
                spacing: 20px;

                // Red top stripe
                Rectangle {
                    height: 4px;
                    border-radius: 2px;
                    background: @linear-gradient(90deg, Cat.red, Cat.red.with-alpha(0.3));
                }

                // Header
                HorizontalLayout {
                    spacing: 14px;
                    VerticalLayout {
                        alignment: center;
                        NavIcon {
                            d: "M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z";
                            icon-color: Cat.red;
                            width: 28px; height: 28px;
                        }
                    }
                    VerticalLayout {
                        alignment: center;
                        spacing: 4px;
                        Text {
                            text: "⚠  UNSUPPORTED DISTRIBUTION";
                            font-size: 16px; font-weight: 800;
                            color: Cat.red;
                            letter-spacing: 0.5px;
                        }
                        Text {
                            text: "xPackageManager is built exclusively for XeroLinux";
                            font-size: 11px; font-weight: 400;
                            color: #aa7777;
                        }
                    }
                }

                // Divider
                Rectangle { height: 1px; background: Cat.red.with-alpha(0.2); }

                // Body
                Text {
                    text: "This application was built specifically for XeroLinux.\n\nUsing it on any other Arch-based distribution is entirely at your own risk. No support, warranty, or guarantees of any kind are provided. \n\nFunctionality may be incomplete or incorrect on unsupported systems.";
                    font-size: 14px;
                    color: #e8c8c8;
                    wrap: word-wrap;
                }

                // Divider
                Rectangle { height: 1px; background: Cat.red.with-alpha(0.2); }

                // Buttons
                HorizontalLayout {
                    spacing: 12px;
                    alignment: end;

                    // Source code link
                    Rectangle {
                        width: src-lbl.preferred-width + 28px;
                        height: 36px;
                        border-radius: 8px;
                        background: src-ta.has-hover ? Cat.blue.with-alpha(0.22) : Cat.blue.with-alpha(0.1);
                        border-width: 1px;
                        border-color: Cat.blue.with-alpha(0.4);
                        animate background { duration: 60ms; }
                        src-lbl := Text {
                            text: "View Source";
                            font-size: 13px; font-weight: 600;
                            color: Cat.blue;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        src-ta := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.open-url("https://github.com/xerolinux/xPackageManager"); }
                        }
                    }

                    // Dismiss
                    Rectangle {
                        width: ack-lbl.preferred-width + 28px;
                        height: 36px;
                        border-radius: 8px;
                        background: ack-ta.has-hover ? Cat.red.with-alpha(0.35) : Cat.red.with-alpha(0.18);
                        border-width: 1px;
                        border-color: Cat.red.with-alpha(0.55);
                        animate background { duration: 60ms; }
                        ack-lbl := Text {
                            text: "I Understand, Proceed";
                            font-size: 13px; font-weight: 700;
                            color: Cat.red;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        ack-ta := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.show-distro-warning = false; }
                        }
                    }
                }
            }
        }
    }
}
}
