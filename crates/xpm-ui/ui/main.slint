import { ListView, ScrollView, Spinner, Palette } from "std-widgets.slint";

export struct PackageData {
    name: string,
    display-name: string,
    version: string,
    description: string,
    repository: string,
    backend: int,
    installed: bool,
    has-update: bool,
    installed-size: string,
    licenses: string,
    url: string,
    dependencies: string,
    required-by: string,
    selected: bool,
}

export struct StatsData {
    pacman-count: int,
    flatpak-count: int,
    orphan-count: int,
    update-count: int,
    cache-size: string,
}

export struct ActivityItem {
    action: string,
    package: string,
    date: string,
}

export struct SysInfo {
    kernel: string,
    uptime: string,
    cpu: string,
    ram-used: string,
    ram-total: string,
    gpu: string,
    disk-used: string,
    disk-total: string,
    hostname: string,
    distro: string,
}

export struct AppRow {
    a: PackageData,
    b: PackageData,
    c: PackageData,
    count: int,
}

export struct DepNode {
    name: string,
    version: string,
    depth: int,
    installed: bool,
    is-optional: bool,
    prefix: string,
    is-root: bool,
}

export global Cat {
    // Core backgrounds — derived from system Palette
    out property <color> base: Palette.background;
    out property <color> mantle: Palette.alternate-background;
    out property <color> crust: Palette.background.darker(0.12);
    // Surfaces
    out property <color> surface0: Palette.control-background;
    out property <color> surface1: Palette.control-background.brighter(0.08);
    out property <color> surface2: Palette.control-background.brighter(0.18);
    // Text / overlays
    out property <color> overlay0: Palette.foreground.with-alpha(0.38);
    out property <color> overlay1: Palette.foreground.with-alpha(0.55);
    out property <color> overlay2: Palette.foreground.with-alpha(0.7);
    out property <color> subtext0: Palette.foreground.with-alpha(0.8);
    out property <color> subtext1: Palette.foreground.with-alpha(0.9);
    out property <color> text: Palette.foreground;
    // Accent — purple
    out property <color> mauve: #c6a0f6;
    out property <color> blue: #8aadf4;
    out property <color> lavender: #b7bdf8;
    // Semantic colors — keep consistent across themes
    out property <color> red: #e06c75;
    out property <color> green: #98c379;
    out property <color> yellow: #e5c07b;
    out property <color> peach: #d19a66;
    out property <color> teal: #56b6c2;
    out property <color> pink: #c678dd;
    out property <color> flamingo: #e06c75;
    out property <color> rosewater: #e5c0c0;
    out property <color> sapphire: #61afef;
    out property <color> sky: #56b6c2;
    out property <color> maroon: #be5046;
}

component NavIcon inherits Rectangle {
    in property <brush> icon-color: Cat.text;
    in property <string> d;
    in property <bool> filled: false;
    width: 18px;
    height: 18px;

    Path {
        width: 100%;
        height: 100%;
        viewbox-x: 0;
        viewbox-y: 0;
        viewbox-width: 24;
        viewbox-height: 24;
        commands: d;
        fill: filled ? icon-color : transparent;
        stroke: filled ? transparent : icon-color;
        stroke-width: 1.5px;
    }
}

component Input inherits Rectangle {
    in-out property <string> text <=> input.text;
    in property <string> placeholder: "";
    out property <bool> has-focus: input.has-focus;
    callback accepted(string);
    callback edited(string);

    height: 34px;
    background: Cat.surface0;
    border-radius: 8px;
    border-width: input.has-focus ? 1px : 0;
    border-color: Cat.mauve.with-alpha(0.5);
    animate border-width { duration: 80ms; }

    TouchArea { clicked => { input.focus(); } }

    if input.text == "" && !input.has-focus: Text {
        x: 12px;
        width: parent.width - 24px;
        height: parent.height;
        text: root.placeholder;
        font-size: 13px;
        color: Cat.overlay0;
        vertical-alignment: center;
    }

    input := TextInput {
        x: 12px;
        y: 0;
        width: parent.width - 24px;
        height: parent.height;
        color: Cat.text;
        font-size: 13px;
        vertical-alignment: center;
        single-line: true;
        selection-background-color: Cat.mauve.with-alpha(0.3);
        selection-foreground-color: Cat.text;
        accepted => { root.accepted(self.text); }
        edited => { root.edited(self.text); }
    }
}

component Btn inherits Rectangle {
    in property <string> label;
    in property <bool> primary: false;
    in property <bool> danger: false;
    in property <bool> enabled: true;
    callback clicked;

    height: 30px;
    min-width: 70px;
    border-radius: 8px;
    background: !enabled ? Cat.surface0 :
                danger ? (btn-touch.has-hover ? Cat.red : Cat.red.with-alpha(0.85)) :
                primary ? (btn-touch.has-hover ? Cat.mauve : Cat.mauve.with-alpha(0.85)) :
                btn-touch.has-hover ? Cat.surface1 : Cat.surface0;
    animate background { duration: 100ms; }

    Text {
        text: label;
        font-size: 12px;
        font-weight: 600;
        color: !enabled ? Cat.overlay0 :
               (primary || danger) ? Cat.crust : Cat.text;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    btn-touch := TouchArea {
        mouse-cursor: enabled ? pointer : default;
        clicked => { if enabled { root.clicked(); } }
    }
}

component NavButton inherits Rectangle {
    in property <string> label;
    in property <string> icon-path: "";
    in property <bool> icon-filled: false;
    in property <bool> active: false;
    in property <string> badge: "";
    callback clicked;

    height: 36px;
    border-radius: 8px;
    background: active ? Cat.mauve.with-alpha(0.2) : (touch.has-hover ? Cat.surface0.with-alpha(0.6) : transparent);
    animate background { duration: 120ms; easing: ease-out; }

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 10px;

        if icon-path != "": VerticalLayout {
            alignment: center;
            NavIcon {
                d: icon-path;
                icon-color: active ? Cat.mauve : Cat.subtext0;
                filled: icon-filled;
            }
        }

        Text {
            text: label;
            font-size: 13px;
            font-weight: active ? 600 : 400;
            color: active ? Cat.mauve : Cat.text;
            opacity: active ? 1.0 : 0.85;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }

        if badge != "": VerticalLayout {
            alignment: center;
            Rectangle {
                width: 22px;
                height: 18px;
                border-radius: 9px;
                background: Cat.red;
                VerticalLayout {
                    alignment: center;
                    Text {
                        text: badge;
                        font-size: 10px;
                        font-weight: 700;
                        color: Cat.crust;
                        horizontal-alignment: center;
                    }
                }
            }
        }
    }
}

component CheckBox inherits Rectangle {
    in property <bool> checked: false;
    callback toggled(bool);

    width: 18px;
    height: 18px;
    border-radius: 5px;
    border-width: checked ? 0 : 1.5px;
    border-color: Cat.surface2;
    background: checked ? Cat.mauve : transparent;
    animate background { duration: 100ms; }

    if checked: NavIcon {
        d: "M20 6L9 17l-5-5";
        icon-color: Cat.crust;
        width: 12px;
        height: 12px;
        x: 3px;
        y: 3px;
    }

    TouchArea {
        mouse-cursor: pointer;
        clicked => { root.toggled(!root.checked); }
    }
}

component PackageRow inherits Rectangle {
    in property <PackageData> pkg;
    in property <bool> show-separator: true;
    in property <bool> show-checkbox: false;
    in property <bool> show-action-button: true;
    callback clicked;
    callback install;
    callback remove;
    callback toggle-selected(bool);

    height: 58px;
    background: pkg.selected ? Cat.mauve.with-alpha(0.07) :
                (touch.has-hover ? Cat.surface0.with-alpha(0.45) : transparent);
    animate background { duration: 80ms; }

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        padding-left: 16px;
        padding-right: 14px;
        spacing: 10px;

        if show-checkbox: VerticalLayout {
            alignment: center;
            CheckBox {
                checked: pkg.selected;
                toggled(val) => { root.toggle-selected(val); }
            }
        }

        VerticalLayout {
            horizontal-stretch: 1;
            spacing: 1px;
            alignment: center;

            Text {
                text: pkg.display-name;
                font-size: 13px;
                font-weight: 600;
                color: pkg.has-update ? Cat.peach : Cat.text;
                overflow: elide;
            }

            HorizontalLayout {
                spacing: 8px;

                Text {
                    text: pkg.version;
                    font-size: 11px;
                    font-weight: 500;
                    color: pkg.has-update ? Cat.peach.with-alpha(0.8) : Cat.mauve.with-alpha(0.7);
                    vertical-alignment: center;
                }

                if pkg.description != "": Text {
                    text: "·";
                    font-size: 11px;
                    color: Cat.overlay0;
                    vertical-alignment: center;
                }

                if pkg.description != "": Text {
                    text: pkg.description;
                    font-size: 11px;
                    color: Cat.subtext0;
                    opacity: 0.75;
                    overflow: elide;
                    horizontal-stretch: 1;
                }
            }
        }

        if pkg.repository != "": VerticalLayout {
            alignment: center;
            Rectangle {
                width: repo-text.preferred-width + 10px;
                height: 18px;
                border-radius: 4px;
                background: Cat.surface0;

                repo-text := Text {
                    text: pkg.repository;
                    font-size: 9.5px;
                    color: Cat.overlay1;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        if show-action-button: VerticalLayout {
            alignment: center;
            Rectangle {
                width: 68px;
                height: 28px;
                border-radius: 6px;
                background: pkg.has-update
                    ? Cat.teal.with-alpha(0.15)
                    : (pkg.installed ? Cat.red.with-alpha(0.15) : Cat.mauve.with-alpha(0.15));

                Text {
                    text: pkg.has-update ? "Update" : (pkg.installed ? "Remove" : "Install");
                    font-size: 11px;
                    font-weight: 600;
                    color: pkg.has-update ? Cat.teal : (pkg.installed ? Cat.red : Cat.mauve);
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                TouchArea {
                    mouse-cursor: pointer;
                    clicked => {
                        if pkg.has-update { root.install(); }
                        else if pkg.installed { root.remove(); }
                        else { root.install(); }
                    }
                }
            }
        }
    }

    if show-separator: Rectangle {
        x: 16px;
        y: parent.height - 1px;
        width: parent.width - 32px;
        height: 1px;
        background: Cat.surface0;
        opacity: 0.6;
    }
}

// Avatar color based on primary category (stored in installed-size field for flatpak)
component AppAvatar inherits Rectangle {
    in property <string> initial;
    in property <string> category;
    width: 56px;
    height: 56px;
    border-radius: 14px;
    background: category == "AudioVideo" ? Cat.pink.with-alpha(0.18) :
                category == "Development" ? Cat.blue.with-alpha(0.18) :
                category == "Game" ? Cat.green.with-alpha(0.18) :
                category == "Graphics" ? Cat.peach.with-alpha(0.18) :
                category == "Network" ? Cat.teal.with-alpha(0.18) :
                category == "Office" ? Cat.sapphire.with-alpha(0.18) :
                category == "Science" ? Cat.sky.with-alpha(0.18) :
                category == "System" ? Cat.overlay1.with-alpha(0.18) :
                category == "Utility" ? Cat.yellow.with-alpha(0.18) :
                Cat.mauve.with-alpha(0.18);
    Text {
        text: initial;
        font-size: 22px;
        font-weight: 800;
        color: category == "AudioVideo" ? Cat.pink :
               category == "Development" ? Cat.blue :
               category == "Game" ? Cat.green :
               category == "Graphics" ? Cat.peach :
               category == "Network" ? Cat.teal :
               category == "Office" ? Cat.sapphire :
               category == "Science" ? Cat.sky :
               category == "System" ? Cat.overlay2 :
               category == "Utility" ? Cat.yellow :
               Cat.mauve;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

component CategoryPill inherits Rectangle {
    in property <string> label;
    in property <bool> active: false;
    callback clicked();

    height: 28px;
    width: pill-lbl.preferred-width + 20px;
    border-radius: 14px;
    background: active ? Cat.mauve : (pill-t.has-hover ? Cat.surface1 : Cat.surface0.with-alpha(0.6));
    animate background { duration: 80ms; }

    pill-lbl := Text {
        text: label;
        font-size: 12px;
        font-weight: active ? 700 : 400;
        color: active ? Cat.crust : Cat.subtext0;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    pill-t := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

component RepoRow inherits Rectangle {
    in property <PackageData> pkg;
    callback install();
    callback remove();
    callback show-tree();

    height: 46px;
    background: row-touch.has-hover ? Cat.surface0.with-alpha(0.3) : transparent;
    animate background { duration: 60ms; }

    // TouchArea first so action buttons sit on top
    row-touch := TouchArea {}

    HorizontalLayout {
        padding-left: 14px; padding-right: 12px;

        // Name + description
        VerticalLayout {
            horizontal-stretch: 1; alignment: center; spacing: 2px;
            Text { text: pkg.display-name; font-size: 13px; font-weight: 500; color: Cat.text; overflow: elide; }
            if pkg.description != "": Text { text: pkg.description; font-size: 10px; color: Cat.overlay0; overflow: elide; }
        }

        // Version — 120px
        Rectangle {
            width: 120px;
            Text { text: pkg.version; font-size: 11px; color: Cat.mauve.with-alpha(0.75); overflow: elide; vertical-alignment: center; horizontal-alignment: right; }
        }

        // Repo badge — 80px
        Rectangle {
            width: 80px;
            Rectangle {
                width: rep-t.preferred-width + 10px; height: 18px; border-radius: 4px; background: Cat.surface0;
                x: parent.width - self.width; y: (parent.height - self.height) / 2;
                rep-t := Text { text: pkg.repository; font-size: 9.5px; color: Cat.overlay1; horizontal-alignment: center; vertical-alignment: center; }
            }
        }

        // Action buttons — 160px (Tree + Install/Remove side by side)
        VerticalLayout {
            alignment: center; width: 160px;
            HorizontalLayout {
                spacing: 6px;
                // Tree button
                Rectangle {
                    width: 52px; height: 26px; border-radius: 6px;
                    background: rr-tree-ta.has-hover ? Cat.teal.with-alpha(0.25) : Cat.teal.with-alpha(0.12);
                    border-width: 1px; border-color: Cat.teal.with-alpha(0.35);
                    animate background { duration: 60ms; }
                    VerticalLayout { alignment: center; Text { text: "Tree"; font-size: 11px; font-weight: 600; color: Cat.teal; horizontal-alignment: center; } }
                    rr-tree-ta := TouchArea { mouse-cursor: pointer; clicked => { root.show-tree(); } }
                }
                // Install / Remove button
                if !pkg.installed: Rectangle {
                    width: 78px; height: 26px; border-radius: 6px;
                    background: rr-inst-ta.has-hover ? Cat.mauve : Cat.mauve.with-alpha(0.75);
                    animate background { duration: 60ms; }
                    VerticalLayout { alignment: center; Text { text: "Install"; font-size: 11px; font-weight: 600; color: #fff; horizontal-alignment: center; } }
                    rr-inst-ta := TouchArea { mouse-cursor: pointer; clicked => { root.install(); } }
                }
                if pkg.installed: Rectangle {
                    width: 78px; height: 26px; border-radius: 6px;
                    background: rr-rm-ta.has-hover ? Cat.red : Cat.red.with-alpha(0.75);
                    animate background { duration: 60ms; }
                    VerticalLayout { alignment: center; Text { text: "Remove"; font-size: 11px; font-weight: 600; color: #fff; horizontal-alignment: center; } }
                    rr-rm-ta := TouchArea { mouse-cursor: pointer; clicked => { root.remove(); } }
                }
            }
        }
    }

    Rectangle { y: parent.height - 1px; height: 1px; width: parent.width - 20px; x: 10px; background: Cat.surface0.with-alpha(0.5); }
}

component SettingsRow inherits Rectangle {
    in property <string> label;
    in property <string> subtitle: "";
    in property <bool> checked: false;
    callback toggled(bool);

    height: subtitle != "" ? 54px : 42px;
    border-radius: 8px;
    background: Cat.surface0.with-alpha(0.4);

    HorizontalLayout {
        padding-left: 16px;
        padding-right: 16px;

        VerticalLayout {
            alignment: center;
            horizontal-stretch: 1;
            spacing: 2px;

            Text {
                text: label;
                font-size: 13px;
                color: Cat.text;
            }

            if subtitle != "": Text {
                text: subtitle;
                font-size: 11px;
                color: Cat.overlay0;
            }
        }

        VerticalLayout {
            alignment: center;
            CheckBox {
                checked: root.checked;
                toggled(val) => { root.toggled(val); }
            }
        }
    }
}

component ActionCard inherits Rectangle {
    in property <string> title;
    in property <string> subtitle;
    in property <string> icon-path: "";
    in property <bool> enabled: true;
    callback clicked;

    height: 48px;
    border-radius: 8px;
    background: enabled ? (card-touch.has-hover ? Cat.surface0.with-alpha(0.7) : Cat.surface0.with-alpha(0.4)) : Cat.surface0.with-alpha(0.2);
    animate background { duration: 100ms; }

    card-touch := TouchArea {
        mouse-cursor: enabled ? pointer : default;
        clicked => { if enabled { root.clicked(); } }
    }

    HorizontalLayout {
        padding-left: 16px;
        padding-right: 16px;
        spacing: 12px;

        if icon-path != "": VerticalLayout {
            alignment: center;
            NavIcon {
                d: icon-path;
                icon-color: enabled ? Cat.subtext0 : Cat.overlay0;
            }
        }

        VerticalLayout {
            alignment: center;
            spacing: 1px;
            horizontal-stretch: 1;

            Text {
                text: title;
                font-size: 13px;
                font-weight: 500;
                color: Cat.text;
                opacity: enabled ? 1.0 : 0.4;
            }

            if subtitle != "": Text {
                text: subtitle;
                font-size: 11px;
                color: Cat.overlay0;
            }
        }

        VerticalLayout {
            alignment: center;
            NavIcon {
                d: "M9 18l6-6-6-6";
                icon-color: Cat.overlay0;
                width: 14px;
                height: 14px;
            }
        }
    }
}


component SectionLabel inherits Text {
    in property <string> section-title;
    text: section-title;
    font-size: 11px;
    font-weight: 700;
    color: Cat.overlay0;
    letter-spacing: 0.8px;
}

component Paginator inherits Rectangle {
    in property <int> current-page;
    in property <int> total-pages;
    callback go-to-page(int);

    height: 40px;

    HorizontalLayout {
        alignment: center;
        spacing: 8px;

        Rectangle {
            width: 32px;
            height: 28px;
            border-radius: 6px;
            background: current-page > 0 ? (prev-touch.has-hover ? Cat.surface1 : Cat.surface0) : Cat.surface0.with-alpha(0.3);

            VerticalLayout {
                alignment: center;
                HorizontalLayout {
                    alignment: center;
                    NavIcon {
                        d: "M15 18l-6-6 6-6";
                        icon-color: current-page > 0 ? Cat.text : Cat.overlay0;
                        width: 14px;
                        height: 14px;
                    }
                }
            }

            prev-touch := TouchArea {
                mouse-cursor: current-page > 0 ? pointer : default;
                clicked => { if current-page > 0 { root.go-to-page(current-page - 1); } }
            }
        }

        Text {
            text: (current-page + 1) + " / " + total-pages;
            font-size: 12px;
            font-weight: 500;
            color: Cat.subtext0;
            vertical-alignment: center;
            min-width: 60px;
            horizontal-alignment: center;
        }

        Rectangle {
            width: 32px;
            height: 28px;
            border-radius: 6px;
            background: current-page < total-pages - 1 ? (next-touch.has-hover ? Cat.surface1 : Cat.surface0) : Cat.surface0.with-alpha(0.3);

            VerticalLayout {
                alignment: center;
                HorizontalLayout {
                    alignment: center;
                    NavIcon {
                        d: "M9 18l6-6-6-6";
                        icon-color: current-page < total-pages - 1 ? Cat.text : Cat.overlay0;
                        width: 14px;
                        height: 14px;
                    }
                }
            }

            next-touch := TouchArea {
                mouse-cursor: current-page < total-pages - 1 ? pointer : default;
                clicked => { if current-page < total-pages - 1 { root.go-to-page(current-page + 1); } }
            }
        }
    }
}

component DetailProperty inherits HorizontalLayout {
    in property <string> prop-label;
    in property <string> prop-value;
    spacing: 8px;

    Text {
        text: prop-label;
        width: 80px;
        font-size: 11.5px;
        color: Cat.overlay0;
        vertical-alignment: top;
    }

    Text {
        text: prop-value;
        font-size: 11.5px;
        color: Cat.text;
        wrap: word-wrap;
        horizontal-stretch: 1;
    }
}

export component MainWindow inherits Window {
    title: "xPackage Manager";
    preferred-width: 1100px;
    preferred-height: 720px;
    min-width: 850px;
    min-height: 550px;
    background: Palette.background;

    in-out property <int> view: 9;
    in-out property <[PackageData]> installed-packages: [];
    in-out property <[PackageData]> update-packages: [];
    in-out property <[PackageData]> flatpak-packages: [];
    in-out property <int> selected-index: -1;
    in-out property <bool> loading: false;
    in-out property <bool> busy: false;
    in-out property <string> status-message: "Ready";
    in-out property <int> progress: 0;
    in-out property <StatsData> stats;
    in-out property <[ActivityItem]> activity-items: [];
    in-out property <SysInfo> sys-info;
    in-out property <string> search-text: "";
    in-out property <string> installed-filter-text: "";
    in-out property <PackageData> local-package;
    in-out property <string> local-package-path: "";
    in-out property <bool> show-local-install: false;
    in-out property <string> progress-text: "";
    in-out property <bool> show-terminal: false;
    in-out property <string> terminal-title: "";
    in-out property <string> terminal-output: "";
    in-out property <bool> terminal-done: false;
    in-out property <bool> terminal-success: false;
    in-out property <bool> setting-aur-enabled: false;
    in-out property <bool> setting-flatpak-enabled: true;
    in-out property <bool> setting-check-updates-on-start: false;
    in-out property <int> setting-notify-interval: 30;
    in-out property <int> setting-parallel-downloads: 5;
    in-out property <int> setting-clean-keep-versions: 3;

    in-out property <int> selected-count: 0;
    in-out property <int> selected-installed-count: 0;
    in-out property <int> selected-uninstalled-count: 0;
    in-out property <bool> multi-select-mode: true;

    // Flatpak remove confirmation dialog
    in-out property <bool> fp-confirm-open: false;
    in-out property <string> fp-confirm-id: "";
    in-out property <string> fp-confirm-name: "";
    callback remove-flatpak(string, bool);  // (app_id, also_delete_data)

    in-out property <bool> show-conflict-dialog: false;
    in-out property <string> conflict-summary: "";
    in-out property <bool> conflict-can-force: false;

    in-out property <bool> show-progress-popup: false;
    in-out property <string> progress-popup-title: "";
    in-out property <int> progress-popup-percent: 0;
    in-out property <string> progress-popup-stage: "";
    in-out property <bool> progress-popup-done: false;
    in-out property <bool> progress-popup-success: false;
    in-out property <string> progress-popup-output: "";
    in-out property <bool> progress-popup-show-input: false;
    in-out property <string> progress-popup-prompt: "";
    in-out property <bool> show-progress-logs: false;

    in-out property <int> current-page: 0;
    in-out property <int> total-pages: 1;
    in-out property <[PackageData]> search-installed: [];
    in-out property <[PackageData]> search-available: [];

    // Flatpak browser (view 10) — Shelly-ALPM style
    in-out property <[string]> flatpak-remotes: [];
    in-out property <string> selected-remote: "";
    in-out property <[PackageData]> remote-apps: [];
    in-out property <bool> remote-apps-loading: false;
    in-out property <bool> flatpak-store-ready: false;
    in-out property <int> flatpak-total-matches: 0;
    in-out property <bool> flatpak-loading-more: false;
    callback load-more-flatpaks;
    in-out property <[string]> flatpak-categories: ["All", "AudioVideo", "Development", "Education", "Game", "Graphics", "Network", "Office", "Science", "System", "Utility"];
    in-out property <string> selected-flatpak-category: "All";
    in-out property <string> flatpak-search: "";
    // Detail panel
    in-out property <bool> show-flatpak-detail: false;
    in-out property <string> flatpak-detail-name: "";
    in-out property <string> flatpak-detail-summary: "";
    in-out property <string> flatpak-detail-description: "";
    in-out property <string> flatpak-detail-developer: "";
    in-out property <string> flatpak-detail-version: "";
    in-out property <string> flatpak-detail-version-date: "";
    in-out property <string> flatpak-detail-changelog: "";
    in-out property <string> flatpak-detail-url-homepage: "";
    in-out property <string> flatpak-detail-url-bug: "";
    in-out property <string> flatpak-detail-url-translate: "";
    in-out property <string> flatpak-detail-url-vcs: "";
    in-out property <[string]> flatpak-detail-tags: [];
    in-out property <bool> flatpak-detail-installed: false;
    in-out property <string> current-flatpak-id: "";
    in-out property <image> flatpak-screenshot;
    in-out property <image> flatpak-detail-icon;
    // Add-Ons modal — split into two clean arrays so sections are trivial
    in-out property <[PackageData]> flatpak-addons: [];           // NOT installed
    in-out property <[PackageData]> flatpak-addons-installed: []; // already installed
    in-out property <[AppRow]> flatpak-app-rows: [];
    in-out property <bool> show-addons-modal: false;
    in-out property <int> flatpak-addons-installed-count: 0;      // = flatpak-addons-installed.length
    in-out property <int> flatpak-update-count: 0;
    // Derived: native (pacman) update count = total updates minus flatpak updates
    property <int> native-update-count: update-packages.length - flatpak-update-count;
    in-out property <[bool]> addon-selected: [];   // parallel bool, one per flatpak-addons entry
    in-out property <int> addon-selected-count: 0;
    callback batch-flatpak-install;
    callback batch-flatpak-remove;
    callback install-selected-addons;
    callback remove-addon(string);         // uninstall a single installed add-on by id
    callback toggle-addon-selected(int);
    callback addon-select-all(bool);
    callback toggle-flatpak-selected(string, bool);
    in-out property <int> flatpak-tab: 0; // 0=browse, 1=installed
    in-out property <[PackageData]> installed-flatpaks: [];
    callback load-installed-flatpaks;
    in-out property <[PackageData]> installed-grouped: [];
    callback load-installed-grouped;
    in-out property <int> repos-view: 0; // 0=browse, 1=installed
    callback downgrade-package(string);

    // Dependency tree (view 12)
    in-out property <string> dep-tree-pkg: "";
    in-out property <string> dep-tree-root-version: "";
    in-out property <[DepNode]> dep-tree-nodes: [];
    in-out property <[DepNode]> dep-reqby-nodes: [];
    in-out property <bool> dep-tree-loading: false;
    in-out property <int> dep-tree-tab: 0;
    callback load-dep-tree(string);

    // Repos browser (view 7/8)
    in-out property <[string]> pacman-repos: [];
    in-out property <string> selected-repo: "";
    in-out property <[PackageData]> repo-packages: [];
    in-out property <bool> repo-loading: false;
    in-out property <bool> repo-has-more: false;
    in-out property <int> repo-extra-count: 0;
    in-out property <bool> show-repo-detail: false;
    in-out property <PackageData> repo-detail-pkg;
    in-out property <string> repo-detail-description: "";
    in-out property <bool> repo-detail-loading: false;
    in-out property <string> repo-search: "";

    callback refresh;
    callback search(string);
    callback install-package(string, int);
    callback remove-package(string, int);
    callback update-package(string, int);
    callback update-all;
    callback update-all-flatpaks;
    callback sync-databases;
    callback open-url(string);
    callback install-local-package(string);
    callback cancel-local-install;
    callback load-flatpak-detail(string);
    callback load-flatpak-icon(string);
    callback browse-remote(string);
    callback filter-flatpak(string, string);
    callback filter-installed(string);
    callback filter-repo(string);
    callback load-pacman-repos;
    callback browse-repo(string);
    callback load-more-repo-pkgs;
    callback select-repo-pkg(string, int);
    callback terminal-send-input(string);
    callback terminal-close;
    callback update-mirrorlists;
    callback fix-keyring;
    callback rebuild-initramfs;
    callback rebuild-grub;

    callback toggle-package-selected(string, int, bool);
    callback bulk-install;
    callback bulk-remove;
    callback clear-selection;

    callback request-install(string, int);
    callback request-remove(string, int);
    callback request-update(string, int);
    callback close-progress-popup;
    callback cancel-operation;
    callback progress-popup-send-input(string);
    callback conflict-force-overwrite;
    callback conflict-cancel;

    callback clean-package-cache;
    callback remove-orphans;
    callback export-package-list;
    callback import-package-list;
    callback load-page(int);
    callback apply-theme(string);
    callback save-settings();

    property <string> icon-home: "M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z M9 22V12h6v10";
    property <string> icon-grid: "M3 3h7v7H3zM14 3h7v7h-7zM3 14h7v7H3zM14 14h7v7h-7z";
    property <string> icon-list: "M3 5h18v2H3zM3 11h18v2H3zM3 17h18v2H3z";
    property <string> icon-search: "M5 11a6 6 0 0 1 12 0a6 6 0 0 1-12 0z M15.5 15.5L20 20";
    property <string> icon-package: "M12 2L3 7v10l9 5 9-5V7zM3 7l9 5 9-5M12 12v10";
    property <string> icon-chip: "M7 4h10v16H7zM4 8h3M4 12h3M4 16h3M17 8h3M17 12h3M17 16h3";
    property <string> icon-gear: "M8 12a4 4 0 0 1 8 0a4 4 0 0 1-8 0zM12 2v4M12 18v4M2 12h4M18 12h4M5.6 5.6l2.8 2.8M15.6 15.6l2.8 2.8M5.6 18.4l2.8-2.8M15.6 8.4l2.8-2.8";
    property <string> icon-arrow-up: "M12 19V5M5 12l7-7 7 7";
    property <string> icon-folder: "M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z";
    property <string> icon-close: "M18 6L6 18M6 6l12 12";
    property <string> icon-link: "M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14L21 3";
    property <string> icon-music: "M9 18V5l12-2v13M9 18a3 3 0 1 1-6 0 3 3 0 0 1 6 0zM21 16a3 3 0 1 1-6 0 3 3 0 0 1 6 0z";
    property <string> icon-code: "M16 18l6-6-6-6M8 6l-6 6 6 6";
    property <string> icon-gamepad: "M6 11h4M8 9v4M15 12h0.01M18 10h0.01M17.32 5H6.68a4 4 0 0 0-3.978 3.59c-.006.052-.01.101-.017.152C2.604 9.416 2 14.456 2 16a3 3 0 0 0 3 3c1 0 1.5-.5 2-1l1.414-1.414A2 2 0 0 1 9.828 16h4.344a2 2 0 0 1 1.414.586L17 18c.5.5 1 1 2 1a3 3 0 0 0 3-3c0-1.545-.604-6.584-.685-7.258-.007-.05-.011-.1-.017-.151A4 4 0 0 0 17.32 5z";
    property <string> icon-image: "M21 19V5a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2zM8.5 10a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zM21 15l-5-5L5 21";
    property <string> icon-globe: "M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20zM2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z";
    property <string> icon-file: "M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7z";
    property <string> icon-graduation: "M22 10v6M2 10l10-5 10 5-10 5z M6 12v5c3 3 9 3 12 0v-5";
    property <string> icon-flask: "M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.13A1 1 0 0 0 5.596 22h12.808a1 1 0 0 0 .876-1.87l-5.07-9.707A2 2 0 0 1 14 9.527V2M8.5 2h7";
    property <string> icon-cpu: "M4 4h16v16H4zM9 9h6v6H9zM9 1v3M15 1v3M9 20v3M15 20v3M20 9h3M20 14h3M1 9h3M1 14h3";
    property <string> icon-wrench: "M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94z";
    property <string> icon-refresh: "M1 4v6h6M23 20v-6h-6M20.49 9A9 9 0 0 0 5.64 5.64L1 10M23 14l-4.64 4.36A9 9 0 0 1 3.51 15";

    property <string> icon-flatpak: "M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5";

    // Drives the indeterminate shimmer on the loading chip (sweeps -40% → 105%)
    property <float> _load-shimmer: -0.4;
    Timer {
        interval: 40ms;
        running: loading || (busy && progress == 0);
        triggered => {
            _load-shimmer = _load-shimmer >= 1.05 ? -0.4 : _load-shimmer + 0.038;
        }
    }

    // Forces ScrollView viewport-y bindings to re-evaluate while output is live.
    // Without this, Slint may not re-evaluate the binding when text grows.
    property <int> _scroll-tick: 0;
    Timer {
        interval: 80ms;
        running: show-terminal || show-progress-popup;
        triggered => { _scroll-tick = _scroll-tick + 1; }
    }

    function get-list() -> [PackageData] {
        if view == 0 { return installed-packages; }
        if view == 1 { return update-packages; }
        if view == 10 { return remote-apps; }
        if view == 8 { return repo-packages; }
        return [];
    }

    Rectangle {
        x: 0;
        y: 0;
        width: 200px;
        height: parent.height;
        background: Cat.mantle;

        VerticalLayout {
            padding: 12px;
            spacing: 2px;

            HorizontalLayout {
                padding-left: 4px;
                padding-bottom: 4px;
                spacing: 8px;

                VerticalLayout {
                    alignment: center;
                    NavIcon {
                        d: icon-package;
                        icon-color: Cat.mauve;
                        width: 20px;
                        height: 20px;
                    }
                }

                Text {
                    text: "xPM";
                    font-size: 17px;
                    font-weight: 700;
                    color: Cat.text;
                    vertical-alignment: center;
                }
            }

            Rectangle { height: 10px; }

            Input {
                text <=> search-text;
                placeholder: "Search packages...";
                accepted(t) => {
                    if search-text != "" {
                        view = 2;
                        root.search(search-text);
                    }
                }
            }

            Rectangle { height: 12px; }
            SectionLabel { section-title: "LIBRARY"; }
            Rectangle { height: 4px; }

            NavButton {
                icon-path: icon-home;
                label: "Home";
                active: view == 9;
                clicked => { view = 9; }
            }

            if setting-flatpak-enabled: NavButton {
                icon-path: icon-flatpak;
                label: "Flatpaks";
                active: view == 10;
                clicked => {
                    view = 10; selected-index = -1; show-flatpak-detail = false;
                    if flatpak-remotes.length == 0 { root.browse-remote(""); }
                }
            }

            NavButton {
                icon-path: icon-folder;
                label: "Browse Repos";
                active: view == 7 || view == 8;
                clicked => {
                    view = 7; repos-view = 0; selected-index = -1;
                    if pacman-repos.length == 0 { root.load-pacman-repos(); }
                    if repo-packages.length == 0 && !repo-loading { root.browse-repo(""); }
                }
            }

            NavButton {
                icon-path: icon-search;
                label: "Search Results";
                active: view == 2;
                clicked => { view = 2; selected-index = -1; }
            }

            Rectangle { height: 6px; }
            Rectangle { height: 1px; background: Cat.surface0; }
            Rectangle { height: 6px; }

            NavButton {
                icon-path: icon-wrench;
                label: "Troubleshooting";
                active: view == 11;
                clicked => { view = 11; }
            }

            NavButton {
                icon-path: icon-gear;
                label: "App Settings";
                active: view == 5;
                clicked => { view = 5; }
            }

            Rectangle { vertical-stretch: 1; }

            if stats.update-count > 0: NavButton {
                icon-path: icon-arrow-up;
                label: "Updates";
                badge: stats.update-count;
                active: view == 1;
                clicked => { view = 1; selected-index = -1; }
            }

            Rectangle {
                height: 34px;
                border-radius: 8px;
                background: sync-touch.has-hover ? Cat.mauve : Cat.mauve.with-alpha(0.85);
                opacity: busy ? 0.5 : 1.0;
                animate background { duration: 100ms; }

                Text {
                    text: "Sync & Update";
                    font-size: 12px;
                    font-weight: 600;
                    color: Cat.crust;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                sync-touch := TouchArea {
                    mouse-cursor: busy ? default : pointer;
                    clicked => { if !busy { root.sync-databases(); } }
                }
            }

            Rectangle { height: 8px; }

            HorizontalLayout {
                padding-left: 4px;
                spacing: 4px;

                Text {
                    text: stats.pacman-count + " pacman";
                    font-size: 10px;
                    color: Cat.overlay0;
                }
                Text {
                    text: "/";
                    font-size: 10px;
                    color: Cat.surface2;
                }
                Text {
                    text: stats.flatpak-count + " flatpak";
                    font-size: 10px;
                    color: Cat.overlay0;
                }
            }
        }
    }

    Rectangle {
        x: 200px;
        y: 0;
        width: 1px;
        height: parent.height;
        background: Cat.surface0;
    }

    Rectangle {
        x: 201px;
        y: 0;
        width: parent.width - 201px;
        height: parent.height;
        clip: true;

        VerticalLayout {
            padding: 24px;
            padding-top: 20px;
            spacing: 12px;

            HorizontalLayout {
                spacing: 12px;

                Text {
                    text: view == 9 ? "Home" :
                          view == 0 ? "Installed" :
                          view == 1 ? "Updates" :
                          view == 2 ? "Search Results" :
                          view == 5 ? "Settings" :
                          view == 7 ? "Browse Repos" :
                          view == 8 ? selected-repo :
                          view == 10 ? (show-flatpak-detail ? flatpak-detail-name : "Flatpaks") : "Packages";
                    font-size: 20px;
                    font-weight: 700;
                    color: Cat.text;
                }

                Rectangle { horizontal-stretch: 1; }

                if (view == 0 || view == 1 || view == 8) || (view == 10 && !show-flatpak-detail): Text {
                    text: get-list().length + " packages";
                    font-size: 12px;
                    color: Cat.overlay0;
                    vertical-alignment: center;
                }

                if view == 1 && flatpak-update-count > 0: Btn {
                    label: "Update All (" + flatpak-update-count + ")";
                    primary: false;
                    enabled: !busy;
                    clicked => { root.update-all-flatpaks(); }
                }

                if view == 1 && update-packages.length > flatpak-update-count: Btn {
                    label: "Update All";
                    primary: true;
                    enabled: !busy;
                    clicked => { root.update-all(); }
                }

                // Flatpaks view — update flatpaks button
                if view == 10 && flatpak-update-count > 0: Btn {
                    label: "Update Flatpaks (" + flatpak-update-count + ")";
                    primary: true;
                    enabled: !busy;
                    clicked => { root.update-all-flatpaks(); }
                }

                // Browse Repos view — update native packages button
                if (view == 7 || view == 8) && native-update-count > 0: Btn {
                    label: "Update All (" + native-update-count + ")";
                    primary: true;
                    enabled: !busy;
                    clicked => { root.update-all(); }
                }

                if view == 0: Btn {
                    label: "Refresh";
                    clicked => { root.refresh(); }
                }
            }

            Rectangle { height: 1px; background: Cat.surface0; opacity: 0.6; }

            // ── Pinned search bar for Native Packages (view 0) ──────────────
            if view == 0: Rectangle {
                height: 48px;

                TouchArea { clicked => { inst-ti.focus(); } }

                Rectangle {
                    x: 0;
                    y: 8px;
                    width: parent.width;
                    height: 32px;
                    border-radius: 16px;
                    background: Cat.surface0;
                    border-width: inst-ti.has-focus ? 1px : 0px;
                    border-color: Cat.blue.with-alpha(0.4);
                    clip: true;
                    animate border-width { duration: 80ms; }

                    HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 12px;
                        spacing: 8px;

                        VerticalLayout {
                            alignment: center;
                            NavIcon {
                                d: "M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0";
                                icon-color: inst-ti.has-focus ? Cat.blue.with-alpha(0.9) : Cat.overlay1;
                                width: 13px;
                                height: 13px;
                            }
                        }

                        VerticalLayout {
                            alignment: center;
                            horizontal-stretch: 1;

                            if installed-filter-text == "" && !inst-ti.has-focus: Text {
                                height: 32px;
                                text: "Filter installed packages...";
                                font-size: 12px;
                                color: Cat.overlay0;
                                vertical-alignment: center;
                            }

                            inst-ti := TextInput {
                                height: 32px;
                                text <=> installed-filter-text;
                                font-size: 12px;
                                color: Cat.text;
                                single-line: true;
                                vertical-alignment: center;
                                selection-background-color: Cat.blue.with-alpha(0.3);
                                selection-foreground-color: Cat.text;
                                edited => { root.filter-installed(self.text); }
                                accepted => { root.filter-installed(self.text); }
                            }
                        }

                        if installed-filter-text != "": VerticalLayout {
                            alignment: center;
                            Rectangle {
                                width: 18px;
                                height: 18px;
                                border-radius: 9px;
                                background: clr-touch.has-hover ? Cat.surface1 : transparent;
                                NavIcon { d: "M18 6L6 18M6 6l12 12"; icon-color: Cat.overlay1; width: 10px; height: 10px; x: 4px; y: 4px; }
                                clr-touch := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { installed-filter-text = ""; root.filter-installed(""); }
                                }
                            }
                        }
                    }
                }
            }

            // Search results empty state (view 2)
            if !loading && view == 2 && search-installed.length == 0 && search-available.length == 0: VerticalLayout {
                vertical-stretch: 1;
                alignment: center;
                spacing: 8px;

                NavIcon {
                    d: icon-search;
                    icon-color: Cat.surface2;
                    width: 32px;
                    height: 32px;
                    x: (parent.width - 32px) / 2;
                }

                Text {
                    text: "Search for packages";
                    font-size: 14px;
                    color: Cat.overlay0;
                    horizontal-alignment: center;
                }
            }

            // Loading skeleton for view 0 / 1
            if loading && (view == 0 || view == 1): VerticalLayout {
                vertical-stretch: 1;
                spacing: 1px;
                for i in [0, 1, 2, 3, 4, 5, 6, 7]: Rectangle {
                    height: 52px;
                    background: Math.mod(i, 2) == 0 ? Cat.surface0.with-alpha(0.15) : transparent;
                    HorizontalLayout {
                        padding-left: 16px;
                        padding-right: 16px;
                        spacing: 12px;
                        VerticalLayout {
                            alignment: center;
                            Rectangle { width: 120px; height: 12px; border-radius: 4px; background: Cat.surface0.with-alpha(0.5); }
                        }
                        Rectangle { horizontal-stretch: 1; }
                        VerticalLayout {
                            alignment: center;
                            Rectangle { width: 60px; height: 10px; border-radius: 4px; background: Cat.surface0.with-alpha(0.35); }
                        }
                    }
                }
            }

            // Empty state for view 0/1 (not loading, no results)
            if !loading && (view == 0 || view == 1) && get-list().length == 0: VerticalLayout {
                vertical-stretch: 1;
                alignment: center;
                spacing: 8px;

                NavIcon {
                    d: icon-package;
                    icon-color: Cat.surface2;
                    width: 32px;
                    height: 32px;
                    x: (parent.width - 32px) / 2;
                }

                Text {
                    text: "No packages found";
                    font-size: 14px;
                    color: Cat.overlay0;
                    horizontal-alignment: center;
                }
            }

            // Installed packages (view 0) — paginated
            if !loading && view == 0 && installed-packages.length > 0: VerticalLayout {
                vertical-stretch: 1;

                ListView {
                    vertical-stretch: 1;
                    for p[i] in installed-packages: PackageRow {
                        pkg: p;
                        show-separator: i < installed-packages.length - 1;
                        show-checkbox: multi-select-mode;
                        install => { root.request-install(p.name, p.backend); }
                        remove => { root.request-remove(p.name, p.backend); }
                        toggle-selected(val) => { root.toggle-package-selected(p.name, p.backend, val); }
                    }
                }

                if total-pages > 1: Paginator {
                    current-page: root.current-page;
                    total-pages: root.total-pages;
                    go-to-page(p) => { root.current-page = p; root.load-page(p); }
                }
            }

            // Updates (view 1)
            if !loading && view == 1 && update-packages.length > 0: ListView {
                vertical-stretch: 1;
                for p[i] in update-packages: PackageRow {
                    pkg: p;
                    show-separator: i < update-packages.length - 1;
                    show-checkbox: false;
                    show-action-button: true;
                    install => { root.request-update(p.name, p.backend); }
                    remove => { root.request-remove(p.name, p.backend); }
                }
            }

            // Flatpaks (view 10) — flat list with pill search + multi-select + detail
            if view == 10: VerticalLayout {
                vertical-stretch: 1;
                spacing: 0;

                // ── Tab strip: Browse | Installed ─────────────────────────────
                Rectangle {
                    height: 44px;
                    background: transparent;

                    HorizontalLayout {
                        padding-left: 16px;
                        spacing: 0;

                        Rectangle {
                            width: 90px;
                            height: parent.height;
                            Text {
                                text: "Browse";
                                font-size: 13px;
                                font-weight: flatpak-tab == 0 ? 700 : 500;
                                color: flatpak-tab == 0 ? Cat.mauve : Cat.overlay1;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            Rectangle {
                                y: parent.height - 2px;
                                height: 2px;
                                width: parent.width;
                                background: flatpak-tab == 0 ? Cat.mauve : transparent;
                                animate background { duration: 120ms; }
                            }
                            TouchArea {
                                mouse-cursor: pointer;
                                clicked => { flatpak-tab = 0; show-flatpak-detail = false; }
                            }
                        }

                        Rectangle {
                            width: 100px;
                            height: parent.height;
                            Text {
                                text: "Installed";
                                font-size: 13px;
                                font-weight: flatpak-tab == 1 ? 700 : 500;
                                color: flatpak-tab == 1 ? Cat.green : Cat.overlay1;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            Rectangle {
                                y: parent.height - 2px;
                                height: 2px;
                                width: parent.width;
                                background: flatpak-tab == 1 ? Cat.green : transparent;
                                animate background { duration: 120ms; }
                            }
                            TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    flatpak-tab = 1;
                                    show-flatpak-detail = false;
                                    if installed-flatpaks.length == 0 { root.load-installed-flatpaks(); }
                                }
                            }
                        }

                        Rectangle { horizontal-stretch: 1; }
                    }

                    Rectangle {
                        y: parent.height - 1px;
                        height: 1px;
                        width: parent.width;
                        background: Cat.surface0;
                    }
                }

                // ── Browse tab ────────────────────────────────────────────────
                if flatpak-tab == 0: VerticalLayout {
                    vertical-stretch: 1;
                    spacing: 0;

                // ── Pill search bar (same style as Repos) ──────────────────────────
                Rectangle {
                    height: 58px;
                    background: transparent;

                    TouchArea { clicked => { fk-ti.focus(); } }

                    Rectangle {
                        x: 14px;
                        y: 11px;
                        width: parent.width - 28px;
                        height: 36px;
                        border-radius: 18px;
                        background: Cat.surface0;
                        border-width: fk-ti.has-focus ? 1px : 0px;
                        border-color: Cat.mauve.with-alpha(0.4);
                        clip: true;
                        animate border-width { duration: 80ms; }

                        HorizontalLayout {
                            padding-left: 14px;
                            padding-right: 14px;
                            spacing: 10px;

                            VerticalLayout {
                                alignment: center;
                                NavIcon {
                                    d: "M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0";
                                    icon-color: fk-ti.has-focus ? Cat.mauve.with-alpha(0.9) : Cat.overlay1;
                                    width: 14px;
                                    height: 14px;
                                }
                            }

                            VerticalLayout {
                                alignment: center;
                                horizontal-stretch: 1;

                                if flatpak-search == "" && !fk-ti.has-focus: Text {
                                    height: 36px;
                                    text: "Search Flathub apps...";
                                    font-size: 13px;
                                    color: Cat.overlay0;
                                    vertical-alignment: center;
                                }

                                fk-ti := TextInput {
                                    height: 36px;
                                    text <=> flatpak-search;
                                    font-size: 13px;
                                    color: Cat.text;
                                    single-line: true;
                                    vertical-alignment: center;
                                    selection-background-color: Cat.mauve.with-alpha(0.3);
                                    selection-foreground-color: Cat.text;
                                    accepted => {
                                        show-flatpak-detail = false;
                                        root.filter-flatpak(selected-flatpak-category, self.text);
                                    }
                                    edited => {
                                        show-flatpak-detail = false;
                                        root.filter-flatpak(selected-flatpak-category, self.text);
                                    }
                                }
                            }
                        }
                    }
                }

                // ── Category pills — centered ───────────────────────────────────────
                Rectangle {
                    height: 44px;

                    HorizontalLayout {
                        alignment: center;
                        padding-left: 14px;
                        padding-right: 14px;
                        spacing: 6px;

                        for cat[ci] in flatpak-categories: CategoryPill {
                            label: cat;
                            active: selected-flatpak-category == cat;
                            clicked => {
                                selected-flatpak-category = cat;
                                show-flatpak-detail = false;
                                root.filter-flatpak(cat, flatpak-search);
                            }
                        }
                    }
                }

                // ── Loading — geeky terminal card ───────────────────────────────────
                if remote-apps-loading || !flatpak-store-ready: VerticalLayout {
                    vertical-stretch: 1;
                    alignment: center;
                    spacing: 0;

                    // Centre the card
                    HorizontalLayout {
                        alignment: center;

                        Rectangle {
                            width: 320px;
                            border-radius: 10px;
                            background: Cat.crust.with-alpha(0.7);
                            border-width: 1px;
                            border-color: Cat.mauve.with-alpha(0.18);
                            clip: true;

                            VerticalLayout {
                                padding: 20px;
                                spacing: 14px;

                                // Title bar dots
                                HorizontalLayout {
                                    spacing: 6px;
                                    Rectangle { width: 8px; height: 8px; border-radius: 4px; background: Cat.red.with-alpha(0.7); }
                                    Rectangle { width: 8px; height: 8px; border-radius: 4px; background: Cat.yellow.with-alpha(0.7); }
                                    Rectangle { width: 8px; height: 8px; border-radius: 4px; background: Cat.green.with-alpha(0.7); }
                                    Rectangle { horizontal-stretch: 1; }
                                    Text { text: "appstream.xml"; font-size: 9px; color: Cat.overlay0; vertical-alignment: center; }
                                }

                                // Fake terminal lines
                                VerticalLayout {
                                    spacing: 5px;

                                    HorizontalLayout {
                                        spacing: 6px;
                                        Text { text: "$"; font-size: 10px; color: Cat.mauve; vertical-alignment: center; }
                                        Text { text: "flatpak remote-info flathub"; font-size: 10px; color: Cat.text; vertical-alignment: center; }
                                    }
                                    HorizontalLayout {
                                        spacing: 6px;
                                        Text { text: "›"; font-size: 10px; color: Cat.overlay0; vertical-alignment: center; }
                                        Text { text: "Parsing appstream metadata..."; font-size: 10px; color: Cat.subtext0; vertical-alignment: center; }
                                    }
                                    HorizontalLayout {
                                        spacing: 6px;
                                        Text { text: "›"; font-size: 10px; color: Cat.overlay0; vertical-alignment: center; }
                                        Text { text: "Indexing application catalogue"; font-size: 10px; color: Cat.subtext0; vertical-alignment: center; }
                                    }
                                }

                                // Progress bar + spinner row
                                HorizontalLayout {
                                    spacing: 10px;

                                    Rectangle {
                                        horizontal-stretch: 1;
                                        height: 3px;
                                        border-radius: 2px;
                                        background: Cat.surface1;
                                        y: 8px;

                                        Rectangle {
                                            height: 3px;
                                            border-radius: 2px;
                                            background: @linear-gradient(90deg, Cat.mauve 0%, Cat.blue 100%);
                                            width: 60px;
                                            animate width { duration: 900ms; easing: ease-in-out; }
                                        }
                                    }

                                    Spinner { indeterminate: true; width: 14px; height: 14px; }
                                }

                                // Status line
                                Text {
                                    text: remote-apps-loading ? "Fetching from remote..." : "Building index...";
                                    font-size: 9.5px;
                                    color: Cat.overlay0;
                                    horizontal-alignment: center;
                                }
                            }
                        }
                    }
                }

                // ── Detail view ──────────────────────────────────────────────────────
                if !remote-apps-loading && show-flatpak-detail: ScrollView {
                    vertical-stretch: 1;

                    VerticalLayout {
                        padding: 0;
                        spacing: 0;

                        // Screenshot banner
                        if flatpak-screenshot.width > 0: Rectangle {
                            height: 300px;
                            clip: true;
                            background: Cat.surface0.with-alpha(0.3);

                            Image {
                                source: flatpak-screenshot;
                                width: parent.width;
                                height: parent.height;
                                image-fit: cover;
                            }

                            Rectangle {
                                y: parent.height - 100px;
                                height: 100px;
                                width: parent.width;
                                background: @linear-gradient(180deg, transparent 0%, Cat.base 100%);
                            }
                        }

                        VerticalLayout {
                            padding: 24px;
                            spacing: 22px;

                            // Back row
                            HorizontalLayout {
                                spacing: 8px;
                                Rectangle {
                                    width: bk-lbl.preferred-width + 28px;
                                    height: 34px;
                                    border-radius: 8px;
                                    background: bk-touch.has-hover ? Cat.surface1 : Cat.surface0.with-alpha(0.7);
                                    border-width: 1px;
                                    border-color: Cat.surface0;
                                    animate background { duration: 80ms; }
                                    VerticalLayout {
                                        alignment: center;
                                        HorizontalLayout {
                                            alignment: center; spacing: 6px;
                                            NavIcon { d: "M19 12H5M12 19l-7-7 7-7"; icon-color: Cat.subtext0; width: 13px; height: 13px; }
                                            bk-lbl := Text { text: "All Apps"; font-size: 12px; color: Cat.subtext0; }
                                        }
                                    }
                                    bk-touch := TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => {
                                            show-flatpak-detail = false;
                                            flatpak-screenshot = @image-url("");
                                            flatpak-detail-icon = @image-url("");
                                        }
                                    }
                                }
                                Rectangle { horizontal-stretch: 1; }
                                Rectangle {
                                    width: rem-d-lbl.preferred-width + 14px;
                                    height: 34px;
                                    border-radius: 8px;
                                    background: Cat.surface0.with-alpha(0.5);
                                    rem-d-lbl := Text {
                                        text: selected-remote;
                                        font-size: 11px;
                                        color: Cat.overlay1;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }

                            // App header: icon + name + buttons
                            HorizontalLayout {
                                spacing: 18px;

                                // Icon
                                VerticalLayout {
                                    alignment: center;
                                    Rectangle {
                                        width: 80px;
                                        height: 80px;
                                        border-radius: 20px;
                                        clip: true;
                                        background: Cat.surface0;

                                        if flatpak-detail-icon.width > 0: Image {
                                            source: flatpak-detail-icon;
                                            width: parent.width;
                                            height: parent.height;
                                            image-fit: contain;
                                        }
                                        if flatpak-detail-icon.width == 0: NavIcon {
                                            d: "M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4";
                                            icon-color: Cat.mauve.with-alpha(0.6);
                                            width: 38px;
                                            height: 38px;
                                            x: 21px;
                                            y: 21px;
                                        }
                                    }
                                }

                                // Name + app_id + developer
                                VerticalLayout {
                                    horizontal-stretch: 1;
                                    spacing: 6px;
                                    alignment: center;

                                    Text {
                                        text: flatpak-detail-name;
                                        font-size: 24px;
                                        font-weight: 800;
                                        color: Cat.text;
                                        wrap: word-wrap;
                                    }

                                    HorizontalLayout {
                                        spacing: 8px;
                                        alignment: start;
                                        Text {
                                            text: current-flatpak-id;
                                            font-size: 11px;
                                            color: Cat.overlay0;
                                            vertical-alignment: center;
                                        }
                                        if flatpak-detail-developer != "": Text {
                                            text: "·  " + flatpak-detail-developer;
                                            font-size: 11px;
                                            color: Cat.subtext0;
                                            vertical-alignment: center;
                                        }
                                    }
                                }

                                // Install/Remove + Add-Ons buttons
                                VerticalLayout {
                                    alignment: center;
                                    spacing: 8px;

                                    // Install / Remove button
                                    if !flatpak-detail-installed: Rectangle {
                                        width: 120px;
                                        height: 38px;
                                        border-radius: 10px;
                                        background: inst-touch.has-hover ? Cat.mauve : Cat.mauve.with-alpha(0.88);
                                        animate background { duration: 80ms; }
                                        Text { text: "Install"; font-size: 14px; font-weight: 700; color: #ffffff; horizontal-alignment: center; vertical-alignment: center; }
                                        inst-touch := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => {
                                                flatpak-detail-installed = true;
                                                root.request-install(current-flatpak-id, 1);
                                            }
                                        }
                                    }
                                    if flatpak-detail-installed: Rectangle {
                                        width: 120px;
                                        height: 38px;
                                        border-radius: 10px;
                                        background: rm-touch.has-hover ? Cat.red : Cat.red.with-alpha(0.85);
                                        animate background { duration: 80ms; }
                                        Text { text: "Remove"; font-size: 14px; font-weight: 700; color: #ffffff; horizontal-alignment: center; vertical-alignment: center; }
                                        rm-touch := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => {
                                                flatpak-detail-installed = false;
                                                root.request-remove(current-flatpak-id, 1);
                                            }
                                        }
                                    }

                                    // Add-Ons button — shown if any addons exist (installed or not)
                                    if flatpak-addons.length > 0 || flatpak-addons-installed.length > 0: Rectangle {
                                        width: 120px;
                                        height: 34px;
                                        border-radius: 10px;
                                        // all-installed = nothing left to install
                                        property <bool> all-installed: flatpak-addons.length == 0;
                                        property <bool> some-installed: flatpak-addons-installed.length > 0 && flatpak-addons.length > 0;
                                        background: all-installed
                                            ? Cat.green.with-alpha(0.15)
                                            : some-installed
                                                ? Cat.peach.with-alpha(0.15)
                                                : Cat.surface0.with-alpha(0.6);
                                        border-width: 1px;
                                        border-color: all-installed
                                            ? Cat.green.with-alpha(0.3)
                                            : some-installed
                                                ? Cat.peach.with-alpha(0.3)
                                                : Cat.surface1;
                                        animate background { duration: 80ms; }

                                        HorizontalLayout {
                                            alignment: center;
                                            spacing: 6px;

                                            VerticalLayout {
                                                alignment: center;
                                                Rectangle {
                                                    width: 7px; height: 7px; border-radius: 3.5px;
                                                    background: all-installed ? Cat.green
                                                        : some-installed ? Cat.peach : Cat.overlay0;
                                                }
                                            }

                                            Text {
                                                text: "Add-Ons";
                                                font-size: 12px; font-weight: 600;
                                                color: all-installed ? Cat.green
                                                    : some-installed ? Cat.peach : Cat.subtext0;
                                                vertical-alignment: center;
                                            }
                                        }

                                        addon-btn-touch := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => { root.show-addons-modal = true; }
                                        }
                                    }
                                }
                            }

                            // Summary tagline
                            if flatpak-detail-summary != "": Text {
                                text: flatpak-detail-summary;
                                font-size: 15px;
                                color: Cat.subtext0;
                                wrap: word-wrap;
                            }

                            Rectangle { height: 1px; background: Cat.surface0; opacity: 0.6; }

                            // Description
                            Text {
                                text: flatpak-detail-description != "" ? flatpak-detail-description : "No description available.";
                                font-size: 13px;
                                color: flatpak-detail-description != "" ? Cat.text : Cat.overlay0;
                                wrap: word-wrap;
                                opacity: 0.9;
                            }

                            // ── Changelog card ───────────────────────────────────────
                            if flatpak-detail-version != "" && flatpak-detail-changelog != "": Rectangle {
                                border-radius: 10px;
                                background: Cat.surface0.with-alpha(0.5);
                                border-width: 1px;
                                border-color: Cat.surface1;
                                VerticalLayout {
                                    padding: 16px;
                                    spacing: 10px;
                                    HorizontalLayout {
                                        spacing: 8px;
                                        alignment: start;
                                        Text {
                                            text: "Changes in version " + flatpak-detail-version;
                                            font-size: 13px;
                                            font-weight: 700;
                                            color: Cat.text;
                                            vertical-alignment: center;
                                        }
                                        if flatpak-detail-version-date != "": Text {
                                            text: "·  " + flatpak-detail-version-date;
                                            font-size: 11px;
                                            color: Cat.overlay1;
                                            vertical-alignment: center;
                                        }
                                    }
                                    Text {
                                        text: flatpak-detail-changelog;
                                        font-size: 12px;
                                        color: Cat.subtext0;
                                        wrap: word-wrap;
                                    }
                                }
                            }

                            // ── Links section ────────────────────────────────────────
                            if flatpak-detail-url-homepage != "" || flatpak-detail-url-bug != "" || flatpak-detail-url-translate != "" || flatpak-detail-url-vcs != "": Rectangle {
                                border-radius: 10px;
                                background: Cat.surface0.with-alpha(0.5);
                                border-width: 1px;
                                border-color: Cat.surface1;
                                VerticalLayout {
                                    padding: 16px;
                                    spacing: 10px;
                                    Text {
                                        text: "Links";
                                        font-size: 13px;
                                        font-weight: 700;
                                        color: Cat.text;
                                    }
                                    if flatpak-detail-url-homepage != "": Rectangle {
                                        height: 26px;
                                        link-home-ta := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => { root.open-url(flatpak-detail-url-homepage); }
                                        }
                                        HorizontalLayout {
                                            spacing: 8px; alignment: start;
                                            NavIcon { d: "M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"; icon-color: Cat.blue; width: 14px; height: 14px; }
                                            Text { text: "Project Website"; font-size: 13px; color: link-home-ta.has-hover ? Cat.lavender : Cat.blue; vertical-alignment: center; animate color { duration: 80ms; } }
                                        }
                                    }
                                    if flatpak-detail-url-bug != "": Rectangle {
                                        height: 26px;
                                        link-bug-ta := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => { root.open-url(flatpak-detail-url-bug); }
                                        }
                                        HorizontalLayout {
                                            spacing: 8px; alignment: start;
                                            NavIcon { d: "M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"; icon-color: Cat.peach; width: 14px; height: 14px; }
                                            Text { text: "Report an Issue"; font-size: 13px; color: link-bug-ta.has-hover ? Cat.yellow : Cat.peach; vertical-alignment: center; animate color { duration: 80ms; } }
                                        }
                                    }
                                    if flatpak-detail-url-translate != "": Rectangle {
                                        height: 26px;
                                        link-tr-ta := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => { root.open-url(flatpak-detail-url-translate); }
                                        }
                                        HorizontalLayout {
                                            spacing: 8px; alignment: start;
                                            NavIcon { d: "M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"; icon-color: Cat.teal; width: 14px; height: 14px; }
                                            Text { text: "Contribute Translations"; font-size: 13px; color: link-tr-ta.has-hover ? Cat.sky : Cat.teal; vertical-alignment: center; animate color { duration: 80ms; } }
                                        }
                                    }
                                    if flatpak-detail-url-vcs != "": Rectangle {
                                        height: 26px;
                                        link-vcs-ta := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => { root.open-url(flatpak-detail-url-vcs); }
                                        }
                                        HorizontalLayout {
                                            spacing: 8px; alignment: start;
                                            NavIcon { d: "M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"; icon-color: Cat.mauve; width: 14px; height: 14px; }
                                            Text { text: "Browse Source Code"; font-size: 13px; color: link-vcs-ta.has-hover ? Cat.lavender : Cat.mauve; vertical-alignment: center; animate color { duration: 80ms; } }
                                        }
                                    }
                                }
                            }

                            // ── Tags row ─────────────────────────────────────────────
                            if flatpak-detail-tags.length > 0: HorizontalLayout {
                                spacing: 6px;
                                alignment: start;
                                for tag in flatpak-detail-tags: Rectangle {
                                    width: tag-lbl.preferred-width + 16px;
                                    height: 24px;
                                    border-radius: 12px;
                                    background: Cat.mauve.with-alpha(0.1);
                                    border-width: 1px;
                                    border-color: Cat.mauve.with-alpha(0.25);
                                    tag-lbl := Text {
                                        text: tag;
                                        font-size: 11px;
                                        color: Cat.mauve;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }

                            // Bottom padding
                            Rectangle { height: 12px; }
                        }
                    }
                }

                // ── Flat app list (replaces AppTile grid) ────────────────────────────
                if !remote-apps-loading && flatpak-store-ready && !show-flatpak-detail: VerticalLayout {
                    vertical-stretch: 1;
                    spacing: 0;

                    // Hero watermark area
                    Rectangle {
                        height: 72px;
                        clip: true;

                        // Package glyph
                        NavIcon {
                            d: "M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5";
                            icon-color: Cat.mauve.with-alpha(0.07);
                            width: 44px;
                            height: 44px;
                            x: parent.width - 54px;
                            y: (parent.height - 44px) / 2;
                        }

                        // Column headers
                        HorizontalLayout {
                            padding-left: 16px;
                            padding-right: 14px;
                            spacing: 10px;

                            VerticalLayout {
                                alignment: center;
                                width: 44px; // avatar placeholder
                            }

                            Text {
                                horizontal-stretch: 1;
                                text: "APPLICATION";
                                font-size: 9.5px;
                                font-weight: 700;
                                color: Cat.overlay0;
                                letter-spacing: 0.8px;
                                vertical-alignment: center;
                            }

                            if flatpak-total-matches > 0 && flatpak-total-matches > remote-apps.length: Text {
                                text: remote-apps.length + " / " + flatpak-total-matches;
                                font-size: 9px;
                                color: Cat.overlay0;
                                vertical-alignment: center;
                                horizontal-alignment: center;
                            }

                            Text {
                                text: "STATUS";
                                font-size: 9.5px;
                                font-weight: 700;
                                color: Cat.overlay0;
                                letter-spacing: 0.8px;
                                vertical-alignment: center;
                                width: 70px;
                                horizontal-alignment: center;
                            }
                        }

                        // Bottom separator
                        Rectangle {
                            y: parent.height - 1px;
                            height: 1px;
                            width: parent.width;
                            background: Cat.surface0;
                            opacity: 0.6;
                        }
                    }

                    if remote-apps.length == 0: VerticalLayout {
                        vertical-stretch: 1;
                        alignment: center;
                        Text { text: "No apps found."; font-size: 13px; color: Cat.overlay0; horizontal-alignment: center; }
                    }

                    ScrollView {
                        vertical-stretch: 1;

                        VerticalLayout {
                            spacing: 0;

                            for pkg[i] in remote-apps: Rectangle {
                                height: 62px;
                                background: fk-row-touch.has-hover ? Cat.surface0.with-alpha(0.4) : transparent;
                                animate background { duration: 60ms; }

                                HorizontalLayout {
                                    padding-left: 16px;
                                    padding-right: 14px;
                                    spacing: 10px;

                                    // Checkbox
                                    VerticalLayout {
                                        alignment: center;
                                        CheckBox {
                                            checked: pkg.selected;
                                            toggled(val) => {
                                                root.toggle-flatpak-selected(pkg.name, val);
                                            }
                                        }
                                    }

                                    // Avatar (letter + category color)
                                    VerticalLayout {
                                        alignment: center;
                                        AppAvatar {
                                            initial: pkg.required-by;
                                            category: pkg.installed-size;
                                            width: 40px;
                                            height: 40px;
                                            border-radius: 10px;
                                        }
                                    }

                                    // Name + app id + description
                                    VerticalLayout {
                                        horizontal-stretch: 1;
                                        alignment: center;
                                        spacing: 2px;

                                        Text {
                                            text: pkg.display-name;
                                            font-size: 13px;
                                            font-weight: 600;
                                            color: Cat.text;
                                            overflow: elide;
                                        }
                                        HorizontalLayout {
                                            spacing: 6px;
                                            Text {
                                                text: pkg.name;
                                                font-size: 10px;
                                                color: Cat.overlay0;
                                                overflow: elide;
                                            }
                                            if pkg.description != "": Text {
                                                text: "·";
                                                font-size: 10px;
                                                color: Cat.overlay0;
                                            }
                                            if pkg.description != "": Text {
                                                text: pkg.description;
                                                font-size: 10px;
                                                color: Cat.subtext0;
                                                opacity: 0.75;
                                                overflow: elide;
                                                horizontal-stretch: 1;
                                            }
                                        }
                                    }

                                    // Install/Remove button
                                    VerticalLayout {
                                        alignment: center;
                                        Rectangle {
                                            width: 72px;
                                            height: 28px;
                                            border-radius: 6px;
                                            background: pkg.installed
                                                ? Cat.red.with-alpha(0.15)
                                                : Cat.mauve.with-alpha(0.15);

                                            Text {
                                                text: pkg.installed ? "Remove" : "Install";
                                                font-size: 11px;
                                                font-weight: 600;
                                                color: pkg.installed ? Cat.red : Cat.mauve;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }

                                            TouchArea {
                                                mouse-cursor: pointer;
                                                clicked => {
                                                    if pkg.installed {
                                                        root.request-remove(pkg.name, 1);
                                                    } else {
                                                        root.request-install(pkg.name, 1);
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }

                                // Row tap → open detail
                                fk-row-touch := TouchArea {
                                    clicked => {
                                        current-flatpak-id = pkg.name;
                                        flatpak-detail-installed = pkg.installed;
                                        flatpak-detail-name = pkg.display-name;
                                        flatpak-detail-summary = pkg.description;
                                        flatpak-detail-description = "";
                                        flatpak-detail-developer = "";
                                        flatpak-detail-version = "";
                                        flatpak-detail-version-date = "";
                                        flatpak-detail-changelog = "";
                                        flatpak-detail-url-homepage = "";
                                        flatpak-detail-url-bug = "";
                                        flatpak-detail-url-translate = "";
                                        flatpak-detail-url-vcs = "";
                                        flatpak-detail-tags = [];
                                        flatpak-screenshot = @image-url("");
                                        flatpak-detail-icon = @image-url("");
                                        flatpak-addons = [];
                                        flatpak-addons-installed = [];
                                        root.load-flatpak-detail(pkg.name);
                                        root.load-flatpak-icon(pkg.name);
                                        show-flatpak-detail = true;
                                    }
                                }

                                // Row separator
                                Rectangle {
                                    x: 16px;
                                    y: parent.height - 1px;
                                    width: parent.width - 32px;
                                    height: 1px;
                                    background: Cat.surface0;
                                    opacity: 0.5;
                                }
                            }

                            // Load More button — shown when there are more results beyond the current page
                            if flatpak-total-matches > remote-apps.length: Rectangle {
                                height: 56px;
                                background: transparent;

                                HorizontalLayout {
                                    alignment: center;
                                    padding: 10px;

                                    Rectangle {
                                        width: 180px;
                                        height: 36px;
                                        border-radius: 8px;
                                        background: load-more-touch.has-hover && !flatpak-loading-more
                                            ? Cat.mauve.with-alpha(0.18)
                                            : Cat.surface0.with-alpha(0.5);
                                        border-width: 1px;
                                        border-color: Cat.mauve.with-alpha(0.2);
                                        animate background { duration: 100ms; }

                                        HorizontalLayout {
                                            alignment: center;
                                            spacing: 6px;

                                            if flatpak-loading-more: Spinner {
                                                indeterminate: true;
                                                width: 14px;
                                                height: 14px;
                                            }

                                            Text {
                                                text: flatpak-loading-more
                                                    ? "Loading..."
                                                    : "Load More  (" + (flatpak-total-matches - remote-apps.length) + " remaining)";
                                                font-size: 12px;
                                                font-weight: 600;
                                                color: flatpak-loading-more ? Cat.overlay0 : Cat.mauve;
                                                vertical-alignment: center;
                                            }
                                        }

                                        load-more-touch := TouchArea {
                                            mouse-cursor: flatpak-loading-more ? default : pointer;
                                            clicked => {
                                                if !flatpak-loading-more {
                                                    flatpak-loading-more = true;
                                                    root.load-more-flatpaks();
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
                } // end browse tab VerticalLayout (if flatpak-tab == 0)

                // ── Installed Flatpaks tab ────────────────────────────────────
                if flatpak-tab == 1: VerticalLayout {
                    vertical-stretch: 1;
                    spacing: 0;

                    // Column header
                    Rectangle {
                        height: 42px;

                        HorizontalLayout {
                            padding-left: 16px;
                            padding-right: 16px;
                            spacing: 10px;

                            Text {
                                horizontal-stretch: 1;
                                text: "INSTALLED FLATPAKS";
                                font-size: 9.5px;
                                font-weight: 700;
                                color: Cat.overlay0;
                                letter-spacing: 0.8px;
                                vertical-alignment: center;
                            }

                            Text {
                                text: installed-flatpaks.length + " apps";
                                font-size: 10px;
                                color: Cat.overlay0;
                                vertical-alignment: center;
                            }
                        }

                        Rectangle {
                            y: parent.height - 1px;
                            height: 1px;
                            width: parent.width;
                            background: Cat.surface0;
                            opacity: 0.6;
                        }
                    }

                    // Empty state
                    if installed-flatpaks.length == 0: VerticalLayout {
                        vertical-stretch: 1;
                        alignment: center;
                        spacing: 8px;

                        NavIcon {
                            d: "M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4";
                            icon-color: Cat.surface2;
                            width: 32px;
                            height: 32px;
                            x: (parent.width - 32px) / 2;
                        }

                        Text {
                            text: "No installed flatpaks";
                            font-size: 14px;
                            color: Cat.overlay0;
                            horizontal-alignment: center;
                        }
                    }

                    // Installed list
                    if installed-flatpaks.length > 0: ScrollView {
                        vertical-stretch: 1;

                        VerticalLayout {
                            spacing: 0;

                            for pkg[i] in installed-flatpaks: Rectangle {
                                height: 56px;
                                background: ifk-touch.has-hover ? Cat.surface0.with-alpha(0.4) : transparent;
                                animate background { duration: 60ms; }

                                // TouchArea FIRST so Remove button's TouchArea sits on top of it
                                ifk-touch := TouchArea {}

                                HorizontalLayout {
                                    padding-left: 16px;
                                    padding-right: 14px;
                                    spacing: 10px;

                                    // Avatar (letter initial)
                                    VerticalLayout {
                                        alignment: center;
                                        AppAvatar {
                                            initial: pkg.required-by;
                                            category: "System";
                                            width: 36px;
                                            height: 36px;
                                            border-radius: 9px;
                                        }
                                    }

                                    // Name + app_id
                                    VerticalLayout {
                                        horizontal-stretch: 1;
                                        alignment: center;
                                        spacing: 2px;

                                        Text {
                                            text: pkg.display-name;
                                            font-size: 13px;
                                            font-weight: 600;
                                            color: Cat.text;
                                            overflow: elide;
                                        }

                                        Text {
                                            text: pkg.name;
                                            font-size: 10px;
                                            color: Cat.overlay0;
                                            overflow: elide;
                                        }
                                    }

                                    // Version pill
                                    VerticalLayout {
                                        alignment: center;
                                        Rectangle {
                                            width: ifk-ver.preferred-width + 16px;
                                            height: 22px;
                                            border-radius: 5px;
                                            background: Cat.surface0.with-alpha(0.7);
                                            ifk-ver := Text {
                                                text: pkg.version;
                                                font-size: 10px;
                                                color: Cat.subtext0;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }

                                    // Remove button
                                    VerticalLayout {
                                        alignment: center;
                                        Rectangle {
                                            width: 72px;
                                            height: 28px;
                                            border-radius: 6px;
                                            background: ifk-rm-touch.has-hover
                                                ? Cat.red.with-alpha(0.28)
                                                : Cat.red.with-alpha(0.15);
                                            animate background { duration: 60ms; }

                                            Text {
                                                text: "Remove";
                                                font-size: 11px;
                                                font-weight: 600;
                                                color: Cat.red;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }

                                            ifk-rm-touch := TouchArea {
                                                mouse-cursor: pointer;
                                                clicked => {
                                                    root.fp-confirm-id = pkg.name;
                                                    root.fp-confirm-name = pkg.display-name;
                                                    root.fp-confirm-open = true;
                                                }
                                            }
                                        }
                                    }
                                }

                                Rectangle {
                                    x: 16px;
                                    y: parent.height - 1px;
                                    width: parent.width - 32px;
                                    height: 1px;
                                    background: Cat.surface0;
                                    opacity: 0.5;
                                }
                            }
                        }
                    }
                } // end installed tab VerticalLayout (if flatpak-tab == 1)

            } // end view 10 VerticalLayout

            // Repos browser — Flatpak-style layout with search + repo tabs + hero
            if view == 7 || view == 8: VerticalLayout {
                vertical-stretch: 1;
                spacing: 0;

                // ── Tab strip: Browse | Installed ─────────────────────────
                Rectangle {
                    height: 44px;
                    background: transparent;

                    HorizontalLayout {
                        padding-left: 16px;
                        spacing: 0;

                        Rectangle {
                            width: 90px;
                            height: parent.height;
                            Text {
                                text: "Browse";
                                font-size: 13px;
                                font-weight: repos-view == 0 ? 700 : 500;
                                color: repos-view == 0 ? Cat.blue : Cat.overlay1;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            Rectangle {
                                y: parent.height - 2px;
                                height: 2px;
                                width: parent.width;
                                background: repos-view == 0 ? Cat.blue : transparent;
                                animate background { duration: 120ms; }
                            }
                            TouchArea {
                                mouse-cursor: pointer;
                                clicked => { repos-view = 0; }
                            }
                        }

                        Rectangle {
                            width: 100px;
                            height: parent.height;
                            Text {
                                text: "Installed";
                                font-size: 13px;
                                font-weight: repos-view == 1 ? 700 : 500;
                                color: repos-view == 1 ? Cat.mauve : Cat.overlay1;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            Rectangle {
                                y: parent.height - 2px;
                                height: 2px;
                                width: parent.width;
                                background: repos-view == 1 ? Cat.mauve : transparent;
                                animate background { duration: 120ms; }
                            }
                            TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    repos-view = 1;
                                    if installed-grouped.length == 0 { root.load-installed-grouped(); }
                                }
                            }
                        }

                        Rectangle { horizontal-stretch: 1; }
                    }

                    Rectangle {
                        y: parent.height - 1px;
                        height: 1px;
                        width: parent.width;
                        background: Cat.surface0;
                    }
                }

                // ── Browse tab ─────────────────────────────────────────────
                if repos-view == 0: VerticalLayout {
                    vertical-stretch: 1;
                    spacing: 0;

                // ── Pill-shaped search bar ─────────────────────────────────
                Rectangle {
                    height: 58px;
                    background: transparent;

                    TouchArea { clicked => { rs-ti.focus(); } }

                    Rectangle {
                        x: 14px;
                        y: 11px;
                        width: parent.width - 28px;
                        height: 36px;
                        border-radius: 18px;
                        background: Cat.surface0;
                        border-width: rs-ti.has-focus ? 1px : 0px;
                        border-color: Cat.blue.with-alpha(0.4);
                        clip: true;
                        animate border-width { duration: 80ms; }

                        HorizontalLayout {
                            padding-left: 14px;
                            padding-right: 14px;
                            spacing: 10px;

                            VerticalLayout {
                                alignment: center;
                                NavIcon {
                                    d: "M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0";
                                    icon-color: rs-ti.has-focus ? Cat.blue.with-alpha(0.9) : Cat.overlay1;
                                    width: 14px;
                                    height: 14px;
                                }
                            }

                            VerticalLayout {
                                alignment: center;
                                horizontal-stretch: 1;

                                if repo-search == "" && !rs-ti.has-focus: Text {
                                    height: 36px;
                                    text: selected-repo != "" ? "Search in " + selected-repo + "..." : "Search all packages...";
                                    font-size: 13px;
                                    color: Cat.overlay0;
                                    vertical-alignment: center;
                                }

                                rs-ti := TextInput {
                                    height: 36px;
                                    text <=> repo-search;
                                    font-size: 13px;
                                    color: Cat.text;
                                    single-line: true;
                                    vertical-alignment: center;
                                    selection-background-color: Cat.blue.with-alpha(0.3);
                                    selection-foreground-color: Cat.text;
                                    accepted => { root.filter-repo(self.text); }
                                    edited => { root.filter-repo(self.text); }
                                }
                            }
                        }
                    }
                }

                // ── Repo tabs as centered pills ─────────────────────────────
                Rectangle {
                    height: 50px;

                    if pacman-repos.length == 0: HorizontalLayout {
                        padding-left: 14px;
                        spacing: 8px;
                        alignment: center;
                        NavIcon {
                            d: "M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15";
                            icon-color: Cat.overlay0;
                            width: 14px;
                            height: 14px;
                        }
                        Text { text: "Loading repositories..."; font-size: 12px; color: Cat.overlay0; vertical-alignment: center; }
                    }

                    if pacman-repos.length > 0: HorizontalLayout {
                        alignment: center;
                        spacing: 8px;
                        padding: 10px;

                        // "All" pill — shows combined packages from all repos
                        Rectangle {
                            width: all-pill-lbl.preferred-width + 28px;
                            height: 30px;
                            border-radius: 15px;
                            border-width: 1px;
                            border-color: selected-repo == "" ? Cat.blue.with-alpha(0.5) : Cat.surface1;
                            background: selected-repo == "" ? Cat.blue.with-alpha(0.12) :
                                        (all-pill-ta.has-hover ? Cat.surface1 : Cat.surface0.with-alpha(0.5));
                            animate background { duration: 70ms; }
                            all-pill-lbl := Text {
                                text: "All";
                                font-size: 12px;
                                font-weight: selected-repo == "" ? 700 : 400;
                                color: selected-repo == "" ? Cat.blue : Cat.subtext0;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            all-pill-ta := TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    selected-repo = "";
                                    view = 8;
                                    repo-search = "";
                                    root.browse-repo("");
                                }
                            }
                        }

                        for repo[i] in pacman-repos: Rectangle {
                            width: rp-lbl.preferred-width + 28px;
                            height: 30px;
                            border-radius: 15px;
                            border-width: 1px;
                            border-color: selected-repo == repo ? Cat.blue.with-alpha(0.5) : Cat.surface1;
                            background: selected-repo == repo ? Cat.blue.with-alpha(0.12) :
                                        (rp-t.has-hover ? Cat.surface1 : Cat.surface0.with-alpha(0.5));
                            animate background { duration: 70ms; }

                            rp-lbl := Text {
                                text: repo;
                                font-size: 12px;
                                font-weight: selected-repo == repo ? 700 : 400;
                                color: selected-repo == repo ? Cat.blue : Cat.subtext0;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            rp-t := TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    selected-repo = repo;
                                    view = 8;
                                    show-repo-detail = false;
                                    repo-search = "";
                                    root.browse-repo(repo);
                                }
                            }
                        }
                    }
                }

                // ── Package list ─────────────────────────────────────────────
                VerticalLayout {
                    vertical-stretch: 1;

                    // Loading state
                    if repo-loading: VerticalLayout {
                        vertical-stretch: 1; alignment: center; spacing: 8px;
                        Spinner { width: 24px; height: 24px; indeterminate: true; x: (parent.width - 24px) / 2; }
                        Text { text: selected-repo != "" ? "Loading " + selected-repo + "..." : "Loading packages..."; font-size: 12px; color: Cat.overlay0; horizontal-alignment: center; }
                    }

                    // Column header
                    if !repo-loading: Rectangle {
                        height: 30px;
                        background: Cat.surface0.with-alpha(0.5);
                        HorizontalLayout {
                            padding-left: 14px; padding-right: 12px;
                            Text { text: "Name"; font-size: 10px; font-weight: 700; color: Cat.overlay0; letter-spacing: 0.5px; vertical-alignment: center; horizontal-stretch: 1; }
                            Rectangle { width: 120px; Text { text: "Version"; font-size: 10px; font-weight: 700; color: Cat.overlay0; letter-spacing: 0.5px; vertical-alignment: center; horizontal-alignment: right; } }
                            Rectangle { width: 80px; Text { text: "Repo"; font-size: 10px; font-weight: 700; color: Cat.overlay0; letter-spacing: 0.5px; vertical-alignment: center; horizontal-alignment: right; } }
                            Rectangle { width: 90px; Text { text: "Action"; font-size: 10px; font-weight: 700; color: Cat.overlay0; letter-spacing: 0.5px; vertical-alignment: center; horizontal-alignment: center; } }
                        }
                    }

                    if !repo-loading && repo-packages.length == 0: VerticalLayout {
                        vertical-stretch: 1; alignment: center;
                        Text { text: "No packages found"; font-size: 13px; color: Cat.overlay0; horizontal-alignment: center; }
                    }

                    if !repo-loading && repo-packages.length > 0: ListView {
                        vertical-stretch: 1;
                        for p[i] in repo-packages: RepoRow {
                            pkg: p;
                            install => { root.request-install(p.name, p.backend); }
                            remove => { root.request-remove(p.name, p.backend); }
                            show-tree => {
                                dep-tree-pkg = p.name;
                                dep-tree-tab = 0;
                                dep-tree-nodes = [];
                                dep-reqby-nodes = [];
                                dep-tree-loading = true;
                                view = 12;
                                root.load-dep-tree(p.name);
                            }
                        }
                    }

                    // Load More button
                    if !repo-loading && repo-has-more: Rectangle {
                        height: 44px;
                        background: Cat.surface0.with-alpha(0.3);
                        Rectangle {
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            width: 200px; height: 28px; border-radius: 8px;
                            background: lm-ta.has-hover ? Cat.blue.with-alpha(0.2) : Cat.blue.with-alpha(0.1);
                            border-width: 1px; border-color: Cat.blue.with-alpha(0.3);
                            animate background { duration: 60ms; }
                            Text { text: "Load " + repo-extra-count + " more packages"; font-size: 11px; font-weight: 600; color: Cat.blue; horizontal-alignment: center; vertical-alignment: center; }
                            lm-ta := TouchArea { mouse-cursor: pointer; clicked => { root.load-more-repo-pkgs(); } }
                        }
                    }
                }
            }

            if !loading && view == 2 && (search-installed.length > 0 || search-available.length > 0): ScrollView {
                vertical-stretch: 1;

                VerticalLayout {
                    spacing: 0px;

                    if search-installed.length > 0: VerticalLayout {
                        spacing: 0px;

                        Rectangle {
                            height: 32px;
                            background: Cat.green.with-alpha(0.06);
                            border-radius: 6px;

                            HorizontalLayout {
                                padding-left: 12px;
                                spacing: 6px;

                                NavIcon {
                                    d: "M20 6L9 17l-5-5";
                                    icon-color: Cat.green;
                                    width: 14px;
                                    height: 14px;
                                }

                                Text {
                                    text: "Installed (" + search-installed.length + ")";
                                    font-size: 11px;
                                    font-weight: 700;
                                    color: Cat.green;
                                    vertical-alignment: center;
                                }
                            }
                        }

                        for p[i] in search-installed: PackageRow {
                            pkg: p;
                            show-separator: i < search-installed.length - 1;
                            show-checkbox: multi-select-mode;
                            install => { root.request-install(p.name, p.backend); }
                            remove => { root.request-remove(p.name, p.backend); }
                            toggle-selected(val) => { root.toggle-package-selected(p.name, p.backend, val); }
                        }
                    }

                    if search-available.length > 0: VerticalLayout {
                        spacing: 0px;

                        Rectangle {
                            height: 32px;
                            background: Cat.blue.with-alpha(0.06);
                            border-radius: 6px;

                            HorizontalLayout {
                                padding-left: 12px;
                                spacing: 6px;

                                NavIcon {
                                    d: icon-package;
                                    icon-color: Cat.blue;
                                    width: 14px;
                                    height: 14px;
                                }

                                Text {
                                    text: "Available (" + search-available.length + ")";
                                    font-size: 11px;
                                    font-weight: 700;
                                    color: Cat.blue;
                                    vertical-alignment: center;
                                }
                            }
                        }

                        for p[i] in search-available: PackageRow {
                            pkg: p;
                            show-separator: i < search-available.length - 1;
                            show-checkbox: multi-select-mode;
                            install => { root.request-install(p.name, p.backend); }
                            remove => { root.request-remove(p.name, p.backend); }
                            toggle-selected(val) => { root.toggle-package-selected(p.name, p.backend, val); }
                        }
                    }
                }
                } // end browse tab (repos-view == 0)

                // ── Installed tab — packages grouped by repo ───────────────
                if repos-view == 1: VerticalLayout {
                    vertical-stretch: 1;
                    spacing: 0;

                    // Column header
                    Rectangle {
                        height: 38px;

                        HorizontalLayout {
                            padding-left: 16px;
                            padding-right: 16px;
                            spacing: 10px;

                            VerticalLayout { width: 40px; alignment: center; }

                            Text {
                                horizontal-stretch: 1;
                                text: "INSTALLED PACKAGES";
                                font-size: 9.5px;
                                font-weight: 700;
                                color: Cat.overlay0;
                                letter-spacing: 0.8px;
                                vertical-alignment: center;
                            }

                            Text {
                                text: installed-packages.length + " pkgs";
                                font-size: 9.5px;
                                color: Cat.overlay0;
                                vertical-alignment: center;
                            }

                            Text {
                                width: 150px;
                                text: "ACTIONS";
                                font-size: 9.5px;
                                font-weight: 700;
                                color: Cat.overlay0;
                                letter-spacing: 0.8px;
                                vertical-alignment: center;
                                horizontal-alignment: center;
                            }
                        }

                        Rectangle {
                            y: parent.height - 1px;
                            height: 1px;
                            width: parent.width;
                            background: Cat.surface0;
                            opacity: 0.6;
                        }
                    }

                    if installed-grouped.length == 0: VerticalLayout {
                        vertical-stretch: 1;
                        alignment: center;
                        spacing: 6px;
                        Spinner { indeterminate: true; width: 20px; height: 20px; x: (parent.width - 20px) / 2; }
                        Text { text: "Loading..."; font-size: 12px; color: Cat.overlay0; horizontal-alignment: center; }
                    }

                    if installed-grouped.length > 0: ListView {
                        vertical-stretch: 1;

                            for pkg[i] in installed-grouped: Rectangle {
                                height: pkg.backend == -1 ? 30px : 54px;
                                background: pkg.backend != -1 && ri-touch.has-hover
                                    ? Cat.surface0.with-alpha(0.35) : transparent;
                                animate background { duration: 60ms; }

                                // hover area BEHIND content so buttons get clicks
                                ri-touch := TouchArea {}

                                // ── Repo header ─────────────────────────────
                                if pkg.backend == -1: HorizontalLayout {
                                    padding-left: 16px;
                                    padding-right: 16px;
                                    spacing: 8px;
                                    VerticalLayout {
                                        alignment: center;
                                        Rectangle {
                                            width: ri-repo-lbl.preferred-width + 14px;
                                            height: 18px;
                                            border-radius: 5px;
                                            background: Cat.surface1.with-alpha(0.7);
                                            ri-repo-lbl := Text {
                                                text: pkg.name;
                                                font-size: 9.5px;
                                                font-weight: 700;
                                                color: pkg.repository == "core" ? Cat.blue :
                                                       pkg.repository == "extra" ? Cat.mauve :
                                                       pkg.repository == "multilib" ? Cat.teal :
                                                       pkg.repository == "aur" ? Cat.peach :
                                                       Cat.overlay1;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                                letter-spacing: 0.5px;
                                            }
                                        }
                                    }
                                    Rectangle {
                                        horizontal-stretch: 1;
                                        height: 1px;
                                        y: parent.height / 2;
                                        background: Cat.surface1.with-alpha(0.4);
                                    }
                                }

                                // ── Package row ──────────────────────────────
                                if pkg.backend != -1: HorizontalLayout {
                                    padding-left: 16px;
                                    padding-right: 14px;
                                    spacing: 10px;

                                    // Avatar
                                    VerticalLayout {
                                        alignment: center;
                                        AppAvatar {
                                            initial: pkg.required-by;
                                            category: pkg.installed-size;
                                            width: 36px;
                                            height: 36px;
                                            border-radius: 9px;
                                        }
                                    }

                                    // Name + description
                                    VerticalLayout {
                                        horizontal-stretch: 1;
                                        alignment: center;
                                        spacing: 2px;
                                        Text {
                                            text: pkg.display-name;
                                            font-size: 13px;
                                            font-weight: 600;
                                            color: Cat.text;
                                            overflow: elide;
                                        }
                                        Text {
                                            text: pkg.description;
                                            font-size: 10px;
                                            color: Cat.subtext0;
                                            opacity: 0.75;
                                            overflow: elide;
                                        }
                                    }

                                    // Version pill
                                    VerticalLayout {
                                        alignment: center;
                                        Rectangle {
                                            width: ri-ver.preferred-width + 14px;
                                            height: 20px;
                                            border-radius: 5px;
                                            background: Cat.surface0.with-alpha(0.7);
                                            ri-ver := Text {
                                                text: pkg.version;
                                                font-size: 10px;
                                                color: Cat.subtext0;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }

                                    // Tree button
                                    VerticalLayout {
                                        alignment: center;
                                        Rectangle {
                                            width: 54px;
                                            height: 28px;
                                            border-radius: 6px;
                                            background: ri-tr-touch.has-hover
                                                ? Cat.sapphire.with-alpha(0.28)
                                                : Cat.sapphire.with-alpha(0.15);
                                            animate background { duration: 60ms; }
                                            Text {
                                                text: "Tree";
                                                font-size: 11px;
                                                font-weight: 600;
                                                color: Cat.sapphire;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                            ri-tr-touch := TouchArea {
                                                mouse-cursor: pointer;
                                                clicked => {
                                                    dep-tree-pkg = pkg.name;
                                                    dep-tree-tab = 0;
                                                    dep-tree-nodes = [];
                                                    dep-reqby-nodes = [];
                                                    dep-tree-loading = true;
                                                    view = 12;
                                                    root.load-dep-tree(pkg.name);
                                                }
                                            }
                                        }
                                    }

                                    // Downgrade button
                                    VerticalLayout {
                                        alignment: center;
                                        Rectangle {
                                            width: 82px;
                                            height: 28px;
                                            border-radius: 6px;
                                            background: ri-dg-touch.has-hover
                                                ? Cat.yellow.with-alpha(0.28)
                                                : Cat.yellow.with-alpha(0.15);
                                            animate background { duration: 60ms; }
                                            Text {
                                                text: "Downgrade";
                                                font-size: 10px;
                                                font-weight: 600;
                                                color: Cat.yellow;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                            ri-dg-touch := TouchArea {
                                                mouse-cursor: pointer;
                                                clicked => { root.downgrade-package(pkg.name); }
                                            }
                                        }
                                    }

                                    // Remove button
                                    VerticalLayout {
                                        alignment: center;
                                        Rectangle {
                                            width: 70px;
                                            height: 28px;
                                            border-radius: 6px;
                                            background: ri-rm-touch.has-hover
                                                ? Cat.red.with-alpha(0.28)
                                                : Cat.red.with-alpha(0.15);
                                            animate background { duration: 60ms; }
                                            Text {
                                                text: "Remove";
                                                font-size: 11px;
                                                font-weight: 600;
                                                color: Cat.red;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                            ri-rm-touch := TouchArea {
                                                mouse-cursor: pointer;
                                                clicked => { root.request-remove(pkg.name, pkg.backend); }
                                            }
                                        }
                                    }
                                }

                                if pkg.backend != -1: Rectangle {
                                    x: 16px;
                                    y: parent.height - 1px;
                                    width: parent.width - 32px;
                                    height: 1px;
                                    background: Cat.surface0;
                                    opacity: 0.4;
                                }
                            }
                    }
                } // end installed tab (repos-view == 1)

            } // end view 7/8 VerticalLayout

            if view == 5: ScrollView {
                vertical-stretch: 1;

                VerticalLayout {
                    padding: 4px;
                    spacing: 28px;


                    VerticalLayout {
                        spacing: 8px;
                        SectionLabel { section-title: "GENERAL"; }

                        SettingsRow {
                            label: "Flatpak Support";
                            subtitle: "Enable Flatpak package management";
                            checked: setting-flatpak-enabled;
                            toggled(val) => {
                                setting-flatpak-enabled = val;
                                if !val && view == 10 { view = 9; }
                                root.save-settings();
                            }
                        }

                        SettingsRow {
                            label: "Check Updates on Startup";
                            subtitle: "Automatically sync databases on launch";
                            checked: setting-check-updates-on-start;
                            toggled(val) => { setting-check-updates-on-start = val; root.save-settings(); }
                        }

                        // Notification interval picker
                        Rectangle {
                            height: 54px;
                            border-radius: 8px;
                            background: Cat.surface0.with-alpha(0.4);

                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 16px;

                                VerticalLayout {
                                    alignment: center;
                                    horizontal-stretch: 1;
                                    spacing: 2px;

                                    Text {
                                        text: "Update Check Interval";
                                        font-size: 13px;
                                        color: Cat.text;
                                    }
                                    Text {
                                        text: "How often xpm-notify checks for updates";
                                        font-size: 11px;
                                        color: Cat.overlay0;
                                    }
                                }

                                HorizontalLayout {
                                    alignment: center;
                                    spacing: 4px;

                                    for opt[i] in [15, 30, 60, 120]: Rectangle {
                                        width: 42px;
                                        height: 26px;
                                        border-radius: 6px;
                                        background: setting-notify-interval == opt ?
                                            Cat.mauve : (opt-touch.has-hover ? Cat.surface1 : Cat.surface0);
                                        animate background { duration: 80ms; }

                                        Text {
                                            text: opt >= 60 ? (opt / 60) + "h" : opt + "m";
                                            font-size: 11px;
                                            font-weight: setting-notify-interval == opt ? 700 : 400;
                                            color: setting-notify-interval == opt ? Cat.crust : Cat.subtext0;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }

                                        opt-touch := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => {
                                                setting-notify-interval = opt;
                                                root.save-settings();
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }

                    VerticalLayout {
                        spacing: 8px;
                        SectionLabel { section-title: "MAINTENANCE"; }

                        HorizontalLayout {
                            spacing: 8px;

                            Rectangle {
                                horizontal-stretch: 1;
                                height: 64px;
                                border-radius: 10px;
                                background: Cat.surface0.with-alpha(0.4);

                                VerticalLayout {
                                    padding: 14px;
                                    spacing: 6px;

                                    Text {
                                        text: "Cache: " + stats.cache-size;
                                        font-size: 12px;
                                        color: Cat.subtext0;
                                    }

                                    Btn {
                                        label: "Clean Cache";
                                        primary: true;
                                        clicked => { root.clean-package-cache(); }
                                    }
                                }
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                                height: 64px;
                                border-radius: 10px;
                                background: Cat.surface0.with-alpha(0.4);

                                VerticalLayout {
                                    padding: 14px;
                                    spacing: 6px;

                                    Text {
                                        text: stats.orphan-count + " orphan packages";
                                        font-size: 12px;
                                        color: Cat.subtext0;
                                    }

                                    Btn {
                                        label: "Remove Orphans";
                                        danger: stats.orphan-count > 0;
                                        enabled: stats.orphan-count > 0;
                                        clicked => { root.remove-orphans(); }
                                    }
                                }
                            }
                        }
                    }

                    VerticalLayout {
                        spacing: 8px;
                        SectionLabel { section-title: "DATA"; }

                        ActionCard {
                            title: "Export Package List";
                            subtitle: "Save explicitly installed packages to ~/xpm-packages.txt";
                            icon-path: icon-file;
                            clicked => { root.export-package-list(); }
                        }

                        ActionCard {
                            title: "Import Package List";
                            subtitle: "Install packages from ~/xpm-packages.txt";
                            icon-path: icon-folder;
                            clicked => { root.import-package-list(); }
                        }
                    }

                    VerticalLayout {
                        spacing: 8px;
                        SectionLabel { section-title: "ABOUT"; }

                        Rectangle {
                            height: 52px;
                            border-radius: 10px;
                            background: Cat.surface0.with-alpha(0.4);

                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 16px;
                                spacing: 12px;

                                VerticalLayout {
                                    alignment: center;
                                    NavIcon {
                                        d: icon-package;
                                        icon-color: Cat.mauve;
                                        width: 22px;
                                        height: 22px;
                                    }
                                }

                                VerticalLayout {
                                    alignment: center;
                                    spacing: 2px;
                                    Text {
                                        text: "xPackage Manager";
                                        font-size: 14px;
                                        font-weight: 600;
                                        color: Cat.text;
                                    }
                                    Text {
                                        text: stats.pacman-count + " pacman  /  " + stats.flatpak-count + " flatpak  /  " + stats.orphan-count + " orphans";
                                        font-size: 11px;
                                        color: Cat.overlay0;
                                    }
                                }
                            }
                        }
                    }
                }
            }

            // ─── View 12: Dependency Tree ─────────────────────────────────────
            if view == 12: Rectangle {
                vertical-stretch: 1;
                border-radius: 14px;
                background: Cat.base.with-alpha(0.82);
                border-width: 1px;
                border-color: Cat.surface0.with-alpha(0.5);
                clip: true;

              VerticalLayout {

                // ── Header — pill card + back button ─────────────────────────
                Rectangle {
                    height: 88px;
                    background: Cat.crust;

                    HorizontalLayout {
                        padding-left: 14px; padding-right: 14px;
                        padding-top: 12px; padding-bottom: 12px;
                        spacing: 12px;

                        // Back button — VerticalLayout centers the 30px button in the 64px height
                        VerticalLayout {
                            alignment: center;
                            Rectangle {
                                width: 76px; height: 30px; border-radius: 8px;
                                background: dt-back-ta.has-hover ? Cat.surface1 : Cat.surface0;
                                animate background { duration: 80ms; }
                                VerticalLayout {
                                    alignment: center;
                                    HorizontalLayout {
                                        alignment: center; spacing: 6px;
                                        NavIcon { d: "M19 12H5M12 19l-7-7 7-7"; icon-color: Cat.subtext0; width: 14px; height: 14px; }
                                        Text { text: "Back"; font-size: 12px; font-weight: 600; color: Cat.subtext0; }
                                    }
                                }
                                dt-back-ta := TouchArea { mouse-cursor: pointer; clicked => { view = 7; repos-view = 1; } }
                            }
                        }

                        // Pill card — horizontal-stretch:1 now works (no alignment: center on parent)
                        Rectangle {
                            horizontal-stretch: 1;
                            border-radius: 14px;
                            background: Cat.mauve.with-alpha(0.1);
                            border-width: 1px; border-color: Cat.mauve.with-alpha(0.28);

                            HorizontalLayout {
                                padding-left: 16px; padding-right: 16px; spacing: 12px;

                                // Icon badge
                                VerticalLayout {
                                    alignment: center;
                                    Rectangle {
                                        width: 38px; height: 38px; border-radius: 10px;
                                        background: Cat.mauve.with-alpha(0.16);
                                        NavIcon { d: icon-package; icon-color: Cat.mauve; width: 20px; height: 20px; x: 9px; y: 9px; }
                                    }
                                }

                                // Package name + version/status
                                VerticalLayout {
                                    alignment: center; horizontal-stretch: 1; spacing: 3px;
                                    Text { text: dep-tree-pkg; font-size: 15px; font-weight: 700; color: Cat.mauve; overflow: elide; }
                                    Text {
                                        text: dep-tree-loading ? "Resolving dependency tree…"
                                            : (dep-tree-root-version == "" ? "version unknown" : dep-tree-root-version);
                                        font-size: 11px; color: Cat.overlay1;
                                    }
                                }

                                // Stat badges (hidden while loading)
                                if !dep-tree-loading: VerticalLayout {
                                    alignment: center; spacing: 5px;
                                    Rectangle {
                                        height: 20px; width: 82px; border-radius: 5px;
                                        background: Cat.blue.with-alpha(0.14);
                                        border-width: 1px; border-color: Cat.blue.with-alpha(0.22);
                                        Text { text: dep-tree-nodes.length + " deps"; font-size: 10px; font-weight: 600; color: Cat.blue; horizontal-alignment: center; vertical-alignment: center; }
                                    }
                                    Rectangle {
                                        height: 20px; width: 82px; border-radius: 5px;
                                        background: Cat.green.with-alpha(0.12);
                                        border-width: 1px; border-color: Cat.green.with-alpha(0.2);
                                        Text { text: dep-reqby-nodes.length + " req by"; font-size: 10px; font-weight: 600; color: Cat.green; horizontal-alignment: center; vertical-alignment: center; }
                                    }
                                }

                                // Loading spinner
                                if dep-tree-loading: VerticalLayout {
                                    alignment: center;
                                    Spinner { width: 22px; height: 22px; indeterminate: true; }
                                }
                            }
                        }
                    }
                }

                // ── Tab strip ────────────────────────────────────────────────
                Rectangle {
                    height: 40px;
                    background: Cat.mantle;

                    HorizontalLayout {
                        padding-left: 14px; spacing: 0px;

                        Rectangle {
                            width: 130px; height: 40px;
                            background: transparent;
                            VerticalLayout {
                                alignment: center;
                                Text { text: "Depends On"; font-size: 12px; font-weight: dep-tree-tab == 0 ? 700 : 400; color: dep-tree-tab == 0 ? Cat.blue : Cat.overlay1; horizontal-alignment: center; }
                            }
                            if dep-tree-tab == 0: Rectangle { y: parent.height - 2px; height: 2px; background: Cat.blue; }
                            dt-tab0 := TouchArea { clicked => { dep-tree-tab = 0; } }
                        }

                        Rectangle {
                            width: 130px; height: 40px;
                            background: transparent;
                            VerticalLayout {
                                alignment: center;
                                Text { text: "Required By"; font-size: 12px; font-weight: dep-tree-tab == 1 ? 700 : 400; color: dep-tree-tab == 1 ? Cat.green : Cat.overlay1; horizontal-alignment: center; }
                            }
                            if dep-tree-tab == 1: Rectangle { y: parent.height - 2px; height: 2px; background: Cat.green; }
                            dt-tab1 := TouchArea { clicked => { dep-tree-tab = 1; } }
                        }

                        Rectangle { horizontal-stretch: 1; }
                    }
                }

                // ── Legend row (clearly separated from tabs) ──────────────────
                Rectangle {
                    height: 28px;
                    background: Cat.crust;

                    HorizontalLayout {
                        padding-left: 16px; padding-right: 16px; spacing: 0px;
                        Rectangle { horizontal-stretch: 1; }
                        VerticalLayout {
                            alignment: center;
                            HorizontalLayout {
                                spacing: 16px;
                                HorizontalLayout { spacing: 5px; VerticalLayout { alignment: center; Rectangle { width: 7px; height: 7px; border-radius: 3px; background: Cat.green; } } Text { text: "installed"; font-size: 10px; color: Cat.overlay0; vertical-alignment: center; } }
                                HorizontalLayout { spacing: 5px; VerticalLayout { alignment: center; Rectangle { width: 7px; height: 7px; border-radius: 3px; background: Cat.red; } } Text { text: "missing"; font-size: 10px; color: Cat.overlay0; vertical-alignment: center; } }
                                HorizontalLayout { spacing: 5px; VerticalLayout { alignment: center; Rectangle { width: 7px; height: 7px; border-radius: 3px; background: Cat.peach; } } Text { text: "optional"; font-size: 10px; color: Cat.overlay0; vertical-alignment: center; } }
                            }
                        }
                    }
                }

                Rectangle { height: 1px; background: Cat.surface0; }

                // ── Loading ──────────────────────────────────────────────────
                if dep-tree-loading: Rectangle {
                    vertical-stretch: 1;
                    Text { text: "Resolving…"; horizontal-alignment: center; vertical-alignment: center; color: Cat.overlay0; font-size: 12px; }
                }

                // ── Depends On tab ───────────────────────────────────────────
                if !dep-tree-loading && dep-tree-tab == 0: VerticalLayout {
                    vertical-stretch: 1;

                    // ── Dependency tree list ──────────────────────────────────
                    if dep-tree-nodes.length == 0: Rectangle {
                        vertical-stretch: 1;
                        Text { text: "No dependencies found."; horizontal-alignment: center; vertical-alignment: center; color: Cat.overlay0; font-size: 13px; }
                    }

                    if dep-tree-nodes.length > 0: ListView {
                        vertical-stretch: 1;

                        for node[i] in dep-tree-nodes: Rectangle {
                            // depth -1 = section separator; depth 1 = direct dep; depth 2 = transitive
                            height: node.depth == -1 ? 32px : 42px;
                            background: node.depth != -1 && dt-node-ta.has-hover
                                ? Cat.surface0.with-alpha(0.25) : transparent;
                            animate background { duration: 60ms; }

                            dt-node-ta := TouchArea {}

                            // Section separator row (optional deps divider)
                            if node.depth == -1: HorizontalLayout {
                                padding-left: 16px; padding-right: 16px; spacing: 10px;
                                VerticalLayout {
                                    alignment: center;
                                    Rectangle { height: 1px; horizontal-stretch: 1; background: Cat.peach.with-alpha(0.3); }
                                }
                                VerticalLayout {
                                    alignment: center;
                                    Text { text: "Optional Dependencies"; font-size: 10px; font-weight: 700; color: Cat.peach.with-alpha(0.7); }
                                }
                                VerticalLayout {
                                    alignment: center;
                                    Rectangle { height: 1px; horizontal-stretch: 1; background: Cat.peach.with-alpha(0.3); }
                                }
                            }

                            // Normal dep row
                            if node.depth != -1: HorizontalLayout {
                                padding-left: 16px; padding-right: 16px; spacing: 0px;

                                // Tree prefix — fixed width prevents squeezing the name
                                VerticalLayout {
                                    alignment: center;
                                    Text {
                                        text: node.prefix;
                                        font-size: 13px;
                                        color: node.is-optional ? Cat.peach.with-alpha(0.5) : Cat.overlay0;
                                        vertical-alignment: center;
                                        width: node.depth == 1 ? 28px : 52px;
                                    }
                                }

                                // Status dot
                                VerticalLayout {
                                    alignment: center; width: 18px;
                                    Rectangle {
                                        width: 8px; height: 8px; border-radius: 4px;
                                        background: node.is-optional ? Cat.peach
                                            : (node.installed ? Cat.green : Cat.red);
                                    }
                                }

                                // Name + hard badge
                                // Rectangle propagates width correctly; no alignment on inner HLayout
                                Rectangle {
                                    horizontal-stretch: 1;
                                    HorizontalLayout {
                                        spacing: 8px;
                                        Text {
                                            preferred-width: 0px;
                                            horizontal-stretch: 1;
                                            text: node.name;
                                            font-size: node.depth == 1 ? 13px : 12px;
                                            font-weight: node.depth == 1 ? 500 : 400;
                                            font-italic: node.is-optional;
                                            color: node.is-optional ? Cat.peach.with-alpha(0.85)
                                                : (node.installed
                                                    ? (node.depth == 1 ? Cat.text : Cat.subtext0)
                                                    : Cat.red);
                                            vertical-alignment: center;
                                            overflow: elide;
                                        }
                                        if !node.is-optional && node.depth == 1: VerticalLayout {
                                            alignment: center;
                                            Rectangle {
                                                width: 34px; height: 16px; border-radius: 4px;
                                                background: Cat.blue.with-alpha(0.12);
                                                Text { text: "hard"; font-size: 9px; font-weight: 700; color: Cat.blue.with-alpha(0.8); horizontal-alignment: center; vertical-alignment: center; }
                                            }
                                        }
                                    }
                                }

                                // Version pill — 80px fits trimmed versions
                                VerticalLayout {
                                    alignment: center; width: 80px;
                                    Rectangle {
                                        height: 20px; border-radius: 5px;
                                        background: Cat.surface0.with-alpha(0.5);
                                        Text {
                                            text: node.version == "" ? "not installed" : node.version;
                                            font-size: 10px;
                                            color: node.version == "" ? Cat.red.with-alpha(0.7) : Cat.overlay1;
                                            horizontal-alignment: center; vertical-alignment: center;
                                            overflow: elide;
                                        }
                                    }
                                }
                            }

                            if node.depth != -1: Rectangle {
                                x: 16px; y: parent.height - 1px;
                                width: parent.width - 32px; height: 1px;
                                background: Cat.surface0.with-alpha(0.35);
                            }
                        }
                    }
                }

                // ── Required By tab ──────────────────────────────────────────
                if !dep-tree-loading && dep-tree-tab == 1: VerticalLayout {
                    vertical-stretch: 1;

                    if dep-reqby-nodes.length == 0: Rectangle {
                        vertical-stretch: 1;
                        VerticalLayout {
                            alignment: center; spacing: 10px;
                            NavIcon { d: icon-package; icon-color: Cat.green; width: 32px; height: 32px; }
                            Text { text: "Nothing depends on " + dep-tree-pkg; font-size: 14px; font-weight: 600; color: Cat.text; horizontal-alignment: center; }
                            Text { text: "This package can be safely removed without breaking other packages."; font-size: 12px; color: Cat.overlay1; horizontal-alignment: center; }
                        }
                    }

                    if dep-reqby-nodes.length > 0: VerticalLayout {
                        vertical-stretch: 1;

                        // Required-by pill header
                        Rectangle { height: 20px; background: transparent; }
                        HorizontalLayout {
                            padding-left: 20px; padding-right: 20px;
                            Rectangle {
                                horizontal-stretch: 1; height: 60px;
                                border-radius: 14px;
                                background: Cat.green.with-alpha(0.08);
                                border-width: 1px; border-color: Cat.green.with-alpha(0.2);
                                HorizontalLayout {
                                    padding-left: 18px; padding-right: 18px; spacing: 12px;
                                    VerticalLayout { alignment: center; NavIcon { d: icon-package; icon-color: Cat.green; width: 20px; height: 20px; } }
                                    VerticalLayout {
                                        alignment: center; horizontal-stretch: 1;
                                        Text { text: dep-tree-pkg + " is required by " + dep-reqby-nodes.length + " installed packages"; font-size: 12px; font-weight: 600; color: Cat.text; }
                                        Text { text: "Removing it may break these packages"; font-size: 10px; color: Cat.overlay1; }
                                    }
                                }
                            }
                        }
                        Rectangle { height: 14px; background: transparent; }
                        Rectangle { x: 20px; height: 1px; width: parent.width - 40px; background: Cat.surface0.with-alpha(0.6); }
                        Rectangle { height: 4px; background: transparent; }

                        ListView {
                            vertical-stretch: 1;
                            for node[i] in dep-reqby-nodes: Rectangle {
                                height: 46px;
                                background: rb-node-ta.has-hover ? Cat.surface0.with-alpha(0.25) : transparent;
                                animate background { duration: 60ms; }

                                rb-node-ta := TouchArea {}

                                HorizontalLayout {
                                    padding-left: 24px; padding-right: 20px; spacing: 12px;
                                    VerticalLayout {
                                        alignment: center;
                                        Rectangle { width: 8px; height: 8px; border-radius: 4px; background: Cat.green; }
                                    }
                                    Text {
                                        preferred-width: 0px; horizontal-stretch: 1;
                                        text: node.name; font-size: 13px; font-weight: 500; color: Cat.text; overflow: elide; vertical-alignment: center;
                                    }
                                    VerticalLayout {
                                        alignment: center;
                                        Rectangle {
                                            height: 20px; width: 80px; border-radius: 5px;
                                            background: Cat.surface0.with-alpha(0.5);
                                            Text { text: node.version == "" ? "—" : node.version; font-size: 10px; color: Cat.overlay1; horizontal-alignment: center; vertical-alignment: center; overflow: elide; }
                                        }
                                    }
                                }

                                Rectangle { x: 16px; y: parent.height - 1px; width: parent.width - 32px; height: 1px; background: Cat.surface0.with-alpha(0.35); }
                            }
                        }
                    }
                }
              } // end inner VerticalLayout
            } // end view 12 Rectangle

            // ─── View 11: Troubleshooting ─────────────────────────────────────
            if view == 11: VerticalLayout {
                vertical-stretch: 1;

                // Geeky terminal-style header
                Rectangle {
                    height: 68px;
                    background: Cat.crust;

                    HorizontalLayout {
                        padding-left: 22px;
                        padding-right: 22px;
                        spacing: 14px;

                        VerticalLayout {
                            alignment: center;
                            Rectangle {
                                width: 40px; height: 40px;
                                border-radius: 8px;
                                background: Cat.green.with-alpha(0.12);
                                border-width: 1px;
                                border-color: Cat.green.with-alpha(0.25);
                                NavIcon {
                                    d: icon-wrench;
                                    icon-color: Cat.green;
                                    width: 20px; height: 20px;
                                    x: 10px; y: 10px;
                                }
                            }
                        }

                        VerticalLayout {
                            alignment: center;
                            spacing: 4px;
                            horizontal-stretch: 1;
                            Text {
                                text: "SYSTEM TROUBLESHOOTING";
                                font-size: 15px;
                                font-weight: 800;
                                color: Cat.green;
                            }
                            Text {
                                text: "root-level diagnostics & system repair  —  use with caution";
                                font-size: 10px;
                                color: Cat.green.with-alpha(0.45);
                            }
                        }

                        VerticalLayout {
                            alignment: center;
                            spacing: 3px;
                            Rectangle { width: 8px; height: 8px; border-radius: 4px; background: Cat.green; }
                            Text { text: "READY"; font-size: 8px; font-weight: 700; color: Cat.green.with-alpha(0.6); horizontal-alignment: center; }
                        }
                    }
                }

                Rectangle { height: 1px; background: Cat.green.with-alpha(0.15); }

                // Title card + card grid centered together as one vertical group
                VerticalLayout {
                    vertical-stretch: 1;
                    alignment: center;
                    padding-left: 40px;
                    padding-right: 40px;
                    padding-top: 20px;
                    padding-bottom: 20px;
                    spacing: 20px;

                    // ── Title card ────────────────────────────────────────────
                    Rectangle {
                        height: 88px;
                        border-radius: 12px;
                        background: Cat.surface0.with-alpha(0.45);
                        border-width: 1px;
                        border-color: Cat.green.with-alpha(0.18);
                        VerticalLayout {
                            alignment: center;
                            padding-left: 24px;
                            padding-right: 24px;
                            spacing: 6px;
                            Text {
                                text: "System Repair Tools";
                                font-size: 17px;
                                font-weight: 700;
                                color: Cat.text;
                                horizontal-alignment: center;
                            }
                            Text {
                                text: "Run these tools to resolve common system issues. Each operation requires root privileges and opens a live terminal output window so you can monitor progress in real time.";
                                font-size: 11px;
                                color: Cat.overlay1;
                                horizontal-alignment: center;
                                wrap: word-wrap;
                            }
                        }
                    }

                    // ── 2×2 card grid (GridLayout guarantees equal column widths) ──
                    GridLayout {
                        spacing: 14px;

                        // ── Card: Update Mirrorlists ──────────────────────
                        Rectangle {
                            row: 0; col: 0;
                            height: 112px;
                            border-radius: 10px;
                            background: mir-ta.has-hover ? Cat.surface0.with-alpha(0.7) : Cat.surface0.with-alpha(0.45);
                            animate background { duration: 80ms; }

                            // hover area BEHIND content
                            mir-ta := TouchArea {}

                            HorizontalLayout {
                                Rectangle {
                                    width: 3px;
                                    background: Cat.teal;
                                }
                                HorizontalLayout {
                                    padding-left: 18px;
                                    padding-right: 18px;
                                    padding-top: 14px;
                                    padding-bottom: 14px;
                                    spacing: 14px;

                                    VerticalLayout {
                                        alignment: center;
                                        Rectangle {
                                            width: 46px; height: 46px;
                                            border-radius: 23px;
                                            background: Cat.teal.with-alpha(0.12);
                                            border-width: 1px;
                                            border-color: Cat.teal.with-alpha(0.25);
                                            NavIcon {
                                                d: icon-globe;
                                                icon-color: Cat.teal;
                                                width: 22px; height: 22px;
                                                x: 12px; y: 12px;
                                            }
                                        }
                                    }

                                    VerticalLayout {
                                        horizontal-stretch: 1;
                                        alignment: center;
                                        spacing: 3px;
                                        Text { text: "Update Mirrorlists"; font-size: 13px; font-weight: 700; color: Cat.text; }
                                        Text { text: "Re-rank fastest mirrors via rate-mirrors"; font-size: 11px; color: Cat.overlay1; }
                                        Text { text: "$ rate-mirrors arch | tee /etc/pacman.d/mirrorlist"; font-size: 10px; color: Cat.teal.with-alpha(0.7); overflow: elide; }
                                    }

                                    VerticalLayout {
                                        alignment: center;
                                        Rectangle {
                                            width: 64px; height: 28px;
                                            border-radius: 6px;
                                            background: mir-btn.has-hover ? Cat.teal.with-alpha(0.25) : Cat.teal.with-alpha(0.1);
                                            border-width: 1px;
                                            border-color: Cat.teal.with-alpha(0.35);
                                            animate background { duration: 70ms; }
                                            Text { text: "▶  RUN"; font-size: 10px; font-weight: 700; color: Cat.teal; horizontal-alignment: center; vertical-alignment: center; }
                                            mir-btn := TouchArea { mouse-cursor: pointer; clicked => { root.update-mirrorlists(); } }
                                        }
                                    }
                                }
                            }
                        }

                        // ── Card: Rebuild InitRamFS ───────────────────────
                        Rectangle {
                            row: 0; col: 1;
                            height: 112px;
                            border-radius: 10px;
                            background: ini-ta.has-hover ? Cat.surface0.with-alpha(0.7) : Cat.surface0.with-alpha(0.45);
                            animate background { duration: 80ms; }

                            // hover area BEHIND content
                            ini-ta := TouchArea {}

                            HorizontalLayout {
                                Rectangle {
                                    width: 3px;
                                    background: Cat.mauve;
                                }
                                HorizontalLayout {
                                    padding-left: 18px;
                                    padding-right: 18px;
                                    padding-top: 14px;
                                    padding-bottom: 14px;
                                    spacing: 14px;

                                    VerticalLayout {
                                        alignment: center;
                                        Rectangle {
                                            width: 46px; height: 46px;
                                            border-radius: 23px;
                                            background: Cat.mauve.with-alpha(0.12);
                                            border-width: 1px;
                                            border-color: Cat.mauve.with-alpha(0.25);
                                            NavIcon {
                                                d: icon-cpu;
                                                icon-color: Cat.mauve;
                                                width: 22px; height: 22px;
                                                x: 12px; y: 12px;
                                            }
                                        }
                                    }

                                    VerticalLayout {
                                        horizontal-stretch: 1;
                                        alignment: center;
                                        spacing: 3px;
                                        Text { text: "Rebuild InitRamFS"; font-size: 13px; font-weight: 700; color: Cat.text; }
                                        Text { text: "Regenerate all initramfs images mkinitcpio"; font-size: 11px; color: Cat.overlay1; }
                                        Text { text: "$ mkinitcpio -P"; font-size: 10px; color: Cat.mauve.with-alpha(0.7); overflow: elide; }
                                    }

                                    VerticalLayout {
                                        alignment: center;
                                        Rectangle {
                                            width: 64px; height: 28px;
                                            border-radius: 6px;
                                            background: ini-btn.has-hover ? Cat.mauve.with-alpha(0.25) : Cat.mauve.with-alpha(0.1);
                                            border-width: 1px;
                                            border-color: Cat.mauve.with-alpha(0.35);
                                            animate background { duration: 70ms; }
                                            Text { text: "▶  RUN"; font-size: 10px; font-weight: 700; color: Cat.mauve; horizontal-alignment: center; vertical-alignment: center; }
                                            ini-btn := TouchArea { mouse-cursor: pointer; clicked => { root.rebuild-initramfs(); } }
                                        }
                                    }
                                }
                            }
                        }

                        // ── Card: Fix GnuPG Keyring ───────────────────────
                        Rectangle {
                            row: 1; col: 0;
                            height: 112px;
                            border-radius: 10px;
                            background: key-ta.has-hover ? Cat.surface0.with-alpha(0.7) : Cat.surface0.with-alpha(0.45);
                            animate background { duration: 80ms; }

                            // hover area BEHIND content
                            key-ta := TouchArea {}

                            HorizontalLayout {
                                Rectangle {
                                    width: 3px;
                                    background: Cat.yellow;
                                }
                                HorizontalLayout {
                                    padding-left: 18px;
                                    padding-right: 18px;
                                    padding-top: 14px;
                                    padding-bottom: 14px;
                                    spacing: 14px;

                                    VerticalLayout {
                                        alignment: center;
                                        Rectangle {
                                            width: 46px; height: 46px;
                                            border-radius: 23px;
                                            background: Cat.yellow.with-alpha(0.12);
                                            border-width: 1px;
                                            border-color: Cat.yellow.with-alpha(0.25);
                                            NavIcon {
                                                d: icon-refresh;
                                                icon-color: Cat.yellow;
                                                width: 22px; height: 22px;
                                                x: 12px; y: 12px;
                                            }
                                        }
                                    }

                                    VerticalLayout {
                                        horizontal-stretch: 1;
                                        alignment: center;
                                        spacing: 3px;
                                        Text { text: "Fix GnuPG Keyring"; font-size: 13px; font-weight: 700; color: Cat.text; }
                                        Text { text: "Reset and repopulate pacman keys"; font-size: 11px; color: Cat.overlay1; }
                                        Text { text: "$ pacman-key --init && pacman-key --populate"; font-size: 10px; color: Cat.yellow.with-alpha(0.7); overflow: elide; }
                                    }

                                    VerticalLayout {
                                        alignment: center;
                                        Rectangle {
                                            width: 64px; height: 28px;
                                            border-radius: 6px;
                                            background: key-btn.has-hover ? Cat.yellow.with-alpha(0.25) : Cat.yellow.with-alpha(0.1);
                                            border-width: 1px;
                                            border-color: Cat.yellow.with-alpha(0.35);
                                            animate background { duration: 70ms; }
                                            Text { text: "▶  RUN"; font-size: 10px; font-weight: 700; color: Cat.yellow; horizontal-alignment: center; vertical-alignment: center; }
                                            key-btn := TouchArea { mouse-cursor: pointer; clicked => { root.fix-keyring(); } }
                                        }
                                    }
                                }
                            }
                        }

                        // ── Card: Rebuild Grub ────────────────────────────
                        Rectangle {
                            row: 1; col: 1;
                            height: 112px;
                            border-radius: 10px;
                            background: grb-ta.has-hover ? Cat.surface0.with-alpha(0.7) : Cat.surface0.with-alpha(0.45);
                            animate background { duration: 80ms; }

                            // hover area BEHIND content
                            grb-ta := TouchArea {}

                            HorizontalLayout {
                                Rectangle {
                                    width: 3px;
                                    background: Cat.peach;
                                }
                                HorizontalLayout {
                                    padding-left: 18px;
                                    padding-right: 18px;
                                    padding-top: 14px;
                                    padding-bottom: 14px;
                                    spacing: 14px;

                                    VerticalLayout {
                                        alignment: center;
                                        Rectangle {
                                            width: 46px; height: 46px;
                                            border-radius: 23px;
                                            background: Cat.peach.with-alpha(0.12);
                                            border-width: 1px;
                                            border-color: Cat.peach.with-alpha(0.25);
                                            NavIcon {
                                                d: icon-chip;
                                                icon-color: Cat.peach;
                                                width: 22px; height: 22px;
                                                x: 12px; y: 12px;
                                            }
                                        }
                                    }

                                    VerticalLayout {
                                        horizontal-stretch: 1;
                                        alignment: center;
                                        spacing: 3px;
                                        Text { text: "Rebuild Grub"; font-size: 13px; font-weight: 700; color: Cat.text; }
                                        Text { text: "Regenerate GRUB bootloader config"; font-size: 11px; color: Cat.overlay1; }
                                        Text { text: "$ update-grub"; font-size: 10px; color: Cat.peach.with-alpha(0.7); overflow: elide; }
                                    }

                                    VerticalLayout {
                                        alignment: center;
                                        Rectangle {
                                            width: 64px; height: 28px;
                                            border-radius: 6px;
                                            background: grb-btn.has-hover ? Cat.peach.with-alpha(0.25) : Cat.peach.with-alpha(0.1);
                                            border-width: 1px;
                                            border-color: Cat.peach.with-alpha(0.35);
                                            animate background { duration: 70ms; }
                                            Text { text: "▶  RUN"; font-size: 10px; font-weight: 700; color: Cat.peach; horizontal-alignment: center; vertical-alignment: center; }
                                            grb-btn := TouchArea { mouse-cursor: pointer; clicked => { root.rebuild-grub(); } }
                                        }
                                    }
                                }
                            }
                        }
                    } // end GridLayout

                    // Bottom info strip
                    Rectangle {
                        height: 36px;
                        border-radius: 8px;
                        background: Cat.crust.with-alpha(0.6);
                        border-width: 1px;
                        border-color: Cat.surface0;

                        HorizontalLayout {
                            padding-left: 16px;
                            padding-right: 16px;
                            spacing: 8px;

                            VerticalLayout {
                                alignment: center;
                                NavIcon { d: icon-chip; icon-color: Cat.overlay0; width: 13px; height: 13px; }
                            }
                            VerticalLayout {
                                alignment: center;
                                horizontal-stretch: 1;
                                Text {
                                    text: "All operations run with root privileges via pkexec / sudo — system-wide changes take effect immediately";
                                    font-size: 10px;
                                    color: Cat.overlay0;
                                }
                            }
                        }
                    }
                }
            }

            if view == 9: ScrollView {
                vertical-stretch: 1;

                VerticalLayout {
                    padding: 4px;
                    spacing: 20px;

                    // Stat cards
                    VerticalLayout {
                        spacing: 8px;
                        SectionLabel { section-title: "SYSTEM OVERVIEW"; }

                        HorizontalLayout {
                            spacing: 10px;

                            Rectangle {
                                horizontal-stretch: 1;
                                height: 82px;
                                border-radius: 10px;
                                background: Cat.blue.with-alpha(0.1);
                                border-width: 1px;
                                border-color: Cat.blue.with-alpha(0.25);

                                VerticalLayout {
                                    alignment: center;
                                    spacing: 4px;

                                    if loading: Rectangle { width: 52px; height: 20px; border-radius: 5px; background: Cat.blue.with-alpha(0.18); x: (parent.width - 52px) / 2; }
                                    if !loading: Text {
                                        text: stats.pacman-count;
                                        font-size: 28px;
                                        font-weight: 700;
                                        color: Cat.blue;
                                        horizontal-alignment: center;
                                    }
                                    Text {
                                        text: "Pacman Packages";
                                        font-size: 11px;
                                        color: Cat.overlay1;
                                        horizontal-alignment: center;
                                    }
                                }
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                                height: 82px;
                                border-radius: 10px;
                                background: Cat.teal.with-alpha(0.1);
                                border-width: 1px;
                                border-color: Cat.teal.with-alpha(0.25);

                                VerticalLayout {
                                    alignment: center;
                                    spacing: 4px;

                                    if loading: Rectangle { width: 40px; height: 20px; border-radius: 5px; background: Cat.teal.with-alpha(0.18); x: (parent.width - 40px) / 2; }
                                    if !loading: Text {
                                        text: stats.flatpak-count;
                                        font-size: 28px;
                                        font-weight: 700;
                                        color: Cat.teal;
                                        horizontal-alignment: center;
                                    }
                                    Text {
                                        text: "Flatpak Apps";
                                        font-size: 11px;
                                        color: Cat.overlay1;
                                        horizontal-alignment: center;
                                    }
                                }
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                                height: 82px;
                                border-radius: 10px;
                                background: stats.orphan-count > 0 ? Cat.yellow.with-alpha(0.1) : Cat.surface0.with-alpha(0.35);
                                border-width: 1px;
                                border-color: stats.orphan-count > 0 ? Cat.yellow.with-alpha(0.25) : Cat.surface0.with-alpha(0.2);

                                VerticalLayout {
                                    alignment: center;
                                    spacing: 4px;

                                    if loading: Rectangle { width: 36px; height: 20px; border-radius: 5px; background: Cat.overlay0.with-alpha(0.12); x: (parent.width - 36px) / 2; }
                                    if !loading: Text {
                                        text: stats.orphan-count;
                                        font-size: 28px;
                                        font-weight: 700;
                                        color: stats.orphan-count > 0 ? Cat.yellow : Cat.overlay0;
                                        horizontal-alignment: center;
                                    }
                                    Text {
                                        text: "Orphaned";
                                        font-size: 11px;
                                        color: Cat.overlay1;
                                        horizontal-alignment: center;
                                    }
                                }
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                                height: 82px;
                                border-radius: 10px;
                                background: stats.update-count > 0 ? Cat.peach.with-alpha(0.1) : Cat.surface0.with-alpha(0.35);
                                border-width: 1px;
                                border-color: stats.update-count > 0 ? Cat.peach.with-alpha(0.25) : Cat.surface0.with-alpha(0.2);

                                VerticalLayout {
                                    alignment: center;
                                    spacing: 4px;

                                    if loading: Rectangle { width: 36px; height: 20px; border-radius: 5px; background: Cat.overlay0.with-alpha(0.12); x: (parent.width - 36px) / 2; }
                                    if !loading: Text {
                                        text: stats.update-count;
                                        font-size: 28px;
                                        font-weight: 700;
                                        color: stats.update-count > 0 ? Cat.peach : Cat.overlay0;
                                        horizontal-alignment: center;
                                    }
                                    Text {
                                        text: "Updates";
                                        font-size: 11px;
                                        color: Cat.overlay1;
                                        horizontal-alignment: center;
                                    }
                                }
                            }
                        }
                    }

                    // Quick actions
                    VerticalLayout {
                        spacing: 8px;
                        SectionLabel { section-title: "QUICK ACTIONS"; }

                        HorizontalLayout {
                            spacing: 10px;

                            Rectangle {
                                horizontal-stretch: 1;
                                height: 66px;
                                border-radius: 10px;
                                background: home-sync-touch.has-hover ? Cat.mauve.with-alpha(0.18) : Cat.surface0.with-alpha(0.4);
                                opacity: busy ? 0.5 : 1.0;
                                animate background { duration: 100ms; }

                                home-sync-touch := TouchArea {
                                    mouse-cursor: busy ? default : pointer;
                                    clicked => { if !busy { root.sync-databases(); } }
                                }

                                VerticalLayout {
                                    padding-left: 16px;
                                    padding-right: 16px;
                                    alignment: center;
                                    spacing: 3px;

                                    Text {
                                        text: "Sync & Update";
                                        font-size: 13px;
                                        font-weight: 600;
                                        color: Cat.mauve;
                                    }
                                    if loading: Rectangle { width: 110px; height: 11px; border-radius: 3px; background: Cat.overlay0.with-alpha(0.1); }
                                    if !loading: Text {
                                        text: stats.update-count > 0 ? stats.update-count + " updates pending" : "System is up to date";
                                        font-size: 11px;
                                        color: Cat.overlay0;
                                    }
                                }
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                                height: 66px;
                                border-radius: 10px;
                                background: home-cache-touch.has-hover ? Cat.blue.with-alpha(0.15) : Cat.surface0.with-alpha(0.4);
                                animate background { duration: 100ms; }

                                home-cache-touch := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.clean-package-cache(); }
                                }

                                VerticalLayout {
                                    padding-left: 16px;
                                    padding-right: 16px;
                                    alignment: center;
                                    spacing: 3px;

                                    Text {
                                        text: "Clean Cache";
                                        font-size: 13px;
                                        font-weight: 600;
                                        color: Cat.blue;
                                    }
                                    if loading: Rectangle { width: 70px; height: 11px; border-radius: 3px; background: Cat.overlay0.with-alpha(0.1); }
                                    if !loading: Text {
                                        text: stats.cache-size + " used";
                                        font-size: 11px;
                                        color: Cat.overlay0;
                                    }
                                }
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                                height: 66px;
                                border-radius: 10px;
                                background: home-orphan-touch.has-hover ? (stats.orphan-count > 0 ? Cat.red.with-alpha(0.18) : Cat.surface0.with-alpha(0.5)) : Cat.surface0.with-alpha(0.4);
                                opacity: stats.orphan-count == 0 ? 0.5 : 1.0;
                                animate background { duration: 100ms; }

                                home-orphan-touch := TouchArea {
                                    mouse-cursor: stats.orphan-count > 0 ? pointer : default;
                                    clicked => { if stats.orphan-count > 0 { root.remove-orphans(); } }
                                }

                                VerticalLayout {
                                    padding-left: 16px;
                                    padding-right: 16px;
                                    alignment: center;
                                    spacing: 3px;

                                    Text {
                                        text: "Remove Orphans";
                                        font-size: 13px;
                                        font-weight: 600;
                                        color: stats.orphan-count > 0 ? Cat.red : Cat.overlay0;
                                    }
                                    if loading: Rectangle { width: 130px; height: 11px; border-radius: 3px; background: Cat.overlay0.with-alpha(0.1); }
                                    if !loading: Text {
                                        text: stats.orphan-count + " orphaned packages";
                                        font-size: 11px;
                                        color: Cat.overlay0;
                                    }
                                }
                            }
                        }
                    }

                    // ── SYSTEM ──────────────────────────────────────────────
                    VerticalLayout {
                        spacing: 8px;

                        SectionLabel { section-title: "SYSTEM"; }

                        // Geeky system card
                        Rectangle {
                            border-radius: 12px;
                            background: Cat.crust.with-alpha(0.55);
                            border-width: 1px;
                            border-color: Cat.mauve.with-alpha(0.12);
                            clip: true;

                            // Subtle grid watermark
                            Rectangle {
                                x: parent.width - 140px;
                                y: -10px;
                                width: 140px;
                                height: parent.height + 20px;
                                background: Cat.mauve.with-alpha(0.025);
                                border-radius: 0;
                            }

                            VerticalLayout {
                                padding: 16px;
                                spacing: 0;

                                // Header row: hostname + distro badge
                                HorizontalLayout {
                                    spacing: 10px;

                                    // Terminal chevron
                                    Text {
                                        text: "▶";
                                        font-size: 10px;
                                        color: Cat.mauve.with-alpha(0.7);
                                        vertical-alignment: center;
                                    }

                                    Text {
                                        text: sys-info.hostname != "" ? sys-info.hostname : "localhost";
                                        font-size: 13px;
                                        font-weight: 700;
                                        color: Cat.mauve;
                                        vertical-alignment: center;
                                        horizontal-stretch: 1;
                                    }

                                    if sys-info.distro != "": Rectangle {
                                        width: distro-lbl.preferred-width + 14px;
                                        height: 20px;
                                        border-radius: 4px;
                                        background: Cat.mauve.with-alpha(0.1);
                                        border-width: 1px;
                                        border-color: Cat.mauve.with-alpha(0.25);
                                        distro-lbl := Text {
                                            text: sys-info.distro;
                                            font-size: 9.5px;
                                            font-weight: 600;
                                            color: Cat.mauve;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                }

                                Rectangle { height: 10px; }
                                Rectangle { height: 1px; background: Cat.mauve.with-alpha(0.08); }
                                Rectangle { height: 10px; }

                                // Grid of specs: 2 columns
                                HorizontalLayout {
                                    spacing: 24px;

                                    VerticalLayout {
                                        horizontal-stretch: 1;
                                        spacing: 9px;

                                        HorizontalLayout {
                                            spacing: 8px;
                                            Text { text: "OS "; font-size: 9px; font-weight: 700; color: Cat.overlay0; letter-spacing: 0.6px; vertical-alignment: center; width: 52px; }
                                            Text { text: sys-info.kernel; font-size: 10.5px; font-weight: 500; color: Cat.teal; vertical-alignment: center; horizontal-stretch: 1; overflow: elide; }
                                        }

                                        HorizontalLayout {
                                            spacing: 8px;
                                            Text { text: "CPU"; font-size: 9px; font-weight: 700; color: Cat.overlay0; letter-spacing: 0.6px; vertical-alignment: center; width: 52px; }
                                            Text { text: sys-info.cpu; font-size: 10.5px; font-weight: 500; color: Cat.text; vertical-alignment: center; horizontal-stretch: 1; overflow: elide; }
                                        }

                                        HorizontalLayout {
                                            spacing: 8px;
                                            Text { text: "MEM"; font-size: 9px; font-weight: 700; color: Cat.overlay0; letter-spacing: 0.6px; vertical-alignment: center; width: 52px; }
                                            Text { text: sys-info.ram-used + " / " + sys-info.ram-total; font-size: 10.5px; font-weight: 500; color: Cat.green; vertical-alignment: center; horizontal-stretch: 1; }
                                        }
                                    }

                                    VerticalLayout {
                                        horizontal-stretch: 1;
                                        spacing: 9px;

                                        HorizontalLayout {
                                            spacing: 8px;
                                            Text { text: "UP "; font-size: 9px; font-weight: 700; color: Cat.overlay0; letter-spacing: 0.6px; vertical-alignment: center; width: 52px; }
                                            Text { text: sys-info.uptime; font-size: 10.5px; font-weight: 500; color: Cat.yellow; vertical-alignment: center; horizontal-stretch: 1; }
                                        }

                                        if sys-info.gpu != "": HorizontalLayout {
                                            spacing: 8px;
                                            Text { text: "GPU"; font-size: 9px; font-weight: 700; color: Cat.overlay0; letter-spacing: 0.6px; vertical-alignment: center; width: 52px; }
                                            Text { text: sys-info.gpu; font-size: 10.5px; font-weight: 500; color: Cat.text; vertical-alignment: center; horizontal-stretch: 1; overflow: elide; }
                                        }

                                        if sys-info.disk-total != "": HorizontalLayout {
                                            spacing: 8px;
                                            Text { text: "DSK"; font-size: 9px; font-weight: 700; color: Cat.overlay0; letter-spacing: 0.6px; vertical-alignment: center; width: 52px; }
                                            Text { text: sys-info.disk-used + " / " + sys-info.disk-total; font-size: 10.5px; font-weight: 500; color: Cat.sapphire; vertical-alignment: center; horizontal-stretch: 1; }
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // ── RECENT ACTIVITY ──────────────────────────────────────
                    VerticalLayout {
                        spacing: 8px;

                        SectionLabel { section-title: "RECENT ACTIVITY"; }

                        VerticalLayout {
                            spacing: 0;

                            if activity-items.length == 0: Rectangle {
                                height: 44px;
                                border-radius: 8px;
                                background: Cat.surface0.with-alpha(0.3);
                                Text {
                                    text: "No activity found";
                                    font-size: 11px;
                                    color: Cat.overlay0;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }

                            for item[i] in activity-items: Rectangle {
                                height: 38px;

                                HorizontalLayout {
                                    padding-left: 12px;
                                    padding-right: 12px;
                                    spacing: 10px;

                                    Rectangle {
                                        width: action-lbl.preferred-width + 12px;
                                        height: 18px;
                                        border-radius: 5px;
                                        y: (parent.height - 18px) / 2;
                                        background: item.action == "installed" ? Cat.green.with-alpha(0.18)
                                            : item.action == "removed" ? Cat.red.with-alpha(0.18)
                                            : Cat.peach.with-alpha(0.18);

                                        action-lbl := Text {
                                            text: item.action;
                                            font-size: 9.5px;
                                            font-weight: 600;
                                            color: item.action == "installed" ? Cat.green
                                                : item.action == "removed" ? Cat.red
                                                : Cat.peach;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }

                                    Text {
                                        text: item.package;
                                        font-size: 12px;
                                        font-weight: 500;
                                        color: Cat.text;
                                        vertical-alignment: center;
                                        horizontal-stretch: 1;
                                        overflow: elide;
                                    }

                                    Text {
                                        text: item.date;
                                        font-size: 10px;
                                        color: Cat.overlay0;
                                        vertical-alignment: center;
                                    }
                                }

                                if i < activity-items.length - 1: Rectangle {
                                    x: 12px;
                                    y: parent.height - 1px;
                                    width: parent.width - 24px;
                                    height: 1px;
                                    background: Cat.surface0;
                                    opacity: 0.5;
                                }
                            }
                        }
                    }
                }

            // Catch-all stretch: keeps all content pinned to top when no view provides a flex child
            if view == 2 || view == 5 || view == 3 || view == 4: Rectangle { vertical-stretch: 1; }
        }
    }

    // ── Top-right loading / progress indicator ──────────────────────────────
    if loading || busy: Rectangle {
        x: parent.width - self.width - 16px;
        y: 12px;
        width: 228px;
        height: 44px;
        border-radius: 8px;
        background: Cat.surface0.with-alpha(0.96);
        border-width: 1px;
        border-color: Cat.mauve.with-alpha(0.3);
        drop-shadow-blur: 14px;
        drop-shadow-color: Cat.crust.with-alpha(0.45);
        drop-shadow-offset-y: 2px;
        clip: true;

        // Left accent stripe
        Rectangle {
            x: 0; y: 0;
            width: 2px; height: parent.height;
            background: Cat.mauve.with-alpha(0.65);
        }

        // ── Text row ─────────────────────────────────────────────────
        HorizontalLayout {
            padding-left: 12px;
            padding-right: 10px;
            padding-top: 7px;
            padding-bottom: 20px;   // leaves 12px for the fill bar below
            spacing: 5px;

            Text {
                text: ">";
                font-size: 10px;
                font-weight: 800;
                color: Cat.mauve;
                vertical-alignment: center;
            }

            Text {
                text: progress-text != "" ? progress-text :
                      busy ? "running operation..." : "resolving packages...";
                font-size: 10px;
                color: Cat.subtext0;
                vertical-alignment: center;
                horizontal-stretch: 1;
                overflow: elide;
            }

            if busy && progress > 0: Text {
                text: progress + "%";
                font-size: 10px;
                font-weight: 700;
                color: Cat.mauve;
                vertical-alignment: center;
            }
        }

        // ── Fill bar — spans full chip width, pinned to bottom ───────
        Rectangle {
            x: 0;
            y: parent.height - 12px;
            width: parent.width;
            height: 12px;
            clip: true;
            background: transparent;

            // Dim background blocks (always visible)
            Text {
                text: "░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░";
                font-size: 8px;
                color: Cat.surface1;
                vertical-alignment: center;
                overflow: clip;
            }

            // Indeterminate shimmer — sweeps left→right on a loop
            if !busy || progress == 0: Rectangle {
                clip: true;
                x: root._load-shimmer * parent.width;
                y: 0;
                height: parent.height;
                width: parent.width * 0.38;

                Text {
                    text: "████████████████████████████████████████████";
                    font-size: 8px;
                    color: Cat.mauve.with-alpha(0.85);
                    vertical-alignment: center;
                    overflow: clip;
                }
            }

            // Determinate fill — grows right as progress increases
            if busy && progress > 0: Rectangle {
                clip: true;
                x: 0; y: 0;
                height: parent.height;
                width: parent.width * progress / 100;
                animate width { duration: 350ms; easing: ease-out; }

                Text {
                    text: "████████████████████████████████████████████";
                    font-size: 8px;
                    color: Cat.mauve;
                    vertical-alignment: center;
                    overflow: clip;
                }
            }
        }
    }

    if selected-count > 0: Rectangle {
        x: (parent.width - 360px) / 2;
        y: parent.height - 64px;
        width: 360px;
        height: 44px;
        border-radius: 22px;
        background: Cat.surface0;
        drop-shadow-blur: 20px;
        drop-shadow-color: Cat.crust.with-alpha(0.5);
        drop-shadow-offset-y: 4px;
        border-width: 1px;
        border-color: Cat.surface1;

        HorizontalLayout {
            padding-left: 16px;
            padding-right: 10px;
            spacing: 8px;

            Text {
                text: selected-count + " selected";
                font-size: 12px;
                font-weight: 500;
                color: Cat.text;
                vertical-alignment: center;
            }

            Rectangle { horizontal-stretch: 1; }

            Rectangle {
                width: 48px;
                height: 28px;
                border-radius: 6px;
                background: fab-clear-touch.has-hover ? Cat.surface1 : transparent;

                Text {
                    text: "Clear";
                    font-size: 11px;
                    color: Cat.subtext0;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                fab-clear-touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => { root.clear-selection(); }
                }
            }

            Btn {
                label: "Install";
                primary: selected-uninstalled-count > 0;
                enabled: selected-uninstalled-count > 0;
                min-width: 60px;
                clicked => {
                    if view == 10 { root.batch-flatpak-install(); }
                    else { root.bulk-install(); }
                }
            }

            Btn {
                label: "Remove";
                danger: selected-installed-count > 0;
                enabled: selected-installed-count > 0;
                min-width: 64px;
                clicked => {
                    if view == 10 { root.batch-flatpak-remove(); }
                    else { root.bulk-remove(); }
                }
            }
        }
    }

    if show-addons-modal: Rectangle {
        width: 100%;
        height: 100%;
        background: Cat.crust.with-alpha(0.65);

        TouchArea { clicked => { root.show-addons-modal = false; root.addon-select-all(false); } }

        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: 500px;
            height: min(560px, parent.height - 60px);
            background: Cat.base;
            border-radius: 14px;
            border-width: 1px;
            border-color: Cat.surface1;
            drop-shadow-blur: 40px;
            drop-shadow-color: Cat.crust.with-alpha(0.7);
            drop-shadow-offset-y: 10px;

            TouchArea {} // intercept backdrop click

            property <bool> all-selected: flatpak-addons.length > 0 && addon-selected-count == flatpak-addons.length;

            VerticalLayout {
                padding: 24px;
                spacing: 0;

                // ── Header ───────────────────────────────────────────────────
                HorizontalLayout {
                    spacing: 10px;

                    NavIcon {
                        d: "M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5";
                        icon-color: Cat.mauve; width: 20px; height: 20px;
                    }
                    Text {
                        text: "Add-Ons & Extensions";
                        font-size: 16px; font-weight: 700; color: Cat.text;
                        vertical-alignment: center; horizontal-stretch: 1;
                    }
                    // Select All button — only when there are uninstalled addons
                    if flatpak-addons.length > 0: Rectangle {
                        width: sel-all-lbl.preferred-width + 24px; height: 28px; border-radius: 6px;
                        background: sel-all-t.has-hover
                            ? (all-selected ? Cat.peach.with-alpha(0.2) : Cat.mauve.with-alpha(0.2))
                            : (all-selected ? Cat.peach.with-alpha(0.1) : Cat.mauve.with-alpha(0.1));
                        border-width: 1px;
                        border-color: all-selected ? Cat.peach.with-alpha(0.4) : Cat.mauve.with-alpha(0.35);
                        animate background { duration: 60ms; }
                        sel-all-lbl := Text {
                            text: all-selected ? "Deselect All" : "Select All";
                            font-size: 11px; font-weight: 600;
                            color: all-selected ? Cat.peach : Cat.mauve;
                            horizontal-alignment: center; vertical-alignment: center;
                        }
                        sel-all-t := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.addon-select-all(!all-selected); }
                        }
                    }
                    Rectangle { width: 6px; }
                    Rectangle {
                        width: 28px; height: 28px; border-radius: 6px;
                        background: close-modal-t.has-hover ? Cat.surface1 : transparent;
                        NavIcon { d: "M18 6L6 18M6 6l12 12"; icon-color: Cat.overlay1; width: 14px; height: 14px; x: 7px; y: 7px; }
                        close-modal-t := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.show-addons-modal = false; root.addon-select-all(false); }
                        }
                    }
                }

                Rectangle { height: 14px; }

                // ── Scrollable list: two sections ────────────────────────────
                ScrollView {
                    vertical-stretch: 1;

                    VerticalLayout {
                        spacing: 0;

                        // ── Section: Available to Install ─────────────────────
                        if flatpak-addons.length > 0: Rectangle {
                            height: 28px;
                            background: Cat.surface0.with-alpha(0.4);
                            border-radius: 6px;
                            HorizontalLayout {
                                padding-left: 10px; padding-right: 10px;
                                Text {
                                    text: "Available to Install";
                                    font-size: 10px; font-weight: 700;
                                    color: Cat.subtext0; vertical-alignment: center;
                                    letter-spacing: 0.5px;
                                }
                            }
                        }

                        for addon[ai] in flatpak-addons: Rectangle {
                            property <bool> is-checked: ai < addon-selected.length && addon-selected[ai];
                            height: 62px;
                            border-radius: 6px;
                            animate background { duration: 60ms; }
                            background: arow-ta.has-hover ? Cat.surface0.with-alpha(0.6) : transparent;

                            arow-ta := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.toggle-addon-selected(ai); }
                            }

                            HorizontalLayout {
                                padding-left: 10px; padding-right: 10px; spacing: 12px;

                                VerticalLayout {
                                    alignment: center;
                                    Rectangle {
                                        width: 18px; height: 18px; border-radius: 5px;
                                        border-width: 1.5px;
                                        border-color: is-checked ? Cat.mauve : Cat.surface2;
                                        background: is-checked ? Cat.mauve : transparent;
                                        animate background { duration: 80ms; }
                                        if is-checked: NavIcon {
                                            d: "M20 6L9 17l-5-5"; icon-color: Cat.crust;
                                            width: 10px; height: 10px; x: 4px; y: 4px;
                                        }
                                    }
                                }

                                VerticalLayout {
                                    horizontal-stretch: 1; spacing: 3px; alignment: center;
                                    Text {
                                        text: addon.display-name;
                                        font-size: 13px; font-weight: 600; color: Cat.text; overflow: elide;
                                    }
                                    Text {
                                        text: addon.description;
                                        font-size: 11px; color: Cat.overlay1; overflow: elide;
                                    }
                                }
                            }

                            if ai < flatpak-addons.length - 1: Rectangle {
                                x: 10px; y: parent.height - 1px;
                                width: parent.width - 20px; height: 1px;
                                background: Cat.surface0; opacity: 0.6;
                            }
                        }

                        // ── Section: Already Installed ────────────────────────
                        if flatpak-addons.length > 0 && flatpak-addons-installed.length > 0: Rectangle {
                            height: 8px; background: transparent;
                        }
                        if flatpak-addons-installed.length > 0: Rectangle {
                            height: 28px;
                            background: Cat.green.with-alpha(0.08);
                            border-radius: 6px;
                            HorizontalLayout {
                                padding-left: 10px; padding-right: 10px;
                                Text {
                                    text: "Already Installed";
                                    font-size: 10px; font-weight: 700;
                                    color: Cat.green; vertical-alignment: center;
                                    letter-spacing: 0.5px;
                                }
                            }
                        }

                        for inst[ii] in flatpak-addons-installed: Rectangle {
                            height: 62px;
                            border-radius: 6px;
                            animate background { duration: 60ms; }
                            background: inst-row-ta.has-hover ? Cat.red.with-alpha(0.06) : transparent;

                            inst-row-ta := TouchArea { mouse-cursor: pointer; }

                            HorizontalLayout {
                                padding-left: 10px; padding-right: 10px; spacing: 12px;

                                // Green installed indicator
                                VerticalLayout {
                                    alignment: center;
                                    Rectangle {
                                        width: 18px; height: 18px; border-radius: 9px;
                                        background: Cat.green.with-alpha(0.15);
                                        NavIcon {
                                            d: "M20 6L9 17l-5-5"; icon-color: Cat.green;
                                            width: 10px; height: 10px; x: 4px; y: 4px;
                                        }
                                    }
                                }

                                VerticalLayout {
                                    horizontal-stretch: 1; spacing: 3px; alignment: center;
                                    Text {
                                        text: inst.display-name;
                                        font-size: 13px; font-weight: 600; color: Cat.subtext1; overflow: elide;
                                    }
                                    Text {
                                        text: inst.description;
                                        font-size: 11px; color: Cat.overlay0; overflow: elide;
                                    }
                                }

                                // Remove button
                                VerticalLayout {
                                    alignment: center;
                                    Rectangle {
                                        width: 64px; height: 26px; border-radius: 6px;
                                        background: rem-ta.has-hover ? Cat.red.with-alpha(0.25) : Cat.red.with-alpha(0.12);
                                        border-width: 1px; border-color: Cat.red.with-alpha(0.3);
                                        animate background { duration: 60ms; }
                                        Text {
                                            text: "Remove";
                                            font-size: 10.5px; font-weight: 600; color: Cat.red;
                                            horizontal-alignment: center; vertical-alignment: center;
                                        }
                                        rem-ta := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => {
                                                root.remove-addon(inst.name);
                                                root.show-addons-modal = false;
                                            }
                                        }
                                    }
                                }
                            }

                            if ii < flatpak-addons-installed.length - 1: Rectangle {
                                x: 10px; y: parent.height - 1px;
                                width: parent.width - 20px; height: 1px;
                                background: Cat.surface0; opacity: 0.6;
                            }
                        }
                    }
                }

                Rectangle { height: 16px; }

                // ── Footer ───────────────────────────────────────────────────
                HorizontalLayout {
                    alignment: end; spacing: 8px;

                    Rectangle {
                        width: 80px; height: 34px; border-radius: 8px;
                        background: close-btn-t.has-hover ? Cat.surface1 : Cat.surface0.with-alpha(0.6);
                        animate background { duration: 60ms; }
                        Text { text: "Close"; font-size: 12px; font-weight: 500; color: Cat.subtext0; horizontal-alignment: center; vertical-alignment: center; }
                        close-btn-t := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.show-addons-modal = false; root.addon-select-all(false); }
                        }
                    }

                    if addon-selected-count > 0: Rectangle {
                        width: inst-sel-lbl.preferred-width + 28px; height: 34px; border-radius: 8px;
                        background: inst-sel-t.has-hover ? Cat.mauve : Cat.mauve.with-alpha(0.85);
                        animate background { duration: 60ms; }
                        inst-sel-lbl := Text {
                            text: "Install " + addon-selected-count + " Add-On" + (addon-selected-count == 1 ? "" : "s");
                            font-size: 12px; font-weight: 600; color: Cat.crust;
                            horizontal-alignment: center; vertical-alignment: center;
                        }
                        inst-sel-t := TouchArea {
                            mouse-cursor: pointer;
                            clicked => {
                                root.install-selected-addons();
                                root.show-addons-modal = false;
                                root.addon-select-all(false);
                            }
                        }
                    }
                }
            }
        }
    }

    if show-local-install: Rectangle {
        width: 100%;
        height: 100%;
        background: Cat.crust.with-alpha(0.7);

        TouchArea { clicked => { root.cancel-local-install(); } }

        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: 440px;
            height: 300px;
            background: Cat.base;
            border-radius: 12px;
            border-width: 1px;
            border-color: Cat.surface0;
            drop-shadow-blur: 30px;
            drop-shadow-color: Cat.crust.with-alpha(0.6);
            drop-shadow-offset-y: 8px;

            TouchArea {}

            VerticalLayout {
                padding: 24px;
                spacing: 16px;

                HorizontalLayout {
                    spacing: 12px;
                    NavIcon {
                        d: icon-package;
                        icon-color: Cat.mauve;
                        width: 24px;
                        height: 24px;
                    }
                    Text {
                        text: "Install Local Package";
                        font-size: 16px;
                        font-weight: 600;
                        color: Cat.text;
                        vertical-alignment: center;
                    }
                }

                Rectangle { height: 1px; background: Cat.surface0; }

                VerticalLayout {
                    spacing: 8px;
                    DetailProperty { prop-label: "Name"; prop-value: local-package.display-name != "" ? local-package.display-name : "Unknown"; }
                    DetailProperty { prop-label: "Version"; prop-value: local-package.version; }
                    DetailProperty { prop-label: "Size"; prop-value: local-package.installed-size; }
                    DetailProperty { prop-label: "File"; prop-value: local-package-path; }
                }

                Rectangle { vertical-stretch: 1; }

                HorizontalLayout {
                    spacing: 8px;
                    alignment: end;

                    Btn {
                        label: "Cancel";
                        clicked => { root.cancel-local-install(); }
                    }

                    Btn {
                        label: "Install";
                        primary: true;
                        enabled: !busy;
                        clicked => { root.install-local-package(local-package-path); }
                    }
                }
            }
        }
    }

    if show-progress-popup: Rectangle {
        width: 100%;
        height: 100%;
        background: Cat.crust.with-alpha(0.65);

        TouchArea {}

        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: min(620px, parent.width - 40px);
            height: min(500px, parent.height - 40px);
            background: Cat.base;
            border-radius: 12px;
            clip: true;
            border-width: 1px;
            border-color: Cat.surface0;
            drop-shadow-blur: 32px;
            drop-shadow-color: Cat.crust.with-alpha(0.7);
            drop-shadow-offset-y: 10px;

            VerticalLayout {
                spacing: 0;

                // Title bar
                Rectangle {
                    height: 48px;
                    background: Cat.mantle;

                    HorizontalLayout {
                        padding-left: 16px;
                        padding-right: 10px;
                        spacing: 10px;

                        if !progress-popup-done: VerticalLayout {
                            alignment: center;
                            Spinner { indeterminate: true; width: 16px; height: 16px; }
                        }

                        if progress-popup-done: VerticalLayout {
                            alignment: center;
                            NavIcon {
                                d: progress-popup-success ? "M20 6L9 17l-5-5" : icon-close;
                                icon-color: progress-popup-success ? Cat.green : Cat.red;
                                width: 16px;
                                height: 16px;
                            }
                        }

                        Text {
                            text: progress-popup-title;
                            font-size: 14px;
                            font-weight: 600;
                            color: Cat.text;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                            overflow: elide;
                        }

                        if !progress-popup-done: VerticalLayout {
                            alignment: center;
                            Rectangle {
                                width: cancel-label.preferred-width + 20px;
                                height: 26px;
                                border-radius: 6px;
                                background: cancel-touch.has-hover ? Cat.red.with-alpha(0.2) : Cat.surface0;
                                animate background { duration: 80ms; }

                                cancel-label := Text {
                                    text: "Cancel";
                                    font-size: 11px;
                                    font-weight: 600;
                                    color: cancel-touch.has-hover ? Cat.red : Cat.overlay0;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                    animate color { duration: 80ms; }
                                }

                                cancel-touch := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.cancel-operation(); }
                                }
                            }
                        }

                        if progress-popup-done: VerticalLayout {
                            alignment: center;
                            Rectangle {
                                width: 28px;
                                height: 28px;
                                border-radius: 6px;
                                background: prog-close-x.has-hover ? Cat.surface0 : transparent;

                                NavIcon {
                                    d: icon-close;
                                    icon-color: Cat.overlay0;
                                    width: 12px;
                                    height: 12px;
                                    x: 8px;
                                    y: 8px;
                                }

                                prog-close-x := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.close-progress-popup(); }
                                }
                            }
                        }
                    }
                }

                // Progress bar + stage
                Rectangle {
                    height: 50px;
                    background: Cat.mantle;

                    Rectangle {
                        y: 0;
                        width: 100%;
                        height: 1px;
                        background: Cat.surface0;
                        opacity: 0.6;
                    }

                    VerticalLayout {
                        padding-left: 16px;
                        padding-right: 16px;
                        padding-top: 10px;
                        spacing: 6px;

                        Rectangle {
                            height: 5px;
                            border-radius: 3px;
                            background: Cat.surface0;

                            Rectangle {
                                width: progress-popup-done ? parent.width :
                                       (progress-popup-percent > 0 ? parent.width * progress-popup-percent / 100 : 4px);
                                height: 100%;
                                border-radius: 3px;
                                background: progress-popup-done ?
                                            (progress-popup-success ? Cat.green : Cat.red) : Cat.mauve;
                                animate width { duration: 300ms; easing: ease-in-out; }
                            }
                        }

                        HorizontalLayout {
                            Text {
                                text: progress-popup-done ?
                                      (progress-popup-success ? "Completed successfully" : "Operation failed") :
                                      progress-popup-stage;
                                font-size: 11px;
                                color: progress-popup-done ?
                                       (progress-popup-success ? Cat.green : Cat.red) : Cat.overlay0;
                                overflow: elide;
                                horizontal-stretch: 1;
                            }

                            Text {
                                text: progress-popup-done ? "done" : progress-popup-percent + "%";
                                font-size: 11px;
                                font-weight: 600;
                                color: progress-popup-done ?
                                       (progress-popup-success ? Cat.green : Cat.red) : Cat.mauve;
                            }
                        }
                    }
                }

                Rectangle { height: 1px; background: Cat.surface0; opacity: 0.5; }

                // Live log output — always visible
                Rectangle {
                    vertical-stretch: 1;
                    background: Cat.crust;

                    ScrollView {
                        // _scroll-tick dependency forces re-eval every 80ms while live
                        viewport-y: { let _ = root._scroll-tick; min(0px, self.visible-height - self.viewport-height); }

                        VerticalLayout {
                            padding: 12px;

                            Text {
                                text: progress-popup-output;
                                font-size: 11.5px;
                                font-family: "monospace";
                                color: Cat.text;
                                opacity: 0.85;
                                wrap: word-wrap;
                            }
                        }
                    }
                }

                // User input prompt (conflict resolution / password / questions)
                if progress-popup-show-input: Rectangle {
                    height: 60px;
                    background: Cat.yellow.with-alpha(0.06);

                    Rectangle { y: 0; width: 100%; height: 1px; background: Cat.surface0; opacity: 0.5; }

                    VerticalLayout {
                        padding: 8px;
                        padding-left: 16px;
                        padding-right: 16px;
                        spacing: 3px;

                        Text {
                            text: progress-popup-prompt;
                            font-size: 10.5px;
                            font-weight: 500;
                            color: Cat.yellow;
                            overflow: elide;
                        }

                        Input {
                            placeholder: "Type response and press Enter...";
                            accepted(text) => {
                                root.progress-popup-send-input(text);
                                self.text = "";
                            }
                        }
                    }
                }

                // Footer when done
                if progress-popup-done: Rectangle {
                    height: 46px;
                    background: progress-popup-success ? Cat.green.with-alpha(0.06) : Cat.red.with-alpha(0.06);

                    Rectangle { y: 0; width: 100%; height: 1px; background: Cat.surface0; opacity: 0.4; }

                    HorizontalLayout {
                        padding-left: 16px;
                        padding-right: 16px;
                        alignment: end;

                        VerticalLayout {
                            alignment: center;
                            Rectangle {
                                width: done-close-label.preferred-width + 28px;
                                height: 28px;
                                border-radius: 7px;
                                background: done-close-touch.has-hover ? Cat.mauve : Cat.mauve.with-alpha(0.85);
                                animate background { duration: 80ms; }

                                done-close-label := Text {
                                    text: "Close";
                                    font-size: 12px;
                                    font-weight: 600;
                                    color: Cat.crust;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }

                                done-close-touch := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.close-progress-popup(); }
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    // ── Flatpak remove confirmation dialog ────────────────────────────────────
    if fp-confirm-open: Rectangle {
        width: 100%; height: 100%;
        background: Cat.crust.with-alpha(0.70);
        TouchArea {}

        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: 400px; height: 210px;
            background: Cat.base;
            border-radius: 14px;
            border-width: 1px;
            border-color: Cat.red.with-alpha(0.3);
            drop-shadow-blur: 28px;
            drop-shadow-color: Cat.crust.with-alpha(0.6);
            drop-shadow-offset-y: 8px;

            VerticalLayout {
                padding: 24px; spacing: 16px;

                // Header
                HorizontalLayout {
                    spacing: 10px;
                    VerticalLayout {
                        alignment: center;
                        Rectangle {
                            width: 36px; height: 36px; border-radius: 10px;
                            background: Cat.red.with-alpha(0.12);
                            NavIcon { d: "M3 6h18M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6M8 6V4a2 2 0 012-2h4a2 2 0 012 2v2"; icon-color: Cat.red; width: 18px; height: 18px; x: 9px; y: 9px; }
                        }
                    }
                    VerticalLayout {
                        alignment: center; horizontal-stretch: 1; spacing: 3px;
                        Text { text: "Remove " + fp-confirm-name + "?"; font-size: 14px; font-weight: 700; color: Cat.text; overflow: elide; }
                        Text { text: "This will uninstall the application from your system."; font-size: 11px; color: Cat.overlay1; }
                    }
                }

                // Data question
                Rectangle {
                    height: 40px; border-radius: 8px;
                    background: Cat.surface0;
                    HorizontalLayout {
                        padding-left: 14px; padding-right: 14px;
                        VerticalLayout {
                            alignment: center; horizontal-stretch: 1;
                            Text { text: "Also remove leftover user data?"; font-size: 12px; color: Cat.subtext1; }
                            Text { text: "Saved settings, files, and app data will be deleted."; font-size: 10px; color: Cat.overlay0; }
                        }
                    }
                }

                // Buttons
                HorizontalLayout {
                    spacing: 8px;

                    // Cancel
                    Rectangle {
                        horizontal-stretch: 1; height: 32px; border-radius: 7px;
                        background: fp-cancel-ta.has-hover ? Cat.surface1 : Cat.surface0;
                        animate background { duration: 60ms; }
                        VerticalLayout { alignment: center; Text { text: "Cancel"; font-size: 12px; font-weight: 600; color: Cat.subtext0; horizontal-alignment: center; } }
                        fp-cancel-ta := TouchArea { mouse-cursor: pointer; clicked => { root.fp-confirm-open = false; } }
                    }

                    // Remove only
                    Rectangle {
                        horizontal-stretch: 1; height: 32px; border-radius: 7px;
                        background: fp-remonly-ta.has-hover ? Cat.red.with-alpha(0.25) : Cat.red.with-alpha(0.14);
                        animate background { duration: 60ms; }
                        VerticalLayout { alignment: center; Text { text: "Remove Only"; font-size: 12px; font-weight: 600; color: Cat.red; horizontal-alignment: center; } }
                        fp-remonly-ta := TouchArea {
                            mouse-cursor: pointer;
                            clicked => {
                                root.fp-confirm-open = false;
                                root.remove-flatpak(root.fp-confirm-id, false);
                            }
                        }
                    }

                    // Remove + Data
                    Rectangle {
                        horizontal-stretch: 1; height: 32px; border-radius: 7px;
                        background: fp-remdata-ta.has-hover ? Cat.red.with-alpha(0.5) : Cat.red.with-alpha(0.3);
                        animate background { duration: 60ms; }
                        VerticalLayout { alignment: center; Text { text: "Remove + Data"; font-size: 12px; font-weight: 700; color: Cat.red; horizontal-alignment: center; } }
                        fp-remdata-ta := TouchArea {
                            mouse-cursor: pointer;
                            clicked => {
                                root.fp-confirm-open = false;
                                root.remove-flatpak(root.fp-confirm-id, true);
                            }
                        }
                    }
                }
            }
        }
    }

    if show-conflict-dialog: Rectangle {
        width: 100%;
        height: 100%;
        background: Cat.crust.with-alpha(0.72);

        TouchArea {}

        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: min(540px, parent.width - 40px);
            height: min(420px, parent.height - 40px);
            background: Cat.base;
            border-radius: 12px;
            clip: true;
            border-width: 1px;
            border-color: Cat.yellow.with-alpha(0.35);
            drop-shadow-blur: 32px;
            drop-shadow-color: Cat.crust.with-alpha(0.7);
            drop-shadow-offset-y: 10px;

            VerticalLayout {
                spacing: 0;

                // Header
                Rectangle {
                    height: 52px;
                    background: Cat.yellow.with-alpha(0.08);

                    Rectangle {
                        y: parent.height - 1px;
                        width: 100%;
                        height: 1px;
                        background: Cat.yellow.with-alpha(0.25);
                    }

                    HorizontalLayout {
                        padding-left: 18px;
                        padding-right: 18px;
                        spacing: 12px;

                        VerticalLayout {
                            alignment: center;
                            NavIcon {
                                d: "M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z M12 9v4 M12 17h.01";
                                icon-color: Cat.yellow;
                                width: 20px;
                                height: 20px;
                            }
                        }

                        VerticalLayout {
                            alignment: center;
                            horizontal-stretch: 1;
                            spacing: 2px;

                            Text {
                                text: "Conflict Detected";
                                font-size: 15px;
                                font-weight: 700;
                                color: Cat.text;
                            }

                            Text {
                                text: conflict-can-force ? "File already exists in filesystem" : "Package dependency conflict";
                                font-size: 11px;
                                color: Cat.yellow;
                            }
                        }
                    }
                }

                // Conflict details (scrollable)
                Rectangle {
                    vertical-stretch: 1;
                    background: Cat.crust;

                    ScrollView {
                        VerticalLayout {
                            padding: 14px;

                            Text {
                                text: conflict-summary;
                                font-size: 11.5px;
                                font-family: "monospace";
                                color: Cat.text;
                                opacity: 0.85;
                                wrap: word-wrap;
                            }
                        }
                    }
                }

                // Advice
                Rectangle {
                    height: 36px;
                    background: conflict-can-force ? Cat.yellow.with-alpha(0.06) : Cat.red.with-alpha(0.06);

                    Rectangle { y: 0; width: 100%; height: 1px; background: Cat.surface0; opacity: 0.5; }

                    Text {
                        x: 18px;
                        width: parent.width - 36px;
                        height: parent.height;
                        text: conflict-can-force
                            ? "Force overwrite will replace the conflicting files. Use with caution."
                            : "This conflict requires manual resolution. Remove the conflicting package first.";
                        font-size: 10.5px;
                        color: conflict-can-force ? Cat.yellow : Cat.red;
                        opacity: 0.8;
                        vertical-alignment: center;
                        wrap: word-wrap;
                        overflow: elide;
                    }
                }

                // Buttons
                Rectangle {
                    height: 52px;
                    background: Cat.mantle;

                    Rectangle { y: 0; width: 100%; height: 1px; background: Cat.surface0; opacity: 0.5; }

                    HorizontalLayout {
                        padding-left: 16px;
                        padding-right: 16px;
                        spacing: 10px;
                        alignment: end;

                        Rectangle {
                            width: cancel-conf-label.preferred-width + 24px;
                            height: 30px;
                            border-radius: 7px;
                            background: cancel-conf-touch.has-hover ? Cat.surface1 : Cat.surface0;
                            animate background { duration: 80ms; }

                            cancel-conf-label := Text {
                                text: "Cancel";
                                font-size: 12px;
                                font-weight: 500;
                                color: Cat.text;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }

                            cancel-conf-touch := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.conflict-cancel(); }
                            }
                        }

                        if conflict-can-force: Rectangle {
                            width: force-label.preferred-width + 24px;
                            height: 30px;
                            border-radius: 7px;
                            background: force-touch.has-hover ? Cat.yellow : Cat.yellow.with-alpha(0.85);
                            animate background { duration: 80ms; }

                            force-label := Text {
                                text: "Force Overwrite";
                                font-size: 12px;
                                font-weight: 700;
                                color: Cat.crust;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }

                            force-touch := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.conflict-force-overwrite(); }
                            }
                        }
                    }
                }
            }
        }
    }

    if show-terminal: Rectangle {
        width: 100%;
        height: 100%;
        background: Cat.crust.with-alpha(0.6);

        TouchArea {}

        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: min(640px, parent.width - 40px);
            height: min(460px, parent.height - 40px);
            border-radius: 12px;
            clip: true;
            background: Cat.base;
            border-width: 1px;
            border-color: Cat.surface0;
            drop-shadow-blur: 30px;
            drop-shadow-color: Cat.crust.with-alpha(0.6);
            drop-shadow-offset-y: 8px;

            VerticalLayout {
                Rectangle {
                    height: 40px;
                    background: Cat.mantle;

                    HorizontalLayout {
                        padding-left: 14px;
                        padding-right: 8px;

                        Text {
                            text: terminal-title;
                            font-size: 13px;
                            font-weight: 500;
                            color: Cat.text;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                            overflow: elide;
                        }

                        VerticalLayout {
                            alignment: center;
                            Rectangle {
                                width: 28px;
                                height: 28px;
                                border-radius: 6px;
                                background: close-touch.has-hover ? Cat.surface0 : transparent;

                                NavIcon {
                                    d: icon-close;
                                    icon-color: Cat.overlay0;
                                    width: 12px;
                                    height: 12px;
                                    x: 8px;
                                    y: 8px;
                                }

                                close-touch := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.terminal-close(); }
                                }
                            }
                        }
                    }
                }

                Rectangle { height: 1px; background: Cat.surface0; }

                Rectangle {
                    vertical-stretch: 1;
                    background: Cat.crust;

                    ScrollView {
                        // _scroll-tick dependency forces re-eval every 80ms while live
                        viewport-y: { let _ = root._scroll-tick; min(0px, self.visible-height - self.viewport-height); }
                        VerticalLayout {
                            padding: 12px;
                            Text {
                                text: terminal-output;
                                font-size: 12px;
                                font-family: "monospace";
                                color: Cat.text;
                                opacity: 0.9;
                                wrap: word-wrap;
                            }
                        }
                    }
                }

                if !terminal-done: Rectangle {
                    height: 38px;
                    background: Cat.mantle;

                    Rectangle { y: 0; width: 100%; height: 1px; background: Cat.surface0; }

                    HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 12px;
                        spacing: 8px;

                        Input {
                            horizontal-stretch: 1;
                            placeholder: "Type response...";
                            accepted(text) => {
                                root.terminal-send-input(text);
                                self.text = "";
                            }
                        }
                    }
                }

                if terminal-done: Rectangle {
                    height: 32px;
                    background: terminal-success ? Cat.green.with-alpha(0.1) : Cat.red.with-alpha(0.1);

                    HorizontalLayout {
                        padding-left: 14px;
                        spacing: 8px;

                        NavIcon {
                            d: terminal-success ? "M20 6L9 17l-5-5" : icon-close;
                            icon-color: terminal-success ? Cat.green : Cat.red;
                            width: 14px;
                            height: 14px;
                        }

                        Text {
                            text: terminal-success ? "Completed successfully" : "Operation failed";
                            font-size: 11px;
                            font-weight: 500;
                            color: terminal-success ? Cat.green : Cat.red;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }
}
}
