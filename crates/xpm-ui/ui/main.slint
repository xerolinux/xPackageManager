    property <string> icon-image: "M21 19V5a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2zM8.5 10a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zM21 15l-5-5L5 21";
    property <string> icon-globe: "M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20zM2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z";
    property <string> icon-file: "M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7z";
    property <string> icon-graduation: "M22 10v6M2 10l10-5 10 5-10 5z M6 12v5c3 3 9 3 12 0v-5";
    property <string> icon-flask: "M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.13A1 1 0 0 0 5.596 22h12.808a1 1 0 0 0 .876-1.87l-5.07-9.707A2 2 0 0 1 14 9.527V2M8.5 2h7";
    property <string> icon-cpu: "M4 4h16v16H4zM9 9h6v6H9zM9 1v3M15 1v3M9 20v3M15 20v3M20 9h3M20 14h3M1 9h3M1 14h3";
    property <string> icon-wrench: "M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94z";
    property <string> icon-refresh: "M1 4v6h6M23 20v-6h-6M20.49 9A9 9 0 0 0 5.64 5.64L1 10M23 14l-4.64 4.36A9 9 0 0 1 3.51 15";

    property <string> icon-flatpak: "M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5";

    function get-list() -> [PackageData] {
        if view == 0 { return installed-packages; }
        if view == 1 { return update-packages; }
        if view == 10 { return remote-apps; }
        if view == 8 { return repo-packages; }
        return [];
    }

    Rectangle {
        x: 0;
        y: 0;
        width: 200px;
        height: parent.height;
        background: Cat.mantle;

        VerticalLayout {
            padding: 12px;
            spacing: 2px;

            HorizontalLayout {
                padding-left: 4px;
                padding-bottom: 4px;
                spacing: 8px;

                VerticalLayout {
                    alignment: center;
                    NavIcon {
                        d: icon-package;
                        icon-color: Cat.mauve;
                        width: 20px;
                        height: 20px;
                    }
                }

                Text {
                    text: "xPM";
                    font-size: 17px;
                    font-weight: 700;
                    color: Cat.text;
                    vertical-alignment: center;
                }
            }

            Rectangle { height: 10px; }

            Input {
                text <=> search-text;
                placeholder: "Search packages...";
                accepted(t) => {
                    if search-text != "" {
                        view = 2;
                        root.search(search-text);
                    }
                }
            }

            Rectangle { height: 12px; }
            SectionLabel { section-title: "LIBRARY"; }
            Rectangle { height: 4px; }

            NavButton {
                icon-path: icon-home;
                label: "Home";
                active: view == 9;
                clicked => { view = 9; }
            }

            NavButton {
                icon-path: icon-list;
                icon-filled: true;
                label: "Installed";
                active: view == 0;
                clicked => { view = 0; selected-index = -1; current-page = 0; root.load-page(0); }
            }

            NavButton {
                icon-path: icon-flatpak;
                label: "Flatpaks";
                active: view == 10;
                clicked => {
                    view = 10; selected-index = -1; show-flatpak-detail = false;
                    if flatpak-remotes.length == 0 { root.browse-remote(""); }
                }
            }

            NavButton {
                icon-path: icon-folder;
                label: "Browse Repos";
                active: view == 7 || view == 8;
                clicked => {
                    view = 7; selected-index = -1;
                    if pacman-repos.length == 0 { root.load-pacman-repos(); }
                }
            }

            NavButton {
                icon-path: icon-search;
                label: "Search Results";
                active: view == 2;
                clicked => { view = 2; selected-index = -1; }
            }

            Rectangle { height: 6px; }
            Rectangle { height: 1px; background: Cat.surface0; }
            Rectangle { height: 6px; }

            NavButton {
                icon-path: icon-gear;
                label: "Settings";
                active: view == 5;
                clicked => { view = 5; }
            }

            Rectangle { vertical-stretch: 1; }

            if stats.update-count > 0: NavButton {
                icon-path: icon-arrow-up;
                label: "Updates";
                badge: stats.update-count;
                active: view == 1;
                clicked => { view = 1; selected-index = -1; }
            }

            Rectangle {
                height: 34px;
                border-radius: 8px;
                background: sync-touch.has-hover ? Cat.mauve : Cat.mauve.with-alpha(0.85);
                opacity: busy ? 0.5 : 1.0;
                animate background { duration: 100ms; }

                Text {
                    text: "Sync & Update";
                    font-size: 12px;
                    font-weight: 600;
                    color: Cat.crust;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                sync-touch := TouchArea {
                    mouse-cursor: busy ? default : pointer;
                    clicked => { if !busy { root.sync-databases(); } }
                }
            }

            Rectangle { height: 8px; }

            HorizontalLayout {
                padding-left: 4px;
                spacing: 4px;

                Text {
                    text: stats.pacman-count + " pacman";
                    font-size: 10px;
                    color: Cat.overlay0;
                }
                Text {
                    text: "/";
                    font-size: 10px;
                    color: Cat.surface2;
                }
                Text {
                    text: stats.flatpak-count + " flatpak";
                    font-size: 10px;
                    color: Cat.overlay0;
                }
            }
        }
    }

    Rectangle {
        x: 200px;
        y: 0;
        width: 1px;
        height: parent.height;
        background: Cat.surface0;
    }

    Rectangle {
        x: 201px;
        y: 0;
        width: parent.width - 201px;
        height: parent.height;
        clip: true;

        VerticalLayout {
            padding: 24px;
            padding-top: 20px;
            spacing: 12px;

            HorizontalLayout {
                spacing: 12px;

                Text {
                    text: view == 9 ? "Home" :
                          view == 0 ? "Installed" :
                          view == 1 ? "Updates" :
                          view == 2 ? "Search Results" :
                          view == 5 ? "Settings" :
                          view == 7 ? "Browse Repos" :
                          view == 8 ? selected-repo :
                          view == 10 ? (show-flatpak-detail ? flatpak-detail-name : "Flatpaks") : "Packages";
                    font-size: 20px;
                    font-weight: 700;
                    color: Cat.text;
                }

                Rectangle { horizontal-stretch: 1; }

                if (view == 0 || view == 1 || view == 8) || (view == 10 && !show-flatpak-detail): Text {
                    text: get-list().length + " packages";
                    font-size: 12px;
                    color: Cat.overlay0;
                    vertical-alignment: center;
                }

                if view == 1 && update-packages.length > 0: Btn {
                    label: "Update All";
                    primary: true;
                    enabled: !busy;
                    clicked => { root.update-all(); }
                }

                if view == 0: Btn {
                    label: "Refresh";
                    clicked => { root.refresh(); }
                }
            }

            Rectangle { height: 1px; background: Cat.surface0; opacity: 0.6; }

            if loading: VerticalLayout {
                vertical-stretch: 1;
                alignment: center;
                HorizontalLayout {
                    alignment: center;
                    Spinner { indeterminate: true; }
                }
            }

            if !loading && view == 2 && search-installed.length == 0 && search-available.length == 0: VerticalLayout {
                vertical-stretch: 1;
                alignment: center;
                spacing: 8px;

                NavIcon {
                    d: icon-search;
                    icon-color: Cat.surface2;
                    width: 32px;
                    height: 32px;
                    x: (parent.width - 32px) / 2;
                }

                Text {
                    text: "Search for packages";
                    font-size: 14px;
                    color: Cat.overlay0;
                    horizontal-alignment: center;
                }
            }

            if !loading && (view == 0 || view == 1 || view == 10) && get-list().length == 0: VerticalLayout {
                vertical-stretch: 1;
                alignment: center;
                spacing: 8px;

                NavIcon {
                    d: icon-package;
                    icon-color: Cat.surface2;
                    width: 32px;
                    height: 32px;
                    x: (parent.width - 32px) / 2;
                }

                Text {
                    text: "No packages found";
                    font-size: 14px;
                    color: Cat.overlay0;
                    horizontal-alignment: center;
                }
            }

            // Installed packages (view 0) — paginated
            if !loading && view == 0 && installed-packages.length > 0: VerticalLayout {
                vertical-stretch: 1;

                ListView {
                    vertical-stretch: 1;
                    for p[i] in installed-packages: PackageRow {
                        pkg: p;
                        show-separator: i < installed-packages.length - 1;
                        show-checkbox: multi-select-mode;
                        install => { root.request-install(p.name, p.backend); }
                        remove => { root.request-remove(p.name, p.backend); }
                        toggle-selected(val) => { root.toggle-package-selected(p.name, p.backend, val); }
                    }
                }

                if total-pages > 1: Paginator {
                    current-page: root.current-page;
                    total-pages: root.total-pages;
                    go-to-page(p) => { root.current-page = p; root.load-page(p); }
                }
            }

            // Updates (view 1)
            if !loading && view == 1 && update-packages.length > 0: ListView {
                vertical-stretch: 1;
                for p[i] in update-packages: PackageRow {
                    pkg: p;
                    show-separator: i < update-packages.length - 1;
                    show-checkbox: false;
                    show-action-button: true;
                    install => { root.request-update(p.name, p.backend); }
                    remove => { root.request-remove(p.name, p.backend); }
                }
            }

            // Flatpaks (view 10) — Shelly-ALPM style with sidebar + card grid + inline detail
            if view == 10: VerticalLayout {
                vertical-stretch: 1;
                spacing: 0;

                // ── Top bar: search + remote selector ─────────────────────
                Rectangle {
                    height: 52px;
                    background: Cat.mantle;

                    HorizontalLayout {
                        padding-left: 14px;
                        padding-right: 14px;
                        spacing: 10px;

                        VerticalLayout {
                            alignment: center;
                            horizontal-stretch: 1;
                            Input {
                                placeholder: "Search apps on Flathub...";
                                text <=> flatpak-search;
                                accepted(t) => {
                                    show-flatpak-detail = false;
                                    root.filter-flatpak(selected-flatpak-category, t);
                                }
                                edited(t) => {
                                    show-flatpak-detail = false;
                                    root.filter-flatpak(selected-flatpak-category, t);
                                }
                            }
                        }

                        if flatpak-remotes.length > 1: VerticalLayout {
                            alignment: center;
                            for r[ri] in flatpak-remotes: Rectangle {
                                height: 28px;
                                width: rmt-lbl.preferred-width + 18px;
                                border-radius: 6px;
                                background: selected-remote == r ? Cat.mauve.with-alpha(0.2) : (rmt-t.has-hover ? Cat.surface1 : Cat.surface0);
                                animate background { duration: 80ms; }
                                rmt-lbl := Text {
                                    text: r;
                                    font-size: 11px;
                                    font-weight: selected-remote == r ? 700 : 400;
                                    color: selected-remote == r ? Cat.mauve : Cat.subtext0;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                                rmt-t := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => {
                                        selected-remote = r;
                                        selected-flatpak-category = "All";
                                        flatpak-search = "";
                                        show-flatpak-detail = false;
                                        root.browse-remote(r);
                                    }
                                }
                            }
                        }
                    }
                }

                // ── Category pills bar ─────────────────────────────────────
                Rectangle {
                    height: 44px;
                    background: Cat.surface0.with-alpha(0.25);

                    ScrollView {
                        HorizontalLayout {
                            padding-left: 14px;
                            padding-right: 14px;
                            spacing: 6px;
                            alignment: start;

                            for cat[ci] in flatpak-categories: CategoryPill {
                                label: cat;
                                active: selected-flatpak-category == cat;
                                clicked => {
                                    selected-flatpak-category = cat;
                                    show-flatpak-detail = false;
                                    root.filter-flatpak(cat, flatpak-search);
                                }
                            }
                        }
                    }
                }

                // ── Loading state ──────────────────────────────────────────
                if remote-apps-loading: VerticalLayout {
                    vertical-stretch: 1;
                    alignment: center;
                    HorizontalLayout { alignment: center; Spinner { indeterminate: true; } }
                    Text { text: "Parsing appstream data…"; font-size: 12px; color: Cat.overlay0; horizontal-alignment: center; }
                }

                // ── Detail view ────────────────────────────────────────────
                if !remote-apps-loading && show-flatpak-detail: ScrollView {
                    vertical-stretch: 1;

                    VerticalLayout {
                        padding: 0;
                        spacing: 0;

                        // Screenshot banner
                        if flatpak-screenshot.width > 0: Rectangle {
                            height: 300px;
                            clip: true;
                            background: Cat.surface0.with-alpha(0.3);

                            Image {
                                source: flatpak-screenshot;
                                width: parent.width;
                                height: parent.height;
                                image-fit: cover;
                            }

                            Rectangle {
                                y: parent.height - 100px;
                                height: 100px;
                                width: parent.width;
                                background: @linear-gradient(180deg, transparent 0%, Cat.base 100%);
                            }
                        }

                        VerticalLayout {
                            padding: 24px;
                            spacing: 22px;

                            // Back row
                            HorizontalLayout {
                                spacing: 8px;
                                Rectangle {
                                    width: bk-lbl.preferred-width + 28px;
                                    height: 34px;
                                    border-radius: 8px;
                                    background: bk-touch.has-hover ? Cat.surface1 : Cat.surface0.with-alpha(0.7);
                                    border-width: 1px;
                                    border-color: Cat.surface0;
                                    animate background { duration: 80ms; }
                                    HorizontalLayout {
                                        alignment: center;
                                        spacing: 6px;
                                        NavIcon { d: "M19 12H5M12 19l-7-7 7-7"; icon-color: Cat.subtext0; width: 13px; height: 13px; }
                                        bk-lbl := Text { text: "All Apps"; font-size: 12px; color: Cat.subtext0; vertical-alignment: center; }
                                    }
                                    bk-touch := TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => {
                                            show-flatpak-detail = false;
                                            flatpak-screenshot = @image-url("");
                                            flatpak-detail-icon = @image-url("");
                                        }
                                    }
                                }
                                Rectangle { horizontal-stretch: 1; }
                                Rectangle {
                                    width: rem-d-lbl.preferred-width + 14px;
                                    height: 34px;
                                    border-radius: 8px;
                                    background: Cat.surface0.with-alpha(0.5);
                                    rem-d-lbl := Text {
                                        text: selected-remote;
                                        font-size: 11px;
                                        color: Cat.overlay1;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }

                            // App header: icon + name/developer + install button
                            HorizontalLayout {
                                spacing: 18px;

                                // App icon (real or placeholder)
                                VerticalLayout {
                                    alignment: start;
                                    Rectangle {
                                        width: 80px;
                                        height: 80px;
                                        border-radius: 20px;
                                        clip: true;
                                        background: Cat.surface0;

                                        if flatpak-detail-icon.width > 0: Image {
                                            source: flatpak-detail-icon;
                                            width: parent.width;
                                            height: parent.height;
                                            image-fit: contain;
                                        }
                                        if flatpak-detail-icon.width == 0: NavIcon {
                                            d: "M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4";
                                            icon-color: Cat.mauve.with-alpha(0.6);
                                            width: 38px;
                                            height: 38px;
                                            x: 21px;
                                            y: 21px;
                                        }
                                    }
                                }

                                // Name + app_id + developer
                                VerticalLayout {
                                    horizontal-stretch: 1;
                                    spacing: 6px;
                                    alignment: center;

                                    Text {
                                        text: flatpak-detail-name;
                                        font-size: 24px;
                                        font-weight: 800;
                                        color: Cat.text;
                                        wrap: word-wrap;
                                    }

                                    HorizontalLayout {
                                        spacing: 8px;
                                        alignment: start;
                                        Text {
                                            text: current-flatpak-id;
                                            font-size: 11px;
                                            color: Cat.overlay0;
                                            vertical-alignment: center;
                                        }
                                        if flatpak-detail-developer != "": Text {
                                            text: "·  " + flatpak-detail-developer;
                                            font-size: 11px;
                                            color: Cat.subtext0;
                                            vertical-alignment: center;
                                        }
                                    }
                                }

                                // Install / Remove
                                VerticalLayout {
                                    alignment: center;
                                    if !flatpak-detail-installed: Rectangle {
                                        width: 120px;
                                        height: 38px;
                                        border-radius: 10px;
                                        background: inst-touch.has-hover ? Cat.mauve : Cat.mauve.with-alpha(0.88);
                                        animate background { duration: 80ms; }
                                        Text { text: "Install"; font-size: 14px; font-weight: 700; color: #ffffff; horizontal-alignment: center; vertical-alignment: center; }
                                        inst-touch := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => {
                                                flatpak-detail-installed = true;
                                                root.request-install(current-flatpak-id, 1);
                                            }
                                        }
                                    }
                                    if flatpak-detail-installed: Rectangle {
                                        width: 120px;
                                        height: 38px;
                                        border-radius: 10px;
                                        background: rm-touch.has-hover ? Cat.red : Cat.red.with-alpha(0.85);
                                        animate background { duration: 80ms; }
                                        Text { text: "Remove"; font-size: 14px; font-weight: 700; color: #ffffff; horizontal-alignment: center; vertical-alignment: center; }
                                        rm-touch := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => {
                                                flatpak-detail-installed = false;
                                                root.request-remove(current-flatpak-id, 1);
                                            }
                                        }
                                    }
                                }
                            }

                            // Summary tagline
                            if flatpak-detail-summary != "": Text {
                                text: flatpak-detail-summary;
                                font-size: 15px;
                                color: Cat.subtext0;
                                wrap: word-wrap;
                            }

                            Rectangle { height: 1px; background: Cat.surface0; opacity: 0.6; }

                            // Description
                            Text {
                                text: flatpak-detail-description != "" ? flatpak-detail-description : "No description available.";
                                font-size: 13px;
                                color: flatpak-detail-description != "" ? Cat.text : Cat.overlay0;
                                wrap: word-wrap;
                                opacity: 0.9;
                            }

                            // Addons section
                            if flatpak-addons.length > 0: VerticalLayout {
                                spacing: 10px;

                                Rectangle { height: 1px; background: Cat.surface0; opacity: 0.6; }

                                Text {
                                    text: "Add-ons & Extensions (" + flatpak-addons.length + ")";
                                    font-size: 13px;
                                    font-weight: 700;
                                    color: Cat.text;
                                }

                                for addon[ai] in flatpak-addons: Rectangle {
                                    height: 64px;
                                    border-radius: 8px;
                                    background: addon-t.has-hover ? Cat.surface1 : Cat.surface0.with-alpha(0.5);
                                    animate background { duration: 70ms; }

                                    HorizontalLayout {
                                        padding: 12px;
                                        spacing: 10px;

                                        VerticalLayout {
                                            horizontal-stretch: 1;
                                            spacing: 3px;
                                            alignment: center;
                                            Text { text: addon.display-name; font-size: 13px; font-weight: 600; color: Cat.text; overflow: elide; }
                                            Text { text: addon.description; font-size: 11px; color: Cat.subtext0; overflow: elide; }
                                        }

                                        VerticalLayout {
                                            alignment: center;
                                            if !addon.installed: Rectangle {
                                                width: 80px; height: 28px; border-radius: 6px;
                                                background: addon-inst-t.has-hover ? Cat.mauve : Cat.mauve.with-alpha(0.2);
                                                animate background { duration: 70ms; }
                                                Text { text: "Install"; font-size: 11px; font-weight: 600; color: addon-inst-t.has-hover ? #ffffff : Cat.mauve; horizontal-alignment: center; vertical-alignment: center; }
                                                addon-inst-t := TouchArea { mouse-cursor: pointer; clicked => { root.request-install(addon.name, 1); } }
                                            }
                                            if addon.installed: Rectangle {
                                                width: 80px; height: 28px; border-radius: 6px;
                                                background: Cat.green.with-alpha(0.12);
                                                Text { text: "Installed"; font-size: 11px; font-weight: 600; color: Cat.green; horizontal-alignment: center; vertical-alignment: center; }
                                            }
                                        }
                                    }

                                    addon-t := TouchArea { }
                                }
                            }
                        }
                    }
                }

                // ── App grid ───────────────────────────────────────────────
                if !remote-apps-loading && !show-flatpak-detail: ScrollView {
                    vertical-stretch: 1;

                    VerticalLayout {
                        padding: 6px;
                        spacing: 0;

                        if flatpak-app-rows.length == 0: VerticalLayout {
                            vertical-stretch: 1;
                            alignment: center;
                            Text { text: "No apps found."; font-size: 13px; color: Cat.overlay0; horizontal-alignment: center; }
                        }

                        for row[ri] in flatpak-app-rows: HorizontalLayout {
                            spacing: 0;

                            AppTile {
                                horizontal-stretch: 1;
                                pkg: row.a;
                                clicked => {
                                    current-flatpak-id = row.a.name;
                                    flatpak-detail-installed = row.a.installed;
                                    flatpak-detail-name = row.a.display-name;
                                    flatpak-detail-summary = row.a.description;
                                    flatpak-detail-description = "";
                                    flatpak-detail-developer = "";
                                    flatpak-screenshot = @image-url("");
                                    flatpak-detail-icon = @image-url("");
                                    flatpak-addons = [];
                                    root.load-flatpak-detail(row.a.name);
                                    root.load-flatpak-icon(row.a.name);
                                    show-flatpak-detail = true;
                                }
                            }

                            if row.count >= 2: AppTile {
                                horizontal-stretch: 1;
                                pkg: row.b;
                                clicked => {
                                    current-flatpak-id = row.b.name;
                                    flatpak-detail-installed = row.b.installed;
                                    flatpak-detail-name = row.b.display-name;
                                    flatpak-detail-summary = row.b.description;
                                    flatpak-detail-description = "";
                                    flatpak-detail-developer = "";
                                    flatpak-screenshot = @image-url("");
                                    flatpak-detail-icon = @image-url("");
                                    flatpak-addons = [];
                                    root.load-flatpak-detail(row.b.name);
                                    root.load-flatpak-icon(row.b.name);
                                    show-flatpak-detail = true;
                                }
                            }
                            if row.count < 2: Rectangle { horizontal-stretch: 1; }

                            if row.count >= 3: AppTile {
                                horizontal-stretch: 1;
                                pkg: row.c;
                                clicked => {
                                    current-flatpak-id = row.c.name;
                                    flatpak-detail-installed = row.c.installed;
                                    flatpak-detail-name = row.c.display-name;
                                    flatpak-detail-summary = row.c.description;
                                    flatpak-detail-description = "";
                                    flatpak-detail-developer = "";
                                    flatpak-screenshot = @image-url("");
                                    flatpak-detail-icon = @image-url("");
                                    flatpak-addons = [];
                                    root.load-flatpak-detail(row.c.name);
                                    root.load-flatpak-icon(row.c.name);
                                    show-flatpak-detail = true;
                                }
                            }
                            if row.count < 3: Rectangle { horizontal-stretch: 1; }
                        }
                    }
                }
            }

            // Repos browser — professional column view with right detail panel
            if view == 7 || view == 8: HorizontalLayout {
                vertical-stretch: 1;
                spacing: 0;

                // ── Left: repo list + package table ────────────────────────
                VerticalLayout {
                    horizontal-stretch: 1;

                    // Repo selector bar
                    Rectangle {
                        height: 44px;
                        background: Cat.mantle;

                        if pacman-repos.length == 0: HorizontalLayout {
                            padding-left: 14px;
                            spacing: 10px;
                            alignment: center;
                            Spinner { indeterminate: true; }
                            Text { text: "Loading repositories..."; font-size: 12px; color: Cat.overlay0; vertical-alignment: center; }
                        }

                        if pacman-repos.length > 0: ScrollView {
                            HorizontalLayout {
                                padding-left: 12px;
                                padding-right: 12px;
                                spacing: 5px;
                                alignment: start;

                                for repo[i] in pacman-repos: Rectangle {
                                    width: rp-lbl.preferred-width + 18px;
                                    height: 28px;
                                    border-radius: 6px;
                                    background: selected-repo == repo ?
                                        Cat.blue.with-alpha(0.85) : (rp-t.has-hover ? Cat.surface1 : Cat.surface0.with-alpha(0.5));
                                    animate background { duration: 70ms; }

                                    rp-lbl := Text {
                                        text: repo;
                                        font-size: 11.5px;
                                        font-weight: selected-repo == repo ? 700 : 400;
                                        color: selected-repo == repo ? #ffffff : Cat.subtext0;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                    rp-t := TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => {
                                            selected-repo = repo;
                                            view = 8;
                                            show-repo-detail = false;
                                            root.browse-repo(repo);
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // Column header
                    if view == 8: Rectangle {
                        height: 32px;
                        background: Cat.surface0.with-alpha(0.6);

                        HorizontalLayout {
                            padding-left: 14px;
                            padding-right: 12px;

                            Text { text: "Name"; font-size: 10px; font-weight: 700; color: Cat.overlay0; letter-spacing: 0.5px; vertical-alignment: center; horizontal-stretch: 1; }
                            Rectangle { width: 130px;
                                Text { text: "Version"; font-size: 10px; font-weight: 700; color: Cat.overlay0; letter-spacing: 0.5px; vertical-alignment: center; horizontal-alignment: right; }
                            }
                            Rectangle { width: 90px;
                                Text { text: "Repo"; font-size: 10px; font-weight: 700; color: Cat.overlay0; letter-spacing: 0.5px; vertical-alignment: center; horizontal-alignment: right; }
                            }
                            Rectangle { width: 80px;
                                Text { text: "Status"; font-size: 10px; font-weight: 700; color: Cat.overlay0; letter-spacing: 0.5px; vertical-alignment: center; horizontal-alignment: center; }
                            }
                        }
                    }

                    // Loading state
                    if repo-loading: VerticalLayout {
                        vertical-stretch: 1;
                        alignment: center;
                        HorizontalLayout { alignment: center; Spinner { indeterminate: true; } }
                        Text { text: "Loading " + selected-repo + "..."; font-size: 12px; color: Cat.overlay0; horizontal-alignment: center; }
                    }

                    // Empty / select prompt
                    if !repo-loading && view == 7: VerticalLayout {
                        vertical-stretch: 1;
                        alignment: center;
                        Text { text: "Select a repository above"; font-size: 14px; font-weight: 600; color: Cat.overlay0; horizontal-alignment: center; }
                        Text { text: "to browse available packages"; font-size: 12px; color: Cat.overlay0; horizontal-alignment: center; }
                    }

                    // Package list
                    if !repo-loading && view == 8 && repo-packages.length > 0: ListView {
                        vertical-stretch: 1;
                        for p[i] in repo-packages: RepoRow {
                            pkg: p;
                            selected: show-repo-detail && repo-detail-pkg.name == p.name;
                            clicked => {
                                repo-detail-pkg = p;
                                show-repo-detail = true;
                                root.select-repo-pkg(p.name, p.backend);
                            }
                        }
                    }

                    if !repo-loading && view == 8 && repo-packages.length == 0: VerticalLayout {
                        vertical-stretch: 1;
                        alignment: center;
                        Text { text: "No packages found"; font-size: 13px; color: Cat.overlay0; horizontal-alignment: center; }
                    }
                }

                // ── Right detail panel (300px) ─────────────────────────────
                if show-repo-detail: Rectangle {
                    width: 300px;
                    background: Cat.mantle;

                    // Vertical divider
                    Rectangle {
                        x: 0;
                        y: 0;
                        width: 1px;
                        height: parent.height;
                        background: Cat.surface0;
                    }

                    VerticalLayout {
                        padding: 20px;
                        spacing: 14px;

                        // Close button
                        HorizontalLayout {
                            Rectangle { horizontal-stretch: 1; }
                            Rectangle {
                                width: 28px;
                                height: 28px;
                                border-radius: 6px;
                                background: cls-t.has-hover ? Cat.surface1 : transparent;
                                animate background { duration: 70ms; }
                                NavIcon { d: "M18 6L6 18M6 6l12 12"; icon-color: Cat.overlay1; width: 14px; height: 14px; x: 7px; y: 7px; }
                                cls-t := TouchArea { mouse-cursor: pointer; clicked => { show-repo-detail = false; } }
                            }
                        }

                        // Package name
                        Text {
                            text: repo-detail-pkg.display-name;
                            font-size: 20px;
                            font-weight: 700;
                            color: Cat.text;
                            wrap: word-wrap;
                        }

                        // Version + repo badges
                        HorizontalLayout {
                            spacing: 8px;
                            alignment: start;

                            Rectangle {
                                width: ver-t.preferred-width + 14px;
                                height: 24px;
                                border-radius: 5px;
                                background: Cat.mauve.with-alpha(0.12);
                                ver-t := Text {
                                    text: repo-detail-pkg.version;
                                    font-size: 11px;
                                    font-weight: 600;
                                    color: Cat.mauve;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }

                            Rectangle {
                                width: rdt.preferred-width + 12px;
                                height: 24px;
                                border-radius: 5px;
                                background: Cat.surface0;
                                rdt := Text {
                                    text: repo-detail-pkg.repository;
                                    font-size: 11px;
                                    color: Cat.overlay1;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }

                        Rectangle { height: 1px; background: Cat.surface0; }

                        // Description
                        if repo-detail-loading: HorizontalLayout {
                            alignment: start;
                            Spinner { indeterminate: true; }
                        }

                        if !repo-detail-loading && repo-detail-description != "": Text {
                            text: repo-detail-description;
                            font-size: 13px;
                            color: Cat.subtext0;
                            wrap: word-wrap;
                        }

                        if !repo-detail-loading && repo-detail-description == "": Text {
                            text: "No description available.";
                            font-size: 12px;
                            color: Cat.overlay0;
                        }

                        Rectangle { vertical-stretch: 1; }

                        // Install / Remove button
                        if !repo-detail-pkg.installed: Rectangle {
                            height: 40px;
                            border-radius: 8px;
                            background: inst-r-t.has-hover ? Cat.mauve : Cat.mauve.with-alpha(0.85);
                            animate background { duration: 80ms; }
                            Text { text: "Install"; font-size: 14px; font-weight: 700; color: #ffffff; horizontal-alignment: center; vertical-alignment: center; }
                            inst-r-t := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.request-install(repo-detail-pkg.name, repo-detail-pkg.backend); }
                            }
                        }
                        if repo-detail-pkg.installed: Rectangle {
                            height: 40px;
                            border-radius: 8px;
                            background: rm-r-t.has-hover ? Cat.red : Cat.red.with-alpha(0.85);
                            animate background { duration: 80ms; }
                            Text { text: "Remove"; font-size: 14px; font-weight: 700; color: #ffffff; horizontal-alignment: center; vertical-alignment: center; }
                            rm-r-t := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.request-remove(repo-detail-pkg.name, repo-detail-pkg.backend); }
                            }
                        }
                    }
                }
            }

            if !loading && view == 2 && (search-installed.length > 0 || search-available.length > 0): ScrollView {
                vertical-stretch: 1;

                VerticalLayout {
                    spacing: 0px;

                    if search-installed.length > 0: VerticalLayout {
                        spacing: 0px;

                        Rectangle {
                            height: 32px;
                            background: Cat.green.with-alpha(0.06);
                            border-radius: 6px;

                            HorizontalLayout {
                                padding-left: 12px;
                                spacing: 6px;

                                NavIcon {
                                    d: "M20 6L9 17l-5-5";
                                    icon-color: Cat.green;
                                    width: 14px;
                                    height: 14px;
                                }

                                Text {
                                    text: "Installed (" + search-installed.length + ")";
                                    font-size: 11px;
                                    font-weight: 700;
                                    color: Cat.green;
                                    vertical-alignment: center;
                                }
                            }
                        }

                        for p[i] in search-installed: PackageRow {
                            pkg: p;
                            show-separator: i < search-installed.length - 1;
                            show-checkbox: multi-select-mode;
                            install => { root.request-install(p.name, p.backend); }
                            remove => { root.request-remove(p.name, p.backend); }
                            toggle-selected(val) => { root.toggle-package-selected(p.name, p.backend, val); }
                        }
                    }

                    if search-available.length > 0: VerticalLayout {
                        spacing: 0px;

                        Rectangle {
                            height: 32px;
                            background: Cat.blue.with-alpha(0.06);
                            border-radius: 6px;

                            HorizontalLayout {
                                padding-left: 12px;
                                spacing: 6px;

                                NavIcon {
                                    d: icon-package;
                                    icon-color: Cat.blue;
                                    width: 14px;
                                    height: 14px;
                                }

                                Text {
                                    text: "Available (" + search-available.length + ")";
                                    font-size: 11px;
                                    font-weight: 700;
                                    color: Cat.blue;
                                    vertical-alignment: center;
                                }
                            }
                        }

                        for p[i] in search-available: PackageRow {
                            pkg: p;
                            show-separator: i < search-available.length - 1;
                            show-checkbox: multi-select-mode;
                            install => { root.request-install(p.name, p.backend); }
                            remove => { root.request-remove(p.name, p.backend); }
                            toggle-selected(val) => { root.toggle-package-selected(p.name, p.backend, val); }
                        }
                    }
                }
            }

            if view == 5: ScrollView {
                vertical-stretch: 1;

                VerticalLayout {
                    padding: 4px;
                    spacing: 28px;


                    VerticalLayout {
                        spacing: 8px;
                        SectionLabel { section-title: "GENERAL"; }

                        SettingsRow {
                            label: "Flatpak Support";
                            subtitle: "Enable Flatpak package management";
                            checked: setting-flatpak-enabled;
                            toggled(val) => { setting-flatpak-enabled = val; root.save-settings(); }
                        }

                        SettingsRow {
                            label: "Check Updates on Startup";
                            subtitle: "Automatically sync databases on launch";
                            checked: setting-check-updates-on-start;
                            toggled(val) => { setting-check-updates-on-start = val; root.save-settings(); }
                        }

                        // Notification interval picker
                        Rectangle {
                            height: 54px;
                            border-radius: 8px;
                            background: Cat.surface0.with-alpha(0.4);

                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 16px;

                                VerticalLayout {
                                    alignment: center;
                                    horizontal-stretch: 1;
                                    spacing: 2px;

                                    Text {
                                        text: "Update Check Interval";
                                        font-size: 13px;
                                        color: Cat.text;
                                    }
                                    Text {
                                        text: "How often xpm-notify checks for updates";
                                        font-size: 11px;
                                        color: Cat.overlay0;
                                    }
                                }

                                HorizontalLayout {
                                    alignment: center;
                                    spacing: 4px;

                                    for opt[i] in [15, 30, 60, 120]: Rectangle {
                                        width: 42px;
                                        height: 26px;
                                        border-radius: 6px;
                                        background: setting-notify-interval == opt ?
                                            Cat.mauve : (opt-touch.has-hover ? Cat.surface1 : Cat.surface0);
                                        animate background { duration: 80ms; }

                                        Text {
                                            text: opt >= 60 ? (opt / 60) + "h" : opt + "m";
                                            font-size: 11px;
                                            font-weight: setting-notify-interval == opt ? 700 : 400;
                                            color: setting-notify-interval == opt ? Cat.crust : Cat.subtext0;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }

                                        opt-touch := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => {
                                                setting-notify-interval = opt;
                                                root.save-settings();
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }

                    VerticalLayout {
                        spacing: 8px;
                        SectionLabel { section-title: "MAINTENANCE"; }

                        HorizontalLayout {
                            spacing: 8px;

                            Rectangle {
                                horizontal-stretch: 1;
                                height: 64px;
                                border-radius: 10px;
                                background: Cat.surface0.with-alpha(0.4);

                                VerticalLayout {
                                    padding: 14px;
                                    spacing: 6px;

                                    Text {
                                        text: "Cache: " + stats.cache-size;
                                        font-size: 12px;
                                        color: Cat.subtext0;
                                    }

                                    Btn {
                                        label: "Clean Cache";
                                        primary: true;
                                        clicked => { root.clean-package-cache(); }
                                    }
                                }
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                                height: 64px;
                                border-radius: 10px;
                                background: Cat.surface0.with-alpha(0.4);

                                VerticalLayout {
                                    padding: 14px;
                                    spacing: 6px;

                                    Text {
                                        text: stats.orphan-count + " orphan packages";
                                        font-size: 12px;
                                        color: Cat.subtext0;
                                    }

                                    Btn {
                                        label: "Remove Orphans";
                                        danger: stats.orphan-count > 0;
                                        enabled: stats.orphan-count > 0;
                                        clicked => { root.remove-orphans(); }
                                    }
                                }
                            }
                        }
                    }

                    VerticalLayout {
                        spacing: 8px;
                        SectionLabel { section-title: "DATA"; }

                        ActionCard {
                            title: "Export Package List";
                            subtitle: "Save explicitly installed packages to ~/xpm-packages.txt";
                            icon-path: icon-file;
                            clicked => { root.export-package-list(); }
                        }

                        ActionCard {
                            title: "Import Package List";
                            subtitle: "Install packages from ~/xpm-packages.txt";
                            icon-path: icon-folder;
                            clicked => { root.import-package-list(); }
                        }
                    }

                    VerticalLayout {
                        spacing: 8px;
                        SectionLabel { section-title: "TROUBLESHOOTING"; }

                        ActionCard {
                            title: "Update Mirrorlists";
                            subtitle: "Re-rank fastest mirrors";
                            icon-path: icon-globe;
                            clicked => { root.update-mirrorlists(); }
                        }

                        ActionCard {
                            title: "Fix GnuPG Keyring";
                            subtitle: "Reset and repopulate keys";
                            icon-path: icon-refresh;
                            clicked => { root.fix-keyring(); }
                        }
                    }

                    VerticalLayout {
                        spacing: 8px;
                        SectionLabel { section-title: "ABOUT"; }

                        Rectangle {
                            height: 52px;
                            border-radius: 10px;
                            background: Cat.surface0.with-alpha(0.4);

                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 16px;
                                spacing: 12px;

                                VerticalLayout {
                                    alignment: center;
                                    NavIcon {
                                        d: icon-package;
                                        icon-color: Cat.mauve;
                                        width: 22px;
                                        height: 22px;
                                    }
                                }

                                VerticalLayout {
                                    alignment: center;
                                    spacing: 2px;
                                    Text {
                                        text: "xPackage Manager";
                                        font-size: 14px;
                                        font-weight: 600;
                                        color: Cat.text;
                                    }
                                    Text {
                                        text: stats.pacman-count + " pacman  /  " + stats.flatpak-count + " flatpak  /  " + stats.orphan-count + " orphans";
                                        font-size: 11px;
                                        color: Cat.overlay0;
                                    }
                                }
                            }
                        }
                    }
                }
            }

            if view == 9: ScrollView {
                vertical-stretch: 1;

                VerticalLayout {
                    padding: 4px;
                    spacing: 20px;

                    // Stat cards
                    VerticalLayout {
                        spacing: 8px;
                        SectionLabel { section-title: "SYSTEM OVERVIEW"; }

                        HorizontalLayout {
                            spacing: 10px;

                            Rectangle {
                                horizontal-stretch: 1;
                                height: 82px;
                                border-radius: 10px;
                                background: Cat.blue.with-alpha(0.1);
                                border-width: 1px;
                                border-color: Cat.blue.with-alpha(0.25);

                                VerticalLayout {
                                    alignment: center;
                                    spacing: 4px;

                                    Text {
                                        text: stats.pacman-count;
                                        font-size: 28px;
                                        font-weight: 700;
                                        color: Cat.blue;
                                        horizontal-alignment: center;
                                    }
                                    Text {
                                        text: "Pacman Packages";
                                        font-size: 11px;
                                        color: Cat.overlay1;
                                        horizontal-alignment: center;
                                    }
                                }
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                                height: 82px;
                                border-radius: 10px;
                                background: Cat.teal.with-alpha(0.1);
                                border-width: 1px;
                                border-color: Cat.teal.with-alpha(0.25);

                                VerticalLayout {
                                    alignment: center;
                                    spacing: 4px;

                                    Text {
                                        text: stats.flatpak-count;
                                        font-size: 28px;
                                        font-weight: 700;
                                        color: Cat.teal;
                                        horizontal-alignment: center;
                                    }
                                    Text {
                                        text: "Flatpak Apps";
                                        font-size: 11px;
                                        color: Cat.overlay1;
                                        horizontal-alignment: center;
                                    }
                                }
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                                height: 82px;
                                border-radius: 10px;
                                background: stats.orphan-count > 0 ? Cat.yellow.with-alpha(0.1) : Cat.surface0.with-alpha(0.35);
                                border-width: 1px;
                                border-color: stats.orphan-count > 0 ? Cat.yellow.with-alpha(0.25) : Cat.surface0.with-alpha(0.2);

                                VerticalLayout {
                                    alignment: center;
                                    spacing: 4px;

                                    Text {
                                        text: stats.orphan-count;
                                        font-size: 28px;
                                        font-weight: 700;
                                        color: stats.orphan-count > 0 ? Cat.yellow : Cat.overlay0;
                                        horizontal-alignment: center;
                                    }
                                    Text {
                                        text: "Orphaned";
                                        font-size: 11px;
                                        color: Cat.overlay1;
                                        horizontal-alignment: center;
                                    }
                                }
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                                height: 82px;
                                border-radius: 10px;
                                background: stats.update-count > 0 ? Cat.peach.with-alpha(0.1) : Cat.surface0.with-alpha(0.35);
                                border-width: 1px;
                                border-color: stats.update-count > 0 ? Cat.peach.with-alpha(0.25) : Cat.surface0.with-alpha(0.2);

                                VerticalLayout {
                                    alignment: center;
                                    spacing: 4px;

                                    Text {
                                        text: stats.update-count;
                                        font-size: 28px;
                                        font-weight: 700;
                                        color: stats.update-count > 0 ? Cat.peach : Cat.overlay0;
                                        horizontal-alignment: center;
                                    }
                                    Text {
                                        text: "Updates";
                                        font-size: 11px;
                                        color: Cat.overlay1;
                                        horizontal-alignment: center;
                                    }
                                }
                            }
                        }
                    }

                    // Quick actions
                    VerticalLayout {
                        spacing: 8px;
                        SectionLabel { section-title: "QUICK ACTIONS"; }

                        HorizontalLayout {
                            spacing: 10px;

                            Rectangle {
                                horizontal-stretch: 1;
                                height: 66px;
                                border-radius: 10px;
                                background: home-sync-touch.has-hover ? Cat.mauve.with-alpha(0.18) : Cat.surface0.with-alpha(0.4);
                                opacity: busy ? 0.5 : 1.0;
                                animate background { duration: 100ms; }

                                home-sync-touch := TouchArea {
                                    mouse-cursor: busy ? default : pointer;
                                    clicked => { if !busy { root.sync-databases(); } }
                                }

                                VerticalLayout {
                                    padding-left: 16px;
                                    padding-right: 16px;
                                    alignment: center;
                                    spacing: 3px;

                                    Text {
                                        text: "Sync & Update";
                                        font-size: 13px;
                                        font-weight: 600;
                                        color: Cat.mauve;
                                    }
                                    Text {
                                        text: stats.update-count > 0 ? stats.update-count + " updates pending" : "System is up to date";
                                        font-size: 11px;
                                        color: Cat.overlay0;
                                    }
                                }
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                                height: 66px;
                                border-radius: 10px;
                                background: home-cache-touch.has-hover ? Cat.blue.with-alpha(0.15) : Cat.surface0.with-alpha(0.4);
                                animate background { duration: 100ms; }

                                home-cache-touch := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.clean-package-cache(); }
                                }

                                VerticalLayout {
                                    padding-left: 16px;
                                    padding-right: 16px;
                                    alignment: center;
                                    spacing: 3px;

                                    Text {
                                        text: "Clean Cache";
                                        font-size: 13px;
                                        font-weight: 600;
                                        color: Cat.blue;
                                    }
                                    Text {
                                        text: stats.cache-size + " used";
                                        font-size: 11px;
                                        color: Cat.overlay0;
                                    }
                                }
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                                height: 66px;
                                border-radius: 10px;
                                background: home-orphan-touch.has-hover ? (stats.orphan-count > 0 ? Cat.red.with-alpha(0.18) : Cat.surface0.with-alpha(0.5)) : Cat.surface0.with-alpha(0.4);
                                opacity: stats.orphan-count == 0 ? 0.5 : 1.0;
                                animate background { duration: 100ms; }

                                home-orphan-touch := TouchArea {
                                    mouse-cursor: stats.orphan-count > 0 ? pointer : default;
                                    clicked => { if stats.orphan-count > 0 { root.remove-orphans(); } }
                                }

                                VerticalLayout {
                                    padding-left: 16px;
                                    padding-right: 16px;
                                    alignment: center;
                                    spacing: 3px;

                                    Text {
                                        text: "Remove Orphans";
                                        font-size: 13px;
                                        font-weight: 600;
                                        color: stats.orphan-count > 0 ? Cat.red : Cat.overlay0;
                                    }
                                    Text {
                                        text: stats.orphan-count + " orphaned packages";
                                        font-size: 11px;
                                        color: Cat.overlay0;
                                    }
                                }
                            }
                        }
                    }

                    // Arch Linux News
                    VerticalLayout {
                        spacing: 8px;

                        HorizontalLayout {
                            alignment: center;
                            spacing: 8px;

                            SectionLabel {
                                section-title: "ARCH LINUX NEWS";
                                horizontal-stretch: 1;
                                vertical-alignment: center;
                            }

                            Rectangle {
                                width: news-refresh-label.preferred-width + 18px;
                                height: 22px;
                                border-radius: 5px;
                                background: news-refresh-touch.has-hover ? Cat.surface1 : Cat.surface0.with-alpha(0.6);
                                animate background { duration: 80ms; }

                                news-refresh-label := Text {
                                    text: "Refresh";
                                    font-size: 10px;
                                    color: Cat.overlay1;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }

                                news-refresh-touch := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.fetch-news(); }
                                }
                            }
                        }

                        if news-items.length == 0: Rectangle {
                            height: 56px;
                            border-radius: 8px;
                            background: Cat.surface0.with-alpha(0.3);

                            Text {
                                text: "No news loaded — click Refresh to fetch";
                                font-size: 12px;
                                color: Cat.overlay0;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        for item[i] in news-items: Rectangle {
                            height: 58px;
                            border-radius: 8px;
                            background: news-item-touch.has-hover ? Cat.surface0.with-alpha(0.6) : Cat.surface0.with-alpha(0.3);
                            animate background { duration: 80ms; }

                            news-item-touch := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.open-url(item.url); }
                            }

                            HorizontalLayout {
                                padding-left: 14px;
                                padding-right: 14px;
                                spacing: 10px;

                                VerticalLayout {
                                    alignment: center;
                                    horizontal-stretch: 1;
                                    spacing: 3px;

                                    Text {
                                        text: item.title;
                                        font-size: 12.5px;
                                        font-weight: 500;
                                        color: Cat.text;
                                        overflow: elide;
                                    }
                                    Text {
                                        text: item.date;
                                        font-size: 10.5px;
                                        color: Cat.overlay0;
                                    }
                                }

                                VerticalLayout {
                                    alignment: center;
                                    NavIcon {
                                        d: icon-link;
                                        icon-color: Cat.overlay0;
                                        width: 13px;
                                        height: 13px;
                                    }
                                }
                            }

                            if i < news-items.length - 1: Rectangle {
                                x: 14px;
                                y: parent.height - 1px;
                                width: parent.width - 28px;
                                height: 1px;
                                background: Cat.surface0;
                                opacity: 0.5;
                            }
                        }
                    }
                }
            }

        }
    }


    if selected-count > 0: Rectangle {
        x: (parent.width - 360px) / 2;
        y: parent.height - 64px;
        width: 360px;
        height: 44px;
        border-radius: 22px;
        background: Cat.surface0;
        drop-shadow-blur: 20px;
        drop-shadow-color: Cat.crust.with-alpha(0.5);
        drop-shadow-offset-y: 4px;
        border-width: 1px;
        border-color: Cat.surface1;

        HorizontalLayout {
            padding-left: 16px;
            padding-right: 10px;
            spacing: 8px;

            Text {
                text: selected-count + " selected";
                font-size: 12px;
                font-weight: 500;
                color: Cat.text;
                vertical-alignment: center;
            }

            Rectangle { horizontal-stretch: 1; }

            Rectangle {
                width: 48px;
                height: 28px;
                border-radius: 6px;
                background: fab-clear-touch.has-hover ? Cat.surface1 : transparent;

                Text {
                    text: "Clear";
                    font-size: 11px;
                    color: Cat.subtext0;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                fab-clear-touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => { root.clear-selection(); }
                }
            }

            Btn {
                label: "Install";
                primary: selected-uninstalled-count > 0;
                enabled: selected-uninstalled-count > 0;
                min-width: 60px;
                clicked => { root.bulk-install(); }
            }

            Btn {
                label: "Remove";
                danger: selected-installed-count > 0;
                enabled: selected-installed-count > 0;
                min-width: 64px;
                clicked => { root.bulk-remove(); }
            }
        }
    }

    if show-local-install: Rectangle {
        width: 100%;
        height: 100%;
        background: Cat.crust.with-alpha(0.7);

        TouchArea { clicked => { root.cancel-local-install(); } }

        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: 440px;
            height: 300px;
            background: Cat.base;
            border-radius: 12px;
            border-width: 1px;
            border-color: Cat.surface0;
            drop-shadow-blur: 30px;
            drop-shadow-color: Cat.crust.with-alpha(0.6);
            drop-shadow-offset-y: 8px;

            TouchArea {}

            VerticalLayout {
                padding: 24px;
                spacing: 16px;

                HorizontalLayout {
                    spacing: 12px;
                    NavIcon {
                        d: icon-package;
                        icon-color: Cat.mauve;
                        width: 24px;
                        height: 24px;
                    }
                    Text {
                        text: "Install Local Package";
                        font-size: 16px;
                        font-weight: 600;
                        color: Cat.text;
                        vertical-alignment: center;
                    }
                }

                Rectangle { height: 1px; background: Cat.surface0; }

                VerticalLayout {
                    spacing: 8px;
                    DetailProperty { prop-label: "Name"; prop-value: local-package.display-name != "" ? local-package.display-name : "Unknown"; }
                    DetailProperty { prop-label: "Version"; prop-value: local-package.version; }
                    DetailProperty { prop-label: "Size"; prop-value: local-package.installed-size; }
                    DetailProperty { prop-label: "File"; prop-value: local-package-path; }
                }

                Rectangle { vertical-stretch: 1; }

                HorizontalLayout {
                    spacing: 8px;
                    alignment: end;

                    Btn {
                        label: "Cancel";
                        clicked => { root.cancel-local-install(); }
                    }

                    Btn {
                        label: "Install";
                        primary: true;
                        enabled: !busy;
                        clicked => { root.install-local-package(local-package-path); }
                    }
                }
            }
        }
    }

    if show-progress-popup: Rectangle {
        width: 100%;
        height: 100%;
        background: Cat.crust.with-alpha(0.65);

        TouchArea {}

        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: min(620px, parent.width - 40px);
            height: min(500px, parent.height - 40px);
            background: Cat.base;
            border-radius: 12px;
            clip: true;
            border-width: 1px;
            border-color: Cat.surface0;
            drop-shadow-blur: 32px;
            drop-shadow-color: Cat.crust.with-alpha(0.7);
            drop-shadow-offset-y: 10px;

            VerticalLayout {
                spacing: 0;

                // Title bar
                Rectangle {
                    height: 48px;
                    background: Cat.mantle;

                    HorizontalLayout {
                        padding-left: 16px;
                        padding-right: 10px;
                        spacing: 10px;

                        if !progress-popup-done: VerticalLayout {
                            alignment: center;
                            Spinner { indeterminate: true; width: 16px; height: 16px; }
                        }

                        if progress-popup-done: VerticalLayout {
                            alignment: center;
                            NavIcon {
                                d: progress-popup-success ? "M20 6L9 17l-5-5" : icon-close;
                                icon-color: progress-popup-success ? Cat.green : Cat.red;
                                width: 16px;
                                height: 16px;
                            }
                        }

                        Text {
                            text: progress-popup-title;
                            font-size: 14px;
                            font-weight: 600;
                            color: Cat.text;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                            overflow: elide;
                        }

                        if !progress-popup-done: VerticalLayout {
                            alignment: center;
                            Rectangle {
                                width: cancel-label.preferred-width + 20px;
                                height: 26px;
                                border-radius: 6px;
                                background: cancel-touch.has-hover ? Cat.red.with-alpha(0.2) : Cat.surface0;
                                animate background { duration: 80ms; }

                                cancel-label := Text {
                                    text: "Cancel";
                                    font-size: 11px;
                                    font-weight: 600;
                                    color: cancel-touch.has-hover ? Cat.red : Cat.overlay0;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                    animate color { duration: 80ms; }
                                }

                                cancel-touch := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.cancel-operation(); }
                                }
                            }
                        }

                        if progress-popup-done: VerticalLayout {
                            alignment: center;
                            Rectangle {
                                width: 28px;
                                height: 28px;
                                border-radius: 6px;
                                background: prog-close-x.has-hover ? Cat.surface0 : transparent;

                                NavIcon {
                                    d: icon-close;
                                    icon-color: Cat.overlay0;
                                    width: 12px;
                                    height: 12px;
                                    x: 8px;
                                    y: 8px;
                                }

                                prog-close-x := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.close-progress-popup(); }
                                }
                            }
                        }
                    }
                }

                // Progress bar + stage
                Rectangle {
                    height: 50px;
                    background: Cat.mantle;

                    Rectangle {
                        y: 0;
                        width: 100%;
                        height: 1px;
                        background: Cat.surface0;
                        opacity: 0.6;
                    }

                    VerticalLayout {
                        padding-left: 16px;
                        padding-right: 16px;
                        padding-top: 10px;
                        spacing: 6px;

                        Rectangle {
                            height: 5px;
                            border-radius: 3px;
                            background: Cat.surface0;

                            Rectangle {
                                width: progress-popup-done ? parent.width :
                                       (progress-popup-percent > 0 ? parent.width * progress-popup-percent / 100 : 4px);
                                height: 100%;
                                border-radius: 3px;
                                background: progress-popup-done ?
                                            (progress-popup-success ? Cat.green : Cat.red) : Cat.mauve;
                                animate width { duration: 300ms; easing: ease-in-out; }
                            }
                        }

                        HorizontalLayout {
                            Text {
                                text: progress-popup-done ?
                                      (progress-popup-success ? "Completed successfully" : "Operation failed") :
                                      progress-popup-stage;
                                font-size: 11px;
                                color: progress-popup-done ?
                                       (progress-popup-success ? Cat.green : Cat.red) : Cat.overlay0;
                                overflow: elide;
                                horizontal-stretch: 1;
                            }

                            Text {
                                text: progress-popup-done ? "done" : progress-popup-percent + "%";
                                font-size: 11px;
                                font-weight: 600;
                                color: progress-popup-done ?
                                       (progress-popup-success ? Cat.green : Cat.red) : Cat.mauve;
                            }
                        }
                    }
                }

                Rectangle { height: 1px; background: Cat.surface0; opacity: 0.5; }

                // Live log output — always visible
                Rectangle {
                    vertical-stretch: 1;
                    background: Cat.crust;

                    ScrollView {
                        viewport-y: min(0px, self.visible-height - self.viewport-height);

                        VerticalLayout {
                            padding: 12px;

                            Text {
                                text: progress-popup-output;
                                font-size: 11.5px;
                                font-family: "monospace";
                                color: Cat.text;
                                opacity: 0.85;
                                wrap: word-wrap;
                            }
                        }
                    }
                }

                // User input prompt (conflict resolution / password / questions)
                if progress-popup-show-input: Rectangle {
                    height: 60px;
                    background: Cat.yellow.with-alpha(0.06);

                    Rectangle { y: 0; width: 100%; height: 1px; background: Cat.surface0; opacity: 0.5; }

                    VerticalLayout {
                        padding: 8px;
                        padding-left: 16px;
                        padding-right: 16px;
                        spacing: 3px;

                        Text {
                            text: progress-popup-prompt;
                            font-size: 10.5px;
                            font-weight: 500;
                            color: Cat.yellow;
                            overflow: elide;
                        }

                        Input {
                            placeholder: "Type response and press Enter...";
                            accepted(text) => {
                                root.progress-popup-send-input(text);
                                self.text = "";
                            }
                        }
                    }
                }

                // Footer when done
                if progress-popup-done: Rectangle {
                    height: 46px;
                    background: progress-popup-success ? Cat.green.with-alpha(0.06) : Cat.red.with-alpha(0.06);

                    Rectangle { y: 0; width: 100%; height: 1px; background: Cat.surface0; opacity: 0.4; }

                    HorizontalLayout {
                        padding-left: 16px;
                        padding-right: 16px;
                        alignment: end;

                        VerticalLayout {
                            alignment: center;
                            Rectangle {
                                width: done-close-label.preferred-width + 28px;
                                height: 28px;
                                border-radius: 7px;
                                background: done-close-touch.has-hover ? Cat.mauve : Cat.mauve.with-alpha(0.85);
                                animate background { duration: 80ms; }

                                done-close-label := Text {
                                    text: "Close";
                                    font-size: 12px;
                                    font-weight: 600;
                                    color: Cat.crust;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }

                                done-close-touch := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.close-progress-popup(); }
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    if show-conflict-dialog: Rectangle {
        width: 100%;
        height: 100%;
        background: Cat.crust.with-alpha(0.72);

        TouchArea {}

        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: min(540px, parent.width - 40px);
            height: min(420px, parent.height - 40px);
            background: Cat.base;
            border-radius: 12px;
            clip: true;
            border-width: 1px;
            border-color: Cat.yellow.with-alpha(0.35);
            drop-shadow-blur: 32px;
            drop-shadow-color: Cat.crust.with-alpha(0.7);
            drop-shadow-offset-y: 10px;

            VerticalLayout {
                spacing: 0;

                // Header
                Rectangle {
                    height: 52px;
                    background: Cat.yellow.with-alpha(0.08);

                    Rectangle {
                        y: parent.height - 1px;
                        width: 100%;
                        height: 1px;
                        background: Cat.yellow.with-alpha(0.25);
                    }

                    HorizontalLayout {
                        padding-left: 18px;
                        padding-right: 18px;
                        spacing: 12px;

                        VerticalLayout {
                            alignment: center;
                            NavIcon {
                                d: "M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z M12 9v4 M12 17h.01";
                                icon-color: Cat.yellow;
                                width: 20px;
                                height: 20px;
                            }
                        }

                        VerticalLayout {
                            alignment: center;
                            horizontal-stretch: 1;
                            spacing: 2px;

                            Text {
                                text: "Conflict Detected";
                                font-size: 15px;
                                font-weight: 700;
                                color: Cat.text;
                            }

                            Text {
                                text: conflict-can-force ? "File already exists in filesystem" : "Package dependency conflict";
                                font-size: 11px;
                                color: Cat.yellow;
                            }
                        }
                    }
                }

                // Conflict details (scrollable)
                Rectangle {
                    vertical-stretch: 1;
                    background: Cat.crust;

                    ScrollView {
                        VerticalLayout {
                            padding: 14px;

                            Text {
                                text: conflict-summary;
                                font-size: 11.5px;
                                font-family: "monospace";
                                color: Cat.text;
                                opacity: 0.85;
                                wrap: word-wrap;
                            }
                        }
                    }
                }

                // Advice
                Rectangle {
                    height: 36px;
                    background: conflict-can-force ? Cat.yellow.with-alpha(0.06) : Cat.red.with-alpha(0.06);

                    Rectangle { y: 0; width: 100%; height: 1px; background: Cat.surface0; opacity: 0.5; }

                    Text {
                        x: 18px;
                        width: parent.width - 36px;
                        height: parent.height;
                        text: conflict-can-force
                            ? "Force overwrite will replace the conflicting files. Use with caution."
                            : "This conflict requires manual resolution. Remove the conflicting package first.";
                        font-size: 10.5px;
                        color: conflict-can-force ? Cat.yellow : Cat.red;
                        opacity: 0.8;
                        vertical-alignment: center;
                        wrap: word-wrap;
                        overflow: elide;
                    }
                }

                // Buttons
                Rectangle {
                    height: 52px;
                    background: Cat.mantle;

                    Rectangle { y: 0; width: 100%; height: 1px; background: Cat.surface0; opacity: 0.5; }

                    HorizontalLayout {
                        padding-left: 16px;
                        padding-right: 16px;
                        spacing: 10px;
                        alignment: end;

                        Rectangle {
                            width: cancel-conf-label.preferred-width + 24px;
                            height: 30px;
                            border-radius: 7px;
                            background: cancel-conf-touch.has-hover ? Cat.surface1 : Cat.surface0;
                            animate background { duration: 80ms; }

                            cancel-conf-label := Text {
                                text: "Cancel";
                                font-size: 12px;
                                font-weight: 500;
                                color: Cat.text;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }

                            cancel-conf-touch := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.conflict-cancel(); }
                            }
                        }

                        if conflict-can-force: Rectangle {
                            width: force-label.preferred-width + 24px;
                            height: 30px;
                            border-radius: 7px;
                            background: force-touch.has-hover ? Cat.yellow : Cat.yellow.with-alpha(0.85);
                            animate background { duration: 80ms; }

                            force-label := Text {
                                text: "Force Overwrite";
                                font-size: 12px;
                                font-weight: 700;
                                color: Cat.crust;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }

                            force-touch := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.conflict-force-overwrite(); }
                            }
                        }
                    }
                }
            }
        }
    }

    if show-terminal: Rectangle {
        width: 100%;
        height: 100%;
        background: Cat.crust.with-alpha(0.6);

        TouchArea {}

        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: min(640px, parent.width - 40px);
            height: min(460px, parent.height - 40px);
            border-radius: 12px;
            clip: true;
            background: Cat.base;
            border-width: 1px;
            border-color: Cat.surface0;
            drop-shadow-blur: 30px;
            drop-shadow-color: Cat.crust.with-alpha(0.6);
            drop-shadow-offset-y: 8px;

            VerticalLayout {
                Rectangle {
                    height: 40px;
                    background: Cat.mantle;

                    HorizontalLayout {
                        padding-left: 14px;
                        padding-right: 8px;

                        Text {
                            text: terminal-title;
                            font-size: 13px;
                            font-weight: 500;
                            color: Cat.text;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                            overflow: elide;
                        }

                        VerticalLayout {
                            alignment: center;
                            Rectangle {
                                width: 28px;
                                height: 28px;
                                border-radius: 6px;
                                background: close-touch.has-hover ? Cat.surface0 : transparent;

                                NavIcon {
                                    d: icon-close;
                                    icon-color: Cat.overlay0;
                                    width: 12px;
                                    height: 12px;
                                    x: 8px;
                                    y: 8px;
                                }

                                close-touch := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.terminal-close(); }
                                }
                            }
                        }
                    }
                }

                Rectangle { height: 1px; background: Cat.surface0; }

                Rectangle {
                    vertical-stretch: 1;
                    background: Cat.crust;

                    ScrollView {
                        viewport-y: min(0px, self.visible-height - self.viewport-height);
                        VerticalLayout {
                            padding: 12px;
                            Text {
                                text: terminal-output;
                                font-size: 12px;
                                font-family: "monospace";
                                color: Cat.text;
                                opacity: 0.9;
                                wrap: word-wrap;
                            }
                        }
                    }
                }

                if !terminal-done: Rectangle {
                    height: 38px;
                    background: Cat.mantle;

                    Rectangle { y: 0; width: 100%; height: 1px; background: Cat.surface0; }

                    HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 12px;
                        spacing: 8px;

                        Input {
                            horizontal-stretch: 1;
                            placeholder: "Type response...";
                            accepted(text) => {
                                root.terminal-send-input(text);
                                self.text = "";
                            }
                        }
                    }
                }

                if terminal-done: Rectangle {
                    height: 32px;
                    background: terminal-success ? Cat.green.with-alpha(0.1) : Cat.red.with-alpha(0.1);

                    HorizontalLayout {
                        padding-left: 14px;
                        spacing: 8px;

                        NavIcon {
                            d: terminal-success ? "M20 6L9 17l-5-5" : icon-close;
                            icon-color: terminal-success ? Cat.green : Cat.red;
                            width: 14px;
                            height: 14px;
                        }

                        Text {
                            text: terminal-success ? "Completed successfully" : "Operation failed";
                            font-size: 11px;
                            font-weight: 500;
                            color: terminal-success ? Cat.green : Cat.red;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }
}
